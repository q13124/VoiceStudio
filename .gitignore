# SpecStory chat history (local IDE artifact)
.specstory/

# Audio uploads (user data)
data/audio_uploads/

# PDF documents (generated, not source)
docs/**/*.pdf

# Output dumps and collection files
collect*.txt
full_collect.txt
errors_check.txt
unit_errors.txt
