# Installer build output (distribute separately)
installer/Output/

# Runtime bundle (downloaded/installed at build time)
installer/runtime/

# External runtime submodules (tracked separately)
runtime/external/deepfacelab_2025/

# Models directory (downloaded at runtime)
models/
