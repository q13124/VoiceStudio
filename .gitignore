_corecompile_errors.txt
build_errors.txt
build-output.log
build.log
msbuild.log
msbuild.binlog
build_diag.binlog

# Temporary working directory
temp/

# Local model binaries (do not commit)
models/**/*.pth
models/**/*.pt
models/**/*.onnx
models/**/*.bin
models/**/*.safetensors
models/**/*.ckpt

# Cursor workspace metadata (IDE/assistant)
.cursor/
