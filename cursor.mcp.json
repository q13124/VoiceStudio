{
  "mcpServers": {
    "// === EXISTING/ORIGINAL MCPs ===": "",
    "GitKraken": {
      "command": "c:\\Users\\Tyler\\AppData\\Roaming\\Cursor\\User\\globalStorage\\eamodio.gitlens\\gk.exe",
      "args": [
        "mcp",
        "--host=cursor",
        "--source=gitlens",
        "--scheme=cursor"
      ],
      "env": {},
      "name": "GitKraken",
      "type": "stdio"
    },
    "mcp-interactive": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-interactive"
      ]
    },
    "openai-websearch": {
      "command": "npx",
      "args": [
        "-y",
        "openai-websearch-mcp"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "openmemory": {
      "command": "npx",
      "args": [
        "-y",
        "openmemory-js",
        "mcp"
      ],
      "env": {
        "OM_TIER": "hybrid",
        "OM_EMBEDDINGS": "synthetic"
      }
    },
    "cursor-browser-extension": {
      "command": "npx",
      "args": [
        "-y",
        "@cursor-browser-extension/mcp-server"
      ]
    },
    "// === VOICE & AUDIO MCPs ===": "",
    "elevenlabs": {
      "command": "npx",
      "args": [
        "-y",
        "@elevenlabs/mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}"
      }
    },
    "hume": {
      "command": "npx",
      "args": [
        "-y",
        "hume-mcp-server"
      ],
      "env": {
        "HUME_API_KEY": "${HUME_API_KEY}",
        "HUME_SECRET_KEY": "${HUME_SECRET_KEY}"
      }
    },
    "// === AI REASONING & INTELLIGENCE MCPs ===": "",
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "DISABLE_THOUGHT_LOGGING": "false"
      }
    },
    "thought-chain": {
      "command": "npx",
      "args": [
        "-y",
        "thought-chain-mcp"
      ]
    },
    "deepseek-thinker": {
      "command": "npx",
      "args": [
        "-y",
        "deepseek-thinker-mcp"
      ],
      "env": {
        "USE_OLLAMA": "true",
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_MODEL": "deepseek-r1:7b"
      }
    },
    "deepseek-api": {
      "command": "npx",
      "args": [
        "-y",
        "deepseek-thinker-mcp"
      ],
      "env": {
        "USE_OLLAMA": "false",
        "API_KEY": "${DEEPSEEK_API_KEY}",
        "BASE_URL": "https://api.deepseek.com"
      }
    },
    "mem0": {
      "command": "npx",
      "args": [
        "-y",
        "@mem0/mcp"
      ]
    },
    "// === PROJECT & PLANNING MCPs ===": "",
    "taskflow": {
      "command": "npx",
      "args": [
        "-y",
        "taskflow-mcp"
      ],
      "env": {
        "TASKFLOW_PROJECT": "VoiceStudio"
      }
    },
    "longterm-planner": {
      "command": "npx",
      "args": [
        "-y",
        "longterm-planner-mcp"
      ]
    },
    "// === LOCAL LLM MCPs (Ollama - Free) ===": "",
    "ollama": {
      "command": "npx",
      "args": [
        "-y",
        "ollama-mcp"
      ],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    },
    "// === DOCUMENTATION & CONTEXT MCPs ===": "",
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
