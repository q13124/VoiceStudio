    "openapi-explorer": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-openapi-schema-explorer"
      ]
    },
    "// === DEVELOPMENT TOOLS MCPs ===": "",
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "fastapi-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "fastapi-mcp"
      ]
    },
    "docker-mcp": {
      "command": "uvx",
      "args": [
        "docker-mcp"
      ]
    },
    "semgrep": {
      "command": "uvx",
      "args": [
        "semgrep-mcp"
      ],
