      "command": "uvx",
      "args": [
        "ast-grep-mcp"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "E:/VoiceStudio"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "console-automation": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-console-automation"
      ]
    },
    "opentelemetry": {
      "command": "npx",
      "args": [
        "-y",
        "opentelemetry-mcp-server"
      ]
    },
    "// === CODE INTELLIGENCE MCPs ===": "",
    "tree-sitter": {
      "command": "uvx",
      "args": [
        "mcp-server-tree-sitter"
      ]
    },
    "lsp": {
      "command": "npx",
      "args": [
        "-y",
        "lsp-mcp"
      ]
    },
    "// === DATABASE & SEARCH MCPs ===": "",
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "E:/VoiceStudio/data/voicestudio.db"
      ]
    },
    "chroma": {
      "command": "uvx",
      "args": [
        "chroma-mcp-server"
      ],
      "env": {
        "CHROMA_PERSISTENCE_DIR": "E:/VoiceStudio/data/chroma"
      }
    },
    "// === ADDITIONAL RECOMMENDED MCPs ===": "",
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/brave-search-mcp"
      ],
      "env": {
