# VoiceStudio Environment Configuration
# Copy this file to .env and customize for your environment
#
# GAP-CFG-001: Centralized environment variable documentation
# ============================================================

# =============================================================================
# PATHS AND DIRECTORIES
# =============================================================================

# Root directory for model storage (required)
# Default: C:\ProgramData\VoiceStudio\models
VOICESTUDIO_MODELS_PATH=C:\ProgramData\VoiceStudio\models

# Projects directory for user projects
VOICESTUDIO_PROJECTS_DIR=C:\Users\<username>\Documents\VoiceStudio\projects

# Cache directory for temporary files
VOICESTUDIO_CACHE_DIR=C:\Users\<username>\AppData\Local\VoiceStudio\cache

# Job storage directory
VOICESTUDIO_JOBS_DIR=C:\Users\<username>\AppData\Local\VoiceStudio\jobs

# FFmpeg executable path (optional - auto-detected if not set)
# VOICESTUDIO_FFMPEG_PATH=C:\path\to\ffmpeg.exe

# =============================================================================
# HUGGING FACE CONFIGURATION
# =============================================================================

# Custom Hugging Face endpoint (optional)
# VOICESTUDIO_HF_ENDPOINT=https://router.huggingface.co
# VOICESTUDIO_HF_INFERENCE_API_BASE=https://router.huggingface.co

# Hugging Face cache directories (set automatically from VOICESTUDIO_MODELS_PATH)
# HF_HOME=${VOICESTUDIO_MODELS_PATH}/hf_cache
# HUGGINGFACE_HUB_CACHE=${HF_HOME}/hub
# TRANSFORMERS_CACHE=${HF_HOME}/transformers
# HF_DATASETS_CACHE=${HF_HOME}/datasets

# Hugging Face token for private models (optional)
# HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# ENGINE-SPECIFIC PATHS
# =============================================================================

# TTS model cache
# TTS_HOME=${VOICESTUDIO_MODELS_PATH}/xtts

# PyTorch model cache
# TORCH_HOME=${VOICESTUDIO_MODELS_PATH}/torch

# Wav2Lip path (optional)
# VOICESTUDIO_WAV2LIP_PATH=runtime/external/wav2lip

# SadTalker path (optional)
# VOICESTUDIO_SADTALKER_PATH=runtime/external/sadtalker

# =============================================================================
# SECURITY AND AUTHENTICATION
# =============================================================================

# JWT secret key for authentication (required in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=your-secret-key-here

# API key encryption key (required if using API key management)
# API_KEY_ENCRYPTION_KEY=your-encryption-key-here

# =============================================================================
# CORS AND NETWORK
# =============================================================================

# Allowed CORS origins (comma-separated)
# Default in production: none (CORS disabled)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# RUNTIME CONFIGURATION
# =============================================================================

# Environment mode: development, production, test
VOICESTUDIO_ENV=development

# Enable JSON logging format (recommended for production)
# VOICESTUDIO_JSON_LOGGING=false

# Enable telemetry (opt-in only)
# VOICESTUDIO_TELEMETRY=false

# Test mode (disables certain features for testing)
# VOICESTUDIO_TEST_MODE=false

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

# Enable PyTorch health checks (may be slow on first run)
# VOICESTUDIO_HEALTH_ENABLE_TORCH=0

# Safe mode for health checks (disable heavy operations)
# VOICESTUDIO_HEALTH_SAFE_MODE=1

# =============================================================================
# EXTERNAL SERVICES (API KEYS)
# =============================================================================
# NOTE: Store API keys in config/api-keys.json (see api-key-management.mdc)
# These environment variables are alternatives for CI/CD environments

# ElevenLabs API key
# ELEVENLABS_API_KEY=your-key-here

# OpenAI API key
# OPENAI_API_KEY=your-key-here

# Anthropic API key
# ANTHROPIC_API_KEY=your-key-here

# Deepgram API key
# DEEPGRAM_API_KEY=your-key-here

# AssemblyAI API key
# ASSEMBLYAI_API_KEY=your-key-here
