<Window
    x:Class="VoiceStudioWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{ThemeResource SystemAccentColor}" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="VoiceStudio Ultimate" FontSize="24" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Navigation and Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Pane -->
            <Border Grid.Column="0" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Width="200" Padding="10">
                <StackPanel>
                    <TextBlock Text="Navigation" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Button x:Name="DashboardButton" Content="📊 Dashboard" Click="NavigateToPage" Tag="Dashboard"
                            Style="{StaticResource NavigationButtonStyle}" Margin="0,2"/>
                    <Button x:Name="VoiceCloningButton" Content="🎤 Voice Cloning" Click="NavigateToPage" Tag="VoiceCloning"
                            Style="{StaticResource NavigationButtonStyle}" Margin="0,2"/>
                    <Button x:Name="MasteringRackButton" Content="🎛️ Mastering Rack" Click="NavigateToPage" Tag="MasteringRack"
                            Style="{StaticResource NavigationButtonStyle}" Margin="0,2"/>
                    <Button x:Name="RealTimeButton" Content="⚡ Real-Time" Click="NavigateToPage" Tag="RealTime"
                            Style="{StaticResource NavigationButtonStyle}" Margin="0,2"/>
                    <Button x:Name="SettingsButton" Content="⚙️ Settings" Click="NavigateToPage" Tag="Settings"
                            Style="{StaticResource NavigationButtonStyle}" Margin="0,2"/>

                    <Separator Margin="0,10"/>

                    <Button x:Name="SBOMButton" Content="📋 Generate SBOM" Click="OnGenSbom"
                            Style="{StaticResource AccentButtonStyle}" Margin="0,5"/>
                    <Button x:Name="OpenSBOMButton" Content="📁 Open SBOM Folder" Click="OnOpenSbomFolder"
                            Margin="0,2"/>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="ContentFrame" Grid.Column="1" Padding="20" NavigationFailed="ContentFrame_NavigationFailed">
                <!-- Default content - Voice Cloning -->
                <ScrollViewer>
                    <StackPanel>
                        <!-- Advanced Voice Cloning Section -->
                        <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="20" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Advanced Voice Cloning" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                                <!-- Model Selection with Advanced Options -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="AI Model:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="ModelComboBox" PlaceholderText="Choose your AI model">
                                            <ComboBoxItem Content="GPT-SoVITS 2.0 Real AI" Tag="gpt_sovits_2"/>
                                            <ComboBoxItem Content="Coqui XTTS 3.0 Real AI" Tag="coqui_xtts_3"/>
                                            <ComboBoxItem Content="RVC 4.0 Real AI" Tag="rvc_4"/>
                                            <ComboBoxItem Content="OpenVoice 2.0 Real AI" Tag="openvoice_2"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Quality Preset:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="QualityComboBox" SelectedIndex="2">
                                            <ComboBoxItem Content="Fast" Tag="fast"/>
                                            <ComboBoxItem Content="Balanced" Tag="balanced"/>
                                            <ComboBoxItem Content="High Quality" Tag="high_quality"/>
                                            <ComboBoxItem Content="Ultimate" Tag="ultimate"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                        <CheckBox x:Name="RealTimeCheckBox" Content="Real-time Processing" IsChecked="False"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,10,0,0">
                                        <CheckBox x:Name="GPUAccelerationCheckBox" Content="GPU Acceleration" IsChecked="True"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Reference Audio with Preview -->
                                <StackPanel Margin="0,15,0,0">
                                    <TextBlock Text="Reference Audio:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedAudioText" Text="No file selected" VerticalAlignment="Center" Grid.Column="0"/>
                                        <Button x:Name="SelectAudioButton" Content="Select" Click="SelectAudioButton_Click" Grid.Column="1" Margin="10,0,5,0"/>
                                        <Button x:Name="PreviewAudioButton" Content="Preview" Click="PreviewAudioButton_Click" Grid.Column="2" IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Target Text with Advanced Options -->
                                <StackPanel Margin="0,15,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Target Text:" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Column="0"/>
                                        <Button x:Name="TextAnalysisButton" Content="Analyze Text" Click="TextAnalysisButton_Click" Grid.Column="1" IsEnabled="False"/>
                                    </Grid>
                                    <TextBox x:Name="TargetTextBox"
                                             PlaceholderText="Enter text to clone voice for..."
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="120"
                                             TextChanged="TargetTextBox_TextChanged"/>
                                    <TextBlock x:Name="TextAnalysisResult" Text="" FontStyle="Italic" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="CloneButton"
                                            Content="Clone Voice"
                                            Grid.Column="0"
                                            Click="CloneButton_Click"
                                            Style="{StaticResource AccentButtonStyle}"/>
                                    <Button x:Name="BatchCloneButton"
                                            Content="Batch Clone"
                                            Grid.Column="1"
                                            Margin="10,0,5,0"
                                            Click="BatchCloneButton_Click"/>
                                    <Button x:Name="CancelButton"
                                            Content="Cancel"
                                            Grid.Column="2"
                                            Margin="5,0,0,0"
                                            Click="CancelButton_Click"
                                            IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Status Section -->
                        <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="20" CornerRadius="8" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="Gray"/>
                                    <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <ProgressBar x:Name="ProgressBar" IsIndeterminate="False" Visibility="Collapsed" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Output Section -->
                        <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="20" CornerRadius="8" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Output" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="PlayButton" Content="Play" Click="PlayButton_Click" IsEnabled="False"/>
                                    <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" IsEnabled="False" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="OutputText" Text="No output generated yet" FontStyle="Italic" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Frame>
        </Grid>
    </Grid>
</Window>
