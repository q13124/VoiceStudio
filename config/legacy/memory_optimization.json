{
  "memory_management": {
    "max_memory_usage": 0.8,
    "garbage_collection": {
      "enabled": true,
      "frequency": "after_each_batch",
      "threshold": 0.7
    },
    "model_caching": {
      "enabled": true,
      "max_models_in_memory": 3,
      "eviction_policy": "LRU"
    },
    "audio_buffer": {
      "max_size_mb": 100,
      "preload_enabled": true,
      "compression": "lossless"
    }
  }
}