{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "Assistant": {
      "Port": 5080,
      "HealthEndpoint": "/health",
      "AutofixEndpoint": "/autofix/status"
    },
    "Orchestrator": {
      "Port": 5090,
      "HealthEndpoint": "/health",
      "SettingsEndpoint": "/settings",
      "WeightsEndpoint": "/weights"
    },
    "Autofix": {
      "Port": 5081,
      "HealthEndpoint": "/health",
      "StatusEndpoint": "/status",
      "AnalyzeEndpoint": "/analyze"
    }
  },
  "VoiceStudio": {
    "Version": "1.0.0",
    "Environment": "Development"
  }
}
