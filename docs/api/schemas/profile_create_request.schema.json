{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProfileCreateRequest",
  "type": "object",
  "description": "Request schema for creating a new voice profile",
  "properties": {
    "name": {
      "type": "string",
      "description": "Profile name",
      "minLength": 1,
      "maxLength": 100,
      "example": "My Voice Profile"
    },
    "language": {
      "type": "string",
      "description": "Language code (ISO 639-1)",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "example": "en"
    },
    "tags": {
      "type": "array",
      "description": "Profile tags",
      "items": {
        "type": "string"
      },
      "default": [],
      "example": ["male", "professional"]
    },
    "reference_audio": {
      "type": "string",
      "description": "Path to reference audio file (optional)",
      "format": "uri"
    },
    "engine": {
      "type": "string",
      "description": "Preferred engine",
      "enum": ["xtts_v2", "chatterbox", "tortoise"],
      "default": "chatterbox"
    }
  },
  "required": ["name", "language"],
  "additionalProperties": false
}

