{
  // VoiceStudio Project Settings
  // Project path: E:\VoiceStudio
  // Terminal settings
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultLocation": "editor",
  // File settings
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.mypy_cache": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.mypy_cache/**": true,
    "**/__pycache__/**": true,
    "**/bin/**": true,
    "**/obj/**": true
  },
  // Python settings
  "python.defaultInterpreterPath": "${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/backend",
    "${workspaceFolder}/backend/api",
    "${workspaceFolder}/backend/mcp_bridge"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "black",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  // Hugging Face settings
  "huggingface.path": "${workspaceFolder}/models",
  "huggingface.cacheDir": "${env:HF_HOME}",
  // LLM language server override (patched build to avoid Instant panic on Windows)
  // Note: this setting does not expand ${workspaceFolder}, so keep it absolute.
  "llm.lsp.binaryPath": "E:\\VoiceStudio\\temp\\llm-ls\\target\\release\\llm-ls.exe",
  // C# / .NET settings
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.useModernNet": true,
  // Editor settings
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  // File associations
  "files.associations": {
    "*.xaml": "xml",
    "*.csproj": "xml",
    "*.props": "xml",
    "*.targets": "xml"
  },
  // Search settings
  "search.exclude": {
    "**/node_modules": true,
    "**/bin": true,
    "**/obj": true,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true
  },
  // Logging settings (addresses rpcFileLoggerFolder warning)
  "log.output.level": "info",
  "log.extensionHost.level": "info",
  // Suppress extension API warnings in console (these are informational)
  "extensions.ignoreRecommendations": false,
  // Workspace-specific settings
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[csharp]": {
    "editor.defaultFormatter": "anysphere.csharp",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[xml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.tabSize": 2
  },
  "markdown.validate.enabled": true,
  "git.ignoreLimitWarning": true,
  "cSpell.words": [
    "Coqui"
  ],
  "todo-tree.tree.scanMode": "current file",
  "yaml.schemas": {
    "file:///c%3A/Users/Tyler/.cursor/extensions/continue.continue-1.3.28-win32-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ],
    "file:///c%3A/Users/Tyler/.cursor/extensions/continue.continue-1.3.29-win32-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ],
    "file:///c%3A/Users/Tyler/.cursor/extensions/continue.continue-1.2.14-win32-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml",
      "file:///c%3A/Users/Tyler/.continue/config.yaml"
    ]
  }
}