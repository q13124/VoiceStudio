<UserControl x:Class="VoiceStudio.App.Controls.VSQToastNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="ToastBorder"
        BorderThickness="1"
        Padding="8"
        AutomationProperties.Name="{x:Bind ToastType, Mode=OneWay}"
        AutomationProperties.HelpText="{x:Bind Message, Mode=OneWay}"
        AutomationProperties.LiveSetting="Polite">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Icon -->
            <TextBlock Grid.Column="0"
                x:Name="IconTextBlock"
                Text="ℹ"
                FontSize="14"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                AutomationProperties.Name="Toast icon" />
            <!-- Content -->
            <StackPanel Grid.Column="1"
                VerticalAlignment="Center">
                <!-- Title -->
                <TextBlock x:Name="TitleTextBlock"
                    Text="{x:Bind Title, Mode=OneWay}"
                    FontWeight="SemiBold"
                    AutomationProperties.Name="Toast title" />
                <!-- Message -->
                <TextBlock Text="{x:Bind Message, Mode=OneWay}"
                    AutomationProperties.Name="Toast message" />
            </StackPanel>
            <!-- Dismiss Button -->
            <Button Grid.Column="2"
                Content="X"
                Click="DismissButton_Click"
                AutomationProperties.Name="Dismiss toast"
                AutomationProperties.HelpText="Close this notification" />
        </Grid>
    </Border>
</UserControl>