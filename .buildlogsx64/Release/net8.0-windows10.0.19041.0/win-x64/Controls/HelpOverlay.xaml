<UserControl x:Class="VoiceStudio.App.Controls.HelpOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <Border Background="#CC000000" Padding="16">
        <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" />
                <Button Content="X" Click="CloseButton_Click" Margin="12,0,0,0" />
            </StackPanel>
            <TextBlock Text="{x:Bind HelpText, Mode=OneWay}" TextWrapping="Wrap" />
            <TextBlock Text="Press Escape to close" Opacity="0.7" />
        </StackPanel>
    </Border>
</UserControl>