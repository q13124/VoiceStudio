<UserControl x:Class="VoiceStudio.App.Controls.BatchQueueTimelineControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <x:Double x:Key="TimelineHeight">150</x:Double>
    <x:Double x:Key="JobBlockHeight">35</x:Double>
    <x:Double x:Key="TimeMarkerSpacing">50</x:Double>
  </UserControl.Resources>
  <Border Background="{StaticResource VSQ.Panel.Background}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="4">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <!-- Timeline Header -->
      <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.HeaderBackground}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Batch Queue Timeline" FontWeight="SemiBold" FontSize="{StaticResource VSQ.FontSize.Caption}" VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <Button Content="Zoom In" Click="ZoomIn_Click" Style="{StaticResource VSQ.Button.Secondary}" FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="8,4" AutomationProperties.Name="Zoom in"/>
            <Button Content="Zoom Out" Click="ZoomOut_Click" Style="{StaticResource VSQ.Button.Secondary}" FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="8,4" AutomationProperties.Name="Zoom out"/>
            <Button Content="Fit" Click="Fit_Click" Style="{StaticResource VSQ.Button.Secondary}" FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="8,4" AutomationProperties.Name="Fit timeline"/>
          </StackPanel>
        </Grid>
      </Border>
      <!-- Timeline Canvas -->
      <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ZoomMode="Disabled">
        <Canvas x:Name="TimelineCanvas" MinHeight="{StaticResource TimelineHeight}" Background="{StaticResource VSQ.Panel.Background.DarkBrush}" PointerPressed="TimelineCanvas_PointerPressed" PointerMoved="TimelineCanvas_PointerMoved" PointerReleased="TimelineCanvas_PointerReleased">
          <!-- Time markers will be drawn here -->
          <!-- Job blocks will be drawn here -->
        </Canvas>
      </ScrollViewer>
      <!-- Timeline Footer (Time Scale + Estimated Queue Time) -->
      <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.HeaderBackground}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0" Padding="8,4" Height="32">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" x:Name="TimeScaleText" Text="0:00" FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" x:Name="EstimatedTimeText" Text="" FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Accent.CyanBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
