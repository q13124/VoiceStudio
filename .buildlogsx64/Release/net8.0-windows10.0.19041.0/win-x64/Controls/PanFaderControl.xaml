<UserControl
    x:Class="VoiceStudio.App.Controls.PanFaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Value Display -->
        <TextBlock Grid.Row="0"
                   x:Name="ValueTextBlock"
                   Text="C"
                   FontSize="9"
                   FontFamily="Consolas"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,2"
                   Foreground="#AAAAAA"/>
        <!-- Pan Fader Track (Horizontal) -->
        <Border Grid.Row="1"
                Background="#2A2F38"
                BorderBrush="#3A3F48"
                BorderThickness="1"
                CornerRadius="2"
                Margin="4,0"
                HorizontalAlignment="Stretch"
                Height="24">
            <Grid>
                <!-- Center Line -->
                <Border Background="#4A4F58"
                        Width="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"/>
                <!-- Pan Fader Knob -->
                <Border x:Name="PanFaderKnob"
                        Background="#4A9EFF"
                        BorderBrush="#6AB4FF"
                        BorderThickness="2"
                        CornerRadius="8"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="-10,0,0,0"
                        PointerPressed="PanFaderKnob_PointerPressed"
                        PointerMoved="PanFaderKnob_PointerMoved"
                        PointerReleased="PanFaderKnob_PointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PanFaderKnobTransform" X="0"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
