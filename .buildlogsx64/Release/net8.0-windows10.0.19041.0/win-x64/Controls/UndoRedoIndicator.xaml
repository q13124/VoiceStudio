<UserControl x:Class="VoiceStudio.App.Controls.UndoRedoIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <!-- Undo Button with Count -->
        <Button x:Name="UndoButton"
                AutomationProperties.Name="Undo">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="↶" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="UndoCountText"
                          Text=""
                          FontSize="11"
                          Opacity="0.7"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <!-- Redo Button with Count -->
        <Button x:Name="RedoButton"
                AutomationProperties.Name="Redo">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="↷" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="RedoCountText"
                          Text=""
                          FontSize="11"
                          Opacity="0.7"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
