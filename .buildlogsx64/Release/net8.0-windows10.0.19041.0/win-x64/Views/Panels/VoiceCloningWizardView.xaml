<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceCloningWizardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  xmlns:converters="using:VoiceStudio.App.Converters">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:StringFormatConverter x:Key="StringFormatConverter" />
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="Voice Cloning Wizard"
          Style="{StaticResource VSQ.Text.Title}"
          VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Cancel"
            Command="{x:Bind ViewModel.CancelWizardCommand, Mode=OneWay}" />
          <Button Content="?"
            Click="HelpButton_Click"
            Style="{StaticResource VSQ.Button.Icon}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Step indicators -->
    <Border Grid.Row="1"
      Background="{StaticResource VSQ.Background.Darker}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
        Spacing="{StaticResource VSQ.Spacing.Large}">
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Accent.CyanBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="1. Upload"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="2. Configure"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="3. Process"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="4. Review"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Step content -->
    <ScrollViewer Grid.Row="2" Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
        <!-- Step 1: Upload Audio -->
        <Border x:Name="Step1Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Visible">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Step 1: Upload Reference Audio"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />
            <TextBlock
              Text="Upload a clear audio file containing the voice you want to clone. Recommended: 10+ seconds, mono, 16kHz+ sample rate."
              Style="{StaticResource VSQ.Text.Body}"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
              TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <Button Content="Browse Audio File"
                Command="{x:Bind ViewModel.BrowseAudioCommand, Mode=OneWay}" />
              <Button Content="Validate Audio"
                Command="{x:Bind ViewModel.ValidateAudioCommand, Mode=OneWay}" />
            </StackPanel>

            <TextBlock
              Text="{x:Bind ViewModel.AudioFileName, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{x:Bind ViewModel.AudioFileName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Validation Results -->
            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
              Padding="{StaticResource VSQ.Spacing.Medium}"
              Visibility="{x:Bind ViewModel.AudioValidation, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
              RightTapped="ValidationResults_RightTapped">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                <TextBlock Text="Validation Results" Style="{StaticResource VSQ.Text.Body}"
                  FontWeight="SemiBold" />
                <TextBlock
                  Text="{x:Bind ViewModel.AudioValidation.IsValid, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <TextBlock
                  Text="{x:Bind ViewModel.AudioValidation.Duration, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <TextBlock
                  Text="{x:Bind ViewModel.AudioValidation.SampleRate, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <TextBlock
                  Text="{x:Bind ViewModel.AudioValidation.Channels, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.AudioValidation.Issues, Mode=OneWay}"
                  Visibility="{x:Bind ViewModel.AudioValidation.Issues, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                        Style="{StaticResource VSQ.Text.Caption}"
                        Foreground="Orange"
                        Margin="20,0,0,0" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Step 2: Configure -->
        <Border x:Name="Step2Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Step 2: Configure Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Profile Name:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{x:Bind ViewModel.ProfileName, Mode=TwoWay}"
                Width="300"
                PlaceholderText="Enter profile name" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Description:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{x:Bind ViewModel.ProfileDescription, Mode=TwoWay}"
                Width="300"
                PlaceholderText="Optional description"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="80" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Engine:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Quality Mode:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{x:Bind ViewModel.QualityModes, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedQualityMode, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <Button Content="Start Processing"
              Command="{x:Bind ViewModel.StartProcessingCommand, Mode=OneWay}"
              HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <!-- Step 3: Process -->
        <Border x:Name="Step3Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Step 3: Processing Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <ProgressBar Value="{x:Bind ViewModel.ProcessingProgress, Mode=OneWay}"
              Maximum="100"
              Height="20" />
            <TextBlock Text="{x:Bind ViewModel.ProcessingStatus, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}" />
          </StackPanel>
        </Border>

        <!-- Step 4: Review -->
        <Border x:Name="Step4Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Step 4: Review Results" Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <TextBlock
              Text="{x:Bind ViewModel.CreatedProfileId, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{x:Bind ViewModel.CreatedProfileId, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Quality Metrics -->
            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
              Padding="{StaticResource VSQ.Spacing.Medium}"
              Visibility="{x:Bind ViewModel.QualityMetrics, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
              RightTapped="QualityMetrics_RightTapped">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                <TextBlock Text="Quality Metrics" Style="{StaticResource VSQ.Text.Body}"
                  FontWeight="SemiBold" />
                <TextBlock
                  Text="{x:Bind ViewModel.QualityMetrics.MosScore, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <TextBlock
                  Text="{x:Bind ViewModel.QualityMetrics.Similarity, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
                <TextBlock
                  Text="{x:Bind ViewModel.QualityMetrics.Naturalness, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Navigation buttons -->
    <Border Grid.Row="3"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,1,0,0"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
          Style="{StaticResource VSQ.Text.Caption}"
          Foreground="Red"
          Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Previous"
            Command="{x:Bind ViewModel.PreviousStepCommand, Mode=OneWay}" />
          <Button Content="Next"
            Command="{x:Bind ViewModel.NextStepCommand, Mode=OneWay}" />
          <Button Content="Finalize"
            Command="{x:Bind ViewModel.FinalizeWizardCommand, Mode=OneWay}"
            Visibility="Collapsed" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay"
      IsVisible="False"
      Visibility="Collapsed" />
  </Grid>
</UserControl>