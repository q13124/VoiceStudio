<UserControl x:Class="VoiceStudio.App.Views.Panels.TimelineView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls">
  <Grid>
    <!-- Minimal placeholders to satisfy code-behind references during Phase 0 -->
    <ScrollViewer x:Name="TimelineScrollViewer" />
    <ListView x:Name="TracksListView" />
    <Canvas x:Name="TimelineScrubCanvas" Background="Transparent" />
    <Canvas x:Name="PlayheadCanvas">
      <Line x:Name="PlayheadLine" />
    </Canvas>
    <Canvas x:Name="DragDropCanvas" IsHitTestVisible="False" Background="Transparent" />
    <controls:SpectrogramControl x:Name="SpectrogramVisualizer" />
    <controls:WaveformControl x:Name="WaveformVisualizer" />
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed" />
  </Grid>
</UserControl>