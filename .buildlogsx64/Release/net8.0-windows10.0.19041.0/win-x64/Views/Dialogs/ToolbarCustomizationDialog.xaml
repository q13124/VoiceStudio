<ContentDialog x:Class="VoiceStudio.App.Views.Dialogs.ToolbarCustomizationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Customize Toolbar"
    PrimaryButtonText="Apply"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary">
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Presets Section -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="PresetComboBox" Width="200" SelectionChanged="PresetComboBox_SelectionChanged"/>
            <Button x:Name="SavePresetButton" Content="Save as Preset..." Margin="16,0,0,0" Click="SavePresetButton_Click"/>
        </StackPanel>
        <!-- Toolbar Items List -->
        <Border Grid.Row="1" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
            <ListView x:Name="ToolbarItemsListView" 
                      CanReorderItems="True" 
                      AllowDrop="True"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Drag Handle -->
                            <TextBlock Grid.Column="0" Text="☰" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <!-- Item Info -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Section}" 
                                           FontSize="10" 
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" 
                                           Margin="8,0,0,0" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Visibility Toggle -->
                            <ToggleSwitch Grid.Column="2" 
                                          IsOn="{Binding IsVisible, Mode=TwoWay}" 
                                          OffContent="Hidden" 
                                          OnContent="Visible"
                                          Margin="16,0,0,0"/>
                            <!-- Order Display -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Order}" 
                                       FontSize="10" 
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}" 
                                       VerticalAlignment="Center" 
                                       Margin="16,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <!-- Info Text -->
        <TextBlock Grid.Row="2" 
                   Text="Drag items to reorder. Toggle visibility to show/hide items. Changes are saved automatically." 
                   FontSize="11" 
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" 
                   TextWrapping="Wrap" 
                   Margin="0,12,0,0"/>
    </Grid>
</ContentDialog>
