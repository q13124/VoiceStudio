<UserControl x:Class="VoiceStudio.App.Views.CommandPaletteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VSQ.Surface}">
  <Grid Padding="{StaticResource VSQ.PanelPadding}" Width="860">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBox Grid.Row="0"
             Height="{StaticResource VSQ.ControlHeight}"
             PlaceholderText="Search commands and panels (Ctrl+P)"
             Text="{Binding FilterText, Mode=TwoWay}"/>
    <ListView Grid.Row="1" 
              ItemsSource="{Binding FilteredItems}"
              SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
      <ListView.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Kind}" 
                       Width="90" 
                       Foreground="{StaticResource VSQ.SubtleText}"/>
            <TextBlock Text="{Binding Title}" 
                       Foreground="{StaticResource VSQ.Text}"/>
            <TextBlock Text="{Binding Shortcut}" 
                       Margin="12,0,0,0" 
                       Foreground="{StaticResource VSQ.SubtleText}"/>
          </StackPanel>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
    <StackPanel Grid.Row="2" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                Spacing="8">
      <TextBlock Text="Enter: Run   Esc: Close   Ctrl+/: Keymap" 
                 Foreground="{StaticResource VSQ.SubtleText}" />
    </StackPanel>
  </Grid>
</UserControl>
