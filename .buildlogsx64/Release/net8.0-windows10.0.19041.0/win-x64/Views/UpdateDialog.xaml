<ContentDialog
  x:Class="VoiceStudio.App.Views.UpdateDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="using:VoiceStudio.App.Converters"
  Title="Update Available"
  PrimaryButtonText="Download"
  SecondaryButtonText="Later"
  CloseButtonText="Dismiss"
  DefaultButton="Primary"
  x:Name="UpdateDialogControl">
  <ContentDialog.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </ContentDialog.Resources>
  <Grid MinWidth="500" MinHeight="400">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <!-- Update Information -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="A new version is available!"
        FontSize="20"
        FontWeight="SemiBold"
        Margin="0,0,0,8" />
      <TextBlock>
        <Run Text="Current version: " />
        <Run Text="{Binding CurrentVersion}" FontWeight="SemiBold" />
      </TextBlock>
      <TextBlock>
        <Run Text="Latest version: " />
        <Run Text="{Binding LatestVersion}" FontWeight="SemiBold"
          Foreground="{StaticResource VSQ.Accent.CyanBrush}" />
      </TextBlock>
    </StackPanel>
    <!-- Download Progress -->
    <StackPanel Grid.Row="1" Margin="0,0,0,16"
      Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
      <TextBlock Text="{Binding DownloadStatusText}"
        Margin="0,0,0,8" />
      <ProgressBar Value="{Binding DownloadProgress}"
        Maximum="1.0"
        Height="8"
        IsIndeterminate="{Binding IsDownloadingUpdate}" />
    </StackPanel>
    <!-- Release Notes -->
    <ScrollViewer Grid.Row="2"
      Margin="0,0,0,16"
      VerticalScrollBarVisibility="Auto"
      HorizontalScrollBarVisibility="Disabled">
      <TextBlock Text="{Binding ReleaseNotes}"
        TextWrapping="Wrap"
        IsTextSelectionEnabled="True" />
    </ScrollViewer>
    <!-- Error Message -->
    <Border Grid.Row="3"
      Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
      BorderBrush="{StaticResource VSQ.Error.Brush}"
      BorderThickness="1"
      CornerRadius="4"
      Padding="12"
      Margin="0,0,0,16"
      Visibility="Collapsed">
      <TextBlock Text="{Binding ErrorMessage}"
        Foreground="{StaticResource VSQ.Error.Brush}"
        TextWrapping="Wrap" />
    </Border>
    <!-- Action Buttons -->
    <StackPanel Grid.Row="4"
      Orientation="Horizontal"
      HorizontalAlignment="Right"
      Spacing="8">
      <Button Content="Check for Updates"
        Command="{Binding CheckForUpdatesCommand}" />
      <Button Content="Download Update"
        Command="{Binding DownloadUpdateCommand}"
        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <Button Content="Install Update"
        Command="{Binding InstallUpdateCommand}"
        Visibility="Collapsed"
        Style="{StaticResource VSQ.Button.Primary}" />
    </StackPanel>
  </Grid>
</ContentDialog>