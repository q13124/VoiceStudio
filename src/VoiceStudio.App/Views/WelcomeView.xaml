<ContentDialog x:Class="VoiceStudio.App.Views.WelcomeView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="Welcome to VoiceStudio Quantum+"
               PrimaryButtonText="Get Started"
               CloseButtonText="Skip"
               DefaultButton="Primary"
>
    <ScrollViewer MaxHeight="500">
        <StackPanel Spacing="16">
            <!-- Welcome Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="🎙️" 
                           FontSize="48" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Welcome to VoiceStudio Quantum+" 
                           FontSize="{StaticResource VSQ.FontSize.Heading}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <TextBlock Text="Professional voice cloning and audio production" 
                           FontSize="{StaticResource VSQ.FontSize.Body}"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           TextAlignment="Center"/>
            </StackPanel>
            <!-- Quick Start Guide -->
            <Border Background="#1A1A1A"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,8,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick Start" 
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="1️⃣" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Create a Voice Profile" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                <TextBlock Text="Go to Profiles panel and create your first voice profile" 
                                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="2️⃣" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Synthesize Voice" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                <TextBlock Text="Use the Timeline to create and edit voice synthesis" 
                                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="3️⃣" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Apply Effects" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                <TextBlock Text="Use the Effects Mixer to enhance your audio" 
                                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- Keyboard Shortcuts -->
            <Border Background="#1A1A1A"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Keyboard Shortcuts" 
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Ctrl+N - New Project" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Ctrl+O - Open Project" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Ctrl+S - Save Project" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Space - Play/Pause" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Ctrl+Z - Undo" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Ctrl+Y - Redo" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Ctrl+P - Command Palette" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="Ctrl+R - Record" 
                                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- Tips -->
            <Border Background="#1A1A1A"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="💡 Tips" 
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <TextBlock Text="• Hover over buttons to see tooltips with keyboard shortcuts" 
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="• Use the Command Palette (Ctrl+P) to quickly access features" 
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="• Check the Diagnostics panel for system health and logs" 
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <!-- Checkbox to show on startup -->
            <CheckBox x:Name="ShowOnStartupCheckBox"
                     Content="Show this welcome dialog on startup"
                     IsChecked="True"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
