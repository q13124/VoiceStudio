<UserControl x:Class="VoiceStudio.App.Views.Shell.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls">
    <StackPanel Background="{StaticResource VSQ.Background.Darker}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,0,1,0">
        <controls:NavIconButton x:Name="NavProfiles"
                                IconGlyph="&#xE8A5;"
                                ToolTipService.ToolTip="Profiles"
                                IsChecked="True"/>
        <controls:NavIconButton x:Name="NavLibrary"
                                IconGlyph="&#xE8F1;"
                                ToolTipService.ToolTip="Library"/>
        <controls:NavIconButton x:Name="NavBatch"
                                IconGlyph="&#xE8F5;"
                                ToolTipService.ToolTip="Batch"/>
    </StackPanel>
</UserControl>
