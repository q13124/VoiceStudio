<UserControl
    x:Class="VoiceStudio.App.Views.KeyboardShortcutsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Background.DarkerBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Keyboard Shortcuts" 
                              Style="{StaticResource VSQ.Text.Heading}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="Press Ctrl+? to open this reference" 
                              Style="{StaticResource VSQ.Text.Caption}"
                              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                </StackPanel>
                <!-- Search Box -->
                <TextBox x:Name="SearchBox"
                        Grid.Column="1"
                        PlaceholderText="Search shortcuts..."
                        Width="300"
                        Margin="0,0,0,0"
                        TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>
        <!-- Shortcuts List -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollMode="Auto" 
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ShortcutsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ShortcutViewModel">
                        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                               BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                               BorderThickness="0,0,0,1"
                               Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind Description, Mode=OneWay}" 
                                              Style="{StaticResource VSQ.Text.Body}"
                                              FontWeight="SemiBold"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind Category, Mode=OneWay}" 
                                              Style="{StaticResource VSQ.Text.Caption}"
                                              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                       Background="{StaticResource VSQ.Background.DarkerBrush}"
                                       BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                       BorderThickness="1"
                                       CornerRadius="4"
                                       Padding="8,4">
                                    <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}" 
                                              Style="{StaticResource VSQ.Text.Caption}"
                                              FontFamily="Consolas"
                                              HorizontalAlignment="Right"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Background.DarkerBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button x:Name="PrintButton" 
                       Content="Print"
                       Click="PrintButton_Click"
                       Style="{StaticResource VSQ.Button.Style}"/>
                <Button x:Name="ExportButton" 
                       Content="Export"
                       Click="ExportButton_Click"
                       Style="{StaticResource VSQ.Button.Style}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
