<ContentDialog
  x:Class="VoiceStudio.App.Views.UpdateDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  xmlns:converters="using:VoiceStudio.App.Converters"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=vm:UpdateViewModel, IsDesignTimeCreatable=False}"
  x:DataType="vm:UpdateViewModel"
  Title="Update Available"
  PrimaryButtonText="Download"
  SecondaryButtonText="Later"
  CloseButtonText="Dismiss"
  DefaultButton="Primary"
  x:Name="UpdateDialogControl">
  <ContentDialog.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </ContentDialog.Resources>
  <Grid MinWidth="500" MinHeight="400">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <!-- Update Information -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="A new version is available!"
        FontSize="20"
        FontWeight="SemiBold"
        Margin="0,0,0,8" />
      <TextBlock>
        <Run Text="Current version: " />
        <Run Text="{x:Bind ViewModel.CurrentVersion, Mode=OneWay}" FontWeight="SemiBold" />
      </TextBlock>
      <TextBlock>
        <Run Text="Latest version: " />
        <Run Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}" FontWeight="SemiBold"
          Foreground="{StaticResource VSQ.Accent.CyanBrush}" />
      </TextBlock>
    </StackPanel>
    <!-- Download Progress -->
    <StackPanel Grid.Row="1" Margin="0,0,0,16"
      Visibility="{x:Bind ViewModel.IsDownloadingUpdate, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
      <TextBlock Text="{x:Bind ViewModel.DownloadStatusText, Mode=OneWay}"
        Margin="0,0,0,8" />
      <ProgressBar Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
        Maximum="1.0"
        Height="8"
        IsIndeterminate="{x:Bind ViewModel.IsDownloadingUpdate, Mode=OneWay}" />
    </StackPanel>
    <!-- Release Notes -->
    <ScrollViewer Grid.Row="2"
      Margin="0,0,0,16"
      VerticalScrollBarVisibility="Auto"
      HorizontalScrollBarVisibility="Disabled">
      <TextBlock Text="{x:Bind ViewModel.ReleaseNotes, Mode=OneWay}"
        TextWrapping="Wrap"
        IsTextSelectionEnabled="True" />
    </ScrollViewer>
    <!-- Error Message -->
    <Border Grid.Row="3"
      Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
      BorderBrush="{StaticResource VSQ.Error.Brush}"
      BorderThickness="1"
      CornerRadius="4"
      Padding="12"
      Margin="0,0,0,16"
      Visibility="Collapsed">
      <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
        Foreground="{StaticResource VSQ.Error.Brush}"
        TextWrapping="Wrap" />
    </Border>
    <!-- Action Buttons -->
    <StackPanel Grid.Row="4"
      Orientation="Horizontal"
      HorizontalAlignment="Right"
      Spacing="8">
      <Button Content="Check for Updates"
        Command="{x:Bind ViewModel.CheckForUpdatesCommand, Mode=OneWay}" />
      <Button Content="Download Update"
        Command="{x:Bind ViewModel.DownloadUpdateCommand, Mode=OneWay}"
        Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <Button Content="Install Update"
        Command="{x:Bind ViewModel.InstallUpdateCommand, Mode=OneWay}"
        Visibility="Collapsed"
        Style="{StaticResource VSQ.Button.Primary}" />
    </StackPanel>
  </Grid>
</ContentDialog>