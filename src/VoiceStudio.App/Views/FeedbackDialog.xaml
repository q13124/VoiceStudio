<!--
  FeedbackDialog.xaml - User feedback collection dialog
  
  AI GUIDELINES:
  - Follows Phase 1 XAML Reliability patterns (x:DataType, d:DataContext, FallbackValue)
  - Uses VSQ design tokens for consistent styling
  - Bindings use {x:Bind} with Mode and FallbackValue where appropriate
-->
<ContentDialog
    x:Class="VoiceStudio.App.Views.FeedbackDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:FeedbackViewModel, IsDesignTimeCreatable=False}"
    x:DataType="vm:FeedbackViewModel"
    Title="Send Feedback"
    PrimaryButtonText="Submit"
    PrimaryButtonCommand="{x:Bind ViewModel.SubmitFeedbackCommand, Mode=OneWay}"
    SecondaryButtonText="Cancel"
    SecondaryButtonCommand="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
    DefaultButton="Primary"
    x:Name="FeedbackDialogControl">

    <ContentDialog.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </ContentDialog.Resources>

    <Grid MinWidth="480" MinHeight="400" Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock 
                Text="We'd love to hear from you!" 
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,0,0,4" />
            <TextBlock 
                Text="Your feedback helps us improve VoiceStudio."
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Rating Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="How would you rate your experience?" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="★" Width="40" Height="40" 
                        Command="{x:Bind ViewModel.SetRatingCommand, Mode=OneWay}"
                        CommandParameter="1"
                        ToolTipService.ToolTip="Poor"
                        AutomationProperties.Name="Rate 1 star" />
                <Button Content="★" Width="40" Height="40"
                        Command="{x:Bind ViewModel.SetRatingCommand, Mode=OneWay}"
                        CommandParameter="2"
                        ToolTipService.ToolTip="Fair"
                        AutomationProperties.Name="Rate 2 stars" />
                <Button Content="★" Width="40" Height="40"
                        Command="{x:Bind ViewModel.SetRatingCommand, Mode=OneWay}"
                        CommandParameter="3"
                        ToolTipService.ToolTip="Good"
                        AutomationProperties.Name="Rate 3 stars" />
                <Button Content="★" Width="40" Height="40"
                        Command="{x:Bind ViewModel.SetRatingCommand, Mode=OneWay}"
                        CommandParameter="4"
                        ToolTipService.ToolTip="Very Good"
                        AutomationProperties.Name="Rate 4 stars" />
                <Button Content="★" Width="40" Height="40"
                        Command="{x:Bind ViewModel.SetRatingCommand, Mode=OneWay}"
                        CommandParameter="5"
                        ToolTipService.ToolTip="Excellent"
                        AutomationProperties.Name="Rate 5 stars" />
                <TextBlock 
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind ViewModel.Rating, Mode=OneWay}" />
                    <Run Text=" / 5" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Category Selection -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Feedback Category" Margin="0,0,0,8" />
            <ComboBox 
                ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Feedback category selector" />
        </StackPanel>

        <!-- Feedback Message -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Your Feedback" Margin="0,0,0,8" />
            <TextBox 
                Text="{x:Bind ViewModel.FeedbackMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Tell us what you think, report a bug, or suggest a feature..."
                TextWrapping="Wrap"
                AcceptsReturn="True"
                MinHeight="120"
                MaxHeight="200"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                AutomationProperties.Name="Feedback message input" />
        </StackPanel>

        <!-- Email (Optional) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="Email (optional - for follow-up)" Margin="0,0,0,8" />
            <TextBox 
                Text="{x:Bind ViewModel.EmailAddress, Mode=TwoWay}"
                PlaceholderText="your@email.com"
                AutomationProperties.Name="Email address for follow-up" />
        </StackPanel>

        <!-- Include System Info Checkbox -->
        <CheckBox 
            Grid.Row="5"
            Content="Include system information (helps diagnose issues)"
            IsChecked="{x:Bind ViewModel.IncludeSystemInfo, Mode=TwoWay}"
            Margin="0,0,0,16"
            AutomationProperties.Name="Include system information checkbox" />

        <!-- Status Messages -->
        <StackPanel Grid.Row="6">
            <!-- Submitting indicator -->
            <StackPanel 
                Orientation="Horizontal" 
                Spacing="8"
                Visibility="{x:Bind ViewModel.IsSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock 
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Submitting...'}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Success message -->
            <Border
                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                CornerRadius="4"
                Padding="12,8"
                Visibility="{x:Bind ViewModel.IsSubmitted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock 
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Thank you!'}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Error message -->
            <Border
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                CornerRadius="4"
                Padding="12,8"
                Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE783;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    <TextBlock 
                        Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred'}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>
