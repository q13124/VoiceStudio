<Window
    x:Class="VoiceStudio.App.Views.AgentApprovalDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Agent Action Approval Required"
    Width="500"
    Height="Auto"
    MinHeight="350"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <FontIcon Glyph="&#xE946;" FontSize="32" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
            <StackPanel Margin="16,0,0,0">
                <TextBlock Text="Approval Required" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="An agent is requesting to perform a high-risk action"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Action Details -->
        <Border Grid.Row="1" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tool:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ToolNameText" Text="{x:Bind ToolName, Mode=OneWay}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Risk Level:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RiskTierText" Margin="0,8,0,0"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Agent ID:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AgentIdText" Margin="0,8,0,0"
                           Style="{StaticResource CaptionTextBlockStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expires:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ExpiresText" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Reason -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Reason for approval:" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock x:Name="ReasonText" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Parameters -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Parameters:" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ParametersText" 
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </ScrollViewer>
        </StackPanel>

        <!-- Decision Reason Input -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="Your reason (optional):" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="DecisionReasonInput" 
                     PlaceholderText="Enter a reason for your decision..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="80"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Spacing="12">
            <Button x:Name="DenyButton"
                    Content="Deny"
                    Click="DenyButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Background="{ThemeResource SystemFillColorCriticalBrush}"
                    Width="100"/>
            <Button x:Name="ApproveButton"
                    Content="Approve"
                    Click="ApproveButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="100"/>
        </StackPanel>
    </Grid>
</Window>
