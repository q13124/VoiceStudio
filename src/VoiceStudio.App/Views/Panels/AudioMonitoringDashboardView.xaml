<UserControl x:Class="VoiceStudio.App.Views.Panels.AudioMonitoringDashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:AudioMonitoringDashboardView">

  <Grid AutomationProperties.AutomationId="AudioMonitoringDashboardView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE767;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Audio Monitoring" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.ResetCommand}"
                AutomationProperties.AutomationId="AudioMonitoringView_ResetButton"
                ToolTipService.ToolTip="Reset">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="AudioMonitoringView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Audio Source & Controls -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" Header="Audio ID"
                   Text="{x:Bind ViewModel.AudioId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Enter audio file ID..."
                   AutomationProperties.AutomationId="AudioMonitoringView_AudioIdInput"/>
          <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.LoadAudioCommand}"
                  AutomationProperties.AutomationId="AudioMonitoringView_LoadButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
              <TextBlock Text="Load"/>
            </StackPanel>
          </Button>
          <ToggleButton Grid.Column="2" VerticalAlignment="Bottom"
                        IsChecked="{x:Bind ViewModel.IsRealTimeEnabled, Mode=TwoWay}"
                        AutomationProperties.AutomationId="AudioMonitoringView_RealTimeToggle">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xEA3A;" FontSize="14"/>
              <TextBlock Text="Live"/>
            </StackPanel>
          </ToggleButton>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Level Meters -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9E9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Level Meters" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <!-- Peak -->
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Peak" FontSize="12" VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <ProgressBar Grid.Column="1" Value="{x:Bind ViewModel.PeakLevelNormalized, Mode=OneWay}"
                       Maximum="1.0" Minimum="0.0" Foreground="{x:Bind ViewModel.PeakLevelColor, Mode=OneWay}"/>
          <TextBlock Grid.Column="2" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right"
                     VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
            <Run Text="{x:Bind ViewModel.PeakLevel, Mode=OneWay}"/>
            <Run Text="dB"/>
          </TextBlock>
        </Grid>

        <!-- RMS -->
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="RMS" FontSize="12" VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <ProgressBar Grid.Column="1" Value="{x:Bind ViewModel.RmsLevelNormalized, Mode=OneWay}"
                       Maximum="1.0" Minimum="0.0" Foreground="{x:Bind ViewModel.RmsLevelColor, Mode=OneWay}"/>
          <TextBlock Grid.Column="2" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right"
                     VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
            <Run Text="{x:Bind ViewModel.RmsLevel, Mode=OneWay}"/>
            <Run Text="dB"/>
          </TextBlock>
        </Grid>

        <!-- LUFS -->
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="LUFS" FontSize="12" VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <ProgressBar Grid.Column="1" Value="{x:Bind ViewModel.LufsProgress, Mode=OneWay}"
                       Maximum="1.0" Minimum="0.0" Foreground="{x:Bind ViewModel.LufsLevelColor, Mode=OneWay}"/>
          <TextBlock Grid.Column="2" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right"
                     VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
            <Run Text="{x:Bind ViewModel.LufsLevel, Mode=OneWay}"/>
          </TextBlock>
        </Grid>

        <!-- Clipping Indicator -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Width="12" Height="12" CornerRadius="6"
                  Background="{x:Bind ViewModel.ClippingColor, Mode=OneWay}"/>
          <TextBlock Text="Clipping" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
            <Run Text="{x:Bind ViewModel.ClippingDetected, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Statistics -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8D6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Statistics" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <Grid ColumnSpacing="16" RowSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Grid.Column="0">
            <TextBlock Text="Max Peak" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="13" FontFamily="Consolas" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
              <Run Text="{x:Bind ViewModel.MaxPeak, Mode=OneWay}"/>
              <Run Text="dB"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Row="0" Grid.Column="1">
            <TextBlock Text="Max RMS" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="13" FontFamily="Consolas" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
              <Run Text="{x:Bind ViewModel.MaxRms, Mode=OneWay}"/>
              <Run Text="dB"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Row="1" Grid.Column="0">
            <TextBlock Text="Average RMS" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="13" FontFamily="Consolas" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
              <Run Text="{x:Bind ViewModel.AverageRms, Mode=OneWay}"/>
              <Run Text="dB"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Dynamic Range" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="13" FontFamily="Consolas" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
              <Run Text="{x:Bind ViewModel.DynamicRange, Mode=OneWay}"/>
              <Run Text="dB"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Row="2" Grid.Column="0">
            <TextBlock Text="Sample Rate" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="13" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
              <Run Text="{x:Bind ViewModel.SampleRate, Mode=OneWay}"/>
              <Run Text="Hz"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Row="2" Grid.Column="1">
            <TextBlock Text="Channels" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.ChannelCount, Mode=OneWay}" FontSize="13"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
          <StackPanel Grid.Row="3" Grid.Column="0">
            <TextBlock Text="Format" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.Format, Mode=OneWay}" FontSize="13"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
          <StackPanel Grid.Row="3" Grid.Column="1">
            <TextBlock Text="Duration" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.Duration, Mode=OneWay}" FontSize="13"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Alerts -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8"
            Visibility="{x:Bind ViewModel.HasAlerts, Mode=OneWay}">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Alerts" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Alerts, Mode=OneWay}"
                       AutomationProperties.AutomationId="AudioMonitoringView_AlertList">
          <ItemsRepeater.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,4" Margin="0,2" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <FontIcon Glyph="&#xE7BA;" FontSize="10" Foreground="Orange"/>
                  <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <TextBlock Text="{Binding Message}" FontSize="11"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
      </StackPanel>
    </Border>

    <!-- Channel Meters -->
    <ItemsRepeater Grid.Row="5" ItemsSource="{x:Bind ViewModel.ChannelMeters, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.HasMultiChannel, Mode=OneWay}"
                   AutomationProperties.AutomationId="AudioMonitoringView_ChannelMeters">
      <ItemsRepeater.ItemTemplate>
        <DataTemplate>
          <Grid ColumnSpacing="8" Margin="0,2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="50"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding ChannelName}" FontSize="11"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1" Value="{Binding PeakLevel}" Maximum="1.0" Minimum="0.0"/>
          </Grid>
        </DataTemplate>
      </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
