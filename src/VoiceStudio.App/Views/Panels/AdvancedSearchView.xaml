<UserControl x:Class="VoiceStudio.App.Views.Panels.AdvancedSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls"
             xmlns:local="using:VoiceStudio.App.Views.Panels"
             x:DataType="local:AdvancedSearchView">
  <Grid AutomationProperties.AutomationId="AdvancedSearchView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
            Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE721;" FontSize="20"/>
          <TextBlock Text="Advanced Search"
                     FontWeight="SemiBold"
                     FontSize="{StaticResource VSQ.FontSize.Title}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <Button Grid.Column="1" Content="?" Click="HelpButton_Click" ToolTipService.ToolTip="Help"/>
      </Grid>
    </Border>
    
    <!-- Content: Under Development -->
    <Grid Grid.Row="1" Padding="32">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MaxWidth="400">
        <FontIcon Glyph="&#xE946;" FontSize="64" Opacity="0.4" HorizontalAlignment="Center"/>
        <TextBlock Text="Advanced Search"
                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="This feature is under development. Advanced search capabilities including regex patterns, fuzzy matching, and cross-panel search will be available in a future update."
                   FontSize="{StaticResource VSQ.FontSize.Body}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Planned Features:"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Text="- Search across all panels and assets"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Regex and wildcard pattern matching"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Search history and saved queries"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Filter by date, type, and metadata"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
    
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
