<UserControl x:Class="VoiceStudio.App.Views.Panels.MCPDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:MCPDashboardView">
    <Grid x:Name="MCPDashboardView_Root"
          AutomationProperties.AutomationId="MCPDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE770;" FontSize="20"/>
                    <TextBlock Text="MCP Dashboard"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Refresh"
                            AutomationProperties.AutomationId="MCPDashboardView_RefreshButton">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                            AutomationProperties.AutomationId="MCPDashboardView_HelpButton">
                        <FontIcon Glyph="&#xE897;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Summary -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Overview" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Total Servers" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.TotalServers, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="MCPDashboardView_TotalServers"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Connected" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.ConnectedServers, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Operations" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.TotalOperations, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Add Server -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Add Server" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBox Header="Name" Text="{x:Bind ViewModel.NewServerName, Mode=TwoWay}"
                                 PlaceholderText="Server name..."
                                 AutomationProperties.AutomationId="MCPDashboardView_ServerName"/>
                        <TextBox Header="Endpoint" Text="{x:Bind ViewModel.NewServerEndpoint, Mode=TwoWay}"
                                 PlaceholderText="http://localhost:8080"
                                 AutomationProperties.AutomationId="MCPDashboardView_ServerEndpoint"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Type" ItemsSource="{x:Bind ViewModel.AvailableServerTypes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.NewServerType, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="MCPDashboardView_ServerType"/>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.CreateServerCommand}"
                                    Content="Add" VerticalAlignment="Bottom"
                                    Style="{StaticResource AccentButtonStyle}"
                                    AutomationProperties.AutomationId="MCPDashboardView_AddServerButton"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Servers List -->
                <ListView ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedServer, Mode=TwoWay}"
                          AutomationProperties.AutomationId="MCPDashboardView_ServerList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ServerType}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusDisplay}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                        <Run Text="Endpoint: "/>
                                        <Run Text="{Binding Endpoint}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CapabilitiesDisplay}" FontSize="10" Opacity="0.5" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="10" Opacity="0.5">
                                        <Run Text="Last connected: "/>
                                        <Run Text="{Binding LastConnectedDisplay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Server Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.ConnectServerCommand}" Content="Connect"
                            AutomationProperties.AutomationId="MCPDashboardView_ConnectButton"/>
                    <Button Command="{x:Bind ViewModel.DisconnectServerCommand}" Content="Disconnect"
                            AutomationProperties.AutomationId="MCPDashboardView_DisconnectButton"/>
                    <Button Command="{x:Bind ViewModel.DeleteServerCommand}" Content="Delete"
                            AutomationProperties.AutomationId="MCPDashboardView_DeleteServerButton"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="MCPDashboardView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
