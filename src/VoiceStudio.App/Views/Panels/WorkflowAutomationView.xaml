<UserControl x:Class="VoiceStudio.App.Views.Panels.WorkflowAutomationView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:WorkflowAutomationView">

  <Grid AutomationProperties.AutomationId="WorkflowAutomationView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE945;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Workflow Automation" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.CreateWorkflowCommand}"
                AutomationProperties.AutomationId="WorkflowAutomationView_NewButton"
                ToolTipService.ToolTip="New workflow (Ctrl+N)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="New"/>
          </StackPanel>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="WorkflowAutomationView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="320"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Workflow Editor -->
      <Grid Grid.Column="0" Margin="0,0,12,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Workflow Name / Description -->
        <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE8AC;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Workflow Details" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Workflow Name" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              <TextBox Text="{x:Bind ViewModel.WorkflowName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Enter workflow name..."
                       AutomationProperties.AutomationId="WorkflowAutomationView_NameTextBox"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              <TextBox Text="{x:Bind ViewModel.WorkflowDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Describe what this workflow does..."
                       AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                       AutomationProperties.AutomationId="WorkflowAutomationView_DescriptionTextBox"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Steps List -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8"
                MinHeight="120">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8CB;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Steps" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center">
                  <Run Text="("/>
                  <Run Text="{x:Bind ViewModel.WorkflowSteps.Count, Mode=OneWay}"/>
                  <Run Text=")"/>
                </TextBlock>
              </StackPanel>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.WorkflowSteps, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedStep, Mode=TwoWay}"
                      SelectionMode="Single"
                      AutomationProperties.AutomationId="WorkflowAutomationView_StepsList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Padding="8,6" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                      <Run Text="#"/>
                      <Run Text="{Binding Order}"/>
                    </TextBlock>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                      <TextBlock Text="{Binding Type}" FontSize="11"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Click="ConfigureStep_Click" CommandParameter="{Binding}"
                            AutomationProperties.AutomationId="WorkflowAutomationView_ConfigureStepButton"
                            ToolTipService.ToolTip="Configure step" Padding="6">
                      <FontIcon Glyph="&#xE713;" FontSize="12"/>
                    </Button>
                    <Button Grid.Column="3" Click="DeleteStep_Click" CommandParameter="{Binding}"
                            AutomationProperties.AutomationId="WorkflowAutomationView_DeleteStepButton"
                            ToolTipService.ToolTip="Remove step" Padding="6">
                      <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

        <!-- Variables Editor -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE943;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Variables" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <Button Grid.Column="1" Click="AddVariable_Click"
                      AutomationProperties.AutomationId="WorkflowAutomationView_AddVariableButton"
                      ToolTipService.ToolTip="Add variable (Ctrl+V)" Padding="6">
                <FontIcon Glyph="&#xE710;" FontSize="12"/>
              </Button>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Variables, Mode=OneWay}"
                      SelectionMode="None"
                      AutomationProperties.AutomationId="WorkflowAutomationView_VariablesList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Padding="8,4" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Accent.CyanBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2" Click="RemoveVariable_Click" CommandParameter="{Binding}"
                            AutomationProperties.AutomationId="WorkflowAutomationView_RemoveVariableButton"
                            ToolTipService.ToolTip="Remove variable" Padding="4">
                      <FontIcon Glyph="&#xE74D;" FontSize="10"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>
      </Grid>

      <!-- Right: Templates and Actions -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Templates -->
        <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Templates" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>

            <ListView ItemsSource="{x:Bind ViewModel.Templates, Mode=OneWay}"
                      SelectionMode="None"
                      AutomationProperties.AutomationId="WorkflowAutomationView_TemplatesList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Border Padding="8" Margin="0,2" CornerRadius="4"
                          PointerPressed="TemplateItem_PointerPressed" Tag="{Binding}">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                      <TextBlock Text="{Binding Description}" FontSize="11"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </Border>

        <!-- Action Library -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE74C;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Action Library" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <TextBlock Text="Click to add a step" FontSize="11"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>

            <StackPanel Spacing="4">
              <Button HorizontalAlignment="Stretch" Tag="synthesize_voice"
                      PointerPressed="ActionItem_PointerPressed"
                      AutomationProperties.AutomationId="WorkflowAutomationView_Action_Synthesize">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE720;" FontSize="12"/>
                  <TextBlock Text="Synthesize Voice" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Tag="batch_synthesize"
                      PointerPressed="ActionItem_PointerPressed"
                      AutomationProperties.AutomationId="WorkflowAutomationView_Action_BatchSynthesize">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE8B1;" FontSize="12"/>
                  <TextBlock Text="Batch Synthesize" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Tag="apply_effect"
                      PointerPressed="ActionItem_PointerPressed"
                      AutomationProperties.AutomationId="WorkflowAutomationView_Action_ApplyEffect">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE9CE;" FontSize="12"/>
                  <TextBlock Text="Apply Effect" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Tag="export_audio"
                      PointerPressed="ActionItem_PointerPressed"
                      AutomationProperties.AutomationId="WorkflowAutomationView_Action_ExportAudio">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                  <TextBlock Text="Export Audio" FontSize="12"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- Bottom Action Bar -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,8,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Status -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                     FontSize="12" Foreground="{StaticResource VSQ.Status.ErrorBrush}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Command="{x:Bind ViewModel.SaveWorkflowCommand}"
                  AutomationProperties.AutomationId="WorkflowAutomationView_SaveButton"
                  ToolTipService.ToolTip="Save workflow (Ctrl+S)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE74E;" FontSize="14"/>
              <TextBlock Text="Save"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.TestWorkflowCommand}"
                  AutomationProperties.AutomationId="WorkflowAutomationView_TestButton"
                  ToolTipService.ToolTip="Test workflow (Ctrl+T)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE768;" FontSize="14"/>
              <TextBlock Text="Test"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource VSQ.Button.Primary}"
                  Command="{x:Bind ViewModel.RunWorkflowCommand}"
                  AutomationProperties.AutomationId="WorkflowAutomationView_RunButton"
                  ToolTipService.ToolTip="Run workflow (Ctrl+Shift+R)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE768;" FontSize="14"/>
              <TextBlock Text="Run"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="3"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="WorkflowAutomationView_LoadingOverlay"/>
  </Grid>
</UserControl>
