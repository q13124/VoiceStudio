<UserControl x:Class="VoiceStudio.App.Views.Panels.AudioAnalysisView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:AudioAnalysisView">

  <Grid AutomationProperties.AutomationId="AudioAnalysisView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE9D9;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Audio Analysis" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="AudioAnalysisView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="AudioAnalysisView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Audio Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Audio Selection" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Audio ID" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedAudioId, Mode=TwoWay}"
                      IsEditable="True" HorizontalAlignment="Stretch"
                      RightTapped="AudioComboBox_RightTapped"
                      AutomationProperties.AutomationId="AudioAnalysisView_AudioIdComboBox"
                      PlaceholderText="Select or enter audio ID"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Reference Audio ID (for comparison)" FontSize="12"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBox Text="{x:Bind ViewModel.ReferenceAudioId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Optional reference audio"
                     AutomationProperties.AutomationId="AudioAnalysisView_ReferenceAudioIdTextBox"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Analysis Options and Actions -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE713;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Analysis Options" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="16">
          <CheckBox Content="Spectral"
                    IsChecked="{x:Bind ViewModel.IncludeSpectral, Mode=TwoWay}" FontSize="12"
                    AutomationProperties.AutomationId="AudioAnalysisView_SpectralCheckBox"/>
          <CheckBox Content="Temporal"
                    IsChecked="{x:Bind ViewModel.IncludeTemporal, Mode=TwoWay}" FontSize="12"
                    AutomationProperties.AutomationId="AudioAnalysisView_TemporalCheckBox"/>
          <CheckBox Content="Perceptual"
                    IsChecked="{x:Bind ViewModel.IncludePerceptual, Mode=TwoWay}" FontSize="12"
                    AutomationProperties.AutomationId="AudioAnalysisView_PerceptualCheckBox"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Style="{StaticResource VSQ.Button.Primary}"
                  Command="{x:Bind ViewModel.AnalyzeAudioCommand}"
                  AutomationProperties.AutomationId="AudioAnalysisView_AnalyzeButton"
                  ToolTipService.ToolTip="Analyze audio">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
              <TextBlock Text="Analyze"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.LoadAnalysisCommand}"
                  AutomationProperties.AutomationId="AudioAnalysisView_LoadButton"
                  ToolTipService.ToolTip="Load existing analysis">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE896;" FontSize="14"/>
              <TextBlock Text="Load"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.CompareAudioCommand}"
                  AutomationProperties.AutomationId="AudioAnalysisView_CompareButton"
                  ToolTipService.ToolTip="Compare with reference">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE9D5;" FontSize="14"/>
              <TextBlock Text="Compare"/>
            </StackPanel>
          </Button>
          <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="20" Height="20" Margin="8,0,0,0"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Analysis Results -->
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
      <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
              CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16"
              RightTapped="AnalysisResult_RightTapped">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE8D6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
            <TextBlock Text="Results" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>

          <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='No analysis loaded', TargetNullValue='No analysis loaded'}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.TertiaryBrush}"/>
        </StackPanel>
      </Border>
    </ScrollViewer>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="AudioAnalysisView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Audio Analysis Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="AudioAnalysisView_LoadingOverlay"/>
  </Grid>
</UserControl>
