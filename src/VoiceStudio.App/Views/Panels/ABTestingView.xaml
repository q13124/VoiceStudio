<UserControl x:Class="VoiceStudio.App.Views.Panels.ABTestingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls">
  <Grid AutomationProperties.AutomationId="ABTestingView_Root">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed"/>
    <StackPanel Spacing="12" Padding="16">
      <TextBlock Text="A/B Testing"
                 FontWeight="SemiBold"
                 FontSize="18"
                 AutomationProperties.Name="A/B Testing panel"/>
      <TextBlock Text="Temporarily simplified for build stability."
                 Opacity="0.7"
                 TextWrapping="Wrap"/>
      <Button Content="Help" Click="HelpButton_Click" />
    </StackPanel>
  </Grid>
</UserControl>
