<UserControl x:Class="VoiceStudio.App.Views.Panels.ABTestingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:ABTestingView">
  <Grid AutomationProperties.AutomationId="ABTestingView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
            Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8EF;" FontSize="20"/>
          <TextBlock Text="A/B Testing"
                     FontWeight="SemiBold"
                     FontSize="{StaticResource VSQ.FontSize.Title}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <Button Grid.Column="1" Content="?" Click="HelpButton_Click" ToolTipService.ToolTip="Help"/>
      </Grid>
    </Border>
    
    <!-- Content: Under Development -->
    <Grid Grid.Row="1" Padding="32">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MaxWidth="400">
        <FontIcon Glyph="&#xE8EF;" FontSize="64" Opacity="0.4" HorizontalAlignment="Center"/>
        <TextBlock Text="A/B Testing"
                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Compare different synthesis outputs side by side. This feature allows you to evaluate engine performance, voice quality, and parameter settings."
                   FontSize="{StaticResource VSQ.FontSize.Body}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Planned Features:"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Text="- Side-by-side audio comparison"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Blind listening tests"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Quality metrics comparison"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Export comparison reports"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
    
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
