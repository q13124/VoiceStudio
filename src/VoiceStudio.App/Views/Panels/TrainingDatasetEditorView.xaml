<UserControl x:Class="VoiceStudio.App.Views.Panels.TrainingDatasetEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:TrainingDatasetEditorView">

  <Grid Padding="16" AutomationProperties.AutomationId="TrainingDatasetEditorView_Root">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8F1;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Training Dataset Editor" FontSize="20" FontWeight="SemiBold"
                   VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}" ToolTipService.ToolTip="Refresh"
                AutomationProperties.AutomationId="TrainingDatasetEditorView_RefreshBtn">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Command="{x:Bind ViewModel.ValidateCommand}" ToolTipService.ToolTip="Validate Dataset"
                AutomationProperties.AutomationId="TrainingDatasetEditorView_ValidateBtn">
          <FontIcon Glyph="&#xE73E;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                AutomationProperties.AutomationId="TrainingDatasetEditorView_HelpBtn">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="12">

        <!-- Dataset Selection -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Dataset" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableDatasets, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedDatasetId, Mode=TwoWay}"
                      PlaceholderText="Select a dataset..." HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_DatasetSelector"/>
          </StackPanel>
        </Border>

        <!-- Dataset Info -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Dataset Info" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <Grid ColumnSpacing="24">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Name" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.DatasetDetail.Name, Mode=OneWay, FallbackValue='--', TargetNullValue='--'}"
                           FontSize="14" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                           AutomationProperties.AutomationId="TrainingDatasetEditorView_DatasetName"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Files / Duration" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{x:Bind ViewModel.DatasetDetail.FilesDisplay, Mode=OneWay, FallbackValue='--', TargetNullValue='--'}"
                             FontSize="14" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <TextBlock Text="{x:Bind ViewModel.DatasetDetail.DurationDisplay, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                             FontSize="14" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Add Audio -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Add Audio" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Text="{x:Bind ViewModel.NewAudioId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Audio ID"
                       AutomationProperties.AutomationId="TrainingDatasetEditorView_NewAudioId"/>
              <TextBox Grid.Column="1"
                       Text="{x:Bind ViewModel.NewTranscript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Transcript (optional)"
                       AutomationProperties.AutomationId="TrainingDatasetEditorView_NewTranscript"/>
              <Button Grid.Column="2" Command="{x:Bind ViewModel.AddAudioCommand}"
                      ToolTipService.ToolTip="Add audio file"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_AddBtn">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE710;" FontSize="14"/>
                  <TextBlock Text="Add"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Audio Files List -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8D6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Audio Files" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <Button Grid.Column="1" Command="{x:Bind ViewModel.RemoveAudioCommand}"
                      CommandParameter="{x:Bind ViewModel.SelectedAudioFile, Mode=OneWay}"
                      ToolTipService.ToolTip="Remove selected audio"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_RemoveBtn">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                  <TextBlock Text="Remove"/>
                </StackPanel>
              </Button>
            </Grid>
            <ListView ItemsSource="{x:Bind ViewModel.DatasetDetail.AudioFiles, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedAudioFile, Mode=TwoWay}"
                      RightTapped="AudioFile_RightTapped" MaxHeight="300"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_AudioFilesList">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DatasetAudioFileItem">
                  <Grid Padding="8,6" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{x:Bind AudioId}" FontSize="13" FontWeight="SemiBold"/>
                      <TextBlock Text="{x:Bind Transcript, TargetNullValue='No transcript'}"
                                 FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{x:Bind DurationDisplay}" FontSize="12"
                               VerticalAlignment="Center" Opacity="0.6"/>
                    <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center" Opacity="0.5">
                      <Run Text="#"/><Run Text="{x:Bind Order}"/>
                    </TextBlock>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </Border>

        <!-- Validation Results -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              <TextBlock Text="Validation" FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <ListView ItemsSource="{x:Bind ViewModel.ValidationErrors, Mode=OneWay}" MaxHeight="100"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_ErrorsList"
                      SelectionMode="None">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <StackPanel Orientation="Horizontal" Spacing="6" Padding="4,2">
                    <FontIcon Glyph="&#xEA39;" FontSize="12" Foreground="Red"/>
                    <TextBlock Text="{x:Bind}" FontSize="12" TextWrapping="Wrap"/>
                  </StackPanel>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <ListView ItemsSource="{x:Bind ViewModel.ValidationWarnings, Mode=OneWay}" MaxHeight="100"
                      AutomationProperties.AutomationId="TrainingDatasetEditorView_WarningsList"
                      SelectionMode="None">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <StackPanel Orientation="Horizontal" Spacing="6" Padding="4,2">
                    <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="Orange"/>
                    <TextBlock Text="{x:Bind}" FontSize="12" TextWrapping="Wrap"/>
                  </StackPanel>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="2" IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}" Severity="Error"
             Title="Dataset Editor Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True" AutomationProperties.AutomationId="TrainingDatasetEditorView_ErrorInfoBar"/>

    <!-- Overlays -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    <controls:LoadingOverlay Grid.RowSpan="3" IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="TrainingDatasetEditorView_LoadingOverlay"/>
  </Grid>
</UserControl>
