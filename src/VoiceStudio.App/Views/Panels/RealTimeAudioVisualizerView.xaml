<UserControl x:Class="VoiceStudio.App.Views.Panels.RealTimeAudioVisualizerView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:RealTimeAudioVisualizerView">
  <Grid AutomationProperties.AutomationId="RealTimeAudioVisualizerView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Real-Time Audio Visualizer"
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="RealTimeAudioVisualizerView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Padding="16" Spacing="12">

        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Session Controls" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ComboBox Grid.Column="0"
                        ItemsSource="{x:Bind ViewModel.AvailableVisualizationTypes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.VisualizationType, Mode=TwoWay}"
                        Header="Visualization" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="RealTimeAudioVisualizerView_VizType"/>
              <ComboBox Grid.Column="1"
                        ItemsSource="{x:Bind ViewModel.AvailableColorSchemes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedColorScheme, Mode=TwoWay}"
                        Header="Color Scheme" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="RealTimeAudioVisualizerView_ColorScheme"/>
            </Grid>

            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ComboBox Grid.Column="0"
                        ItemsSource="{x:Bind ViewModel.AvailableWindowTypes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.WindowType, Mode=TwoWay}"
                        Header="Window Type" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="RealTimeAudioVisualizerView_WindowType"/>
              <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.FftSize, Mode=TwoWay}"
                         Header="FFT Size" Minimum="256" Maximum="8192"
                         SpinButtonPlacementMode="Compact"
                         AutomationProperties.AutomationId="RealTimeAudioVisualizerView_FFTSize"/>
            </Grid>

            <StackPanel Spacing="4">
              <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                <Run Text="Update Rate: "/>
                <Run Text="{x:Bind ViewModel.UpdateRate, Mode=OneWay}"/>
                <Run Text=" Hz"/>
              </TextBlock>
              <Slider Minimum="1" Maximum="60" StepFrequency="1"
                      Value="{x:Bind ViewModel.UpdateRate, Mode=TwoWay}"
                      AutomationProperties.AutomationId="RealTimeAudioVisualizerView_UpdateRate"/>
            </StackPanel>

            <CheckBox Content="Show Phase" IsChecked="{x:Bind ViewModel.ShowPhase, Mode=TwoWay}"
                      AutomationProperties.AutomationId="RealTimeAudioVisualizerView_ShowPhase"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Command="{x:Bind ViewModel.StartSessionCommand}"
                      Style="{StaticResource VSQ.Button.Primary}"
                      AutomationProperties.AutomationId="RealTimeAudioVisualizerView_StartButton">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE768;" FontSize="14"/>
                  <TextBlock Text="Start"/>
                </StackPanel>
              </Button>
              <Button Command="{x:Bind ViewModel.StopSessionCommand}"
                      AutomationProperties.AutomationId="RealTimeAudioVisualizerView_StopButton">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                  <TextBlock Text="Stop"/>
                </StackPanel>
              </Button>
              <Button Command="{x:Bind ViewModel.DeleteSessionCommand}"
                      AutomationProperties.AutomationId="RealTimeAudioVisualizerView_DeleteButton"
                      ToolTipService.ToolTip="Delete session">
                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" MinHeight="200">
          <StackPanel Spacing="8">
            <TextBlock Text="Visualizer" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
              <Run Text="Session: "/>
              <Run Text="{x:Bind ViewModel.SessionId, Mode=OneWay, TargetNullValue='None'}"/>
              <Run Text=" | Streaming: "/>
              <Run Text="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"/>
            </TextBlock>
            <Border Background="{StaticResource VSQ.Panel.Background}" CornerRadius="4"
                    MinHeight="150" Padding="8"
                    AutomationProperties.AutomationId="RealTimeAudioVisualizerView_VisualizerArea">
              <TextBlock Text="Visualization area - start a session to begin"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="12" Opacity="0.5"/>
            </Border>
          </StackPanel>
        </Border>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
      </StackPanel>
    </ScrollViewer>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
