<UserControl x:Class="VoiceStudio.App.Views.Panels.EmotionStylePresetEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:EmotionStylePresetEditorView">

  <Grid x:Name="EmotionStylePresetEditorView_Root"
        AutomationProperties.AutomationId="EmotionStylePresetEditorView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Emotion Style Preset Editor"
                 FontSize="{StaticResource VSQ.FontSize.Title}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.PreviewPresetCommand}"
                AutomationProperties.AutomationId="EmotionStylePresetEditorView_PreviewButton"
                ToolTipService.ToolTip="Preview Preset">
          <FontIcon Glyph="&#xE768;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="EmotionStylePresetEditorView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Preset List -->
      <Border Grid.Column="0"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="0,0,1,0" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Presets"
                     FontSize="{StaticResource VSQ.FontSize.Body}" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,8"/>

          <ListView Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                    SelectionMode="Single"
                    AutomationProperties.AutomationId="EmotionStylePresetEditorView_PresetsList">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="local:EmotionStylePreset">
                <StackPanel Padding="8,6" Spacing="2">
                  <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Body}"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <TextBlock Text="{x:Bind EmotionSummary, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                             TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Command="{x:Bind ViewModel.CreatePresetCommand}"
                    AutomationProperties.AutomationId="EmotionStylePresetEditorView_CreateButton"
                    ToolTipService.ToolTip="Create Preset">
              <FontIcon Glyph="&#xE710;" FontSize="14"/>
            </Button>
            <Button Command="{x:Bind ViewModel.DeletePresetCommand}"
                    AutomationProperties.AutomationId="EmotionStylePresetEditorView_DeleteButton"
                    ToolTipService.ToolTip="Delete Preset">
              <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource VSQ.Error.Brush}"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Right: Preset Editor -->
      <ScrollViewer Grid.Column="1" Padding="16,8">
        <StackPanel Spacing="12">

          <!-- Name & Description -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Preset Details" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <TextBox Text="{x:Bind ViewModel.PresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Preset name..."
                       AutomationProperties.AutomationId="EmotionStylePresetEditorView_NameTextBox"/>
              <TextBox Text="{x:Bind ViewModel.PresetDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Description (optional)..."
                       TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"
                       AutomationProperties.AutomationId="EmotionStylePresetEditorView_DescTextBox"/>
            </StackPanel>
          </Border>

          <!-- Emotions -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Emotions" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

              <ItemsRepeater ItemsSource="{x:Bind ViewModel.SelectedEmotions, Mode=OneWay}"
                             AutomationProperties.AutomationId="EmotionStylePresetEditorView_SelectedEmotionsList">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="6"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="local:SelectedEmotion">
                    <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            CornerRadius="4" Padding="8,6"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                          <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                     FontSize="{StaticResource VSQ.FontSize.Body}"
                                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" FontWeight="SemiBold"/>
                          <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                     FontSize="{StaticResource VSQ.FontSize.Caption}"
                                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                                   Foreground="{StaticResource VSQ.Accent.CyanBrush}">
                          <Run Text="{x:Bind Intensity, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                        <Button Grid.Column="2" Click="RemoveEmotion_Click"
                                CommandParameter="{Binding}"
                                Background="Transparent" Padding="4"
                                ToolTipService.ToolTip="Remove Emotion">
                          <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{StaticResource VSQ.Error.Brush}"/>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>

              <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                <Button Tag="neutral" Click="EmotionButton_Click" Content="Neutral" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_NeutralButton"/>
                <Button Tag="happy" Click="EmotionButton_Click" Content="Happy" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_HappyButton"/>
                <Button Tag="sad" Click="EmotionButton_Click" Content="Sad" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_SadButton"/>
                <Button Tag="excited" Click="EmotionButton_Click" Content="Excited" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_ExcitedButton"/>
                <Button Tag="angry" Click="EmotionButton_Click" Content="Angry" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_AngryButton"/>
                <Button Tag="calm" Click="EmotionButton_Click" Content="Calm" Padding="8,4"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_CalmButton"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Style Parameters -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Style Parameters" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

              <StackPanel Spacing="2">
                <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="Speaking Rate:"/><Run Text=" "/><Run Text="{x:Bind ViewModel.SpeakingRate, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{x:Bind ViewModel.SpeakingRate, Mode=TwoWay}"
                        Minimum="0.5" Maximum="2.0" StepFrequency="0.1"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_SpeakingRateSlider"/>
              </StackPanel>

              <StackPanel Spacing="2">
                <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="Pitch:"/><Run Text=" "/><Run Text="{x:Bind ViewModel.Pitch, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{x:Bind ViewModel.Pitch, Mode=TwoWay}"
                        Minimum="-100" Maximum="100" StepFrequency="5"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_PitchSlider"/>
              </StackPanel>

              <StackPanel Spacing="2">
                <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="Energy:"/><Run Text=" "/><Run Text="{x:Bind ViewModel.Energy, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{x:Bind ViewModel.Energy, Mode=TwoWay}"
                        Minimum="0" Maximum="100" StepFrequency="5"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_EnergySlider"/>
              </StackPanel>

              <StackPanel Spacing="2">
                <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="Pause Duration:"/><Run Text=" "/><Run Text="{x:Bind ViewModel.PauseDuration, Mode=OneWay}"/><Run Text="ms"/>
                </TextBlock>
                <Slider Value="{x:Bind ViewModel.PauseDuration, Mode=TwoWay}"
                        Minimum="0" Maximum="500" StepFrequency="10"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_PauseDurationSlider"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Preview -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Preview" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <TextBox Text="{x:Bind ViewModel.PreviewText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Preview text..."
                       TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"
                       AutomationProperties.AutomationId="EmotionStylePresetEditorView_PreviewTextBox"/>
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Command="{x:Bind ViewModel.SavePresetCommand}"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_SaveButton">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                    <TextBlock Text="Save"/>
                  </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ApplyToSynthesisCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="EmotionStylePresetEditorView_ApplyButton">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE73E;" FontSize="14"/>
                    <TextBlock Text="Apply to Synthesis"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="EmotionStylePresetEditorView_HelpOverlay"/>
  </Grid>
</UserControl>
