<UserControl x:Class="VoiceStudio.App.Views.Panels.AIProductionAssistantView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:AIProductionAssistantView">

    <Grid x:Name="AIProductionAssistantView_Root"
          AutomationProperties.AutomationId="AIProductionAssistantView_Root"
          Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE99A;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="AI Production Assistant" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.ClearChatCommand}"
                        AutomationProperties.AutomationId="AIProductionAssistantView_ClearChatButton"
                        ToolTipService.ToolTip="Clear chat">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="AIProductionAssistantView_RefreshButton"
                        ToolTipService.ToolTip="Refresh context">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Welcome / Chat Messages -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
            <Grid>
                <!-- Welcome Screen -->
                <StackPanel Visibility="{x:Bind ViewModel.WelcomeVisibility, Mode=OneWay}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <FontIcon Glyph="&#xE99A;" FontSize="48"
                              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="AI Production Assistant" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Ask me anything about your voice production workflow."
                               FontSize="13" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Chat Messages -->
                <ListView ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedMessage, Mode=TwoWay}"
                          SelectionMode="Single"
                          AutomationProperties.AutomationId="AIProductionAssistantView_MessagesList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Role Badge -->
                                <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                        VerticalAlignment="Top"
                                        Background="{StaticResource VSQ.Accent.CyanBrush}">
                                    <TextBlock Text="{Binding RoleDisplay}" FontSize="9" FontWeight="Bold"/>
                                </Border>

                                <!-- Message Content -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Content}" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <Button Visibility="{Binding ActionVisibility}"
                                            AutomationProperties.AutomationId="AIProductionAssistantView_ExecuteActionButton"
                                            ToolTipService.ToolTip="Execute suggested action" Padding="6,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE768;" FontSize="10"/>
                                            <TextBlock Text="Execute Action" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="2" Text="{Binding TimestampDisplay}"
                                           FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Suggestions -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8"
                Visibility="{x:Bind ViewModel.SuggestionsVisibility, Mode=OneWay}">
            <StackPanel Spacing="8">
                <TextBlock Text="Suggestions" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}"
                               AutomationProperties.AutomationId="AIProductionAssistantView_SuggestionsList">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Padding="8,4" CornerRadius="12"
                                    AutomationProperties.AutomationId="AIProductionAssistantView_SuggestionChip">
                                <TextBlock Text="{x:Bind}" FontSize="12"/>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>

        <!-- Query Input -->
        <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.CurrentQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask me about your production..."
                         AutomationProperties.AutomationId="AIProductionAssistantView_QueryTextBox"/>
                <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                        Command="{x:Bind ViewModel.SendQueryCommand}"
                        AutomationProperties.AutomationId="AIProductionAssistantView_SendButton"
                        ToolTipService.ToolTip="Send query">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE724;" FontSize="14"/>
                        <TextBlock Text="Send"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="4"
                 AutomationProperties.AutomationId="AIProductionAssistantView_ErrorInfoBar"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error" Title="AI Assistant Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
                 IsClosable="True"/>

        <!-- HelpOverlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

        <!-- Loading Overlay -->
        <controls:LoadingOverlay Grid.RowSpan="5"
                                 IsLoading="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                                 AutomationProperties.AutomationId="AIProductionAssistantView_LoadingOverlay"/>
    </Grid>
</UserControl>
