<UserControl x:Class="VoiceStudio.App.Views.Panels.TimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:models="using:VoiceStudio.Core.Models"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:TimelineViewModel, IsDesignTimeCreatable=False}"
    x:DataType="local:TimelineView">

    <Grid x:Name="TimelineView_Root" 
          AutomationProperties.AutomationId="TimelineView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <TextBlock Text="Timeline" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                
                <!-- Phase 3 Fix 4: Guidance InfoBar -->
                <InfoBar x:Name="GuidanceInfoBar"
                         IsOpen="{x:Bind ViewModel.ShowGuidanceInfoBar, Mode=OneWay}"
                         Severity="Informational"
                         Title="Getting Started"
                         Message="{x:Bind ViewModel.GuidanceMessage, Mode=OneWay}"
                         IsClosable="True"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Top"
                         Margin="80,0,0,0" />
            </Grid>
        </Border>

        <!-- Transport Bar -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.PlayAudioCommand}" MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Play">
                        <FontIcon Glyph="&#xE768;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Command="{x:Bind ViewModel.StopAudioCommand}" MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Stop">
                        <FontIcon Glyph="&#xE71A;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Record">
                        <FontIcon Glyph="&#xE7C8;" FontSize="16" Foreground="{StaticResource VSQ.Accent.RedBrush}" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource VSQ.Panel.BorderBrush}" Margin="4,0" />
                    <ToggleButton MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Loop">
                        <FontIcon Glyph="&#xE8EE;" FontSize="14" FontFamily="Segoe Fluent Icons" />
                    </ToggleButton>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TimePositionDisplay" Text="00:00.000" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Accent.CyanBrush}" FontFamily="Consolas"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.AddTrackCommand}" MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Add Track">
                        <FontIcon Glyph="&#xE710;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Command="{x:Bind ViewModel.ZoomInCommand}" MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Zoom In">
                        <FontIcon Glyph="&#xE8A3;" FontSize="14" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Command="{x:Bind ViewModel.ZoomOutCommand}" MinWidth="{StaticResource VSQ.Touch.MinSize}" MinHeight="{StaticResource VSQ.Touch.MinSize}" Padding="8" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Zoom Out">
                        <FontIcon Glyph="&#xE71F;" FontSize="14" FontFamily="Segoe Fluent Icons" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Time Ruler -->
        <Border Grid.Row="2" Height="24" Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="160,0,0,0" Spacing="80">
                <TextBlock Text="0:00" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:05" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:10" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:15" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:20" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:25" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="0:30" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Timeline Area -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="TimelineScrollViewer" />
            <!-- GAP-CS-004: Added x:DataType for compile-time binding validation -->
            <ListView x:Name="TracksListView" ItemsSource="{x:Bind ViewModel.Tracks, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AudioTrack">
                        <Grid Height="60" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,1,0" Padding="8,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Name, FallbackValue='Track'}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="2" Margin="0,4,0,0">
                                        <ToggleButton Content="M" Width="24" Height="20" FontSize="9" Padding="0" ToolTipService.ToolTip="Mute" />
                                        <ToggleButton Content="S" Width="24" Height="20" FontSize="9" Padding="0" ToolTipService.ToolTip="Solo" />
                                        <ToggleButton Content="R" Width="24" Height="20" FontSize="9" Padding="0" Foreground="{StaticResource VSQ.Accent.RedBrush}" ToolTipService.ToolTip="Record Arm" />
                                        <Slider Minimum="0" Maximum="1" Value="0.8" Width="50" Height="16" Margin="4,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Margin="1,2">
                                <Rectangle Fill="{StaticResource VSQ.Panel.Background}" Opacity="0.3" RadiusX="2" RadiusY="2" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Canvas x:Name="TimelineScrubCanvas" Background="Transparent" 
                    PointerPressed="TimelineScrubCanvas_PointerPressed"
                    PointerMoved="TimelineScrubCanvas_PointerMoved"
                    PointerReleased="TimelineScrubCanvas_PointerReleased" />
            <Canvas x:Name="PlayheadCanvas">
                <Line x:Name="PlayheadLine" Stroke="{StaticResource VSQ.Accent.CyanBrush}" StrokeThickness="2" />
            </Canvas>
            <Canvas x:Name="DragDropCanvas" IsHitTestVisible="False" Background="Transparent" />
        </Grid>

        <!-- Transcript Track (Audit M-1 + X-3: Transcript display in Timeline) -->
        <Border Grid.Row="4"
                AutomationProperties.AutomationId="TimelineView_TranscriptTrack"
                Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,1,0,0"
                MinHeight="0"
                MaxHeight="120"
                Visibility="{x:Bind ViewModel.HasTranscriptSegments, Mode=OneWay}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Transcript track header -->
                <Border Grid.Row="0" Padding="8,4"
                        Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEE56;" FontSize="12" Opacity="0.7" />
                            <TextBlock Text="Transcript" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.TranscriptSegmentCount, Mode=OneWay}"
                                       FontSize="11" Opacity="0.5" />
                            <TextBlock Text="segments" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <Button Grid.Column="1" Padding="4,2"
                                AutomationProperties.AutomationId="TimelineView_ClearTranscriptButton"
                                ToolTipService.ToolTip="Clear transcript from timeline"
                                Command="{x:Bind ViewModel.ClearTranscriptCommand}">
                            <FontIcon Glyph="&#xE711;" FontSize="10" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Transcript segments display -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="8,4">
                    <ItemsRepeater AutomationProperties.AutomationId="TimelineView_TranscriptSegments"
                                   ItemsSource="{x:Bind ViewModel.TranscriptSegments, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,3" CornerRadius="3"
                                        Background="{StaticResource VSQ.Panel.Background}"
                                        PointerPressed="TranscriptSegment_PointerPressed">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="10" Opacity="0.6"
                                                   FontFamily="Consolas">
                                            <Run Text="{Binding StartFormatted}" />
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" FontSize="11"
                                                   Text="{Binding Text}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Visualizer Row -->
        <Grid Grid.Row="5" Background="{StaticResource VSQ.Panel.Background.DarkerBrush}">
            <controls:SpectrogramControl x:Name="SpectrogramVisualizer" />
            <controls:WaveformControl x:Name="WaveformVisualizer" />
        </Grid>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="6"
                              IsVisible="False" 
                              Visibility="Collapsed"
                              d:Visibility="Collapsed" />
    </Grid>
</UserControl>
