<UserControl x:Class="VoiceStudio.App.Views.Panels.PluginManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters">
    <UserControl.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:StringFormatConverter x:Key="StringFormatConverter" />
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with search and filters -->
        <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchQueryTextBox"
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                        PlaceholderText="Search plugins..."
                        Margin="0,0,4,0" />
                    <ToggleSwitch Grid.Column="1"
                        IsOn="{x:Bind ViewModel.ShowEnabledOnly, Mode=TwoWay}"
                        OffContent="All"
                        OnContent="Enabled Only"
                        VerticalAlignment="Center" />
                </Grid>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <Button Content="Refresh"
                        Command="{x:Bind ViewModel.RefreshPluginsCommand, Mode=OneWay}" />
                    <Button Content="?"
                        Click="HelpButton_Click"
                        Style="{StaticResource VSQ.Button.Icon}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Plugin list (left) + Details (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Plugin list -->
            <Grid Grid.Column="0" Margin="8">
                <controls:LoadingOverlay IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    LoadingMessage="Loading plugins..." />
                <controls:EmptyState Icon="🔌"
                    Title="No Plugins"
                    Message="No plugins found. Plugins are loaded from the Plugins directory."
                    Visibility="{x:Bind ViewModel.HasFilteredPlugins, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                <ListView x:Name="PluginList"
                    ItemsSource="{x:Bind ViewModel.FilteredPlugins, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedPlugin, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.HasFilteredPlugins, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="{StaticResource VSQ.Spacing.Value.Small}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}"
                                        Style="{StaticResource VSQ.Text.Body}"
                                        FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}"
                                        Style="{StaticResource VSQ.Text.Caption}"
                                        Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="2" />
                                    <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                        <TextBlock
                                            Text="{Binding Version, Converter={StaticResource StringFormatConverter}, ConverterParameter='v{0}'}"
                                            Style="{StaticResource VSQ.Text.Caption}"
                                            Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                        <TextBlock
                                            Text="{Binding Author, Converter={StaticResource StringFormatConverter}, ConverterParameter='by {0}'}"
                                            Style="{StaticResource VSQ.Text.Caption}"
                                            Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                    <Border CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="{Binding IsEnabled, Converter={StaticResource BooleanToBrushConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Enabled"
                                                Style="{StaticResource VSQ.Text.Caption}"
                                                FontSize="10"
                                                Visibility="{Binding IsEnabled}" />
                                            <TextBlock Text="Disabled"
                                                Style="{StaticResource VSQ.Text.Caption}"
                                                FontSize="10"
                                                Visibility="{Binding IsEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding Status}"
                                        Style="{StaticResource VSQ.Text.Caption}"
                                        Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Plugin details panel -->
            <Border Grid.Column="1"
                Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1,0,0,0"
                Padding="{StaticResource VSQ.Spacing.Medium}">
                <ScrollViewer>
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Medium}">
                        <controls:EmptyState Icon="📋"
                            Title="No Plugin Selected"
                            Message="Select a plugin from the list to view details and manage its state."
                            Visibility="{Binding SelectedPlugin, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}" />

                        <StackPanel
                            Visibility="{x:Bind ViewModel.SelectedPlugin, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                            Spacing="{StaticResource VSQ.Spacing.Medium}">
                            <TextBlock Text="{x:Bind ViewModel.SelectedPlugin.Name, Mode=OneWay}"
                                Style="{StaticResource VSQ.Text.Heading}" />

                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Version:"
                                    Style="{StaticResource VSQ.Text.Body}"
                                    Width="80" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedPlugin.Version, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Body}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Author:"
                                    Style="{StaticResource VSQ.Text.Body}"
                                    Width="80" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedPlugin.Author, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Body}" />
                            </StackPanel>

                            <TextBlock Text="Description:"
                                Style="{StaticResource VSQ.Text.Body}"
                                FontWeight="SemiBold" />
                            <TextBlock
                                Text="{x:Bind ViewModel.SelectedPlugin.Description, Mode=OneWay}"
                                Style="{StaticResource VSQ.Text.Body}"
                                TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Status:"
                                    Style="{StaticResource VSQ.Text.Body}"
                                    Width="80" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedPlugin.Status, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Body}" />
                            </StackPanel>

                            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                                Padding="{StaticResource VSQ.Spacing.Medium}">
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedPlugin.ErrorMessage, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Caption}"
                                    Foreground="Red"
                                    TextWrapping="Wrap"
                                    Visibility="{x:Bind ViewModel.SelectedPlugin.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                            </Border>

                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <Button Content="Enable"
                                    Command="{x:Bind ViewModel.EnablePluginCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedPlugin, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.SelectedPlugin.IsEnabled, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <Button Content="Disable"
                                    Command="{x:Bind ViewModel.DisablePluginCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedPlugin, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.SelectedPlugin.IsEnabled, Mode=OneWay}" />
                                <Button Content="Reload"
                                    Command="{x:Bind ViewModel.ReloadPluginCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedPlugin, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                <TextBlock Grid.Column="1"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="Red"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay"
            IsVisible="False"
            Visibility="Collapsed" />
    </Grid>
</UserControl>