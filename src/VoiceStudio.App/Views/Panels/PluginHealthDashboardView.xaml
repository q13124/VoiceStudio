<!--
  PluginHealthDashboardView.xaml - Plugin Health Monitoring Dashboard
  
  AI GUIDELINES:
  - Use {x:Bind ViewModel.Property, Mode=OneWay/TwoWay} for all bindings
  - Always specify Mode explicitly (OneWay for display, TwoWay for input controls)
  - DataTemplates must include x:DataType for compile-time checking
  - Use StaticResource for theme resources (VSQ.* prefix)
  - DO NOT use {Binding} without ElementName - prefer {x:Bind}
  - Commands should use IRelayCommand/IAsyncRelayCommand patterns
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.PluginHealthDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:PluginHealthDashboardViewModel, IsDesignTimeCreatable=False}"
    x:DataType="vm:PluginHealthDashboardViewModel">
    <UserControl.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Health Status Colors - now using global VSQ.Status.* tokens from DesignTokens.xaml -->
        
        <!-- Card Style -->
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource VSQ.Panel.Background.DarkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VSQ.Panel.BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource VSQ.CornerRadius.Panel}" />
            <Setter Property="Padding" Value="{StaticResource VSQ.Spacing.Medium}" />
            <Setter Property="Margin" Value="4" />
        </Style>
    </UserControl.Resources>
    
    <Grid AutomationProperties.AutomationId="PluginHealthDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Plugin Health Dashboard"
                               Style="{StaticResource VSQ.Text.Title}"
                               VerticalAlignment="Center" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="20" Height="20" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="Auto"
                                  IsChecked="{x:Bind ViewModel.AutoRefreshEnabled, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Auto-refresh every 30 seconds"
                                  AutomationProperties.AutomationId="PluginHealthDashboard_AutoRefreshToggle" />
                    <Button Content="Refresh"
                            Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}"
                            AutomationProperties.AutomationId="PluginHealthDashboard_RefreshButton" />
                    <Button Content="Export"
                            Command="{x:Bind ViewModel.ExportMetricsCommand, Mode=OneWay}"
                            AutomationProperties.AutomationId="PluginHealthDashboard_ExportButton" />
                    <Button Content="?"
                            Click="HelpButton_Click"
                            Style="{StaticResource VSQ.Button.Icon}" />
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- System Health Summary Cards -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Padding="{StaticResource VSQ.Spacing.Small}">
                <!-- Total Plugins Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Total Plugins" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalPlugins, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                
                <!-- Healthy Plugins Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Healthy" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Status.HealthyBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.HealthyPlugins, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource VSQ.Status.HealthyBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Degraded Plugins Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Degraded" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Status.DegradedBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.DegradedPlugins, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource VSQ.Status.DegradedBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Unhealthy Plugins Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Unhealthy" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Status.UnhealthyBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.UnhealthyPlugins, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource VSQ.Status.UnhealthyBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Error Rate Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="160">
                    <StackPanel>
                        <TextBlock Text="System Error Rate" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SystemErrorRateDisplay, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                
                <!-- Avg Latency Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Avg Latency" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.AvgLatencyDisplay, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                
                <!-- Total Memory Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Total Memory" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalMemoryDisplay, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                
                <!-- Total Calls Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Total Calls" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalCallsDisplay, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                
                <!-- Total Errors Card -->
                <Border Style="{StaticResource MetricCardStyle}" Width="140">
                    <StackPanel>
                        <TextBlock Text="Total Errors" Style="{StaticResource VSQ.Text.Caption}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalErrorsDisplay, Mode=OneWay}"
                                   Style="{StaticResource VSQ.Text.Title}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource VSQ.Status.UnhealthyBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Main Content: Plugin List + Details -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Plugin List (Left Panel) -->
            <Border Grid.Column="0"
                    Background="{StaticResource VSQ.Background.Darker}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Padding="{StaticResource VSQ.Spacing.Small}"
                            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
                        <TextBlock Text="Plugins" Style="{StaticResource VSQ.Text.Heading}" />
                    </Border>
                    
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Plugins, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedPlugin, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PluginHealthItem">
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Health Indicator -->
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{x:Bind StatusBrush, Mode=OneWay}"
                                             VerticalAlignment="Center" />
                                    
                                    <!-- Plugin Info -->
                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBlock Text="{x:Bind PluginId, Mode=OneWay}"
                                                   Style="{StaticResource VSQ.Text.Body}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind CallsDisplay, Mode=OneWay}"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                            <TextBlock Text="|"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       Foreground="{StaticResource VSQ.Text.TertiaryBrush}" />
                                            <TextBlock Text="{x:Bind ErrorRateDisplay, Mode=OneWay}"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Status Badge -->
                                    <Border Grid.Column="2"
                                            Background="{x:Bind StatusBrush, Mode=OneWay}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                   Style="{StaticResource VSQ.Text.Caption}"
                                                   Foreground="White"
                                                   FontSize="10" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
            
            <!-- Plugin Details (Right Panel) -->
            <ScrollViewer Grid.Column="1" Padding="{StaticResource VSQ.Spacing.Medium}">
                <StackPanel>
                    <!-- No Selection State -->
                    <TextBlock Text="Select a plugin to view details"
                               Style="{StaticResource VSQ.Text.Body}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,100,0,0"
                               Visibility="{x:Bind ViewModel.HasSelectedPlugin, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    
                    <!-- Plugin Details Content -->
                    <StackPanel Visibility="{x:Bind ViewModel.HasSelectedPlugin, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- Plugin Header -->
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedPluginId, Mode=OneWay}"
                                               Style="{StaticResource VSQ.Text.Heading}"
                                               FontSize="18" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedPluginLastActivity, Mode=OneWay}"
                                               Style="{StaticResource VSQ.Text.Caption}"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{x:Bind ViewModel.SelectedPluginStatusBrush, Mode=OneWay}"
                                        CornerRadius="4"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedPluginStatus, Mode=OneWay}"
                                               Style="{StaticResource VSQ.Text.Body}"
                                               Foreground="White"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Method Statistics Section -->
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Method Statistics"
                                           Style="{StaticResource VSQ.Text.Heading}"
                                           Margin="0,0,0,12" />
                                
                                <ListView ItemsSource="{x:Bind ViewModel.SelectedPluginMethods, Mode=OneWay}"
                                          SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MethodStatsItem">
                                            <Grid Padding="0,8" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                                  BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{x:Bind Method, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Body}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind CallCountDisplay, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Caption}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind SuccessRateDisplay, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Caption}" />
                                                <TextBlock Grid.Column="3" Text="{x:Bind AvgDurationDisplay, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Caption}" />
                                                <TextBlock Grid.Column="4" Text="{x:Bind P95DurationDisplay, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Caption}" />
                                                <TextBlock Grid.Column="5" Text="{x:Bind P99DurationDisplay, Mode=OneWay}"
                                                           Style="{StaticResource VSQ.Text.Caption}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <ListView.Header>
                                        <Grid Padding="0,4" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Method"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="Calls"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="Success"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="3" Text="Avg (ms)"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="4" Text="P95 (ms)"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="5" Text="P99 (ms)"
                                                       Style="{StaticResource VSQ.Text.Caption}"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                    </ListView.Header>
                                </ListView>
                            </StackPanel>
                        </Border>
                        
                        <!-- Counters and Gauges Section -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Counters -->
                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,4,8">
                                <StackPanel>
                                    <TextBlock Text="Counters"
                                               Style="{StaticResource VSQ.Text.Heading}"
                                               Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedPluginCounters, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MetricItem">
                                                <Grid Padding="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Body}" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind ValueDisplay, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Body}"
                                                               FontWeight="SemiBold" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            
                            <!-- Gauges -->
                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="4,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Gauges"
                                               Style="{StaticResource VSQ.Text.Heading}"
                                               Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedPluginGauges, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MetricItem">
                                                <Grid Padding="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Body}" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind ValueDisplay, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Body}"
                                                               FontWeight="SemiBold" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- Recent Errors Section -->
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,8"
                                Visibility="{x:Bind ViewModel.HasSelectedPluginErrors, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Recent Errors"
                                           Style="{StaticResource VSQ.Text.Heading}"
                                           Foreground="{StaticResource VSQ.Status.UnhealthyBrush}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedPluginErrors, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ErrorItem">
                                            <Border Padding="8" Margin="0,4"
                                                    Background="{StaticResource VSQ.Background.Darker}"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Caption}"
                                                               Foreground="{StaticResource VSQ.Text.TertiaryBrush}" />
                                                    <TextBlock Text="{x:Bind Message, Mode=OneWay}"
                                                               Style="{StaticResource VSQ.Text.Body}"
                                                               Foreground="{StaticResource VSQ.Status.UnhealthyBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource VSQ.Text.Caption}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Style="{StaticResource VSQ.Text.Caption}"
                           Foreground="{StaticResource VSQ.Status.UnhealthyBrush}"
                           Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
            </Grid>
        </Border>
        
        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlayControl"
                              Grid.RowSpan="4"
                              IsVisible="False"
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
