<!--
  VoiceSynthesisView.xaml - Main TTS synthesis panel
  
  AI GUIDELINES:
  - ViewModel is in VoiceStudio.App.Views.Panels (not ViewModels)
  - Use {x:Bind ViewModel.Property, Mode=OneWay/TwoWay} for all bindings
  - Engine selection ComboBox drives available voice options
  - SynthesizeCommand is async with built-in cancellation support
  - DO NOT modify the output audio player controls without updating IMediaPlayerService
  - Progress binding updates during synthesis - ensure Mode=OneWay
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceSynthesisView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=local:VoiceSynthesisViewModel, IsDesignTimeCreatable=False}"
  x:DataType="local:VoiceSynthesisViewModel">
  
  <Grid AutomationProperties.AutomationId="VoiceSynthesisView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    
    <!-- Row 0: Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE768;" FontSize="24"/>
        <TextBlock Text="Voice Synthesis" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </StackPanel>
      
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button x:Name="RefreshButton"
                AutomationProperties.AutomationId="VoiceSynthesisView_RefreshButton"
                Command="{x:Bind ViewModel.LoadProfilesCommand}"
                ToolTipService.ToolTip="Refresh profiles and engines (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button x:Name="HelpButton" Click="HelpButton_Click"
                AutomationProperties.AutomationId="VoiceSynthesisView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>
    
    <!-- Row 1: Profile and Engine Selection -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
      <StackPanel Spacing="4" MinWidth="200">
        <TextBlock Text="Voice Profile" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="ProfileComboBox"
                  AutomationProperties.AutomationId="VoiceSynthesisView_ProfileComboBox"
                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"/>
      </StackPanel>
      
      <StackPanel Spacing="4" MinWidth="150">
        <TextBlock Text="Engine" FontSize="12" Opacity="0.7"/>
        <!-- GAP-CRIT-005: Engine selection with availability indication via DisplayName property -->
        <ComboBox x:Name="EngineComboBox"
                  AutomationProperties.AutomationId="VoiceSynthesisView_EngineComboBox"
                  ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"
                  HorizontalAlignment="Stretch"/>
      </StackPanel>
      
      <StackPanel Spacing="4" MinWidth="100">
        <TextBlock Text="Language" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="LanguageComboBox"
                  AutomationProperties.AutomationId="VoiceSynthesisView_LanguageComboBox"
                  SelectedItem="{x:Bind ViewModel.Language, Mode=TwoWay}"
                  HorizontalAlignment="Stretch">
          <ComboBoxItem Content="en" IsSelected="True"/>
          <ComboBoxItem Content="es"/>
          <ComboBoxItem Content="fr"/>
          <ComboBoxItem Content="de"/>
          <ComboBoxItem Content="it"/>
          <ComboBoxItem Content="pt"/>
          <ComboBoxItem Content="zh"/>
          <ComboBoxItem Content="ja"/>
        </ComboBox>
      </StackPanel>
      
      <StackPanel Spacing="4" MinWidth="120">
        <TextBlock Text="Emotion" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="EmotionComboBox"
                  AutomationProperties.AutomationId="VoiceSynthesisView_EmotionComboBox"
                  SelectedItem="{x:Bind ViewModel.Emotion, Mode=TwoWay}"
                  PlaceholderText="Select emotion"
                  HorizontalAlignment="Stretch">
          <ComboBoxItem Content="neutral" IsSelected="True"/>
          <ComboBoxItem Content="happy"/>
          <ComboBoxItem Content="sad"/>
          <ComboBoxItem Content="angry"/>
          <ComboBoxItem Content="excited"/>
          <ComboBoxItem Content="calm"/>
        </ComboBox>
      </StackPanel>
    </StackPanel>
    
    <!-- Row 2: Text Input -->
    <TextBox x:Name="TextInput" Grid.Row="2"
             AutomationProperties.AutomationId="VoiceSynthesisView_TextInput"
             Text="{x:Bind ViewModel.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             PlaceholderText="Enter text to synthesize..."
             TextWrapping="Wrap"
             AcceptsReturn="True"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             Margin="0,0,0,12"/>
    
    <!-- Row 3: Voice Controls -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
            Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}" />
          <TextBlock Text="Controls" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </StackPanel>

        <!-- Speed -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Speed" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider Grid.Column="1" Minimum="0.5" Maximum="2.0" StepFrequency="0.05" Value="1.0" Height="{StaticResource VSQ.Touch.MinSize}" />
          <TextBlock Grid.Column="2" Text="1.00" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Grid>

        <!-- Pitch -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Pitch Shift" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider Grid.Column="1" Minimum="-12" Maximum="12" StepFrequency="1" Value="0" Height="{StaticResource VSQ.Touch.MinSize}" />
          <TextBlock Grid.Column="2" Text="+0" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Grid>

        <!-- Stability -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Stability" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider Grid.Column="1" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0.72" Height="{StaticResource VSQ.Touch.MinSize}" />
          <TextBlock Grid.Column="2" Text="0.72" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Grid>

        <!-- Clarity -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Clarity" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider Grid.Column="1" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0.58" Height="{StaticResource VSQ.Touch.MinSize}" />
          <TextBlock Grid.Column="2" Text="0.58" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Grid>

        <!-- Temperature -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Temperature" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider Grid.Column="1" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0.35" Height="{StaticResource VSQ.Touch.MinSize}" />
          <TextBlock Grid.Column="2" Text="0.35" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Grid>

        <!-- Options row -->
        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
          <CheckBox Content="Enhance Quality"
                    AutomationProperties.AutomationId="VoiceSynthesisView_EnhanceQualityCheckBox"
                    IsChecked="{x:Bind ViewModel.EnhanceQuality, Mode=TwoWay}" FontSize="11" />
          <CheckBox Content="Multi-Engine"
                    AutomationProperties.AutomationId="VoiceSynthesisView_MultiEngineCheckBox"
                    IsChecked="{x:Bind ViewModel.UseMultiEngineEnsemble, Mode=TwoWay}" FontSize="11" />
          <CheckBox Content="Auto-Optimize"
                    AutomationProperties.AutomationId="VoiceSynthesisView_AutoApplyCheckBox"
                    IsChecked="{x:Bind ViewModel.AutoApplyRecommendations, Mode=TwoWay}"
                    ToolTipService.ToolTip="Automatically apply quality recommendations" FontSize="11" />
          <CheckBox Content="Streaming"
                    AutomationProperties.AutomationId="VoiceSynthesisView_StreamingModeCheckBox"
                    IsChecked="{x:Bind ViewModel.StreamingMode, Mode=TwoWay}"
                    ToolTipService.ToolTip="Enable real-time streaming playback" FontSize="11" />
        </StackPanel>
        
        <!-- Streaming status (visible when streaming is enabled) -->
        <Grid Visibility="{x:Bind ViewModel.StreamingMode, Mode=OneWay}" Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <FontIcon Grid.Column="0" Glyph="&#xE93E;" FontSize="12" Foreground="{StaticResource VSQ.Accent.MagentaBrush}" 
                    Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}" Margin="0,0,8,0"/>
          <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StreamingStatus, Mode=OneWay}" 
                     FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="2" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" VerticalAlignment="Center">
            <Run Text="Chunks: "/>
            <Run Text="{x:Bind ViewModel.StreamingReceivedChunks, Mode=OneWay}"/>
            <Run Text=" / Buffered: "/>
            <Run Text="{x:Bind ViewModel.StreamingBufferedChunks, Mode=OneWay}"/>
          </TextBlock>
        </Grid>
      </StackPanel>
    </Border>
    
    <!-- Row 4: Actions -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Style="{StaticResource AccentButtonStyle}"
              AutomationProperties.AutomationId="VoiceSynthesisView_SynthesizeButton"
              Command="{x:Bind ViewModel.SynthesizeCommand}"
              Visibility="{x:Bind ViewModel.StreamingMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverseConverter}}"
              ToolTipService.ToolTip="Synthesize speech (Ctrl+Enter)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE768;" FontSize="14"/>
          <TextBlock Text="Synthesize"/>
        </StackPanel>
      </Button>
      <Button Style="{StaticResource AccentButtonStyle}"
              AutomationProperties.AutomationId="VoiceSynthesisView_StreamButton"
              Command="{x:Bind ViewModel.StartStreamingCommand}"
              Visibility="{x:Bind ViewModel.StreamingMode, Mode=OneWay}"
              ToolTipService.ToolTip="Start streaming synthesis (Ctrl+Enter)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE93E;" FontSize="14"/>
          <TextBlock Text="Stream"/>
        </StackPanel>
      </Button>
      <Button AutomationProperties.AutomationId="VoiceSynthesisView_StopStreamButton"
              Command="{x:Bind ViewModel.StopStreamingCommand}"
              Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"
              ToolTipService.ToolTip="Stop streaming">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE71A;" FontSize="14"/>
          <TextBlock Text="Stop Stream"/>
        </StackPanel>
      </Button>
      <Button AutomationProperties.AutomationId="VoiceSynthesisView_PlayButton"
              Command="{x:Bind ViewModel.PlayAudioCommand}"
              IsEnabled="{x:Bind ViewModel.CanPlayAudio, Mode=OneWay}"
              ToolTipService.ToolTip="Play synthesized audio (Space)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE768;" FontSize="14"/>
          <TextBlock Text="Play"/>
        </StackPanel>
      </Button>
      <Button AutomationProperties.AutomationId="VoiceSynthesisView_StopButton"
              Command="{x:Bind ViewModel.StopAudioCommand}"
              ToolTipService.ToolTip="Stop playback (Escape)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE71A;" FontSize="14"/>
          <TextBlock Text="Stop"/>
        </StackPanel>
      </Button>
      <Button AutomationProperties.AutomationId="VoiceSynthesisView_AnalyzeButton"
              Command="{x:Bind ViewModel.AnalyzeTextCommand}"
              ToolTipService.ToolTip="Analyze text for optimal synthesis settings">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
          <TextBlock Text="Analyze"/>
        </StackPanel>
      </Button>
      <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="24" Height="24" Margin="8,0,0,0"/>
      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Ready', TargetNullValue='Ready'}"
                 VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
    </StackPanel>
    
    <!-- Row 5: Error/Status InfoBar -->
    <InfoBar Grid.Row="5"
             AutomationProperties.AutomationId="VoiceSynthesisView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error"
             Title="Synthesis Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>
    
    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed" d:Visibility="Collapsed" Grid.RowSpan="6"/>
    
    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="6" 
          Background="{ThemeResource SystemControlBackgroundAltMediumHighBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
          d:Visibility="Collapsed">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <ProgressRing IsActive="True" Width="48" Height="48"/>
        <TextBlock Text="Synthesizing..." FontSize="16" Opacity="0.8"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
