<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceSynthesisView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls">
  
  <Grid AutomationProperties.AutomationId="VoiceSynthesisView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    
    <!-- Row 0: Profile and Engine Selection -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
      <StackPanel Spacing="4" MinWidth="200">
        <TextBlock Text="Voice Profile" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="ProfileComboBox"
                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"/>
      </StackPanel>
      
      <StackPanel Spacing="4" MinWidth="150">
        <TextBlock Text="Engine" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="EngineComboBox"
                  ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"/>
      </StackPanel>
      
      <StackPanel Spacing="4" MinWidth="100">
        <TextBlock Text="Language" FontSize="12" Opacity="0.7"/>
        <ComboBox x:Name="LanguageComboBox">
          <ComboBoxItem Content="English" IsSelected="True"/>
          <ComboBoxItem Content="Spanish"/>
          <ComboBoxItem Content="French"/>
          <ComboBoxItem Content="German"/>
        </ComboBox>
      </StackPanel>
    </StackPanel>
    
    <!-- Row 1: Text Input -->
    <TextBox x:Name="TextInput" Grid.Row="1"
             Text="{x:Bind ViewModel.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             PlaceholderText="Enter text to synthesize..."
             TextWrapping="Wrap"
             AcceptsReturn="True"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             Margin="0,0,0,12"/>
    
    <!-- Row 2: Options -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12">
      <CheckBox Content="Enhance Quality"
                IsChecked="{x:Bind ViewModel.EnhanceQuality, Mode=TwoWay}"/>
      <CheckBox Content="Multi-Engine"
                IsChecked="{x:Bind ViewModel.UseMultiEngineEnsemble, Mode=TwoWay}"/>
      <ComboBox x:Name="EmotionComboBox" PlaceholderText="Emotion" MinWidth="120">
        <ComboBoxItem Content="Neutral"/>
        <ComboBoxItem Content="Happy"/>
        <ComboBoxItem Content="Sad"/>
        <ComboBoxItem Content="Angry"/>
      </ComboBox>
    </StackPanel>
    
    <!-- Row 3: Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
      <Button Content="Synthesize" Style="{StaticResource AccentButtonStyle}"
              Command="{x:Bind ViewModel.SynthesizeCommand}"/>
      <Button Content="Play" Command="{x:Bind ViewModel.PlayAudioCommand}"
              IsEnabled="{x:Bind ViewModel.CanPlayAudio, Mode=OneWay}"/>
      <Button Content="Stop" Command="{x:Bind ViewModel.StopAudioCommand}"/>
      <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="24" Height="24" Margin="8,0,0,0"/>
      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                 VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
    </StackPanel>
    
    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed" Grid.RowSpan="4"/>
  </Grid>
</UserControl>
