<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceMorphingBlendingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:VoiceMorphingBlendingView">
    <Grid AutomationProperties.AutomationId="VoiceMorphingBlendingView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Voice Morphing and Blending"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                               VerticalAlignment="Center" />
                    <ComboBox AutomationProperties.AutomationId="VoiceMorphing_ModeSelector"
                              ItemsSource="{x:Bind ViewModel.AvailableModes, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                              MinWidth="160"
                              VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button AutomationProperties.AutomationId="VoiceMorphing_LoadProfilesBtn"
                            Command="{x:Bind ViewModel.LoadVoiceProfilesCommand}"
                            ToolTipService.ToolTip="Load voice profiles">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="VoiceMorphing_HelpBtn"
                            Click="HelpButton_Click"
                            ToolTipService.ToolTip="Help">
                        <FontIcon Glyph="&#xE897;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
            <StackPanel Spacing="16">

                <!-- Blend Voices Section -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                        Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Blend Voices"
                                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox AutomationProperties.AutomationId="VoiceMorphing_VoiceACombo"
                                      Grid.Column="0"
                                      Header="Voice A"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.VoiceAId, Mode=TwoWay}"
                                      PlaceholderText="Select Voice A..."
                                      HorizontalAlignment="Stretch" />

                            <ComboBox AutomationProperties.AutomationId="VoiceMorphing_VoiceBCombo"
                                      Grid.Column="1"
                                      Header="Voice B"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.VoiceBId, Mode=TwoWay}"
                                      PlaceholderText="Select Voice B..."
                                      HorizontalAlignment="Stretch" />
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Blend Ratio"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                       Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="A" VerticalAlignment="Center"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,0,8,0" />
                                <Slider AutomationProperties.AutomationId="VoiceMorphing_BlendRatioSlider"
                                        Grid.Column="1"
                                        Value="{x:Bind ViewModel.BlendRatio, Mode=TwoWay}"
                                        Minimum="0" Maximum="1" StepFrequency="0.05"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="B" VerticalAlignment="Center"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <TextBox AutomationProperties.AutomationId="VoiceMorphing_PreviewTextInput"
                                 Header="Preview Text"
                                 Text="{x:Bind ViewModel.PreviewText, Mode=TwoWay}"
                                 PlaceholderText="Enter text for preview..."
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60" />

                        <ToggleSwitch AutomationProperties.AutomationId="VoiceMorphing_SaveAsProfileToggle"
                                      Header="Save as Profile"
                                      IsOn="{x:Bind ViewModel.SaveAsProfile, Mode=TwoWay}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button AutomationProperties.AutomationId="VoiceMorphing_PreviewBlendBtn"
                                    Content="Preview Blend"
                                    Command="{x:Bind ViewModel.PreviewBlendCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button AutomationProperties.AutomationId="VoiceMorphing_BlendVoicesBtn"
                                    Content="Blend Voices"
                                    Command="{x:Bind ViewModel.BlendVoicesCommand}" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsBlending, Mode=OneWay}"
                                          Width="20" Height="20"
                                          VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{x:Bind ViewModel.BlendedProfileId, Mode=OneWay}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <!-- Morph Timeline Section -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                        Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Morph Timeline"
                                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                        <TextBox AutomationProperties.AutomationId="VoiceMorphing_SourceAudioInput"
                                 Header="Source Audio ID"
                                 Text="{x:Bind ViewModel.SourceAudioId, Mode=TwoWay}"
                                 PlaceholderText="Enter source audio ID..." />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox AutomationProperties.AutomationId="VoiceMorphing_MorphVoiceACombo"
                                      Grid.Column="0"
                                      Header="Voice A (Start)"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.MorphVoiceAId, Mode=TwoWay}"
                                      PlaceholderText="Select start voice..."
                                      HorizontalAlignment="Stretch" />

                            <ComboBox AutomationProperties.AutomationId="VoiceMorphing_MorphVoiceBCombo"
                                      Grid.Column="1"
                                      Header="Voice B (End)"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.MorphVoiceBId, Mode=TwoWay}"
                                      PlaceholderText="Select end voice..."
                                      HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start Ratio"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,0,0,4" />
                                <Slider AutomationProperties.AutomationId="VoiceMorphing_StartRatioSlider"
                                        Value="{x:Bind ViewModel.StartRatio, Mode=TwoWay}"
                                        Minimum="0" Maximum="1" StepFrequency="0.05" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="End Ratio"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,0,0,4" />
                                <Slider AutomationProperties.AutomationId="VoiceMorphing_EndRatioSlider"
                                        Value="{x:Bind ViewModel.EndRatio, Mode=TwoWay}"
                                        Minimum="0" Maximum="1" StepFrequency="0.05" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Morph Speed"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,0,0,4" />
                                <Slider AutomationProperties.AutomationId="VoiceMorphing_MorphSpeedSlider"
                                        Value="{x:Bind ViewModel.MorphSpeed, Mode=TwoWay}"
                                        Minimum="0.1" Maximum="3" StepFrequency="0.1" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button AutomationProperties.AutomationId="VoiceMorphing_MorphVoiceBtn"
                                    Content="Morph Voice"
                                    Command="{x:Bind ViewModel.MorphVoiceCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsMorphing, Mode=OneWay}"
                                          Width="20" Height="20"
                                          VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{x:Bind ViewModel.MorphedAudioId, Mode=OneWay}"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing Grid.Column="0"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="16" Height="16"
                              Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="#80000000"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <ProgressRing IsActive="True" Width="32" Height="32" />
                <TextBlock Text="Processing..." Foreground="White" />
            </StackPanel>
        </Grid>

        <controls:HelpOverlay x:Name="HelpOverlay"
                              Grid.RowSpan="3"
                              IsVisible="False"
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
