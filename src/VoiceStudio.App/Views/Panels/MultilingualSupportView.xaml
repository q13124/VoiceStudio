<UserControl x:Class="VoiceStudio.App.Views.Panels.MultilingualSupportView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  x:DataType="local:MultilingualSupportView">
  <Grid AutomationProperties.AutomationId="MultilingualSupportView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Multilingual Support"
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
          <Button AutomationProperties.AutomationId="Multilingual_LoadLanguagesBtn"
                  Command="{x:Bind ViewModel.LoadSupportedLanguagesCommand}"
                  ToolTipService.ToolTip="Load supported languages">
            <FontIcon Glyph="&#xE774;" FontSize="14" />
          </Button>
          <Button AutomationProperties.AutomationId="Multilingual_RefreshBtn"
                  Command="{x:Bind ViewModel.RefreshCommand}"
                  ToolTipService.ToolTip="Refresh">
            <FontIcon Glyph="&#xE72C;" FontSize="14" />
          </Button>
          <Button AutomationProperties.AutomationId="Multilingual_HelpBtn"
                  Click="HelpButton_Click"
                  ToolTipService.ToolTip="Help">
            <FontIcon Glyph="&#xE897;" FontSize="14" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left: Source Text + Translation -->
      <Grid Grid.Column="0" Margin="0,0,8,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Source Language Selection -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ComboBox AutomationProperties.AutomationId="Multilingual_SourceLanguageCombo"
                    Grid.Column="0"
                    Header="Source Language"
                    ItemsSource="{x:Bind ViewModel.SupportedLanguages, Mode=OneWay}"
                    DisplayMemberPath="Name"
                    SelectionChanged="SourceLanguage_SelectionChanged"
                    PlaceholderText="Select source language..."
                    HorizontalAlignment="Stretch" />
          <ToggleSwitch AutomationProperties.AutomationId="Multilingual_AutoDetectToggle"
                        Grid.Column="1"
                        Header="Auto-detect"
                        IsOn="{x:Bind ViewModel.AutoDetectLanguage, Mode=TwoWay}"
                        Margin="12,0,0,0" />
        </Grid>

        <!-- Detected Language Display -->
        <TextBlock Grid.Row="1"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   FontSize="12"
                   Margin="0,0,0,8">
          <Run Text="Detected: " />
          <Run Text="{x:Bind ViewModel.DetectedLanguage, Mode=OneWay}" />
        </TextBlock>

        <!-- Source Text Input -->
        <TextBox AutomationProperties.AutomationId="Multilingual_SourceTextInput"
                 Grid.Row="2"
                 Header="Source Text"
                 Text="{x:Bind ViewModel.Text, Mode=TwoWay}"
                 PlaceholderText="Enter text to translate..."
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="100"
                 MaxHeight="180"
                 Margin="0,0,0,8" />

        <!-- Translation Result -->
        <Grid Grid.Row="3">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Button AutomationProperties.AutomationId="Multilingual_TranslateBtn"
                  Grid.Row="0"
                  Content="Translate"
                  Command="{x:Bind ViewModel.TranslateCommand}"
                  HorizontalAlignment="Stretch"
                  Style="{StaticResource AccentButtonStyle}"
                  Margin="0,0,0,8" />

          <TextBox AutomationProperties.AutomationId="Multilingual_TranslatedText"
                   Grid.Row="1"
                   Header="Translated Text"
                   Text="{x:Bind ViewModel.TranslatedText, Mode=OneWay}"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   MinHeight="80"
                   MaxHeight="140"
                   Margin="0,0,0,8" />

          <TextBlock Grid.Row="2" Text="Synthesized Audio"
                     FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                     Margin="0,0,0,4" />

          <ListView Grid.Row="3"
                    AutomationProperties.AutomationId="Multilingual_SynthesizedAudiosList"
                    ItemsSource="{x:Bind ViewModel.SynthesizedAudios, Mode=OneWay}"
                    SelectionMode="None">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="vm:MultilingualAudioItem">
                <Grid Padding="8,4" ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <FontIcon Grid.Column="0" Glyph="&#xE8D6;" FontSize="14" />
                  <TextBlock Grid.Column="1"
                             TextTrimming="CharacterEllipsis">
                    <Run Text="{x:Bind LanguageName, Mode=OneWay}" />
                    <Run Text=" (" />
                    <Run Text="{x:Bind LanguageCode, Mode=OneWay}" />
                    <Run Text=")" />
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Grid>

      <!-- Right: Target Languages + Options -->
      <Grid Grid.Column="1" Margin="8,0,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Target Languages"
                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   Margin="0,0,0,4" />

        <ListView Grid.Row="1"
                  AutomationProperties.AutomationId="Multilingual_TargetLanguagesList"
                  ItemsSource="{x:Bind ViewModel.SupportedLanguages, Mode=OneWay}"
                  SelectionMode="Multiple">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:LanguageItem">
              <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <!-- Synthesis Options -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,12,0,8">
          <TextBlock Text="Synthesis Options"
                     FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
          <ToggleSwitch AutomationProperties.AutomationId="Multilingual_PreserveEmotionToggle"
                        Header="Preserve Emotion"
                        IsOn="{x:Bind ViewModel.PreserveEmotion, Mode=TwoWay}" />
          <ToggleSwitch AutomationProperties.AutomationId="Multilingual_PreserveStyleToggle"
                        Header="Preserve Style"
                        IsOn="{x:Bind ViewModel.PreserveStyle, Mode=TwoWay}" />
        </StackPanel>

        <Button AutomationProperties.AutomationId="Multilingual_SynthesizeBtn"
                Grid.Row="3"
                Content="Synthesize All"
                Command="{x:Bind ViewModel.SynthesizeCommand}"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}" />
      </Grid>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="12,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressRing Grid.Column="0"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="16" Height="16"
                      Margin="0,0,8,0" />
        <TextBlock Grid.Column="1"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="2"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="3"
          Background="#80000000"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <ProgressRing IsActive="True" Width="32" Height="32" />
        <TextBlock Text="Processing..." Foreground="White" />
      </StackPanel>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay"
                          Grid.RowSpan="3"
                          IsVisible="False"
                          Visibility="Collapsed" />
  </Grid>
</UserControl>
