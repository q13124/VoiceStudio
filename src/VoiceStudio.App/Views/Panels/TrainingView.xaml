<UserControl x:Class="VoiceStudio.App.Views.Panels.TrainingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:converters="using:VoiceStudio.App.Converters">
  <UserControl.Resources>
    <converters:NumberFormatConverter x:Key="PercentFormatConverter" Format="P0" />
  </UserControl.Resources>
  <Grid ColumnSpacing="12" RowSpacing="12" Padding="12" AutomationProperties.AutomationId="TrainingView_Root">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Spacing="10">
      <TextBlock Text="Datasets" FontSize="16" FontWeight="SemiBold" />
      <ListView x:Name="DatasetsListView"
        ItemsSource="{x:Bind ViewModel.Datasets, Mode=OneWay}"
        SelectedItem="{x:Bind ViewModel.SelectedDataset, Mode=TwoWay}"
        SelectionMode="None"
        RightTapped="Dataset_RightTapped">
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="core:TrainingDataset" xmlns:core="using:VoiceStudio.Core.Models">
            <StackPanel Padding="6">
              <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
              <TextBlock Text="{x:Bind Description}" Opacity="0.7" FontSize="11" />
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <TextBlock Text="Create Dataset" FontWeight="SemiBold" Margin="0,8,0,0" />
      <TextBox Header="Name" Text="{x:Bind ViewModel.DatasetName, Mode=TwoWay}" />
      <TextBox Header="Description" Text="{x:Bind ViewModel.DatasetDescription, Mode=TwoWay}" />
      <TextBox Header="Audio Files (comma-separated IDs)"
        Text="{x:Bind ViewModel.AudioFilesText, Mode=TwoWay}" AcceptsReturn="True" Height="80" />
      <Button Content="Create Dataset"
        Command="{x:Bind ViewModel.CreateDatasetCommand}"
        HorizontalAlignment="Left" />
    </StackPanel>

    <StackPanel Grid.Column="1" Spacing="10">
      <TextBlock Text="Training Jobs" FontSize="16" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox x:Name="StatusFilter" Width="160" SelectionChanged="StatusFilter_SelectionChanged">
          <ComboBoxItem Content="All" Tag="" IsSelected="True" />
          <ComboBoxItem Content="Running" Tag="running" />
          <ComboBoxItem Content="Pending" Tag="pending" />
          <ComboBoxItem Content="Completed" Tag="completed" />
          <ComboBoxItem Content="Failed" Tag="failed" />
          <ComboBoxItem Content="Cancelled" Tag="cancelled" />
        </ComboBox>
        <Button Content="Refresh" Command="{x:Bind ViewModel.LoadTrainingJobsCommand}" />
      </StackPanel>

      <ListView x:Name="TrainingJobsListView"
        ItemsSource="{x:Bind ViewModel.TrainingJobs, Mode=OneWay}"
        SelectedItem="{x:Bind ViewModel.SelectedTrainingJob, Mode=TwoWay}"
        SelectionMode="None"
        RightTapped="TrainingJob_RightTapped">
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="core:TrainingStatus" xmlns:core="using:VoiceStudio.Core.Models">
            <StackPanel Padding="6">
              <TextBlock Text="{x:Bind Status}" FontWeight="SemiBold" />
              <TextBlock
                Text="{x:Bind Progress, Mode=OneWay, Converter={StaticResource PercentFormatConverter}}"
                Opacity="0.7" FontSize="11" />
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <controls:TrainingProgressChart x:Name="ProgressChart" Height="200"
        Loaded="ProgressChart_Loaded" />
    </StackPanel>

    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed"
      Grid.ColumnSpan="2" />
  </Grid>
</UserControl>