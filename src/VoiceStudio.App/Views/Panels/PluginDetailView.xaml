<UserControl
    x:Class="VoiceStudio.App.Views.Panels.PluginDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:models="using:VoiceStudio.Core.Plugins.Models"
    AutomationProperties.AutomationId="PluginDetailView_Root">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Grid Grid.Row="0" 
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Click="BackButton_Click"
                    AutomationProperties.AutomationId="PluginDetail.Button.Back">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    <TextBlock Text="Back to Gallery"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="InstallButton"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="InstallButton_Click"
                        AutomationProperties.AutomationId="PluginDetail.Button.Install">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="14"/>
                        <TextBlock x:Name="InstallButtonText" Text="Install"/>
                    </StackPanel>
                </Button>
                <Button x:Name="UninstallButton"
                        Visibility="Collapsed"
                        Click="UninstallButton_Click"
                        AutomationProperties.AutomationId="PluginDetail.Button.Uninstall">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="Uninstall"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="900">
                
                <!-- Plugin Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Large Icon -->
                    <Border Width="72"
                            Height="72"
                            CornerRadius="12"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <FontIcon Glyph="&#xE74C;" 
                                  FontSize="32" 
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title and Meta -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock x:Name="PluginNameText"
                                       Text="Plugin Name"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       AutomationProperties.AutomationId="PluginDetail.Name"/>
                            <Border x:Name="VerifiedBadge"
                                    Visibility="Collapsed"
                                    Background="#107C10"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="White"/>
                                    <TextBlock Text="Verified" FontSize="12" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock x:Name="AuthorText"
                                   Text="by Author"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   AutomationProperties.AutomationId="PluginDetail.Author"/>

                        <!-- Stats Row -->
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE735;" FontSize="14" Foreground="#FFD700"/>
                                <TextBlock x:Name="RatingText" 
                                           Text="4.5" 
                                           FontSize="14"/>
                                <TextBlock x:Name="RatingCountText"
                                           Text="(128 ratings)"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="DownloadCountText"
                                           Text="1,500 downloads"
                                           FontSize="14"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="VersionText"
                                           Text="v1.0.0"
                                           FontSize="14"
                                           AutomationProperties.AutomationId="PluginDetail.Version"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Tags -->
                <ItemsControl x:Name="TagsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="8,4">
                                <TextBlock Text="{x:Bind}" 
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Description -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Description"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="DescriptionText"
                                   Text="Plugin description goes here..."
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   AutomationProperties.AutomationId="PluginDetail.Description"/>
                    </StackPanel>
                </Border>

                <!-- Screenshots (if available) -->
                <Border x:Name="ScreenshotsSection"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20"
                        Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Screenshots"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <GridView x:Name="ScreenshotsGrid"
                                  Height="200">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Image Source="{x:Bind}" 
                                           Height="180"
                                           Stretch="Uniform"/>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </Border>

                <!-- Version History -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Version History"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <ListView x:Name="VersionHistoryList"
                                  SelectionMode="None"
                                  AutomationProperties.AutomationId="PluginDetail.VersionHistory">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:PluginVersion">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Version}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind ReleaseDate}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind ReleaseNotes}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Additional Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="12">
                            <TextBlock Text="Information"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Category:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="CategoryText" Grid.Column="1" Text="Voice Effects"/>

                                <TextBlock Grid.Row="1" Text="License:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="LicenseText" Grid.Row="1" Grid.Column="1" Text="MIT"/>

                                <TextBlock Grid.Row="2" Text="Min Version:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="MinVersionText" Grid.Row="2" Grid.Column="1" Text="1.0.0"/>

                                <TextBlock Grid.Row="3" Text="Last Updated:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="LastUpdatedText" Grid.Row="3" Grid.Column="1" Text="Jan 1, 2026"/>
                            </Grid>
                        </StackPanel>

                        <!-- Links -->
                        <StackPanel Grid.Column="1" Spacing="12">
                            <TextBlock Text="Links"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            <HyperlinkButton x:Name="HomepageLink"
                                             Content="Homepage"
                                             NavigateUri="https://example.com"
                                             AutomationProperties.AutomationId="PluginDetail.Link.Homepage"/>
                            <HyperlinkButton x:Name="SupportLink"
                                             Content="Support"
                                             NavigateUri="https://example.com/support"/>
                            <HyperlinkButton x:Name="IssuesLink"
                                             Content="Report Issues"
                                             NavigateUri="https://example.com/issues"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
