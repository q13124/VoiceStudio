<UserControl x:Class="VoiceStudio.App.Views.Panels.TagOrganizationView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:TagOrganizationView">

  <Grid AutomationProperties.AutomationId="TagOrganizationView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8EC;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Tag Organization" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="TagOrganizationView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="TagOrganizationView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- View Mode & Search -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" Header="View" SelectedIndex="0"
                    SelectionChanged="ViewModeComboBox_SelectionChanged"
                    AutomationProperties.AutomationId="TagOrganizationView_ViewModeCombo">
            <ComboBoxItem Content="Cloud"/>
            <ComboBoxItem Content="Hierarchy"/>
            <ComboBoxItem Content="List"/>
          </ComboBox>
          <TextBox Grid.Column="1" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Filter tags..." VerticalAlignment="Bottom"
                   AutomationProperties.AutomationId="TagOrganizationView_SearchBox"/>
        </Grid>
        <TextBlock Text="{x:Bind ViewModel.ActiveFilterTag, Mode=OneWay}" FontSize="11"
                   Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                   Visibility="{x:Bind ViewModel.ActiveFilterTag, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"/>
      </StackPanel>
    </Border>

    <!-- Tag Cloud View -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <ScrollViewer>
        <Grid>
          <!-- Cloud View -->
          <ItemsRepeater ItemsSource="{x:Bind ViewModel.TagCloudItems, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.IsCloudView, Mode=OneWay}"
                         AutomationProperties.AutomationId="TagOrganizationView_CloudView">
            <ItemsRepeater.Layout>
              <UniformGridLayout MinItemWidth="80" MinItemHeight="36" MinColumnSpacing="4" MinRowSpacing="4"
                                 ItemsStretch="Fill"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate>
                <Button HorizontalAlignment="Stretch" Padding="8,4" Tag="{Binding}"
                        PointerPressed="TagCloudItem_PointerPressed"
                        AutomationProperties.AutomationId="TagOrganizationView_CloudTag">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" FontSize="{Binding FontSize}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <TextBlock Text="{Binding Count}" FontSize="10" VerticalAlignment="Center"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>

          <!-- Hierarchy View -->
          <TreeView ItemsSource="{x:Bind ViewModel.TagHierarchy, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsHierarchyView, Mode=OneWay}"
                    AutomationProperties.AutomationId="TagOrganizationView_HierarchyView">
            <TreeView.ItemTemplate>
              <DataTemplate>
                <TreeViewItem ItemsSource="{Binding Children}" Content="{Binding}">
                  <TreeViewItem.ContentTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Name}" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                          <Run Text="("/>
                          <Run Text="{Binding Count}"/>
                          <Run Text=")"/>
                        </TextBlock>
                      </StackPanel>
                    </DataTemplate>
                  </TreeViewItem.ContentTemplate>
                </TreeViewItem>
              </DataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>

          <!-- List View -->
          <ListView ItemsSource="{x:Bind ViewModel.TagListItems, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsListView, Mode=OneWay}"
                    AutomationProperties.AutomationId="TagOrganizationView_ListView">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid Padding="8,6" ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <TextBlock Text="{Binding Category}" FontSize="11"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                    <Run Text="{Binding Count}"/>
                    <Run Text="uses"/>
                  </TextBlock>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button CommandParameter="{Binding}" Click="FilterByTag_Click"
                            ToolTipService.ToolTip="Filter" Padding="6">
                      <FontIcon Glyph="&#xE71C;" FontSize="12"/>
                    </Button>
                    <Button CommandParameter="{Binding}" Click="EditTag_Click"
                            ToolTipService.ToolTip="Edit" Padding="6">
                      <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </ScrollViewer>
    </Border>

    <!-- Status -->
    <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.ActiveFilterTag, Mode=OneWay}"
               FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,0,0,4"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="4" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
