<UserControl x:Class="VoiceStudio.App.Views.Panels.ModelManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:ModelManagerView">
    <Grid x:Name="ModelManagerView_Root" 
          AutomationProperties.AutomationId="ModelManagerView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Model Manager" 
                       FontSize="{StaticResource VSQ.FontSize.Title}" 
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>