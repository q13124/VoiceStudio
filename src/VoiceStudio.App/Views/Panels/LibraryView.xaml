<UserControl x:Class="VoiceStudio.App.Views.Panels.LibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:LibraryView">

    <Grid x:Name="LibraryView_Root" 
          AutomationProperties.AutomationId="LibraryView_Root"
          Background="{StaticResource VSQ.Panel.Background}"
          AllowDrop="True"
          DragOver="LibraryPanel_DragOver"
          Drop="LibraryPanel_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Library" 
                       FontSize="{StaticResource VSQ.FontSize.Title}" 
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Search Box -->
            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Row="0"
                            PlaceholderText="Search assets..."
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find"
                            Margin="{StaticResource VSQ.Spacing.Small}"
                            AutomationProperties.AutomationId="LibraryView_SearchBox" />
            
            <!-- Folders List (collapsible) -->
            <ListView x:Name="FoldersListView"
                      Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Folders, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.ShowFolders, Mode=OneWay}"
                      MaxHeight="150"
                      Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                      AutomationProperties.AutomationId="LibraryView_FoldersListView" />
            
            <!-- Assets List with Context Menu -->
            <ListView x:Name="AssetsListView"
                      Grid.Row="2"
                      ItemsSource="{x:Bind ViewModel.Assets, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedAsset, Mode=TwoWay}"
                      Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                      AutomationProperties.AutomationId="LibraryView_AssetsListView">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LibraryAsset">
                        <Grid Padding="8,4" ContextRequested="AssetItem_ContextRequested">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="PlayMenuItem" Text="Play" Icon="Play" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="CloneReferenceMenuItem" Text="Use as Clone Reference" />
                                    <MenuFlyoutItem x:Name="UseSynthesisVoiceMenuItem" Text="Use for Synthesis" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="DeleteMenuItem" Text="Delete" Icon="Delete" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Icon based on type -->
                            <FontIcon Grid.Column="0" 
                                      Glyph="&#xE8D6;" 
                                      FontSize="16" 
                                      Margin="0,0,8,0" 
                                      Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                            <!-- Asset name -->
                            <TextBlock Grid.Column="1" 
                                       Text="{x:Bind Name}" 
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                            <!-- Duration if available -->
                            <TextBlock Grid.Column="2" 
                                       Text="{x:Bind Duration}" 
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource VSQ.Text.TertiaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <Canvas x:Name="DragDropCanvas" Grid.RowSpan="3" IsHitTestVisible="False" Background="Transparent"
                    AutomationProperties.AutomationId="LibraryView_DragDropCanvas" />
        </Grid>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
