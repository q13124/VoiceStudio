<UserControl x:Class="VoiceStudio.App.Views.Panels.ImageGenView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:converters="using:VoiceStudio.App.Converters"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:ImageGenView">

  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
  </UserControl.Resources>

  <Grid Padding="16" AutomationProperties.AutomationId="ImageGenView_Root">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8B9;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Image Generation" FontSize="20" FontWeight="SemiBold"
                   VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Click="QualitySettings_Click" ToolTipService.ToolTip="Quality Settings"
                AutomationProperties.AutomationId="ImageGenView_QualitySettingsBtn">
          <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                AutomationProperties.AutomationId="ImageGenView_HelpBtn">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="320"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Settings -->
        <StackPanel Grid.Column="0" Spacing="12">

          <!-- Engine + Quality Preset -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
            <StackPanel Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE71C;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Engine" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <ComboBox ItemsSource="{x:Bind ViewModel.Engines, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="ImageGenView_EngineSelector"/>

              <TextBlock Text="Quality Preset" FontSize="12"
                         Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              <ComboBox ItemsSource="{x:Bind ViewModel.QualityPresets, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedQualityPreset, Mode=TwoWay}"
                        DisplayMemberPath="Name" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="ImageGenView_QualityPresetSelector"/>
            </StackPanel>
          </Border>

          <!-- Prompt -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
            <StackPanel Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8D3;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Prompt" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <TextBox Text="{x:Bind ViewModel.Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Describe the image you want to generate..."
                       TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" MaxHeight="160"
                       AutomationProperties.AutomationId="ImageGenView_PromptInput"/>
              <TextBox Text="{x:Bind ViewModel.NegativePrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Negative prompt (things to avoid)..."
                       TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="80"
                       AutomationProperties.AutomationId="ImageGenView_NegativePromptInput"/>
            </StackPanel>
          </Border>

          <!-- Generation Parameters -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
            <StackPanel Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE713;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Parameters" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>

              <!-- Width / Height -->
              <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="Width" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <NumberBox Value="{x:Bind ViewModel.Width, Mode=TwoWay}"
                             Minimum="64" Maximum="2048" SpinButtonPlacementMode="Compact"
                             SmallChange="64" LargeChange="256"
                             AutomationProperties.AutomationId="ImageGenView_WidthInput"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Height" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <NumberBox Value="{x:Bind ViewModel.Height, Mode=TwoWay}"
                             Minimum="64" Maximum="2048" SpinButtonPlacementMode="Compact"
                             SmallChange="64" LargeChange="256"
                             AutomationProperties.AutomationId="ImageGenView_HeightInput"/>
                </StackPanel>
              </Grid>

              <!-- Steps -->
              <StackPanel Spacing="4">
                <Grid>
                  <TextBlock Text="Steps" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Text="{x:Bind ViewModel.Steps, Mode=OneWay}" FontSize="12"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}" HorizontalAlignment="Right"/>
                </Grid>
                <Slider Value="{x:Bind ViewModel.Steps, Mode=TwoWay}"
                        Minimum="1" Maximum="100" StepFrequency="1"
                        AutomationProperties.AutomationId="ImageGenView_StepsSlider"/>
              </StackPanel>

              <!-- CFG Scale -->
              <StackPanel Spacing="4">
                <Grid>
                  <TextBlock Text="CFG Scale" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Text="{x:Bind ViewModel.CfgScale, Mode=OneWay}" FontSize="12"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}" HorizontalAlignment="Right"/>
                </Grid>
                <Slider Value="{x:Bind ViewModel.CfgScale, Mode=TwoWay}"
                        Minimum="1" Maximum="20" StepFrequency="0.5"
                        AutomationProperties.AutomationId="ImageGenView_CfgScaleSlider"/>
              </StackPanel>

              <!-- Sampler / Seed -->
              <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="Sampler" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBox Text="{x:Bind ViewModel.Sampler, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="Default"
                           AutomationProperties.AutomationId="ImageGenView_SamplerInput"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Seed" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBox Text="{x:Bind ViewModel.Seed, Mode=TwoWay, TargetNullValue=''}"
                           PlaceholderText="Random"
                           AutomationProperties.AutomationId="ImageGenView_SeedInput"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Generate + Upscale Buttons -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
            <StackPanel Spacing="8">
              <Button Command="{x:Bind ViewModel.GenerateCommand}"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource VSQ.Button.Primary}"
                      AutomationProperties.AutomationId="ImageGenView_GenerateBtn">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                  <FontIcon Glyph="&#xE768;" FontSize="14"/>
                  <TextBlock Text="Generate"/>
                </StackPanel>
              </Button>
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{x:Bind ViewModel.UpscaleCommand}"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="ImageGenView_UpscaleBtn">
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8A3;" FontSize="14"/>
                    <TextBlock Text="Upscale Selected"/>
                  </StackPanel>
                </Button>
                <ComboBox Grid.Column="1" Width="80"
                          SelectedItem="{x:Bind ViewModel.UpscaleFactor, Mode=TwoWay}"
                          AutomationProperties.AutomationId="ImageGenView_UpscaleFactorSelector">
                  <x:String>2x</x:String>
                  <x:String>4x</x:String>
                  <x:String>8x</x:String>
                </ComboBox>
              </Grid>

              <!-- Quality Comparison -->
              <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.HasQualityComparison, Mode=OneWay}">
                <TextBlock Text="{x:Bind ViewModel.CurrentQualityMetrics, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- Right Panel: Generated Images + Preview -->
        <StackPanel Grid.Column="1" Spacing="12">

          <!-- Image Preview -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16"
                  MinHeight="300">
            <Grid>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                          Visibility="{x:Bind ViewModel.HasGeneratedImages, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay, FallbackValue=Visible}">
                <FontIcon Glyph="&#xE8B9;" FontSize="48" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                          HorizontalAlignment="Center" Opacity="0.4"/>
                <TextBlock Text="No images generated yet" FontSize="14"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Enter a prompt and click Generate" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           HorizontalAlignment="Center" Opacity="0.6"/>
              </StackPanel>

              <StackPanel Spacing="8"
                          Visibility="{x:Bind ViewModel.HasGeneratedImages, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <FontIcon Glyph="&#xE91B;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  <TextBlock Text="Preview" FontSize="13" FontWeight="SemiBold"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <Border CornerRadius="8" HorizontalAlignment="Center" MaxHeight="400">
                  <Image Source="{x:Bind ViewModel.CurrentImageUrl, Mode=OneWay}"
                         Stretch="Uniform"
                         AutomationProperties.AutomationId="ImageGenView_PreviewImage"/>
                </Border>

                <!-- Quality Metrics -->
                <Grid ColumnSpacing="16"
                      Visibility="{x:Bind ViewModel.HasGeneratedImages, Mode=OneWay}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Spacing="2"
                              AutomationProperties.AutomationId="ImageGenView_ClarityMetric">
                    <TextBlock Text="Clarity" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ImageClarity, Mode=OneWay, FallbackValue='--'}"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2"
                              AutomationProperties.AutomationId="ImageGenView_DetailMetric">
                    <TextBlock Text="Detail" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ImageDetail, Mode=OneWay, FallbackValue='--'}"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="2"
                              AutomationProperties.AutomationId="ImageGenView_StyleFidelityMetric">
                    <TextBlock Text="Style" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ImageStyleFidelity, Mode=OneWay, FallbackValue='--'}"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="2"
                              AutomationProperties.AutomationId="ImageGenView_OverallQualityMetric">
                    <TextBlock Text="Overall" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ImageOverallQuality, Mode=OneWay, FallbackValue='--'}"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Generated Images Gallery -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16"
                  Visibility="{x:Bind ViewModel.HasGeneratedImages, Mode=OneWay}">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8B9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Generated Images" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <GridView ItemsSource="{x:Bind ViewModel.GeneratedImages, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=TwoWay}"
                        RightTapped="Image_RightTapped"
                        MaxHeight="250"
                        AutomationProperties.AutomationId="ImageGenView_ImagesGrid">
                <GridView.ItemTemplate>
                  <DataTemplate x:DataType="local:GeneratedImage">
                    <Border Width="120" Height="120" CornerRadius="6"
                            BorderBrush="{StaticResource VSQ.Text.SecondaryBrush}" BorderThickness="1"
                            Margin="4">
                      <Grid>
                        <Image Source="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                        <StackPanel VerticalAlignment="Bottom" Padding="4"
                                    Background="#80000000">
                          <TextBlock Text="{x:Bind Engine}" FontSize="10"
                                     Foreground="White" TextTrimming="CharacterEllipsis"/>
                          <TextBlock FontSize="9" Foreground="#CCCCCC">
                            <Run Text="{x:Bind Width}"/><Run Text="×"/><Run Text="{x:Bind Height}"/>
                          </TextBlock>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </GridView.ItemTemplate>
              </GridView>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="2" IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}" Severity="Error"
             Title="Image Generation Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True" AutomationProperties.AutomationId="ImageGenView_ErrorInfoBar"/>

    <!-- Overlays -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    <controls:LoadingOverlay Grid.RowSpan="3" IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="ImageGenView_LoadingOverlay"/>
  </Grid>
</UserControl>
