<UserControl x:Class="VoiceStudio.App.Views.Panels.QualityBenchmarkView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:QualityBenchmarkView">
    <Grid x:Name="QualityBenchmarkView_Root" 
          AutomationProperties.AutomationId="QualityBenchmarkView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <TextBlock Text="Quality Benchmark" 
                       FontSize="{StaticResource VSQ.FontSize.Title}" 
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Configuration" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Voice Profile" FontSize="12"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                                      DisplayMemberPath="Name" PlaceholderText="Select a profile"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="QualityBenchmarkView_ProfileSelector"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Test Text" FontSize="12"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.TestText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Enter test text..."
                                     TextWrapping="Wrap" MinHeight="60"
                                     AutomationProperties.AutomationId="QualityBenchmarkView_TestText"/>
                        </StackPanel>

                        <TextBlock Text="Engines to Test" FontSize="12"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Content="XTTS" IsChecked="{x:Bind ViewModel.TestXTTS, Mode=TwoWay}"
                                      AutomationProperties.AutomationId="QualityBenchmarkView_TestXTTS"/>
                            <CheckBox Content="Chatterbox" IsChecked="{x:Bind ViewModel.TestChatterbox, Mode=TwoWay}"
                                      AutomationProperties.AutomationId="QualityBenchmarkView_TestChatterbox"/>
                            <CheckBox Content="Tortoise" IsChecked="{x:Bind ViewModel.TestTortoise, Mode=TwoWay}"
                                      AutomationProperties.AutomationId="QualityBenchmarkView_TestTortoise"/>
                        </StackPanel>

                        <CheckBox Content="Enhance Quality" IsChecked="{x:Bind ViewModel.EnhanceQuality, Mode=TwoWay}"
                                  AutomationProperties.AutomationId="QualityBenchmarkView_EnhanceQuality"/>

                        <Button Command="{x:Bind ViewModel.RunBenchmarkCommand}"
                                Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="QualityBenchmarkView_RunButton">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                <TextBlock Text="Run Benchmark" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Results" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

                        <TextBlock Text="{x:Bind ViewModel.ResultsSummary, Mode=OneWay}"
                                   FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>

                        <ListView ItemsSource="{x:Bind ViewModel.BenchmarkResults, Mode=OneWay}"
                                  AutomationProperties.AutomationId="QualityBenchmarkView_ResultsList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="0,2">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Engine}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding MosScoreDisplay}" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SimilarityDisplay}" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TimeDisplay}" FontSize="12"/>
                                            <TextBlock Grid.Column="4" Text="{Binding StatusDisplay}" FontSize="12"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}" Severity="Error"
                         Title="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="True"
                         AutomationProperties.AutomationId="QualityBenchmarkView_ErrorBar"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
