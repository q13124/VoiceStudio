<UserControl
    x:Class="VoiceStudio.App.Views.Panels.HealthCheckView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          AutomationProperties.AutomationId="HealthCheckView_Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    Text="System Health"
                    Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock
                    Text="Real-time health status of all system components"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="RefreshButton"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="Refresh health status">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
                <Button
                    x:Name="HelpButton"
                    Click="HelpButton_Click"
                    ToolTipService.ToolTip="Health check help">
                    <FontIcon Glyph="&#xE897;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Overall Status Summary -->
        <Border
            Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Margin="24,0,24,16"
            Padding="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Overall Status -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Ellipse
                        Width="16"
                        Height="16"
                        Fill="{x:Bind ViewModel.OverallStatusColor, Mode=OneWay}"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.OverallStatusText, Mode=OneWay}"
                        Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.LastCheckTimeText, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Component Counts -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="10" Height="10" Fill="#10B981"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.HealthyCount, Mode=OneWay}"
                        Foreground="#10B981"/>
                    <TextBlock Text="Healthy" Opacity="0.7"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="#F59E0B"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}"
                        Foreground="#F59E0B"/>
                    <TextBlock Text="Warning" Opacity="0.7"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="#EF4444"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}"
                        Foreground="#EF4444"/>
                    <TextBlock Text="Critical" Opacity="0.7"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="#6B7280"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.UnknownCount, Mode=OneWay}"
                        Foreground="#6B7280"/>
                    <TextBlock Text="Unknown" Opacity="0.7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Health Check Items -->
        <ScrollViewer Grid.Row="2" Padding="24,0">
            <ItemsControl ItemsSource="{x:Bind ViewModel.HealthChecks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Margin="0,0,0,8"
                            Padding="16">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status Indicator -->
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Fill="{Binding StatusColor}"
                                    VerticalAlignment="Center"/>

                                <!-- Component Info -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock
                                        Text="{Binding Description}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock
                                        Text="{Binding StatusMessage}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{Binding StatusMessageColor}"
                                        Visibility="{Binding HasStatusMessage}"
                                        Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Response Time -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                                    <TextBlock
                                        Text="{Binding ResponseTimeText}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        HorizontalAlignment="Right"/>
                                    <TextBlock
                                        Text="Response Time"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Right"/>
                                </StackPanel>

                                <!-- Last Check Time -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{Binding LastCheckText}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        HorizontalAlignment="Right"/>
                                    <TextBlock
                                        Text="Last Check"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Opacity="0.9"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                <TextBlock
                    Text="Checking system health..."
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Help Overlay -->
        <Grid
            x:Name="HelpOverlay"
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="#80000000"
            Visibility="Collapsed"
            Tapped="HelpOverlay_Tapped">
            <Border
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="8"
                MaxWidth="500"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Health Check Help"
                        Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        The Health Check panel monitors all system components in real-time.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        <Run FontWeight="SemiBold">Status Colors:</Run>
                        <LineBreak/>
                        <Run Foreground="#10B981">● Green</Run> - Component is healthy
                        <LineBreak/>
                        <Run Foreground="#F59E0B">● Yellow</Run> - Component has warnings
                        <LineBreak/>
                        <Run Foreground="#EF4444">● Red</Run> - Component is critical/down
                        <LineBreak/>
                        <Run Foreground="#6B7280">● Gray</Run> - Status unknown
                    </TextBlock>
                    <Button
                        Content="Close"
                        HorizontalAlignment="Right"
                        Click="CloseHelp_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
