<UserControl x:Class="VoiceStudio.App.Views.Panels.SpatialStageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:SpatialStageView">
    <Grid x:Name="SpatialStageView_Root"
          AutomationProperties.AutomationId="SpatialStageView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE809;" FontSize="20"/>
                    <TextBlock Text="Spatial Stage"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Refresh"
                            AutomationProperties.AutomationId="SpatialStageView_RefreshButton">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                            AutomationProperties.AutomationId="SpatialStageView_HelpButton">
                        <FontIcon Glyph="&#xE897;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Config Setup -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBox Header="Config Name" Text="{x:Bind ViewModel.ConfigName, Mode=TwoWay}"
                                 PlaceholderText="Enter configuration name..."
                                 AutomationProperties.AutomationId="SpatialStageView_ConfigName"/>
                        <ComboBox Header="Audio Source" ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedAudioId, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="SpatialStageView_AudioComboBox"/>
                    </StackPanel>
                </Border>

                <!-- Position -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Position" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <NumberBox Header="X" Value="{x:Bind ViewModel.PositionX, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Compact"
                                       AutomationProperties.AutomationId="SpatialStageView_PosX"/>
                            <NumberBox Grid.Column="1" Header="Y" Value="{x:Bind ViewModel.PositionY, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Compact"
                                       AutomationProperties.AutomationId="SpatialStageView_PosY"/>
                            <NumberBox Grid.Column="2" Header="Z" Value="{x:Bind ViewModel.PositionZ, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Compact"
                                       AutomationProperties.AutomationId="SpatialStageView_PosZ"/>
                        </Grid>
                        <NumberBox Header="Distance" Value="{x:Bind ViewModel.Distance, Mode=TwoWay}"
                                   Minimum="0" SpinButtonPlacementMode="Compact"
                                   AutomationProperties.AutomationId="SpatialStageView_Distance"/>
                    </StackPanel>
                </Border>

                <!-- Environment -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Environment" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Slider Header="Room Size" Value="{x:Bind ViewModel.RoomSize, Mode=TwoWay}"
                                Minimum="0" Maximum="100" StepFrequency="1"
                                AutomationProperties.AutomationId="SpatialStageView_RoomSize"/>
                        <Slider Header="Reverb" Value="{x:Bind ViewModel.ReverbAmount, Mode=TwoWay}"
                                Minimum="0" Maximum="1" StepFrequency="0.01"
                                AutomationProperties.AutomationId="SpatialStageView_Reverb"/>
                        <Slider Header="Occlusion" Value="{x:Bind ViewModel.Occlusion, Mode=TwoWay}"
                                Minimum="0" Maximum="1" StepFrequency="0.01"
                                AutomationProperties.AutomationId="SpatialStageView_Occlusion"/>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.EnableDoppler, Mode=TwoWay}" Header="Doppler"
                                      AutomationProperties.AutomationId="SpatialStageView_DopplerToggle"/>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.EnableHrtf, Mode=TwoWay}" Header="HRTF"
                                      AutomationProperties.AutomationId="SpatialStageView_HrtfToggle"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.CreateConfigCommand}" Content="Create Config"
                            Style="{StaticResource AccentButtonStyle}"
                            AutomationProperties.AutomationId="SpatialStageView_CreateButton"/>
                    <Button Command="{x:Bind ViewModel.PreviewSpatialCommand}" Content="Preview"
                            AutomationProperties.AutomationId="SpatialStageView_PreviewButton"/>
                    <Button Command="{x:Bind ViewModel.ApplySpatialCommand}" Content="Apply"
                            AutomationProperties.AutomationId="SpatialStageView_ApplyButton"/>
                </StackPanel>

                <!-- Configs List -->
                <ListView ItemsSource="{x:Bind ViewModel.Configs, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedConfig, Mode=TwoWay}"
                          AutomationProperties.AutomationId="SpatialStageView_ConfigList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PositionDisplay}" FontSize="11" Opacity="0.5"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Room: "/>
                                            <Run Text="{Binding RoomSize}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Reverb: "/>
                                            <Run Text="{Binding ReverbAmount}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="SpatialStageView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
