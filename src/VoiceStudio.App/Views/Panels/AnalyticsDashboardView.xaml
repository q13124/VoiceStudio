<UserControl x:Class="VoiceStudio.App.Views.Panels.AnalyticsDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:AnalyticsDashboardView">
    <Grid x:Name="AnalyticsDashboardView_Root" 
          AutomationProperties.AutomationId="AnalyticsDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Analytics Dashboard" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="AnalyticsDashboardView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Syntheses" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Summary.TotalSynthesis, Mode=OneWay, FallbackValue='0'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="AnalyticsDashboardView_TotalSynthesis"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Projects" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Summary.TotalProjects, Mode=OneWay, FallbackValue='0'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="AnalyticsDashboardView_TotalProjects"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Processing" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Summary.ProcessingTimeDisplay, Mode=OneWay, FallbackValue='--'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="AnalyticsDashboardView_ProcessingTime"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Quality" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Summary.QualityScoreDisplay, Mode=OneWay, FallbackValue='--'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="AnalyticsDashboardView_Quality"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Filters" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                      PlaceholderText="Category" HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="AnalyticsDashboardView_Category"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.AvailableTimeRanges, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedTimeRange, Mode=TwoWay}"
                                      PlaceholderText="Time Range" HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="AnalyticsDashboardView_TimeRange"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Bind ViewModel.AvailableIntervals, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedInterval, Mode=TwoWay}"
                                      PlaceholderText="Interval" HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="AnalyticsDashboardView_Interval"/>
                        </Grid>
                        <CheckBox Content="Show Statistical Analysis"
                                  IsChecked="{x:Bind ViewModel.ShowStatisticalAnalysis, Mode=TwoWay}"
                                  AutomationProperties.AutomationId="AnalyticsDashboardView_StatsToggle"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Category Metrics" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.CategoryMetrics, Mode=OneWay}"
                                  MaxHeight="250"
                                  AutomationProperties.AutomationId="AnalyticsDashboardView_MetricsList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayLabel}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp}" FontSize="11" Opacity="0.6"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12"
                        Visibility="{x:Bind ViewModel.ShowStatisticalAnalysis, Mode=OneWay}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Statistical Analysis" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="24" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Mean" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.MeanDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Median" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.MedianDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Std Dev" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.StandardDeviationDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3">
                                <TextBlock Text="Sample Size" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.SampleSize, Mode=OneWay, FallbackValue='0'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Skewness" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.SkewnessDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Kurtosis" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.KurtosisDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="IQR" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.IQRDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="3">
                                <TextBlock Text="Range" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind ViewModel.StatisticalAnalysis.RangeDisplay, Mode=OneWay, FallbackValue='--'}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
