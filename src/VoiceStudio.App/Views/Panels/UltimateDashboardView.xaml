<UserControl x:Class="VoiceStudio.App.Views.Panels.UltimateDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:UltimateDashboardView">
    <Grid x:Name="UltimateDashboardView_Root" 
          AutomationProperties.AutomationId="UltimateDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ultimate Dashboard" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="UltimateDashboardView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="System Overview" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="16" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Projects" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.TotalProjects, Mode=OneWay, FallbackValue='0'}"
                                           FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="UltimateDashboardView_TotalProjects"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Profiles" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.TotalProfiles, Mode=OneWay, FallbackValue='0'}"
                                           FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="UltimateDashboardView_TotalProfiles"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Audio Files" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.TotalAudioFiles, Mode=OneWay, FallbackValue='0'}"
                                           FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="CPU" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.CpuUtilizationDisplay, Mode=OneWay, FallbackValue='--'}"
                                           FontSize="14" AutomationProperties.AutomationId="UltimateDashboardView_CPU"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="GPU" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.GpuUtilizationDisplay, Mode=OneWay, FallbackValue='--'}"
                                           FontSize="14" AutomationProperties.AutomationId="UltimateDashboardView_GPU"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="Memory" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.MemoryUsageDisplay, Mode=OneWay, FallbackValue='--'}"
                                           FontSize="14" AutomationProperties.AutomationId="UltimateDashboardView_Memory"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quick Stats" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.QuickStats, Mode=OneWay}"
                                      AutomationProperties.AutomationId="UltimateDashboardView_QuickStats">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="12" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TrendDisplay}" FontSize="11" Opacity="0.6"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Recent Activity" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.RecentActivities, Mode=OneWay}"
                                  MaxHeight="250"
                                  AutomationProperties.AutomationId="UltimateDashboardView_RecentActivities">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="16" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="11" Opacity="0.6"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16"
                        Visibility="{x:Bind ViewModel.SystemAlerts.Count, Mode=OneWay}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="System Alerts" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.SystemAlerts, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <InfoBar IsOpen="True" Severity="Warning" Message="{Binding}" IsClosable="False" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
