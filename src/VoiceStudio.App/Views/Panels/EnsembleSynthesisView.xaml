<UserControl x:Class="VoiceStudio.App.Views.Panels.EnsembleSynthesisView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:converters="using:VoiceStudio.App.Converters">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <converters:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
  </UserControl.Resources>

  <Grid x:Name="EnsembleSynthesisView_Root"
        AutomationProperties.AutomationId="EnsembleSynthesisView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="200"/>
    </Grid.RowDefinitions>

    <!-- Row 0: Header with Actions -->
    <Grid Grid.Row="0" Padding="16,12" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
        <TextBlock Text="Ensemble Synthesis" 
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   VerticalAlignment="Center"/>
        
        <!-- Mix Mode Selection -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Mix Mode:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" 
                     VerticalAlignment="Center" FontSize="{StaticResource VSQ.FontSize.Body}"/>
          <ComboBox x:Name="MixModeComboBox"
                    AutomationProperties.AutomationId="EnsembleSynthesisView_MixModeComboBox"
                    ItemsSource="{x:Bind ViewModel.AvailableMixModes, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.MixMode, Mode=TwoWay}"
                    MinWidth="120"/>
        </StackPanel>

        <!-- Output Format Selection -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Format:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                     VerticalAlignment="Center" FontSize="{StaticResource VSQ.FontSize.Body}"/>
          <ComboBox x:Name="OutputFormatComboBox"
                    AutomationProperties.AutomationId="EnsembleSynthesisView_OutputFormatComboBox"
                    ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.OutputFormat, Mode=TwoWay}"
                    MinWidth="80"/>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button AutomationProperties.AutomationId="EnsembleSynthesisView_AddVoiceButton"
                Command="{x:Bind ViewModel.AddVoiceCommand}"
                ToolTipService.ToolTip="Add Voice (Ctrl+N)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="Add Voice"/>
          </StackPanel>
        </Button>
        
        <Button AutomationProperties.AutomationId="EnsembleSynthesisView_SynthesizeButton"
                Command="{x:Bind ViewModel.SynthesizeCommand}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Synthesize Ensemble (Ctrl+Enter)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE768;" FontSize="14"/>
            <TextBlock Text="Synthesize"/>
          </StackPanel>
        </Button>

        <Button AutomationProperties.AutomationId="EnsembleSynthesisView_RefreshButton"
                Command="{x:Bind ViewModel.RefreshCommand}"
                ToolTipService.ToolTip="Refresh Jobs (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>

        <Button x:Name="HelpButton" Click="HelpButton_Click"
                AutomationProperties.AutomationId="EnsembleSynthesisView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Row 1: Voice Configuration List -->
    <ScrollViewer Grid.Row="1" Padding="16,8">
      <ItemsControl ItemsSource="{x:Bind ViewModel.Voices, Mode=OneWay}"
                    AutomationProperties.AutomationId="EnsembleSynthesisView_VoicesList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,0,8"
                    Padding="12"
                    CanDrag="True"
                    AllowDrop="True"
                    RightTapped="Voice_RightTapped"
                    DragStarting="Voice_DragStarting"
                    DragOver="Voice_DragOver"
                    Drop="Voice_Drop"
                    DragLeave="Voice_DragLeave">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Drag Handle -->
                <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="16"
                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          ToolTipService.ToolTip="Drag to reorder"/>

                <!-- Voice Configuration -->
                <StackPanel Grid.Column="1" Spacing="8">
                  <!-- Row 1: Profile, Engine, Language -->
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel Spacing="4" MinWidth="180">
                      <TextBlock Text="Voice Profile" FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                      <ComboBox ItemsSource="{Binding DataContext.AvailableProfiles, ElementName=EnsembleSynthesisView_Root, Mode=OneWay}"
                                SelectedItem="{Binding ProfileId, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EnsembleSynthesisView_VoiceProfileComboBox"/>
                    </StackPanel>

                    <StackPanel Spacing="4" MinWidth="140">
                      <TextBlock Text="Engine" FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                      <ComboBox ItemsSource="{Binding DataContext.AvailableEngines, ElementName=EnsembleSynthesisView_Root, Mode=OneWay}"
                                SelectedItem="{Binding Engine, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EnsembleSynthesisView_VoiceEngineComboBox"/>
                    </StackPanel>

                    <StackPanel Spacing="4" MinWidth="100">
                      <TextBlock Text="Language" FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                      <ComboBox SelectedItem="{Binding Language, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EnsembleSynthesisView_VoiceLanguageComboBox">
                        <ComboBoxItem Content="en" IsSelected="True"/>
                        <ComboBoxItem Content="es"/>
                        <ComboBoxItem Content="fr"/>
                        <ComboBoxItem Content="de"/>
                        <ComboBoxItem Content="zh"/>
                        <ComboBoxItem Content="ja"/>
                      </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4" MinWidth="120">
                      <TextBlock Text="Emotion" FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                      <ComboBox SelectedItem="{Binding Emotion, Mode=TwoWay}"
                                PlaceholderText="(optional)"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EnsembleSynthesisView_VoiceEmotionComboBox">
                        <ComboBoxItem Content="neutral"/>
                        <ComboBoxItem Content="happy"/>
                        <ComboBoxItem Content="sad"/>
                        <ComboBoxItem Content="angry"/>
                        <ComboBoxItem Content="surprised"/>
                      </ComboBox>
                    </StackPanel>
                  </StackPanel>

                  <!-- Row 2: Text Input -->
                  <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="Enter text for this voice..."
                           TextWrapping="Wrap"
                           AcceptsReturn="True"
                           MinHeight="60"
                           MaxHeight="120"
                           AutomationProperties.AutomationId="EnsembleSynthesisView_VoiceTextInput"/>
                </StackPanel>

                <!-- Remove Button -->
                <Button Grid.Column="2"
                        Command="{Binding DataContext.RemoveVoiceCommand, ElementName=EnsembleSynthesisView_Root}"
                        CommandParameter="{Binding}"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        ToolTipService.ToolTip="Remove Voice"
                        AutomationProperties.AutomationId="EnsembleSynthesisView_RemoveVoiceButton">
                  <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="{StaticResource VSQ.Error.Brush}"/>
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Row 2: Timeline Preview -->
    <Grid Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
          Padding="16,8" MinHeight="80">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Timeline Preview" 
                 FontSize="{StaticResource VSQ.FontSize.Body}"
                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                 Margin="0,0,0,8"/>

      <controls:EnsembleTimelineControl x:Name="EnsembleTimeline" Grid.Row="1"
                                        AutomationProperties.AutomationId="EnsembleSynthesisView_Timeline"/>
    </Grid>

    <!-- Row 3: Jobs List -->
    <Grid Grid.Row="3" Padding="16,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Jobs Header -->
      <Grid Grid.Row="0" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Synthesis Jobs" 
                     FontSize="{StaticResource VSQ.FontSize.Body}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{x:Bind ViewModel.SelectedJobCount, Mode=OneWay, FallbackValue='0'}"
                     FontSize="{StaticResource VSQ.FontSize.Caption}"
                     Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                     VerticalAlignment="Center"
                     Visibility="{x:Bind ViewModel.HasMultipleJobSelection, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <TextBlock Text="selected"
                     FontSize="{StaticResource VSQ.FontSize.Caption}"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                     VerticalAlignment="Center"
                     Visibility="{x:Bind ViewModel.HasMultipleJobSelection, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Command="{x:Bind ViewModel.SelectAllJobsCommand}"
                  Content="Select All"
                  FontSize="{StaticResource VSQ.FontSize.Caption}"
                  Padding="8,4"
                  AutomationProperties.AutomationId="EnsembleSynthesisView_SelectAllJobsButton"/>
          <Button Command="{x:Bind ViewModel.ClearJobSelectionCommand}"
                  Content="Clear"
                  FontSize="{StaticResource VSQ.FontSize.Caption}"
                  Padding="8,4"
                  AutomationProperties.AutomationId="EnsembleSynthesisView_ClearSelectionButton"/>
          <Button Command="{x:Bind ViewModel.DeleteSelectedJobsCommand}"
                  FontSize="{StaticResource VSQ.FontSize.Caption}"
                  Padding="8,4"
                  ToolTipService.ToolTip="Delete Selected Jobs"
                  AutomationProperties.AutomationId="EnsembleSynthesisView_DeleteSelectedJobsButton">
            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource VSQ.Error.Brush}"/>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Jobs ListView -->
      <ListView x:Name="JobsListView" Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
                SelectionMode="Single"
                RightTapped="Job_RightTapped"
                Background="Transparent"
                AutomationProperties.AutomationId="EnsembleSynthesisView_JobsListView">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8" Margin="0,2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <!-- Status Indicator -->
              <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Fill="{StaticResource VSQ.Accent.CyanBrush}"/>

              <!-- Job Info -->
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding JobId}" 
                           FontSize="{StaticResource VSQ.FontSize.Body}"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding VoicesDisplay}"
                             FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Text="{Binding Status}"
                             FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                </StackPanel>
              </StackPanel>

              <!-- Progress -->
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="12,0"
                          VerticalAlignment="Center">
                <ProgressBar Value="{Binding Progress}"
                             Maximum="1"
                             Width="80" Height="4"
                             Foreground="{StaticResource VSQ.Progress.ForegroundBrush}"/>
                <TextBlock Text="{Binding ProgressDisplay}"
                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           MinWidth="40"/>
              </StackPanel>

              <!-- Created Time -->
              <TextBlock Grid.Column="3" Text="{Binding Created}"
                         FontSize="{StaticResource VSQ.FontSize.Caption}"
                         Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                         VerticalAlignment="Center" Margin="8,0"/>

              <!-- Delete Button -->
              <Button Grid.Column="4"
                      Command="{Binding DataContext.DeleteJobCommand, ElementName=EnsembleSynthesisView_Root}"
                      CommandParameter="{Binding}"
                      Background="Transparent"
                      Padding="8,4"
                      ToolTipService.ToolTip="Delete Job"
                      AutomationProperties.AutomationId="EnsembleSynthesisView_DeleteJobButton">
                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
              </Button>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="4" 
          Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Loading...'}"
                   Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <!-- Error Message -->
    <InfoBar Grid.Row="0" Grid.RowSpan="4"
             IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBooleanConverter}}"
             Severity="Error"
             Title="Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
             VerticalAlignment="Top"
             Margin="16"
             AutomationProperties.AutomationId="EnsembleSynthesisView_ErrorInfoBar"/>

    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="4"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="EnsembleSynthesisView_HelpOverlay"/>
  </Grid>
</UserControl>
