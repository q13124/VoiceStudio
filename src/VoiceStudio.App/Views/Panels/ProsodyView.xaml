<UserControl x:Class="VoiceStudio.App.Views.Panels.ProsodyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:ProsodyView">
    <Grid AutomationProperties.AutomationId="ProsodyView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <FontIcon AutomationProperties.AutomationId="Prosody_HeaderIcon"
                              Glyph="&#xEFA9;"
                              FontSize="20"
                              Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="Prosody &amp; Phoneme Control"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button AutomationProperties.AutomationId="Prosody_LoadConfigsBtn"
                            Command="{x:Bind ViewModel.LoadConfigsCommand}"
                            ToolTipService.ToolTip="Load configurations">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="Prosody_RefreshBtn"
                            Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="Prosody_HelpBtn"
                            Click="HelpButton_Click"
                            ToolTipService.ToolTip="Help">
                        <FontIcon Glyph="&#xE897;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Configuration Editor -->
            <ScrollViewer Grid.Column="0" Margin="0,0,8,0">
                <StackPanel Spacing="12">

                    <!-- Saved Configurations -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Saved Configurations"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <ListView AutomationProperties.AutomationId="Prosody_ConfigsList"
                                      ItemsSource="{x:Bind ViewModel.Configs, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedConfig, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      MaxHeight="160"
                                      RightTapped="Config_RightTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProsodyConfigItem">
                                        <Grid Padding="8,6" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Name, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind PitchDisplay, Mode=OneWay}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind RateDisplay, Mode=OneWay}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind VolumeDisplay, Mode=OneWay}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Configuration Editor -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Configuration Editor"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <TextBox AutomationProperties.AutomationId="Prosody_ConfigNameInput"
                                     Header="Configuration Name"
                                     Text="{x:Bind ViewModel.ConfigName, Mode=TwoWay}"
                                     PlaceholderText="Enter config name..." />

                            <!-- Pitch -->
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pitch"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                               FontSize="12">
                                        <Run Text="{x:Bind ViewModel.Pitch, Mode=OneWay}" />
                                        <Run Text="x" />
                                    </TextBlock>
                                </Grid>
                                <Slider AutomationProperties.AutomationId="Prosody_PitchSlider"
                                        Value="{x:Bind ViewModel.Pitch, Mode=TwoWay}"
                                        Minimum="0.5" Maximum="2.0" StepFrequency="0.05" />
                            </StackPanel>

                            <!-- Rate -->
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rate"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                               FontSize="12">
                                        <Run Text="{x:Bind ViewModel.Rate, Mode=OneWay}" />
                                        <Run Text="x" />
                                    </TextBlock>
                                </Grid>
                                <Slider AutomationProperties.AutomationId="Prosody_RateSlider"
                                        Value="{x:Bind ViewModel.Rate, Mode=TwoWay}"
                                        Minimum="0.25" Maximum="4.0" StepFrequency="0.05" />
                            </StackPanel>

                            <!-- Volume -->
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Volume"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                               FontSize="12">
                                        <Run Text="{x:Bind ViewModel.Volume, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                                <Slider AutomationProperties.AutomationId="Prosody_VolumeSlider"
                                        Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                        Minimum="0" Maximum="1.0" StepFrequency="0.05" />
                            </StackPanel>

                            <!-- Intonation -->
                            <ComboBox AutomationProperties.AutomationId="Prosody_IntonationCombo"
                                      Header="Intonation Pattern"
                                      ItemsSource="{x:Bind ViewModel.AvailableIntonations, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.Intonation, Mode=TwoWay}"
                                      PlaceholderText="Select intonation..."
                                      HorizontalAlignment="Stretch" />

                            <!-- Config Actions -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button AutomationProperties.AutomationId="Prosody_CreateConfigBtn"
                                        Content="Create"
                                        Command="{x:Bind ViewModel.CreateConfigCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <Button AutomationProperties.AutomationId="Prosody_UpdateConfigBtn"
                                        Content="Update"
                                        Command="{x:Bind ViewModel.UpdateConfigCommand}" />
                                <Button AutomationProperties.AutomationId="Prosody_DeleteConfigBtn"
                                        Content="Delete"
                                        Command="{x:Bind ViewModel.DeleteConfigCommand}" />
                                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Phoneme Analysis + Apply -->
            <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                <StackPanel Spacing="12">

                    <!-- Voice & Engine Selection -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Voice &amp; Engine"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <ComboBox AutomationProperties.AutomationId="Prosody_VoiceProfileCombo"
                                      Header="Voice Profile"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedVoiceProfileId, Mode=TwoWay}"
                                      PlaceholderText="Select voice profile..."
                                      HorizontalAlignment="Stretch" />

                            <ComboBox AutomationProperties.AutomationId="Prosody_EngineCombo"
                                      Header="Engine"
                                      ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                                      PlaceholderText="Select engine..."
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <!-- Phoneme Analysis -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Phoneme Analysis"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <TextBox AutomationProperties.AutomationId="Prosody_InputTextBox"
                                     Header="Input Text"
                                     Text="{x:Bind ViewModel.InputText, Mode=TwoWay}"
                                     PlaceholderText="Enter text for phoneme analysis..."
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="60" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button AutomationProperties.AutomationId="Prosody_AnalyzePhonemesBtn"
                                        Content="Analyze Phonemes"
                                        Command="{x:Bind ViewModel.AnalyzePhonemesCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center" />
                            </StackPanel>

                            <ListView AutomationProperties.AutomationId="Prosody_PhonemesList"
                                      ItemsSource="{x:Bind ViewModel.Phonemes, Mode=OneWay}"
                                      SelectionMode="None"
                                      MaxHeight="180">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PhonemeItem">
                                        <Grid Padding="8,4" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE8D6;"
                                                      FontSize="12"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Phoneme, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind TimingDisplay, Mode=OneWay}"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Apply Prosody -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Apply to Synthesis"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <TextBlock Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap">
                                Select a config, voice profile, and enter text, then apply prosody settings to generate styled speech.
                            </TextBlock>

                            <Button AutomationProperties.AutomationId="Prosody_ApplyBtn"
                                    Content="Apply Prosody"
                                    Command="{x:Bind ViewModel.ApplyProsodyCommand}"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing Grid.Column="0"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="16" Height="16"
                              Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="#80000000"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <ProgressRing IsActive="True" Width="32" Height="32" />
                <TextBlock Text="Processing..." Foreground="White" />
            </StackPanel>
        </Grid>

        <controls:HelpOverlay x:Name="HelpOverlay"
                              Grid.RowSpan="3"
                              IsVisible="False"
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
