<UserControl x:Class="VoiceStudio.App.Views.Panels.DeepfakeCreatorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:DeepfakeCreatorView">

  <Grid AutomationProperties.AutomationId="DeepfakeCreatorView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8B3;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Deepfake Creator" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="DeepfakeCreatorView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="DeepfakeCreatorView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Source Face Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE77B;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Source Face" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True"
                   Text="{x:Bind ViewModel.SourceFaceFilePath, Mode=OneWay, FallbackValue='No file selected', TargetNullValue='No file selected'}"
                   PlaceholderText="Select source face image..."
                   AutomationProperties.AutomationId="DeepfakeCreatorView_SourceFaceDisplay"/>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                  Click="BrowseSourceFaceButton_Click"
                  AutomationProperties.AutomationId="DeepfakeCreatorView_BrowseSourceButton"
                  ToolTipService.ToolTip="Browse source face image">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Target Media Selection -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8B3;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Target Media" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True"
                   Text="{x:Bind ViewModel.TargetMediaFilePath, Mode=OneWay, FallbackValue='No file selected', TargetNullValue='No file selected'}"
                   PlaceholderText="Select target image or video..."
                   AutomationProperties.AutomationId="DeepfakeCreatorView_TargetMediaDisplay"/>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                  Click="BrowseTargetMediaButton_Click"
                  AutomationProperties.AutomationId="DeepfakeCreatorView_BrowseTargetButton"
                  ToolTipService.ToolTip="Browse target media file">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Settings -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12" RowSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <ComboBox Grid.Column="0" Grid.Row="0" Header="Engine"
                    ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="DeepfakeCreatorView_EngineSelector"/>
          <ComboBox Grid.Column="1" Grid.Row="0" Header="Media Type"
                    ItemsSource="{x:Bind ViewModel.AvailableMediaTypes}"
                    SelectedItem="{x:Bind ViewModel.SelectedMediaType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="DeepfakeCreatorView_MediaTypeSelector"/>
          <ComboBox Grid.Column="2" Grid.Row="0" Header="Quality"
                    ItemsSource="{x:Bind ViewModel.AvailableQualities}"
                    SelectedItem="{x:Bind ViewModel.SelectedQuality, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="DeepfakeCreatorView_QualitySelector"/>

          <CheckBox Grid.Column="0" Grid.Row="1"
                    Content="I have consent from all parties"
                    IsChecked="{x:Bind ViewModel.ConsentGiven, Mode=TwoWay}"
                    AutomationProperties.AutomationId="DeepfakeCreatorView_ConsentCheckBox"/>
          <CheckBox Grid.Column="1" Grid.Row="1"
                    Content="Apply watermark"
                    IsChecked="{x:Bind ViewModel.ApplyWatermark, Mode=TwoWay}"
                    AutomationProperties.AutomationId="DeepfakeCreatorView_WatermarkCheckBox"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Create Action -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.CreateDeepfakeCommand}"
                  AutomationProperties.AutomationId="DeepfakeCreatorView_CreateButton"
                  ToolTipService.ToolTip="Create deepfake (Ctrl+C)">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE8B3;" FontSize="16"/>
              <TextBlock Text="Create Deepfake" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Command="{x:Bind ViewModel.DeleteJobCommand}"
                  AutomationProperties.AutomationId="DeepfakeCreatorView_DeleteJobButton"
                  ToolTipService.ToolTip="Delete selected job">
            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
          </Button>
        </Grid>

        <ProgressBar Value="{x:Bind ViewModel.UploadProgress, Mode=OneWay}"
                     Maximum="100" Minimum="0"
                     Visibility="{x:Bind ViewModel.IsUploading, Mode=OneWay}"
                     AutomationProperties.AutomationId="DeepfakeCreatorView_UploadProgress"/>

        <ProgressBar IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                     AutomationProperties.AutomationId="DeepfakeCreatorView_ProcessingProgress"/>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                   FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Jobs List -->
    <Border Grid.Row="5" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8A7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Jobs" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.DeepfakeJobs, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
                  RightTapped="Job_RightTapped"
                  AutomationProperties.AutomationId="DeepfakeCreatorView_JobList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:DeepfakeJobItem">
              <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE8B3;" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{x:Bind JobId}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                  <TextBlock Text="{x:Bind ConsentDisplay}" FontSize="11" Opacity="0.7"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{x:Bind ProgressDisplay}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Grid.Column="3" Text="{x:Bind Status}" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.7"/>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Error display -->
    <TextBlock Grid.Row="6"
               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
               FontSize="12" Foreground="IndianRed" TextWrapping="Wrap"
               AutomationProperties.AutomationId="DeepfakeCreatorView_ErrorText"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="7" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="7"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="DeepfakeCreatorView_LoadingOverlay"/>
  </Grid>
</UserControl>
