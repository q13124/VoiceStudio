<UserControl x:Class="VoiceStudio.App.Views.Panels.QualityDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:QualityDashboardView">
    <Grid x:Name="QualityDashboardView_Root" 
          AutomationProperties.AutomationId="QualityDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quality Dashboard" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="QualityDashboardView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <TextBlock Text="{x:Bind ViewModel.DashboardStatusMessage, Mode=OneWay}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" TextWrapping="Wrap"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="MOS Score" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Overview.AverageMosScoreDisplay, Mode=OneWay, FallbackValue='--'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="QualityDashboardView_MosScore"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Similarity" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Overview.AverageSimilarityDisplay, Mode=OneWay, FallbackValue='--'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="QualityDashboardView_Similarity"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Naturalness" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Overview.AverageNaturalnessDisplay, Mode=OneWay, FallbackValue='--'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="QualityDashboardView_Naturalness"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Total Samples" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Overview.TotalSamples, Mode=OneWay, FallbackValue='0'}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="QualityDashboardView_TotalSamples"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.AvailableTimeRanges, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedTimeRange, Mode=TwoWay}"
                                      PlaceholderText="Time Range" MinWidth="100"
                                      AutomationProperties.AutomationId="QualityDashboardView_TimeRange"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Bind ViewModel.AvailableVisualizationTypes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedVisualizationType, Mode=TwoWay}"
                                      PlaceholderText="Viz Type" MinWidth="120" Margin="8,0,0,0"
                                      AutomationProperties.AutomationId="QualityDashboardView_VizType"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quality Presets" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.QualityPresets, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                                  MaxHeight="200"
                                  AutomationProperties.AutomationId="QualityDashboardView_PresetList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TargetMetricsDisplay}" FontSize="11" Opacity="0.6"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quality Trends" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.QualityTrends, Mode=OneWay}"
                                  MaxHeight="200"
                                  AutomationProperties.AutomationId="QualityDashboardView_TrendsList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding MosScoreDisplay}" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SimilarityDisplay}" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding NaturalnessDisplay}" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
