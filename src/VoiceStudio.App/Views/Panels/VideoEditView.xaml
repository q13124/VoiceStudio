<UserControl x:Class="VoiceStudio.App.Views.Panels.VideoEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:VideoEditView">

  <Grid AutomationProperties.AutomationId="VideoEditView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8B1;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Video Editor" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <Button Grid.Column="1"
              Click="HelpButton_Click"
              AutomationProperties.AutomationId="VideoEditView_HelpButton"
              ToolTipService.ToolTip="Help">
        <FontIcon Glyph="&#xE897;" FontSize="14"/>
      </Button>
    </Grid>

    <!-- Video File Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Video File" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True"
                   Text="{x:Bind ViewModel.SelectedVideoPath, Mode=OneWay, FallbackValue='No video selected', TargetNullValue='No video selected'}"
                   PlaceholderText="Select a video file..."
                   RightTapped="VideoPath_RightTapped"
                   AutomationProperties.AutomationId="VideoEditView_VideoPathDisplay"/>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                  Command="{x:Bind ViewModel.SelectVideoCommand}"
                  AutomationProperties.AutomationId="VideoEditView_SelectVideoButton"
                  ToolTipService.ToolTip="Select video file (Ctrl+O)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
            <Run Text="Duration: "/>
            <Run Text="{x:Bind ViewModel.VideoDuration, Mode=OneWay}"/>
            <Run Text="s"/>
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Trim Controls -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE78A;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Trim / Split" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="16" RowSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <NumberBox Grid.Column="0" Header="Start Time (s)"
                     Value="{x:Bind ViewModel.TrimStart, Mode=TwoWay}"
                     Minimum="0" SmallChange="0.5" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoEditView_TrimStartInput"/>
          <NumberBox Grid.Column="1" Header="End Time (s)"
                     Value="{x:Bind ViewModel.TrimEnd, Mode=TwoWay}"
                     Minimum="0" SmallChange="0.5" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoEditView_TrimEndInput"/>
        </Grid>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.TrimCommand}"
                  AutomationProperties.AutomationId="VideoEditView_TrimButton"
                  ToolTipService.ToolTip="Trim video (Ctrl+T)">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE78A;" FontSize="14"/>
              <TextBlock Text="Trim"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.SplitCommand}"
                  AutomationProperties.AutomationId="VideoEditView_SplitButton"
                  ToolTipService.ToolTip="Split video at start time (Ctrl+S)">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xF138;" FontSize="14"/>
              <TextBlock Text="Split"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Effects & Transitions -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE2B1;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Effects &amp; Transitions" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12" RowSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <ComboBox Grid.Column="0" Grid.Row="0" Header="Effect"
                    ItemsSource="{x:Bind ViewModel.Effects}"
                    SelectedItem="{x:Bind ViewModel.SelectedEffect, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoEditView_EffectSelector"/>
          <Button Grid.Column="1" Grid.Row="0" VerticalAlignment="Bottom"
                  Command="{x:Bind ViewModel.ApplyEffectCommand}"
                  AutomationProperties.AutomationId="VideoEditView_ApplyEffectButton"
                  ToolTipService.ToolTip="Apply selected effect">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE73E;" FontSize="14"/>
              <TextBlock Text="Apply"/>
            </StackPanel>
          </Button>

          <ComboBox Grid.Column="0" Grid.Row="1" Header="Transition"
                    ItemsSource="{x:Bind ViewModel.Transitions}"
                    SelectedItem="{x:Bind ViewModel.SelectedTransition, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoEditView_TransitionSelector"/>
          <Button Grid.Column="1" Grid.Row="1" VerticalAlignment="Bottom"
                  Command="{x:Bind ViewModel.ApplyTransitionCommand}"
                  AutomationProperties.AutomationId="VideoEditView_ApplyTransitionButton"
                  ToolTipService.ToolTip="Apply selected transition">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE73E;" FontSize="14"/>
              <TextBlock Text="Apply"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Export -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xEDE1;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Export" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" Header="Format"
                    ItemsSource="{x:Bind ViewModel.ExportFormats}"
                    SelectedItem="{x:Bind ViewModel.ExportFormat, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoEditView_ExportFormatSelector"/>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
              <Run Text="Quality: "/>
              <Run Text="{x:Bind ViewModel.ExportQuality, Mode=OneWay}"/>
              <Run Text="/10"/>
            </TextBlock>
            <Slider Value="{x:Bind ViewModel.ExportQuality, Mode=TwoWay}"
                    Minimum="1" Maximum="10" StepFrequency="1"
                    AutomationProperties.AutomationId="VideoEditView_QualitySlider"/>
          </StackPanel>
        </Grid>

        <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExportCommand}"
                AutomationProperties.AutomationId="VideoEditView_ExportButton"
                ToolTipService.ToolTip="Export video (Ctrl+E)">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
            <TextBlock Text="Export" FontSize="14" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Status -->
    <StackPanel Grid.Row="5" Spacing="4" VerticalAlignment="Bottom">
      <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                   AutomationProperties.AutomationId="VideoEditView_ProgressBar"/>
      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 FontSize="12" Foreground="IndianRed" TextWrapping="Wrap"
                 AutomationProperties.AutomationId="VideoEditView_ErrorText"/>
    </StackPanel>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="VideoEditView_LoadingOverlay"/>
  </Grid>
</UserControl>
