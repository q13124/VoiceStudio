<UserControl x:Class="VoiceStudio.App.Views.Panels.MultiVoiceGeneratorView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:MultiVoiceGeneratorView">

  <Grid AutomationProperties.AutomationId="MultiVoiceGeneratorView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE902;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Multi-Voice Generator" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="MultiVoiceGeneratorView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="MultiVoiceGeneratorView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Add to Queue -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Add to Queue" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="8" RowSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
            <TextBlock Text="Profile ID" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBox Text="{x:Bind ViewModel.NewItemProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Enter profile ID"
                     AutomationProperties.AutomationId="MultiVoiceGeneratorView_ProfileIdTextBox"/>
          </StackPanel>

          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
            <TextBlock Text="Engine" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.NewItemEngine, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="MultiVoiceGeneratorView_EngineComboBox"/>
          </StackPanel>

          <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4">
            <TextBlock Text="Text" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBox Text="{x:Bind ViewModel.NewItemText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Enter text to synthesize"
                     AutomationProperties.AutomationId="MultiVoiceGeneratorView_TextTextBox"
                     TextWrapping="Wrap" MinHeight="48"/>
          </StackPanel>

          <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
            <TextBlock Text="Quality" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.QualityModes, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.NewItemQualityMode, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="MultiVoiceGeneratorView_QualityComboBox"/>
          </StackPanel>

          <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Orientation="Horizontal" VerticalAlignment="Bottom">
            <Button Style="{StaticResource VSQ.Button.Primary}"
                    Command="{x:Bind ViewModel.AddToQueueCommand}"
                    AutomationProperties.AutomationId="MultiVoiceGeneratorView_AddButton"
                    ToolTipService.ToolTip="Add to queue (Ctrl+A)">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                <TextBlock Text="Add"/>
              </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.ImportCSVCommand}"
                    AutomationProperties.AutomationId="MultiVoiceGeneratorView_ImportCSVButton"
                    ToolTipService.ToolTip="Import CSV (Ctrl+I)">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                <TextBlock Text="Import CSV"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Generation Queue -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8CB;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Queue" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.TertiaryBrush}" VerticalAlignment="Center">
            <Run Text="("/>
            <Run Text="{x:Bind ViewModel.GenerationQueue.Count, Mode=OneWay}"/>
            <Run Text=" items)"/>
          </TextBlock>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.GenerationQueue, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedQueueItem, Mode=TwoWay}"
                  RightTapped="QueueItem_RightTapped"
                  AutomationProperties.AutomationId="MultiVoiceGeneratorView_QueueListView"
                  SelectionMode="Single">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE768;" FontSize="12" VerticalAlignment="Center"
                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Command="{x:Bind ViewModel.RemoveFromQueueCommand}"
                  AutomationProperties.AutomationId="MultiVoiceGeneratorView_RemoveButton"
                  ToolTipService.ToolTip="Remove selected">
            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
          </Button>
          <Button Command="{x:Bind ViewModel.ClearQueueCommand}"
                  AutomationProperties.AutomationId="MultiVoiceGeneratorView_ClearButton"
                  ToolTipService.ToolTip="Clear queue">
            <FontIcon Glyph="&#xE894;" FontSize="14"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Style="{StaticResource VSQ.Button.Primary}"
              Command="{x:Bind ViewModel.StartGenerationCommand}"
              AutomationProperties.AutomationId="MultiVoiceGeneratorView_StartButton"
              ToolTipService.ToolTip="Start generation (Ctrl+S)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE768;" FontSize="14"/>
          <TextBlock Text="Generate"/>
        </StackPanel>
      </Button>
      <Button Command="{x:Bind ViewModel.ExportCSVCommand}"
              AutomationProperties.AutomationId="MultiVoiceGeneratorView_ExportCSVButton"
              ToolTipService.ToolTip="Export results CSV (Ctrl+E)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
          <TextBlock Text="Export CSV"/>
        </StackPanel>
      </Button>
      <Button Command="{x:Bind ViewModel.CompareVoicesCommand}"
              AutomationProperties.AutomationId="MultiVoiceGeneratorView_CompareButton"
              ToolTipService.ToolTip="Compare voices">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE9D5;" FontSize="14"/>
          <TextBlock Text="Compare"/>
        </StackPanel>
      </Button>
      <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="24" Height="24" Margin="8,0,0,0"/>
      <TextBlock Text="{x:Bind ViewModel.JobStatus, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 VerticalAlignment="Center" FontSize="12"
                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="4,0,0,0"/>
      <ProgressBar Value="{x:Bind ViewModel.JobProgress, Mode=OneWay}"
                   Maximum="1.0" Minimum="0.0" Width="120"
                   Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                   VerticalAlignment="Center" Margin="4,0,0,0"/>
    </StackPanel>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="MultiVoiceGeneratorView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Multi-Voice Generator Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="MultiVoiceGeneratorView_LoadingOverlay"/>
  </Grid>
</UserControl>
