<UserControl x:Class="VoiceStudio.App.Views.Panels.StyleTransferView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:converters="using:VoiceStudio.App.Converters"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:StyleTransferView">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:NullToVisibilityConverter x:Key="NullToVis"/>
  </UserControl.Resources>

  <Grid x:Name="StyleTransferView_Root"
        AutomationProperties.AutomationId="StyleTransferView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="200"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Style Transfer"
                 FontSize="{StaticResource VSQ.FontSize.Title}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.CreateTransferCommand}"
                Style="{StaticResource AccentButtonStyle}"
                AutomationProperties.AutomationId="StyleTransferView_TransferButton"
                ToolTipService.ToolTip="Start Transfer (Ctrl+T)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE768;" FontSize="14"/>
            <TextBlock Text="Transfer"/>
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="StyleTransferView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="StyleTransferView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Configuration -->
    <ScrollViewer Grid.Row="1" Padding="16,8">
      <StackPanel Spacing="12">

        <!-- Source & Target -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- Source Audio -->
          <Border Grid.Column="0"
                  Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Source Audio" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SourceAudioId, Mode=TwoWay}"
                        PlaceholderText="Select source audio..."
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="StyleTransferView_SourceAudioComboBox"/>
            </StackPanel>
          </Border>

          <!-- Target Style -->
          <Border Grid.Column="2"
                  Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Target Style Voice" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.TargetStyleId, Mode=TwoWay}"
                        PlaceholderText="Select target style..."
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="StyleTransferView_TargetStyleComboBox"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Style Presets -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Style Presets" FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <ItemsControl ItemsSource="{x:Bind ViewModel.StylePresets, Mode=OneWay}"
                          AutomationProperties.AutomationId="StyleTransferView_PresetsList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StyleTransferPresetItem">
                  <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                          CornerRadius="4" Padding="12,8"
                          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Body}"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}" FontWeight="SemiBold"/>
                      <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Transfer Settings -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Transfer Settings" FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <StackPanel Spacing="2">
              <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                <Run Text="Transfer Strength:"/><Run Text=" "/><Run Text="{x:Bind ViewModel.TransferStrength, Mode=OneWay}"/>
              </TextBlock>
              <Slider Value="{x:Bind ViewModel.TransferStrength, Mode=TwoWay}"
                      Minimum="0" Maximum="1" StepFrequency="0.05"
                      AutomationProperties.AutomationId="StyleTransferView_TransferStrengthSlider"/>
            </StackPanel>

            <ToggleSwitch IsOn="{x:Bind ViewModel.PreserveContent, Mode=TwoWay}"
                          OnContent="Preserve Content" OffContent="Preserve Content"
                          AutomationProperties.AutomationId="StyleTransferView_PreserveContentToggle"/>
            <ToggleSwitch IsOn="{x:Bind ViewModel.PreserveEmotion, Mode=TwoWay}"
                          OnContent="Preserve Emotion" OffContent="Preserve Emotion"
                          AutomationProperties.AutomationId="StyleTransferView_PreserveEmotionToggle"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Jobs Header -->
    <Grid Grid.Row="2" Padding="16,8"
          Background="{StaticResource VSQ.Panel.Background.DarkerBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Transfer Jobs"
                 FontSize="{StaticResource VSQ.FontSize.Body}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>
      <Button Grid.Column="1"
              Command="{x:Bind ViewModel.DeleteJobCommand}"
              ToolTipService.ToolTip="Delete Selected Job"
              AutomationProperties.AutomationId="StyleTransferView_DeleteJobButton">
        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource VSQ.Error.Brush}"/>
      </Button>
    </Grid>

    <!-- Jobs List -->
    <ListView Grid.Row="3"
              ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}"
              SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
              SelectionMode="Single"
              RightTapped="Job_RightTapped"
              Padding="16,0"
              AutomationProperties.AutomationId="StyleTransferView_JobsList">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:StyleTransferJobItem">
          <Grid Padding="8,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                     VerticalAlignment="Center"
                     Fill="{StaticResource VSQ.Accent.CyanBrush}"/>

            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="{x:Bind JobId, Mode=OneWay}"
                         FontSize="{StaticResource VSQ.FontSize.Body}"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind StatusDisplay, Mode=OneWay}"
                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                           Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="{x:Bind Created, Mode=OneWay}"
                           FontSize="{StaticResource VSQ.FontSize.Caption}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="12,0"
                        VerticalAlignment="Center">
              <ProgressBar Value="{x:Bind Progress, Mode=OneWay}" Maximum="1"
                           Width="80" Height="4"
                           Foreground="{StaticResource VSQ.Progress.ForegroundBrush}"/>
              <TextBlock Text="{x:Bind ProgressDisplay, Mode=OneWay}"
                         FontSize="{StaticResource VSQ.FontSize.Caption}"
                         Foreground="{StaticResource VSQ.Text.SecondaryBrush}" MinWidth="40"/>
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="4" Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Processing...'}"
                   Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="0" Grid.RowSpan="4"
             IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"
             Severity="Error" Title="Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
             VerticalAlignment="Top" Margin="16"
             AutomationProperties.AutomationId="StyleTransferView_ErrorInfoBar"/>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="4"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="StyleTransferView_HelpOverlay"/>
  </Grid>
</UserControl>
