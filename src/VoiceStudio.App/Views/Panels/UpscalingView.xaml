<UserControl x:Class="VoiceStudio.App.Views.Panels.UpscalingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:UpscalingView">

  <Grid AutomationProperties.AutomationId="UpscalingView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE740;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Upscaling" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="UpscalingView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="UpscalingView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- File Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="File Selection" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True"
                   Text="{x:Bind ViewModel.SelectedFilePath, Mode=OneWay, FallbackValue='No file selected', TargetNullValue='No file selected'}"
                   PlaceholderText="Select image or video to upscale..."
                   AutomationProperties.AutomationId="UpscalingView_FilePathDisplay"/>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                  Click="BrowseButton_Click"
                  AutomationProperties.AutomationId="UpscalingView_BrowseButton"
                  ToolTipService.ToolTip="Browse file (Ctrl+O)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Settings -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Upscaling Settings" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <ComboBox Grid.Column="0" Header="Engine"
                    ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="UpscalingView_EngineSelector"/>
          <ComboBox Grid.Column="1" Header="Media Type"
                    ItemsSource="{x:Bind ViewModel.AvailableMediaTypes}"
                    SelectedItem="{x:Bind ViewModel.SelectedMediaType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="UpscalingView_MediaTypeSelector"/>
          <ComboBox Grid.Column="2" Header="Scale Factor"
                    ItemsSource="{x:Bind ViewModel.AvailableScaleFactors, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedScaleFactor, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="UpscalingView_ScaleFactorSelector"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Upscale Action -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.UpscaleCommand}"
                  AutomationProperties.AutomationId="UpscalingView_UpscaleButton"
                  ToolTipService.ToolTip="Start upscaling (Ctrl+U)">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE740;" FontSize="16"/>
              <TextBlock Text="Upscale" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Command="{x:Bind ViewModel.DeleteJobCommand}"
                  AutomationProperties.AutomationId="UpscalingView_DeleteJobButton"
                  ToolTipService.ToolTip="Delete selected job">
            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
          </Button>
        </Grid>

        <ProgressBar Value="{x:Bind ViewModel.UploadProgress, Mode=OneWay}"
                     Maximum="100" Minimum="0"
                     Visibility="{x:Bind ViewModel.IsUploading, Mode=OneWay}"
                     AutomationProperties.AutomationId="UpscalingView_UploadProgress"/>

        <ProgressBar IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                     AutomationProperties.AutomationId="UpscalingView_ProcessingProgress"/>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                   FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Jobs List -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8A7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Upscaling Jobs" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.UpscalingJobs, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
                  RightTapped="Job_RightTapped"
                  AutomationProperties.AutomationId="UpscalingView_JobList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:UpscalingJobItem">
              <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE740;" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{x:Bind JobId}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                  <TextBlock Text="{x:Bind DimensionsDisplay}" FontSize="11" Opacity="0.7"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{x:Bind ProgressDisplay}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Grid.Column="3" Text="{x:Bind Status}" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.7"/>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Error display -->
    <TextBlock Grid.Row="5"
               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
               FontSize="12" Foreground="IndianRed" TextWrapping="Wrap"
               AutomationProperties.AutomationId="UpscalingView_ErrorText"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="UpscalingView_LoadingOverlay"/>
  </Grid>
</UserControl>
