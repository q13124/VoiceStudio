<UserControl x:Class="VoiceStudio.App.Views.Panels.MarkerManagerView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:MarkerManagerView">

  <Grid AutomationProperties.AutomationId="MarkerManagerView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xECAD;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Marker Manager" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="MarkerManagerView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="MarkerManagerView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Filters -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ComboBox Grid.Column="0" Header="Project" PlaceholderText="Select project" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.AvailableProjects, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                  AutomationProperties.AutomationId="MarkerManagerView_ProjectFilter"/>
        <ComboBox Grid.Column="1" Header="Category" PlaceholderText="All categories" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                  AutomationProperties.AutomationId="MarkerManagerView_CategoryFilter"/>
      </Grid>
    </Border>

    <!-- Marker List -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <ListView ItemsSource="{x:Bind ViewModel.Markers, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedMarker, Mode=TwoWay}"
                AutomationProperties.AutomationId="MarkerManagerView_MarkerList">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8,6" ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="4" CornerRadius="2"
                      Background="{StaticResource VSQ.Accent.CyanBrush}" VerticalAlignment="Stretch"/>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Category}" FontSize="11"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Text="{Binding Description}" FontSize="11" TextTrimming="CharacterEllipsis" MaxLines="1"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
              <Border Grid.Column="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                      CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                <TextBlock Text="{Binding TimeDisplay}" FontSize="12" FontFamily="Consolas"
                           Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
              </Border>
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Command="{Binding DataContext.UpdateMarkerCommand, ElementName=MarkerManagerView_MarkerList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Edit" Padding="6">
                  <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                </Button>
                <Button Command="{Binding DataContext.DeleteMarkerCommand, ElementName=MarkerManagerView_MarkerList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Delete" Padding="6">
                  <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                </Button>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Border>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Style="{StaticResource VSQ.Button.Primary}" Command="{x:Bind ViewModel.CreateMarkerCommand}"
              AutomationProperties.AutomationId="MarkerManagerView_CreateButton">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE710;" FontSize="14"/>
          <TextBlock Text="Add Marker"/>
        </StackPanel>
      </Button>
      <Button Command="{x:Bind ViewModel.SelectAllMarkersCommand}" Content="Select All"
              AutomationProperties.AutomationId="MarkerManagerView_SelectAllButton"/>
      <Button Command="{x:Bind ViewModel.DeleteSelectedMarkersCommand}"
              AutomationProperties.AutomationId="MarkerManagerView_DeleteSelectedButton">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE74D;" FontSize="14"/>
          <TextBlock>
            <Run Text="Delete"/>
            <Run Text="{x:Bind ViewModel.SelectedMarkerCount, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="MarkerManagerView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Marker Manager Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="MarkerManagerView_LoadingOverlay"/>
  </Grid>
</UserControl>
