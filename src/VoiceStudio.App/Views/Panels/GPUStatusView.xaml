<UserControl x:Class="VoiceStudio.App.Views.Panels.GPUStatusView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:GPUStatusView">
    <Grid x:Name="GPUStatusView_Root" 
          AutomationProperties.AutomationId="GPUStatusView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="GPU Status" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="GPUStatusView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Total Devices" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.TotalDevices, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="GPUStatusView_TotalDevices"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Available" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.AvailableDevices, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="GPUStatusView_AvailableDevices"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AutoRefresh, Mode=TwoWay}"
                                          Header="Auto-Refresh"
                                          AutomationProperties.AutomationId="GPUStatusView_AutoRefreshToggle"/>
                            <NumberBox Value="{x:Bind ViewModel.RefreshIntervalSeconds, Mode=TwoWay}"
                                       Header="Interval (s)" Minimum="1" Maximum="60" SpinButtonPlacementMode="Compact"
                                       AutomationProperties.AutomationId="GPUStatusView_RefreshInterval"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListView ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                          AutomationProperties.AutomationId="GPUStatusView_DeviceList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,4">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Vendor}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusDisplay}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Utilization: "/>
                                            <Run Text="{Binding UtilizationDisplay}"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding UtilizationPercent}" Maximum="100" Minimum="0"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Memory: "/>
                                            <Run Text="{Binding MemoryUsedDisplay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding MemoryTotalDisplay}"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding MemoryUsagePercent}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Temperature" FontSize="11" Opacity="0.6"/>
                                            <TextBlock Text="{Binding TemperatureDisplay}" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Power" FontSize="11" Opacity="0.6"/>
                                            <TextBlock Text="{Binding PowerDisplay}" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Driver" FontSize="11" Opacity="0.6"/>
                                            <TextBlock Text="{Binding DriverVersion}" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
