<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceBrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:VoiceBrowserView">
    <Grid x:Name="VoiceBrowserView_Root" 
          AutomationProperties.AutomationId="VoiceBrowserView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Voice Browser" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            AutomationProperties.AutomationId="VoiceBrowserView_RefreshButton"
                            ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Search &amp; Filters" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

                        <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search voices..."
                                 AutomationProperties.AutomationId="VoiceBrowserView_SearchBox"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Language" FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableLanguages, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                          PlaceholderText="All Languages" HorizontalAlignment="Stretch"
                                          AutomationProperties.AutomationId="VoiceBrowserView_LanguageFilter"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Gender" FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <ComboBox SelectedItem="{x:Bind ViewModel.SelectedGender, Mode=TwoWay}"
                                          PlaceholderText="All Genders" HorizontalAlignment="Stretch"
                                          AutomationProperties.AutomationId="VoiceBrowserView_GenderFilter">
                                    <ComboBoxItem Content="Male"/>
                                    <ComboBoxItem Content="Female"/>
                                    <ComboBoxItem Content="Neutral"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                <Run Text="Min Quality Score: "/>
                                <Run Text="{x:Bind ViewModel.MinQualityScore, Mode=OneWay}"/>
                            </TextBlock>
                            <Slider Minimum="0" Maximum="5" StepFrequency="0.1"
                                    Value="{x:Bind ViewModel.MinQualityScore, Mode=TwoWay}"
                                    AutomationProperties.AutomationId="VoiceBrowserView_QualitySlider"/>
                        </StackPanel>

                        <Button Command="{x:Bind ViewModel.SearchCommand}" Style="{StaticResource VSQ.Button.Primary}"
                                AutomationProperties.AutomationId="VoiceBrowserView_SearchButton">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE721;" FontSize="14"/>
                                <TextBlock Text="Search"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
                            <Run Text="Voices ("/>
                            <Run Text="{x:Bind ViewModel.TotalVoices, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>

                        <ListView ItemsSource="{x:Bind ViewModel.Voices, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedVoice, Mode=TwoWay}"
                                  MaxHeight="400"
                                  AutomationProperties.AutomationId="VoiceBrowserView_VoiceList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Language}" FontSize="11" Opacity="0.6"/>
                                                <TextBlock Text="{Binding Gender}" FontSize="11" Opacity="0.6"/>
                                                <TextBlock Text="{Binding SampleCountDisplay}" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding QualityScoreDisplay}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{x:Bind ViewModel.PreviousPageCommand}"
                                    AutomationProperties.AutomationId="VoiceBrowserView_PrevPage">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                <Run Text="Page "/>
                                <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Grid.Column="2" Command="{x:Bind ViewModel.NextPageCommand}"
                                    AutomationProperties.AutomationId="VoiceBrowserView_NextPage">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, TargetNullValue=Collapsed}"/>

                <InfoBar IsOpen="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Severity="Informational"
                         Title="Loading..." IsClosable="False"
                         AutomationProperties.AutomationId="VoiceBrowserView_LoadingBar"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
