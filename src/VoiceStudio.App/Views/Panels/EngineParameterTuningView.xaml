<UserControl x:Class="VoiceStudio.App.Views.Panels.EngineParameterTuningView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:EngineParameterTuningView">
    <Grid AutomationProperties.AutomationId="EngineParameterTuningView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" FontSize="20"/>
                    <TextBlock Text="Engine Parameter Tuning"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.ResetToDefaultsCommand}"
                            ToolTipService.ToolTip="Reset to defaults"
                            AutomationProperties.AutomationId="EngineParameterTuningView_ResetButton">
                        <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ApplyParametersCommand}"
                            ToolTipService.ToolTip="Apply parameters"
                            AutomationProperties.AutomationId="EngineParameterTuningView_ApplyButton">
                        <FontIcon Glyph="&#xE73E;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Engine Selection -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Engine" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="EngineParameterTuningView_EngineComboBox"/>
                        <TextBlock Text="Preset" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="0,8,0,0"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{x:Bind ViewModel.ParameterPresets, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="EngineParameterTuningView_PresetComboBox"/>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.SavePresetCommand}"
                                    Content="Save Preset"
                                    AutomationProperties.AutomationId="EngineParameterTuningView_SavePresetButton"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Quality Predictions -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quality Predictions" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="MOS Score" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.PredictedMosScore, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="EngineParameterTuningView_MosScore"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Similarity" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.PredictedSimilarity, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="EngineParameterTuningView_Similarity"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                                <TextBlock Text="Naturalness" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.PredictedNaturalness, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="EngineParameterTuningView_Naturalness"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock Text="SNR" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.PredictedSnr, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="EngineParameterTuningView_Snr"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Speed" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.EstimatedSpeed, Mode=OneWay}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Tradeoff" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.QualitySpeedTradeoff, Mode=OneWay}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Auto Optimize -->
                <Button Command="{x:Bind ViewModel.AutoOptimizeCommand}"
                        Content="Auto-Optimize Parameters"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="EngineParameterTuningView_AutoOptimizeButton"/>

                <!-- Parameter Impact -->
                <TextBlock Text="{x:Bind ViewModel.ParameterImpactSummary, Mode=OneWay}"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>

                <!-- Parameters List -->
                <ListView ItemsSource="{x:Bind ViewModel.Parameters, Mode=OneWay}"
                          SelectionMode="None"
                          AutomationProperties.AutomationId="EngineParameterTuningView_ParameterList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Click="ParameterInfo_Click" CommandParameter="{Binding}"
                                                ToolTipService.ToolTip="Parameter info" Padding="4">
                                            <FontIcon Glyph="&#xE946;" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                    <Slider Value="{Binding Value, Mode=TwoWay}"
                                            Minimum="{Binding MinValue}" Maximum="{Binding MaxValue}"
                                            StepFrequency="{Binding StepSize}"
                                            ValueChanged="ParameterValueChanged"
                                            IsEnabled="{Binding IsEnabled}"
                                            AutomationProperties.Name="{Binding Name}"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding MinValue}" FontSize="10" Opacity="0.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MaxValue}" FontSize="10" Opacity="0.5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="EngineParameterTuningView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
