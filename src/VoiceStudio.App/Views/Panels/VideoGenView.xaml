<UserControl x:Class="VoiceStudio.App.Views.Panels.VideoGenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:VideoGenView">

  <Grid AutomationProperties.AutomationId="VideoGenView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE714;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Video Generation" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Click="QualitySettings_Click"
                AutomationProperties.AutomationId="VideoGenView_QualitySettingsButton"
                ToolTipService.ToolTip="Quality Settings">
          <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="VideoGenView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Engine & Prompt -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Generation Settings" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" Header="Engine"
                    ItemsSource="{x:Bind ViewModel.Engines}"
                    SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoGenView_EngineSelector"/>
          <ComboBox Grid.Column="1" Header="Quality Preset"
                    ItemsSource="{x:Bind ViewModel.QualityPresets}"
                    SelectedItem="{x:Bind ViewModel.SelectedQualityPreset, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoGenView_QualityPresetSelector"/>
        </Grid>

        <TextBox Header="Prompt"
                 Text="{x:Bind ViewModel.Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Describe the video you want to generate..."
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                 AutomationProperties.AutomationId="VideoGenView_PromptTextBox"/>

        <!-- Image input (engine-dependent) -->
        <Grid Visibility="{x:Bind ViewModel.ShowImageInput, Mode=OneWay}" ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True" Header="Input Image"
                   Text="{x:Bind ViewModel.SelectedImagePath, Mode=OneWay, FallbackValue='No image selected', TargetNullValue='No image selected'}"
                   AutomationProperties.AutomationId="VideoGenView_ImagePathDisplay"/>
          <Button Grid.Column="1" VerticalAlignment="Bottom"
                  Command="{x:Bind ViewModel.SelectImageCommand}"
                  AutomationProperties.AutomationId="VideoGenView_SelectImageButton"
                  ToolTipService.ToolTip="Select input image">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xEB9F;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>

        <!-- Audio input (engine-dependent) -->
        <Grid Visibility="{x:Bind ViewModel.ShowAudioInput, Mode=OneWay}" ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True" Header="Input Audio"
                   Text="{x:Bind ViewModel.SelectedAudioPath, Mode=OneWay, FallbackValue='No audio selected', TargetNullValue='No audio selected'}"
                   AutomationProperties.AutomationId="VideoGenView_AudioPathDisplay"/>
          <Button Grid.Column="1" VerticalAlignment="Bottom"
                  Command="{x:Bind ViewModel.SelectAudioCommand}"
                  AutomationProperties.AutomationId="VideoGenView_SelectAudioButton"
                  ToolTipService.ToolTip="Select input audio">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE8D6;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Parameters -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Parameters" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="16" RowSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <NumberBox Grid.Column="0" Grid.Row="0" Header="Width"
                     Value="{x:Bind ViewModel.Width, Mode=TwoWay}"
                     Minimum="64" Maximum="2048" SmallChange="64" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_WidthInput"/>
          <NumberBox Grid.Column="1" Grid.Row="0" Header="Height"
                     Value="{x:Bind ViewModel.Height, Mode=TwoWay}"
                     Minimum="64" Maximum="2048" SmallChange="64" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_HeightInput"/>
          <NumberBox Grid.Column="2" Grid.Row="0" Header="FPS"
                     Value="{x:Bind ViewModel.Fps, Mode=TwoWay}"
                     Minimum="1" Maximum="60" SmallChange="1" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_FpsInput"/>
          <NumberBox Grid.Column="3" Grid.Row="0" Header="Duration (s)"
                     Value="{x:Bind ViewModel.Duration, Mode=TwoWay}"
                     Minimum="1" Maximum="120" SmallChange="1" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_DurationInput"/>

          <NumberBox Grid.Column="0" Grid.Row="1" Header="Steps"
                     Value="{x:Bind ViewModel.Steps, Mode=TwoWay}"
                     Minimum="1" Maximum="150" SmallChange="5" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_StepsInput"/>
          <NumberBox Grid.Column="1" Grid.Row="1" Header="CFG Scale"
                     Value="{x:Bind ViewModel.CfgScale, Mode=TwoWay}"
                     Minimum="1" Maximum="30" SmallChange="0.5" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_CfgScaleInput"/>
          <NumberBox Grid.Column="2" Grid.Row="1" Header="Bitrate (Mbps)"
                     Value="{x:Bind ViewModel.Bitrate, Mode=TwoWay}"
                     Minimum="1" Maximum="50" SmallChange="1" SpinButtonPlacementMode="Compact"
                     AutomationProperties.AutomationId="VideoGenView_BitrateInput"/>
          <ComboBox Grid.Column="3" Grid.Row="1" Header="Codec"
                    SelectedItem="{x:Bind ViewModel.Codec, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="VideoGenView_CodecSelector">
            <x:String>H.264</x:String>
            <x:String>H.265</x:String>
            <x:String>VP9</x:String>
            <x:String>AV1</x:String>
          </ComboBox>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Generate Actions -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.GenerateCommand}"
                  AutomationProperties.AutomationId="VideoGenView_GenerateButton"
                  ToolTipService.ToolTip="Generate video (Ctrl+Enter)">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE714;" FontSize="16"/>
              <TextBlock Text="Generate" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Command="{x:Bind ViewModel.UpscaleCommand}"
                  AutomationProperties.AutomationId="VideoGenView_UpscaleButton"
                  ToolTipService.ToolTip="Upscale selected video">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE740;" FontSize="14"/>
              <TextBlock Text="Upscale"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="2" Command="{x:Bind ViewModel.AutoOptimizeQualityCommand}"
                  AutomationProperties.AutomationId="VideoGenView_AutoOptimizeButton"
                  ToolTipService.ToolTip="Auto-optimize quality">
            <FontIcon Glyph="&#xE771;" FontSize="14"/>
          </Button>
        </Grid>

        <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                     AutomationProperties.AutomationId="VideoGenView_ProgressBar"/>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                   FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Generated Videos List -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8B2;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Generated Videos" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.GeneratedVideos}"
                  SelectedItem="{x:Bind ViewModel.SelectedVideo, Mode=TwoWay}"
                  RightTapped="Video_RightTapped"
                  AutomationProperties.AutomationId="VideoGenView_VideoList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:GeneratedVideo">
              <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE714;" FontSize="20" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{x:Bind Prompt}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                  <TextBlock FontSize="11" Opacity="0.7">
                    <Run Text="{x:Bind Engine}"/>
                    <Run Text=" &#x00B7; "/>
                    <Run Text="{x:Bind Width}"/>
                    <Run Text="&#x00D7;"/>
                    <Run Text="{x:Bind Height}"/>
                  </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Opacity="0.6">
                  <Run Text="{x:Bind Duration}"/>
                  <Run Text="s"/>
                </TextBlock>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Status -->
    <TextBlock Grid.Row="5"
               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
               FontSize="12" Foreground="IndianRed" TextWrapping="Wrap"
               AutomationProperties.AutomationId="VideoGenView_ErrorText"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="VideoGenView_LoadingOverlay"/>
  </Grid>
</UserControl>
