<UserControl x:Class="VoiceStudio.App.Views.Panels.TagManagerView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:TagManagerView">

  <Grid AutomationProperties.AutomationId="TagManagerView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8EC;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Tag Manager" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.LoadTagsCommand}"
                AutomationProperties.AutomationId="TagManagerView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="TagManagerView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Search & Filter -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search tags..."
                 AutomationProperties.AutomationId="TagManagerView_SearchBox"/>
        <ComboBox Header="Category" PlaceholderText="All categories" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                  AutomationProperties.AutomationId="TagManagerView_CategoryFilter"/>
      </StackPanel>
    </Border>

    <!-- Tag List -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <ListView ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedTag, Mode=TwoWay}"
                AutomationProperties.AutomationId="TagManagerView_TagList">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8,6" ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6"
                      Background="{StaticResource VSQ.Accent.CyanBrush}" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <TextBlock Text="{Binding Category}" FontSize="11"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              </StackPanel>
              <Border Grid.Column="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                      CornerRadius="8" Padding="6,2" VerticalAlignment="Center">
                <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="{Binding UsageCount}"/>
                  <Run Text="uses"/>
                </TextBlock>
              </Border>
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Command="{Binding DataContext.StartEditCommand, ElementName=TagManagerView_TagList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Edit" Padding="6">
                  <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                </Button>
                <Button Command="{Binding DataContext.DeleteTagCommand, ElementName=TagManagerView_TagList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Delete" Padding="6">
                  <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                </Button>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Border>

    <!-- Edit Panel -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8"
            Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay}">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE70F;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Edit Tag" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <TextBox Header="Name" Text="{x:Bind ViewModel.EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.AutomationId="TagManagerView_EditName"/>
        <TextBox Header="Category" Text="{x:Bind ViewModel.EditingCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.AutomationId="TagManagerView_EditCategory"/>
        <TextBox Header="Color" Text="{x:Bind ViewModel.EditingColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="#FF00FF00"
                 AutomationProperties.AutomationId="TagManagerView_EditColor"/>
        <TextBox Header="Description" Text="{x:Bind ViewModel.EditingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                 AutomationProperties.AutomationId="TagManagerView_EditDescription"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Style="{StaticResource VSQ.Button.Primary}" Command="{x:Bind ViewModel.SaveEditCommand}"
                  AutomationProperties.AutomationId="TagManagerView_SaveButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE74E;" FontSize="14"/>
              <TextBlock Text="Save"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.CancelEditCommand}"
                  AutomationProperties.AutomationId="TagManagerView_CancelButton">
            <TextBlock Text="Cancel"/>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Actions -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Style="{StaticResource VSQ.Button.Primary}" Command="{x:Bind ViewModel.CreateTagCommand}"
              AutomationProperties.AutomationId="TagManagerView_CreateButton">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE710;" FontSize="14"/>
          <TextBlock Text="New Tag"/>
        </StackPanel>
      </Button>
      <Button Command="{x:Bind ViewModel.SelectAllTagsCommand}" Content="Select All"
              AutomationProperties.AutomationId="TagManagerView_SelectAllButton"/>
      <Button Command="{x:Bind ViewModel.DeleteSelectedTagsCommand}"
              AutomationProperties.AutomationId="TagManagerView_DeleteSelectedButton">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE74D;" FontSize="14"/>
          <TextBlock>
            <Run Text="Delete"/>
            <Run Text="{x:Bind ViewModel.SelectedTagCount, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="5"
             AutomationProperties.AutomationId="TagManagerView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Tag Manager Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="TagManagerView_LoadingOverlay"/>
  </Grid>
</UserControl>
