<UserControl x:Class="VoiceStudio.App.Views.Panels.EmbeddingExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:EmbeddingExplorerView">

    <Grid AutomationProperties.AutomationId="EmbeddingExplorerView_Root" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE9D9;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Embedding Explorer" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="EmbeddingExplorerView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button Click="HelpButton_Click"
                        AutomationProperties.AutomationId="EmbeddingExplorerView_HelpButton"
                        ToolTipService.ToolTip="Help">
                    <FontIcon Glyph="&#xE897;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Extract Embedding Controls -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="Extract Embedding" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <ComboBox Header="Audio Source" PlaceholderText="Select audio file" HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SourceAudioId, Mode=TwoWay}"
                          AutomationProperties.AutomationId="EmbeddingExplorerView_AudioSelect"/>
                <ComboBox Header="Voice Profile (optional)" PlaceholderText="Select profile" HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedVoiceProfileId, Mode=TwoWay}"
                          AutomationProperties.AutomationId="EmbeddingExplorerView_ProfileSelect"/>
                <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ExtractEmbeddingCommand}"
                        AutomationProperties.AutomationId="EmbeddingExplorerView_ExtractButton">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                        <TextBlock Text="Extract Embedding"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Embeddings List -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Embeddings" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,8"/>
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Embeddings, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedEmbedding1, Mode=TwoWay}"
                          AutomationProperties.AutomationId="EmbeddingExplorerView_EmbeddingList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding EmbeddingId}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding VoiceProfileId}" FontSize="11"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DimensionDisplay}" FontSize="11"
                                                   Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Visualization Controls -->
        <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="Visualization &amp; Clustering" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Header="Method" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.AvailableVisualizationMethods, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.VisualizationMethod, Mode=TwoWay}"
                              AutomationProperties.AutomationId="EmbeddingExplorerView_MethodSelect"/>
                    <NumberBox Grid.Column="1" Header="Clusters" Value="{x:Bind ViewModel.NumClusters, Mode=TwoWay}"
                               Minimum="2" Maximum="20" SpinButtonPlacementMode="Compact"
                               AutomationProperties.AutomationId="EmbeddingExplorerView_ClusterCount"/>
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.VisualizeEmbeddingsCommand}"
                            AutomationProperties.AutomationId="EmbeddingExplorerView_VisualizeButton">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="12"/>
                            <TextBlock Text="Visualize"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.ClusterEmbeddingsCommand}"
                            AutomationProperties.AutomationId="EmbeddingExplorerView_ClusterButton">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE902;" FontSize="12"/>
                            <TextBlock Text="Cluster"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.CompareEmbeddingsCommand}"
                            AutomationProperties.AutomationId="EmbeddingExplorerView_CompareButton">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8F1;" FontSize="12"/>
                            <TextBlock Text="Compare"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Clusters Display -->
        <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="4">
                <TextBlock Text="Clusters" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,4"/>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Clusters, Mode=OneWay}"
                               AutomationProperties.AutomationId="EmbeddingExplorerView_ClusterList">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" Margin="0,2" CornerRadius="4"
                                    Background="{StaticResource VSQ.Panel.Background.DarkBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding ClusterId}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>

        <!-- Error / Export -->
        <StackPanel Grid.Row="5" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.ExportEmbeddingsCommand}"
                        AutomationProperties.AutomationId="EmbeddingExplorerView_ExportButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                        <TextBlock Text="Export"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.DeleteEmbeddingCommand}"
                        AutomationProperties.AutomationId="EmbeddingExplorerView_DeleteButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="Delete Selected"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <InfoBar AutomationProperties.AutomationId="EmbeddingExplorerView_ErrorInfoBar"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Embedding Explorer Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- HelpOverlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

        <!-- Loading Overlay -->
        <controls:LoadingOverlay Grid.RowSpan="6"
                                 IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                 AutomationProperties.AutomationId="EmbeddingExplorerView_LoadingOverlay"/>
    </Grid>
</UserControl>
