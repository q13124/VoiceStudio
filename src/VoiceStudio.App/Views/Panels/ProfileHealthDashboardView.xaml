<UserControl x:Class="VoiceStudio.App.Views.Panels.ProfileHealthDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:ProfileHealthDashboardView">
    <Grid x:Name="ProfileHealthDashboardView_Root" 
          AutomationProperties.AutomationId="ProfileHealthDashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Profile Health Dashboard" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.CheckSelectedProfileCommand}"
                            AutomationProperties.AutomationId="ProfileHealthDashboardView_CheckButton"
                            ToolTipService.ToolTip="Check selected profile">
                        <FontIcon Glyph="&#xE9D5;" FontSize="14"/>
                    </Button>
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            AutomationProperties.AutomationId="ProfileHealthDashboardView_RefreshButton"
                            ToolTipService.ToolTip="Refresh all">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Total" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalProfiles, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="ProfileHealthDashboardView_TotalCount"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Healthy" FontSize="11" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.HealthyProfiles, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="ProfileHealthDashboardView_HealthyCount"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Degraded" FontSize="11" Foreground="#FF9800" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.DegradedProfiles, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="ProfileHealthDashboardView_DegradedCount"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Critical" FontSize="11" Foreground="#F44336" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.CriticalProfiles, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"
                                       AutomationProperties.AutomationId="ProfileHealthDashboardView_CriticalCount"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Profiles" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                                  MaxHeight="400"
                                  AutomationProperties.AutomationId="ProfileHealthDashboardView_ProfileList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ProfileName}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Opacity="0.6">
                                                <Run Text="{Binding Language}"/>
                                                <Run Text=" | Trend: "/>
                                                <Run Text="{Binding Trend}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentQuality}" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding HealthStatusText}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Grid.Column="3" Width="12" Height="12" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Background="{Binding HealthStatusColor}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
