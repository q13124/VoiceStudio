<UserControl x:Class="VoiceStudio.App.Views.Panels.SonographyVisualizationView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:SonographyVisualizationView">
  <Grid AutomationProperties.AutomationId="SonographyVisualizationView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Sonography Visualization"
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="SonographyVisualizationView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Padding="16" Spacing="12">

        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Configuration" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedAudioId, Mode=TwoWay}"
                      Header="Audio File" PlaceholderText="Select audio..." HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="SonographyVisualizationView_AudioSelector"/>

            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ComboBox Grid.Column="0"
                        ItemsSource="{x:Bind ViewModel.AvailablePerspectives, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedPerspective, Mode=TwoWay}"
                        Header="Perspective" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="SonographyVisualizationView_Perspective"/>
              <ComboBox Grid.Column="1"
                        ItemsSource="{x:Bind ViewModel.AvailableColorSchemes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedColorScheme, Mode=TwoWay}"
                        Header="Color Scheme" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="SonographyVisualizationView_ColorScheme"/>
            </Grid>

            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <NumberBox Grid.Column="0" Value="{x:Bind ViewModel.FrequencyResolution, Mode=TwoWay}"
                         Header="Freq Resolution" Minimum="128" Maximum="8192"
                         SpinButtonPlacementMode="Compact"
                         AutomationProperties.AutomationId="SonographyVisualizationView_FreqRes"/>
              <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.TimeResolution, Mode=TwoWay}"
                         Header="Time Resolution" Minimum="10" Maximum="1000"
                         SpinButtonPlacementMode="Compact"
                         AutomationProperties.AutomationId="SonographyVisualizationView_TimeRes"/>
            </Grid>

            <StackPanel Spacing="4">
              <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                <Run Text="Time Window: "/>
                <Run Text="{x:Bind ViewModel.TimeWindow, Mode=OneWay}"/>
                <Run Text="s"/>
              </TextBlock>
              <Slider Minimum="0.1" Maximum="5.0" StepFrequency="0.1"
                      Value="{x:Bind ViewModel.TimeWindow, Mode=TwoWay}"
                      AutomationProperties.AutomationId="SonographyVisualizationView_TimeWindow"/>
            </StackPanel>

            <Button Command="{x:Bind ViewModel.GenerateSonographyCommand}"
                    Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="SonographyVisualizationView_GenerateButton">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
                <TextBlock Text="Generate Sonography" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" MinHeight="200">
          <StackPanel Spacing="8">
            <TextBlock Text="Sonograph Display" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
              <Run Text="Duration: "/>
              <Run Text="{x:Bind ViewModel.SonographyData.DurationDisplay, Mode=OneWay, FallbackValue='--'}"/>
              <Run Text=" | Frames: "/>
              <Run Text="{x:Bind ViewModel.SonographyData.FrameCountDisplay, Mode=OneWay, FallbackValue='--'}"/>
            </TextBlock>
            <Border Background="{StaticResource VSQ.Panel.Background}" CornerRadius="4"
                    MinHeight="200" Padding="8"
                    AutomationProperties.AutomationId="SonographyVisualizationView_DisplayArea">
              <TextBlock Text="Sonograph display - select audio and generate to view"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="12" Opacity="0.5"/>
            </Border>
          </StackPanel>
        </Border>

        <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
      </StackPanel>
    </ScrollViewer>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
