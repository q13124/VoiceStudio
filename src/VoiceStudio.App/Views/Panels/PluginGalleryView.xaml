<UserControl
    x:Class="VoiceStudio.App.Views.Panels.PluginGalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:models="using:VoiceStudio.Core.Plugins.Models"
    AutomationProperties.AutomationId="PluginGalleryView_Root">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Plugin Gallery"
                           FontSize="28"
                           FontWeight="SemiBold"
                           AutomationProperties.AutomationId="PluginGallery.Title"/>
                <TextBlock Text="Discover and install plugins to extend VoiceStudio"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <!-- GAP-B18: Migrated from Click handler to Command binding -->
                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="PluginGallery.Button.Refresh">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" Modifiers="None"/>
                    </Button.KeyboardAccelerators>
                </Button>
                <!-- GAP-B18: Migrated from Click handler to Command binding -->
                <Button x:Name="CheckUpdatesButton"
                        Content="Check Updates"
                        Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                        AutomationProperties.AutomationId="PluginGallery.Button.CheckUpdates"/>
            </StackPanel>
        </Grid>

        <!-- Search and Filters -->
        <Grid Grid.Row="1" Padding="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search plugins..."
                     TextChanged="SearchBox_TextChanged"
                     AutomationProperties.AutomationId="PluginGallery.TextBox.Search">
                <TextBox.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F" Modifiers="Control"/>
                </TextBox.KeyboardAccelerators>
            </TextBox>

            <!-- Category Filter -->
            <ComboBox x:Name="CategoryCombo"
                      Grid.Column="1"
                      PlaceholderText="Category"
                      Width="150"
                      Margin="12,0,0,0"
                      SelectionChanged="CategoryCombo_SelectionChanged"
                      AutomationProperties.AutomationId="PluginGallery.ComboBox.Category"/>

            <!-- Sort By -->
            <ComboBox x:Name="SortCombo"
                      Grid.Column="2"
                      Width="130"
                      Margin="12,0,0,0"
                      SelectionChanged="SortCombo_SelectionChanged"
                      AutomationProperties.AutomationId="PluginGallery.ComboBox.Sort">
                <ComboBoxItem Content="Popular" Tag="Popular"/>
                <ComboBoxItem Content="Rating" Tag="Rating"/>
                <ComboBoxItem Content="Recent" Tag="RecentlyUpdated"/>
                <ComboBoxItem Content="Name" Tag="Name"/>
                <ComboBoxItem Content="Newest" Tag="Newest"/>
            </ComboBox>

            <!-- Filter Toggles -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0" Spacing="12">
                <CheckBox x:Name="InstalledOnlyCheck"
                          Content="Installed"
                          Checked="FilterCheck_Changed"
                          Unchecked="FilterCheck_Changed"
                          AutomationProperties.AutomationId="PluginGallery.CheckBox.Installed"/>
                <CheckBox x:Name="UpdatesOnlyCheck"
                          Content="Updates"
                          Checked="FilterCheck_Changed"
                          Unchecked="FilterCheck_Changed"
                          AutomationProperties.AutomationId="PluginGallery.CheckBox.Updates"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <!-- Loading Indicator -->
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Width="60"
                          Height="60"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <!-- Plugin Grid -->
            <ScrollViewer x:Name="PluginScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,0">
                
                <StackPanel Spacing="24">
                    <!-- Featured Section -->
                    <StackPanel x:Name="FeaturedSection" Visibility="Visible">
                        <TextBlock Text="Featured Plugins"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        
                        <GridView x:Name="FeaturedGridView"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="FeaturedGridView_ItemClick"
                                  AutomationProperties.AutomationId="PluginGallery.GridView.Featured">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:PluginInfo">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Width="280"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Width="36" Height="36" CornerRadius="8" 
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                                    <FontIcon Glyph="&#xE74C;" FontSize="18" Foreground="White"/>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="{x:Bind Name}" 
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{x:Bind Author}" 
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{x:Bind Description}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       FontSize="13"
                                                       Margin="0,12,0,0"/>

                                            <!-- Stats -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                                                        Spacing="16" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE735;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GoldBrush}"/>
                                                    <TextBlock Text="{x:Bind Rating}" 
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Version}" 
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>

                    <!-- All Plugins Section -->
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="All Plugins"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="ResultCountText"
                                       HorizontalAlignment="Right"
                                       FontSize="14"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <GridView x:Name="PluginsGridView"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="PluginsGridView_ItemClick"
                                  AutomationProperties.AutomationId="PluginGallery.GridView.Plugins">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:PluginInfo">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Width="320"
                                            Padding="16"
                                            Margin="0,0,8,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="40" Height="40" CornerRadius="8" 
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                                    <FontIcon Glyph="&#xE74C;" FontSize="18" Foreground="White"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" 
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind Author}" 
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Visibility="{x:Bind IsVerified}"
                                                        Background="{StaticResource VSQ.Status.VerifiedBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <FontIcon Glyph="&#xE73E;" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{x:Bind Description}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       FontSize="13"
                                                       Margin="0,0,0,12"/>

                                            <!-- Footer -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" Spacing="16">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE735;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GoldBrush}"/>
                                                        <TextBlock Text="{x:Bind Rating}" 
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE896;" FontSize="12" 
                                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock Text="{x:Bind DownloadCount}" 
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Version}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <FontIcon Glyph="&#xE721;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="No plugins found"
                           FontSize="18"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <Button Content="Clear Filters" Click="ClearFilters_Click"/>
            </StackPanel>
        </Grid>

        <!-- Status Bar / Pagination -->
        <Border Grid.Row="3" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message -->
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           AutomationProperties.AutomationId="PluginGallery.StatusText"/>

                <!-- Pagination -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <!-- GAP-B18: Migrated from Click handler to Command binding -->
                    <Button x:Name="PrevPageButton"
                            Content="Previous"
                            Command="{x:Bind ViewModel.PreviousPageCommand}"
                            AutomationProperties.AutomationId="PluginGallery.Button.PrevPage"/>
                    <TextBlock x:Name="PageText"
                               Text="Page 1 of 1"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- GAP-B18: Migrated from Click handler to Command binding -->
                    <Button x:Name="NextPageButton"
                            Content="Next"
                            Command="{x:Bind ViewModel.NextPageCommand}"
                            AutomationProperties.AutomationId="PluginGallery.Button.NextPage"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Install Progress Overlay -->
        <Grid x:Name="InstallProgressOverlay"
              Grid.RowSpan="4"
              Visibility="Collapsed"
              Background="#80000000">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="32"
                    Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="InstallTitleText"
                               Text="Installing Plugin..."
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="InstallProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 AutomationProperties.AutomationId="PluginGallery.ProgressBar.Install"/>
                    <TextBlock x:Name="InstallStatusText"
                               Text="Preparing..."
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <!-- GAP-B18: Migrated from Click handler to Command binding -->
                    <Button Content="Cancel"
                            HorizontalAlignment="Center"
                            Command="{x:Bind ViewModel.CancelInstallCommand}"
                            AutomationProperties.AutomationId="PluginGallery.Button.CancelInstall"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
