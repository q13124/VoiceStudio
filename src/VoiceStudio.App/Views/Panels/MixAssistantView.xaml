<UserControl x:Class="VoiceStudio.App.Views.Panels.MixAssistantView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:MixAssistantView">

    <Grid x:Name="MixAssistantView_Root"
          AutomationProperties.AutomationId="MixAssistantView_Root"
          Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE9CE;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Mix Assistant" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="MixAssistantView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button Click="HelpButton_Click"
                        AutomationProperties.AutomationId="MixAssistantView_HelpButton"
                        ToolTipService.ToolTip="Help">
                    <FontIcon Glyph="&#xE897;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Project Selection -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="Project" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>

                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableProjects, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedProject, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Select a project..."
                          HorizontalAlignment="Stretch"
                          AutomationProperties.AutomationId="MixAssistantView_ProjectSelector"/>
            </StackPanel>
        </Border>

        <!-- Analysis Options -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="Analysis Options" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>

                <Grid ColumnSpacing="24" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Grid.Column="0" Content="Levels"
                              IsChecked="{x:Bind ViewModel.AnalyzeLevels, Mode=TwoWay}"
                              AutomationProperties.AutomationId="MixAssistantView_AnalyzeLevelsCheckBox"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" Content="Frequency"
                              IsChecked="{x:Bind ViewModel.AnalyzeFrequency, Mode=TwoWay}"
                              AutomationProperties.AutomationId="MixAssistantView_AnalyzeFrequencyCheckBox"/>
                    <CheckBox Grid.Row="1" Grid.Column="0" Content="Stereo"
                              IsChecked="{x:Bind ViewModel.AnalyzeStereo, Mode=TwoWay}"
                              AutomationProperties.AutomationId="MixAssistantView_AnalyzeStereoCheckBox"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Dynamics"
                              IsChecked="{x:Bind ViewModel.AnalyzeDynamics, Mode=TwoWay}"
                              AutomationProperties.AutomationId="MixAssistantView_AnalyzeDynamicsCheckBox"/>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Genre" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableGenres, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedGenre, Mode=TwoWay}"
                                  PlaceholderText="Select genre..."
                                  HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="MixAssistantView_GenreSelector"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Preset Name" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.PresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Name for preset..."
                                 AutomationProperties.AutomationId="MixAssistantView_PresetNameTextBox"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource VSQ.Button.Primary}"
                            Command="{x:Bind ViewModel.AnalyzeMixCommand}"
                            AutomationProperties.AutomationId="MixAssistantView_AnalyzeButton"
                            ToolTipService.ToolTip="Analyze mix (Ctrl+A)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
                            <TextBlock Text="Analyze"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.GeneratePresetCommand}"
                            AutomationProperties.AutomationId="MixAssistantView_GeneratePresetButton"
                            ToolTipService.ToolTip="Generate AI preset">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                            <TextBlock Text="Generate Preset"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Suggestions -->
        <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE82F;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
                        <TextBlock Text="Suggestions" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="("/>
                            <Run Text="{x:Bind ViewModel.Suggestions.Count, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{x:Bind ViewModel.ApplyAllSuggestionsCommand}"
                            AutomationProperties.AutomationId="MixAssistantView_ApplyAllButton"
                            ToolTipService.ToolTip="Apply all suggestions (Ctrl+Enter)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                            <TextBlock Text="Apply All" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Filters -->
                <Grid Grid.Row="1" Margin="0,0,0,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              PlaceholderText="Category"
                              HorizontalAlignment="Stretch"
                              AutomationProperties.AutomationId="MixAssistantView_CategoryFilter"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{x:Bind ViewModel.AvailablePriorities, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedPriority, Mode=TwoWay}"
                              PlaceholderText="Priority"
                              HorizontalAlignment="Stretch"
                              AutomationProperties.AutomationId="MixAssistantView_PriorityFilter"/>
                </Grid>

                <!-- Suggestions List -->
                <ListView Grid.Row="2"
                          ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSuggestion, Mode=TwoWay}"
                          SelectionMode="Single"
                          RightTapped="Suggestion_RightTapped"
                          AutomationProperties.AutomationId="MixAssistantView_SuggestionsList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource VSQ.Accent.CyanBrush}"
                                        CornerRadius="4" Padding="6,2" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"/>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                        <Run Text="Priority: "/>
                                        <Run Text="{Binding Priority}"/>
                                        <Run Text=" · Confidence: "/>
                                        <Run Text="{Binding ConfidenceDisplay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ValueChangeDisplay}" FontSize="11"
                                               Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                    <Button AutomationProperties.AutomationId="MixAssistantView_ApplySuggestionButton"
                                            ToolTipService.ToolTip="Apply" Padding="6">
                                        <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                                    </Button>
                                    <Button AutomationProperties.AutomationId="MixAssistantView_DismissSuggestionButton"
                                            ToolTipService.ToolTip="Dismiss" Padding="6">
                                        <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="2" Text="No suggestions yet. Select a project and click Analyze."
                           FontSize="13" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="4"
                 AutomationProperties.AutomationId="MixAssistantView_ErrorInfoBar"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error" Title="Mix Assistant Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
                 IsClosable="True"/>

        <!-- HelpOverlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

        <!-- Loading Overlay -->
        <controls:LoadingOverlay Grid.RowSpan="5"
                                 IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                 AutomationProperties.AutomationId="MixAssistantView_LoadingOverlay"/>
    </Grid>
</UserControl>
