<UserControl x:Class="VoiceStudio.App.Views.Panels.APIKeyManagerView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:APIKeyManagerView">

  <Grid AutomationProperties.AutomationId="APIKeyManagerView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8D7;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="API Key Manager" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="APIKeyManagerView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="APIKeyManagerView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Add New Key -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Add API Key" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <ComboBox Header="Service" PlaceholderText="Select service" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.SupportedServices, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.NewServiceName, Mode=TwoWay}"
                  IsEditable="True"
                  AutomationProperties.AutomationId="APIKeyManagerView_ServiceSelect"/>
        <PasswordBox Header="API Key" PlaceholderText="Enter API key"
                     Password="{x:Bind ViewModel.NewKeyValue, Mode=TwoWay}"
                     AutomationProperties.AutomationId="APIKeyManagerView_KeyInput"/>
        <TextBox Header="Description (optional)"
                 Text="{x:Bind ViewModel.NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="What is this key for?"
                 AutomationProperties.AutomationId="APIKeyManagerView_DescriptionInput"/>
        <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CreateKeyCommand}"
                AutomationProperties.AutomationId="APIKeyManagerView_AddButton">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="Add Key"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- API Key List -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <Grid>
        <ListView ItemsSource="{x:Bind ViewModel.ApiKeys, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedKey, Mode=TwoWay}"
                  AutomationProperties.AutomationId="APIKeyManagerView_KeyList">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="8,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Indicator -->
                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center">
                  <Border.Background>
                    <SolidColorBrush Color="{StaticResource VSQ.Accent.Green}"/>
                  </Border.Background>
                </Border>

                <!-- Key Info -->
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding ServiceName}" FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <TextBlock Text="{Binding KeyValueMasked}" FontSize="11" FontFamily="Consolas"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding StatusDisplay}" FontSize="10"
                               Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                      <Run Text="Used:"/>
                      <Run Text="{Binding UsageCount}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                      <Run Text="Last:"/>
                      <Run Text="{Binding LastUsedDisplay}"/>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Button Command="{Binding DataContext.ValidateKeyCommand, ElementName=APIKeyManagerView_KeyList}"
                          ToolTipService.ToolTip="Validate" Padding="6">
                    <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                  </Button>
                  <Button Command="{Binding DataContext.DeleteKeyCommand, ElementName=APIKeyManagerView_KeyList}"
                          ToolTipService.ToolTip="Delete" Padding="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                  </Button>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <!-- Empty State -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
          <FontIcon Glyph="&#xE8D7;" FontSize="32" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Text="No API keys configured" FontSize="14"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
          <TextBlock Text="Add a key above to get started" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Selected Key Detail -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8"
            Visibility="{x:Bind ViewModel.SelectedKeyVisibility, Mode=OneWay}">
      <StackPanel Spacing="8">
        <TextBlock Text="Key Details" FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        <Grid ColumnSpacing="8" RowSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Service:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.SelectedKey.ServiceName, Mode=OneWay}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Created:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedKey.CreatedAtDisplay, Mode=OneWay}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedKey.Description, Mode=OneWay, FallbackValue='None', TargetNullValue='None'}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" TextWrapping="Wrap"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Command="{x:Bind ViewModel.ValidateKeyCommand}"
                  AutomationProperties.AutomationId="APIKeyManagerView_ValidateButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE73E;" FontSize="14"/>
              <TextBlock Text="Validate"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.DeleteKeyCommand}"
                  AutomationProperties.AutomationId="APIKeyManagerView_DeleteButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE74D;" FontSize="14"/>
              <TextBlock Text="Delete"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="APIKeyManagerView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="API Key Manager Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="APIKeyManagerView_LoadingOverlay"/>
  </Grid>
</UserControl>
