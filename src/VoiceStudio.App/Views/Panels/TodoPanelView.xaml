<UserControl x:Class="VoiceStudio.App.Views.Panels.TodoPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:TodoPanelView">
    <Grid AutomationProperties.AutomationId="TodoPanelView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE762;" FontSize="20"/>
                    <TextBlock Text="Todo Panel"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Refresh"
                            AutomationProperties.AutomationId="TodoPanelView_RefreshButton">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                            AutomationProperties.AutomationId="TodoPanelView_HelpButton">
                        <FontIcon Glyph="&#xE897;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Summary Cards -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Summary" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Total" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.Total, Mode=OneWay}" FontSize="18" FontWeight="Bold"
                                           AutomationProperties.AutomationId="TodoPanelView_TotalCount"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Pending" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.Pending, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="In Progress" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.InProgress, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Completed" FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Summary.Completed, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Create Todo -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="New Todo" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBox Header="Title" Text="{x:Bind ViewModel.NewTodoTitle, Mode=TwoWay}"
                                 PlaceholderText="Todo title..."
                                 AutomationProperties.AutomationId="TodoPanelView_NewTitle"/>
                        <TextBox Header="Description" Text="{x:Bind ViewModel.NewTodoDescription, Mode=TwoWay}"
                                 PlaceholderText="Description..."
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 AutomationProperties.AutomationId="TodoPanelView_NewDescription"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Priority" ItemsSource="{x:Bind ViewModel.AvailablePriorities, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.NewTodoPriority, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="TodoPanelView_NewPriority"/>
                            <ComboBox Grid.Column="1" Header="Category" ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.NewTodoCategory, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="TodoPanelView_NewCategory"/>
                        </Grid>
                        <TextBox Header="Tags" Text="{x:Bind ViewModel.NewTodoTags, Mode=TwoWay}"
                                 PlaceholderText="Comma-separated tags"
                                 AutomationProperties.AutomationId="TodoPanelView_NewTags"/>
                        <Button Command="{x:Bind ViewModel.CreateTodoCommand}"
                                Content="Create Todo"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.AutomationId="TodoPanelView_CreateButton"/>
                    </StackPanel>
                </Border>

                <!-- Filters -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Filters" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Status" ItemsSource="{x:Bind ViewModel.AvailableStatuses, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.FilterStatus, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="TodoPanelView_FilterStatus"/>
                            <ComboBox Grid.Column="1" Header="Priority" ItemsSource="{x:Bind ViewModel.AvailablePriorities, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.FilterPriority, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.AutomationId="TodoPanelView_FilterPriority"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Todo List -->
                <ListView ItemsSource="{x:Bind ViewModel.Todos, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedTodo, Mode=TwoWay}"
                          RightTapped="Todo_RightTapped"
                          AutomationProperties.AutomationId="TodoPanelView_TodoList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PriorityDisplay}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                               MaxLines="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Status: "/>
                                            <Run Text="{Binding StatusDisplay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                            <Run Text="Due: "/>
                                            <Run Text="{Binding DueDateDisplay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TagsDisplay}" FontSize="10" Opacity="0.5"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="TodoPanelView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
