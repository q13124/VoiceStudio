<UserControl x:Class="VoiceStudio.App.Views.Panels.TextSpeechEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:converters="using:VoiceStudio.App.Converters"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:TextSpeechEditorView">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:NullToVisibilityConverter x:Key="NullToVis"/>
  </UserControl.Resources>

  <Grid x:Name="TextSpeechEditorView_Root"
        AutomationProperties.AutomationId="TextSpeechEditorView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
        <TextBlock Text="Text Speech Editor"
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   VerticalAlignment="Center"/>
        <TextBox Text="{x:Bind ViewModel.NewSessionTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="200" PlaceholderText="Session title..."
                 VerticalAlignment="Center"
                 AutomationProperties.AutomationId="TextSpeechEditorView_SessionTitleTextBox"/>
        <Button Command="{x:Bind ViewModel.CreateSessionCommand}"
                AutomationProperties.AutomationId="TextSpeechEditorView_CreateSessionButton"
                ToolTipService.ToolTip="Create Session (Ctrl+N)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="New"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.SynthesizeSessionCommand}"
                Style="{StaticResource AccentButtonStyle}"
                AutomationProperties.AutomationId="TextSpeechEditorView_SynthesizeButton"
                ToolTipService.ToolTip="Synthesize Session">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE768;" FontSize="14"/>
            <TextBlock Text="Synthesize"/>
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="TextSpeechEditorView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="TextSpeechEditorView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="280"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Session List -->
      <Border Grid.Column="0"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="0,0,1,0" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Sessions"
                     FontSize="{StaticResource VSQ.FontSize.Body}" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,8"/>

          <ListView Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                    SelectionMode="Single"
                    RightTapped="Session_RightTapped"
                    AutomationProperties.AutomationId="TextSpeechEditorView_SessionsList">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="vm:EditorSessionItem">
                <StackPanel Padding="8,6" Spacing="2">
                  <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Body}"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind SegmentCountDisplay, Mode=OneWay}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="{x:Bind DurationDisplay, Mode=OneWay}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Center: Segments -->
      <Grid Grid.Column="1" Padding="16,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Segments"
                     FontSize="{StaticResource VSQ.FontSize.Body}" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                     VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Command="{x:Bind ViewModel.AddSegmentCommand}"
                    AutomationProperties.AutomationId="TextSpeechEditorView_AddSegmentButton"
                    ToolTipService.ToolTip="Add Segment">
              <FontIcon Glyph="&#xE710;" FontSize="14"/>
            </Button>
            <Button Command="{x:Bind ViewModel.RemoveSegmentCommand}"
                    AutomationProperties.AutomationId="TextSpeechEditorView_RemoveSegmentButton"
                    ToolTipService.ToolTip="Remove Segment">
              <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource VSQ.Error.Brush}"/>
            </Button>
          </StackPanel>
        </Grid>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedSegment, Mode=TwoWay}"
                  SelectionMode="Single"
                  RightTapped="Segment_RightTapped"
                  AutomationProperties.AutomationId="TextSpeechEditorView_SegmentsList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:TextSegmentItem">
              <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                      CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                      BorderThickness="1" Padding="12" Margin="0,0,0,4">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBox Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Segment text..."
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"
                             BorderThickness="0" Background="Transparent"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{x:Bind TimeRangeDisplay, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                      <TextBlock Text="{x:Bind DurationDisplay, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    </StackPanel>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{x:Bind Speaker, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                             VerticalAlignment="Top"
                             Visibility="{x:Bind Speaker, Mode=OneWay, Converter={StaticResource NullToVis}}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>

      <!-- Right: Settings -->
      <Border Grid.Column="2"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="1,0,0,0">
        <ScrollViewer Padding="12,8">
          <StackPanel Spacing="12">

            <!-- Voice Settings -->
            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Voice Settings" FontSize="{StaticResource VSQ.FontSize.Body}"
                           FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

                <StackPanel Spacing="4">
                  <TextBlock Text="Voice Profile" FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <ComboBox ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedVoiceProfileId, Mode=TwoWay}"
                            PlaceholderText="Select profile..."
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="TextSpeechEditorView_ProfileComboBox"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Engine" FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                            PlaceholderText="Select engine..."
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="TextSpeechEditorView_EngineComboBox"/>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Text="Project" FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <ComboBox ItemsSource="{x:Bind ViewModel.AvailableProjects, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                            PlaceholderText="Select project..."
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="TextSpeechEditorView_ProjectComboBox"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- SSML Mode -->
            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1" Padding="12">
              <StackPanel Spacing="8">
                <ToggleSwitch IsOn="{x:Bind ViewModel.SsmlMode, Mode=TwoWay}"
                              OnContent="SSML Mode" OffContent="SSML Mode"
                              AutomationProperties.AutomationId="TextSpeechEditorView_SSMLModeToggle"/>

                <StackPanel Spacing="4"
                            Visibility="{x:Bind ViewModel.SsmlMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                  <TextBlock Text="SSML / Transcript" FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBox Text="{x:Bind ViewModel.EditedTranscript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="SSML or transcript..."
                           AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                           FontFamily="Consolas"
                           AutomationProperties.AutomationId="TextSpeechEditorView_TranscriptTextBox"/>
                  <Button Command="{x:Bind ViewModel.PreviewSynthesisCommand}"
                          HorizontalAlignment="Right"
                          AutomationProperties.AutomationId="TextSpeechEditorView_PreviewButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE768;" FontSize="14"/>
                      <TextBlock Text="Preview"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Session Actions -->
            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Session Actions" FontSize="{StaticResource VSQ.FontSize.Body}"
                           FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <Button Command="{x:Bind ViewModel.UpdateSessionCommand}"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="TextSpeechEditorView_SaveSessionButton">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                    <TextBlock Text="Save Session"/>
                  </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.DeleteSessionCommand}"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="TextSpeechEditorView_DeleteSessionButton">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource VSQ.Error.Brush}"/>
                    <TextBlock Text="Delete Session"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Error.Brush}"
                   Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"/>
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="3" Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="Processing..." Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="TextSpeechEditorView_HelpOverlay"/>
  </Grid>
</UserControl>
