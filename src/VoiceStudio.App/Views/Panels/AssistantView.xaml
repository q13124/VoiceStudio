<UserControl x:Class="VoiceStudio.App.Views.Panels.AssistantView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:AssistantView">

  <Grid AutomationProperties.AutomationId="AssistantView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8BD;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Assistant" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="AssistantView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="AssistantView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content: Sidebar + Chat -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left Sidebar: Conversations + Projects -->
      <Grid Grid.Column="0" Margin="0,0,12,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Conversations List -->
        <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE8F2;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Conversations" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              </StackPanel>
              <Button Grid.Column="1" Command="{x:Bind ViewModel.DeleteConversationCommand}"
                      AutomationProperties.AutomationId="AssistantView_DeleteConversationButton"
                      ToolTipService.ToolTip="Delete conversation" Padding="4">
                <FontIcon Glyph="&#xE74D;" FontSize="10"/>
              </Button>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Conversations, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedConversation, Mode=TwoWay}"
                      SelectionMode="Single"
                      AutomationProperties.AutomationId="AssistantView_ConversationsList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <StackPanel Padding="6,4" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" MaxLines="1"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <TextBlock Text="{Binding Updated}" FontSize="10"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </StackPanel>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

        <!-- Project Selector -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
          <StackPanel Spacing="6">
            <TextBlock Text="Project" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableProjects, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedProject, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      PlaceholderText="Select project..."
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="AssistantView_ProjectSelector"/>
          </StackPanel>
        </Border>

        <!-- Suggest Tasks -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
          <Button HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.SuggestTasksCommand}"
                  AutomationProperties.AutomationId="AssistantView_SuggestTasksButton"
                  ToolTipService.ToolTip="Suggest tasks for project (Ctrl+T)">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE82F;" FontSize="12"/>
              <TextBlock Text="Suggest Tasks" FontSize="12"/>
            </StackPanel>
          </Button>
        </Border>
      </Grid>

      <!-- Right: Messages + Task Suggestions -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Messages List -->
        <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
          <Grid>
            <ListView ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                      SelectionMode="None"
                      AutomationProperties.AutomationId="AssistantView_MessagesList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Padding="8,6" Margin="0,2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Role Icon -->
                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                            Background="{StaticResource VSQ.Accent.CyanBrush}"
                            Margin="0,0,10,0" VerticalAlignment="Top">
                      <TextBlock Text="{Binding Role}" FontSize="9" FontWeight="Bold"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- Content -->
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Text="{Binding Content}" FontSize="13" TextWrapping="Wrap"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                      <TextBlock Text="{Binding Timestamp}" FontSize="10"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
              <FontIcon Glyph="&#xE8BD;" FontSize="36"
                        Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                        HorizontalAlignment="Center"/>
              <TextBlock Text="Start a conversation" FontSize="14"
                         Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Task Suggestions -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8"
                MinHeight="40">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
              <FontIcon Glyph="&#xE82F;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
              <TextBlock Text="Task Suggestions" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                         VerticalAlignment="Center">
                <Run Text="("/>
                <Run Text="{x:Bind ViewModel.TaskSuggestions.Count, Mode=OneWay}"/>
                <Run Text=")"/>
              </TextBlock>
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.TaskSuggestions, Mode=OneWay}"
                      SelectionMode="None" MaxHeight="160"
                      AutomationProperties.AutomationId="AssistantView_TaskSuggestionsList">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Padding="6,4" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                      <TextBlock Text="{Binding Description}" FontSize="11"
                                 Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" MaxLines="2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                      <TextBlock FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                 HorizontalAlignment="Right">
                        <Run Text="{Binding Priority}"/>
                      </TextBlock>
                      <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="10"
                                 Foreground="{StaticResource VSQ.Accent.GreenBrush}"
                                 HorizontalAlignment="Right"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

        <!-- Message Input -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{x:Bind ViewModel.ChatMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Type a message..."
                     KeyDown="ChatInput_KeyDown"
                     AutomationProperties.AutomationId="AssistantView_ChatInput"/>
            <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                    Command="{x:Bind ViewModel.SendMessageCommand}"
                    AutomationProperties.AutomationId="AssistantView_SendButton"
                    ToolTipService.ToolTip="Send message (Enter)">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE724;" FontSize="14"/>
                <TextBlock Text="Send"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="2"
             AutomationProperties.AutomationId="AssistantView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Assistant Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="3"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="AssistantView_LoadingOverlay"/>
  </Grid>
</UserControl>
