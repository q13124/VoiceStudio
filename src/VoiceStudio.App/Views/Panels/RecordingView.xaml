<UserControl x:Class="VoiceStudio.App.Views.Panels.RecordingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:RecordingView">

  <Grid AutomationProperties.AutomationId="RecordingView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE720;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Recording" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.LoadDevicesCommand}"
                AutomationProperties.AutomationId="RecordingView_RefreshDevicesButton"
                ToolTipService.ToolTip="Refresh devices">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="RecordingView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Device and Settings -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE7F6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Device &amp; Settings" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Input Device" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <ComboBox ItemsSource="{x:Bind ViewModel.AvailableDevices, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    RightTapped="DeviceComboBox_RightTapped"
                    AutomationProperties.AutomationId="RecordingView_DeviceComboBox"
                    PlaceholderText="Select input device"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Sample Rate" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableSampleRates}"
                      SelectedItem="{x:Bind ViewModel.SampleRate, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="RecordingView_SampleRateComboBox"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Channels" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableChannels}"
                      SelectedItem="{x:Bind ViewModel.Channels, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="RecordingView_ChannelsComboBox"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="Bit Depth" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableBitDepths}"
                      SelectedItem="{x:Bind ViewModel.BitDepth, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="RecordingView_BitDepthComboBox"/>
          </StackPanel>

          <StackPanel Grid.Column="3" Spacing="4">
            <TextBlock Text="Format" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableFormats, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedFormat, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="RecordingView_FormatComboBox"/>
          </StackPanel>
        </Grid>

        <StackPanel Spacing="4">
          <TextBlock Text="Filename (optional)" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBox Text="{x:Bind ViewModel.Filename, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Auto-generated if empty"
                   AutomationProperties.AutomationId="RecordingView_FilenameTextBox"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Recording Controls -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xEA3A;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Controls" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0" Style="{StaticResource VSQ.Button.Primary}"
                  Command="{x:Bind ViewModel.StartRecordingCommand}"
                  AutomationProperties.AutomationId="RecordingView_StartButton"
                  ToolTipService.ToolTip="Start recording (Space)" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE7C8;" FontSize="14"/>
              <TextBlock Text="Record"/>
            </StackPanel>
          </Button>

          <Button Grid.Column="1"
                  Command="{x:Bind ViewModel.StopRecordingCommand}"
                  AutomationProperties.AutomationId="RecordingView_StopButton"
                  ToolTipService.ToolTip="Stop recording (Space)" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE71A;" FontSize="14"/>
              <TextBlock Text="Stop"/>
            </StackPanel>
          </Button>

          <Button Grid.Column="2" Style="{StaticResource VSQ.Button.Secondary}"
                  Command="{x:Bind ViewModel.CancelRecordingCommand}"
                  AutomationProperties.AutomationId="RecordingView_CancelButton"
                  ToolTipService.ToolTip="Cancel recording">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE711;" FontSize="14"/>
              <TextBlock Text="Cancel"/>
            </StackPanel>
          </Button>

          <TextBlock Grid.Column="4"
                     Text="{x:Bind ViewModel.RecordingDurationDisplay, Mode=OneWay}"
                     FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                     AutomationProperties.AutomationId="RecordingView_DurationDisplay"/>
        </Grid>

        <TextBlock Text="{x:Bind ViewModel.RecordingId, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                   FontSize="12" Foreground="{StaticResource VSQ.Text.TertiaryBrush}"
                   Visibility="{x:Bind ViewModel.IsRecording, Mode=OneWay}"/>
      </StackPanel>
    </Border>

    <!-- Status -->
    <StackPanel Grid.Row="3" VerticalAlignment="Bottom" Spacing="4" Margin="0,8,0,0">
      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 FontSize="12" Foreground="{StaticResource VSQ.Text.TertiaryBrush}"/>
      <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="20" Height="20"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Left"/>
    </StackPanel>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="RecordingView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Recording Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="RecordingView_LoadingOverlay"/>
  </Grid>
</UserControl>
