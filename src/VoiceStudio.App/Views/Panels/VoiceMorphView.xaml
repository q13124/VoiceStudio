<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceMorphView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:converters="using:VoiceStudio.App.Converters"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:VoiceMorphView">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:NullToVisibilityConverter x:Key="NullToVis"/>
  </UserControl.Resources>

  <Grid x:Name="VoiceMorphView_Root"
        AutomationProperties.AutomationId="VoiceMorphView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0" Text="Voice Morphing"
                 FontSize="{StaticResource VSQ.FontSize.Title}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button AutomationProperties.AutomationId="VoiceMorphView_RefreshButton"
                Command="{x:Bind ViewModel.RefreshCommand}"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="VoiceMorphView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Config List -->
      <Border Grid.Column="0"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="0,0,1,0"
              Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Configurations"
                       FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <Button AutomationProperties.AutomationId="VoiceMorphView_CreateConfigButton"
                    Command="{x:Bind ViewModel.CreateConfigCommand}"
                    HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                <TextBlock Text="New Config"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <ListView Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Configs, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedConfig, Mode=TwoWay}"
                    SelectionMode="Single"
                    RightTapped="Config_RightTapped"
                    AutomationProperties.AutomationId="VoiceMorphView_ConfigsList">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="vm:MorphConfigItem">
                <StackPanel Padding="8,6" Spacing="2">
                  <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Body}"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind MorphStrengthDisplay, Mode=OneWay}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="{x:Bind VoiceCountDisplay, Mode=OneWay}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Right: Config Editor -->
      <ScrollViewer Grid.Column="1" Padding="16,8">
        <StackPanel Spacing="12">

          <!-- Config Name -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Config Name" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <TextBox Text="{x:Bind ViewModel.ConfigName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Enter configuration name..."
                       AutomationProperties.AutomationId="VoiceMorphView_ConfigNameTextBox"/>
            </StackPanel>
          </Border>

          <!-- Source Audio -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Source Audio" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSourceAudioId, Mode=TwoWay}"
                        PlaceholderText="Select source audio..."
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="VoiceMorphView_SourceAudioComboBox"/>
            </StackPanel>
          </Border>

          <!-- Target Voices -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Target Voices"
                           FontSize="{StaticResource VSQ.FontSize.Body}"
                           FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.AddTargetVoiceCommand}"
                        AutomationProperties.AutomationId="VoiceMorphView_AddTargetVoiceButton">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    <TextBlock Text="Add"/>
                  </StackPanel>
                </Button>
              </Grid>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedVoiceProfileId, Mode=TwoWay}"
                          PlaceholderText="Voice profile..."
                          MinWidth="180"
                          AutomationProperties.AutomationId="VoiceMorphView_VoiceProfileComboBox"/>
                <StackPanel Spacing="2">
                  <TextBlock Text="Weight" FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <Slider Value="{x:Bind ViewModel.VoiceWeight, Mode=TwoWay}"
                          Minimum="0" Maximum="1" StepFrequency="0.05"
                          Width="120"
                          AutomationProperties.AutomationId="VoiceMorphView_VoiceWeightSlider"/>
                </StackPanel>
              </StackPanel>

              <ListView ItemsSource="{x:Bind ViewModel.TargetVoices, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedTargetVoice, Mode=TwoWay}"
                        SelectionMode="Single"
                        RightTapped="TargetVoice_RightTapped"
                        MaxHeight="200"
                        AutomationProperties.AutomationId="VoiceMorphView_TargetVoicesList">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="vm:VoiceBlendItem">
                    <Grid Padding="8,4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{x:Bind VoiceProfileId, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Body}"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{x:Bind WeightDisplay, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </Border>

          <!-- Morph Settings -->
          <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                  CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                  BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                  BorderThickness="1" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Morph Settings" FontSize="{StaticResource VSQ.FontSize.Body}"
                         FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

              <StackPanel Spacing="4">
                <TextBlock Text="Morph Strength" FontSize="{StaticResource VSQ.FontSize.Caption}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <Slider Value="{x:Bind ViewModel.MorphStrength, Mode=TwoWay}"
                        Minimum="0" Maximum="1" StepFrequency="0.05"
                        AutomationProperties.AutomationId="VoiceMorphView_MorphStrengthSlider"/>
              </StackPanel>

              <ToggleSwitch IsOn="{x:Bind ViewModel.PreserveEmotion, Mode=TwoWay}"
                            OnContent="Preserve Emotion" OffContent="Preserve Emotion"
                            AutomationProperties.AutomationId="VoiceMorphView_PreserveEmotionToggle"/>
              <ToggleSwitch IsOn="{x:Bind ViewModel.PreserveProsody, Mode=TwoWay}"
                            OnContent="Preserve Prosody" OffContent="Preserve Prosody"
                            AutomationProperties.AutomationId="VoiceMorphView_PreserveProsodyToggle"/>
            </StackPanel>
          </Border>

          <!-- Actions -->
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Command="{x:Bind ViewModel.UpdateConfigCommand}"
                    AutomationProperties.AutomationId="VoiceMorphView_SaveConfigButton">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                <TextBlock Text="Save Config"/>
              </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.DeleteConfigCommand}"
                    AutomationProperties.AutomationId="VoiceMorphView_DeleteConfigButton">
              <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource VSQ.Error.Brush}"/>
            </Button>
            <Button Command="{x:Bind ViewModel.ApplyMorphCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    AutomationProperties.AutomationId="VoiceMorphView_ApplyMorphButton">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE768;" FontSize="14"/>
                <TextBlock Text="Apply Morph"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
        <TextBlock Grid.Column="1"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                   Foreground="{StaticResource VSQ.Error.Brush}"
                   Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"/>
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="3"
          Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="Processing..." Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="VoiceMorphView_HelpOverlay"/>
  </Grid>
</UserControl>
