<!--
  ProfilesView.xaml - Voice profile management panel
  
  AI GUIDELINES:
  - ViewModel is in VoiceStudio.App.Views.Panels namespace (not ViewModels)
  - Profile items use models:VoiceProfile from VoiceStudio.Core.Models
  - SelectedProfile binding drives the detail editor on the right
  - Use FallbackValue for Name/Language bindings (user may have empty profiles)
  - DO NOT change the master-detail layout structure
  - CreateProfileCommand and DeleteProfileCommand are async
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:models="using:VoiceStudio.Core.Models"
    xmlns:converters="using:VoiceStudio.App.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:ProfilesViewModel, IsDesignTimeCreatable=False}"
    x:DataType="local:ProfilesViewModel">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullToBooleanConverter x:Key="NullToBooleanConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
    </UserControl.Resources>

    <Grid x:Name="ProfilesView_Root" 
          AutomationProperties.AutomationId="ProfilesView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                CornerRadius="{StaticResource VSQ.CornerRadius.PanelHeader}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Voice Profiles" 
                               FontSize="{StaticResource VSQ.FontSize.Title}" 
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.TotalProfiles, Mode=OneWay}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button AutomationProperties.AutomationId="ProfilesView_CreateButton"
                            Click="CreateProfileButton_Click"
                            ToolTipService.ToolTip="Create New Profile"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="New Profile" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.AutomationId="ProfilesView_RefreshButton"
                            Command="{x:Bind ViewModel.LoadProfilesCommand}"
                            ToolTipService.ToolTip="Refresh Profiles"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="ProfilesView_HelpButton"
                            Click="HelpButton_Click"
                            ToolTipService.ToolTip="Help"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE897;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search and Filter Bar -->
        <Grid Grid.Row="0" Margin="8,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Profile Grid -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Search and Tabs -->
                <StackPanel Grid.Row="0" Margin="8,4,8,4" Spacing="8">
                    <TextBox x:Name="ProfileSearchBox"
                             PlaceholderText="Search profiles..."
                             AutomationProperties.AutomationId="ProfilesView_SearchBox"
                             TextChanged="ProfileSearchBox_TextChanged"
                             Height="32" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="All" FontSize="11" Padding="8,2" MinHeight="24" />
                        <Button Content="Favorites" FontSize="11" Padding="8,2" MinHeight="24" Background="Transparent" />
                        <Button Content="Recent" FontSize="11" Padding="8,2" MinHeight="24" Background="Transparent" />
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Padding="{StaticResource VSQ.Spacing.Medium}"
                              RightTapped="ProfilesEmptyArea_RightTapped">
                    <GridView x:Name="ProfilesGrid"
                              AutomationProperties.AutomationId="ProfilesView_ProfilesGrid"
                              ItemsSource="{x:Bind ViewModel.FilteredProfiles, Mode=OneWay}"
                              SelectionMode="Single">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:VoiceProfile">
                                <Border Tag="{x:Bind Id, Mode=OneWay}"
                                        Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                        BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                                        Width="180"
                                        Height="120"
                                        Padding="10"
                                        PointerPressed="ProfileCard_PointerPressed"
                                        RightTapped="ProfileCard_RightTapped">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Avatar with image support and initials fallback -->
                                        <PersonPicture Grid.Column="0" Grid.RowSpan="3"
                                                       Width="40" Height="40"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Top"
                                                       DisplayName="{x:Bind Name, Mode=OneWay}"
                                                       Initials="{x:Bind DisplayInitial, Mode=OneWay}"
                                                       ProfilePicture="{x:Bind AvatarUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}" />

                                        <!-- Name -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{x:Bind Name, Mode=OneWay, FallbackValue='Unnamed Profile', TargetNullValue='Unnamed Profile'}"
                                                   FontSize="{StaticResource VSQ.FontSize.Body}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />

                                        <!-- Language + Emotion tags -->
                                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                            <Border Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                                                    CornerRadius="4" Padding="4,1">
                                                <TextBlock Text="{x:Bind Language, Mode=OneWay, FallbackValue='en'}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource VSQ.Accent.CyanBrush}" />
                                            </Border>
                                            <Border Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                                                    CornerRadius="4" Padding="4,1">
                                                <TextBlock Text="{x:Bind Emotion, Mode=OneWay, FallbackValue='neutral'}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Quality score indicator -->
                                        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                            <ProgressBar Value="{x:Bind QualityScore, Mode=OneWay}" Maximum="1.0" Width="60" Height="3" />
                                            <TextBlock FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                                <Run Text="Q:" />
                                                <Run Text="{x:Bind QualityScore, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Selection indicator -->
                                        <Border x:Name="SelectionIndicator"
                                                Grid.ColumnSpan="2" Grid.RowSpan="3"
                                                BorderBrush="{StaticResource VSQ.Accent.CyanBrush}"
                                                BorderThickness="2"
                                                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                                                Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>
            </Grid>

            <!-- Splitter -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource VSQ.Panel.BorderBrush}" Margin="4,8" />

            <!-- Detail Inspector Panel -->
            <ScrollViewer Grid.Column="2" Padding="{StaticResource VSQ.Spacing.Medium}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Profile Details"
                               FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                    <!-- Empty state -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedProfile, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"
                                Spacing="8" Margin="0,20,0,0" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE77B;" FontSize="32" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Select a profile to view details"
                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                   FontStyle="Italic" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Selected profile details -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedProfile, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                Spacing="12">
                        <!-- Profile name -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Name, Mode=OneWay, FallbackValue='—'}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                        </StackPanel>

                        <!-- Language -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Language" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Language, Mode=OneWay, FallbackValue='—'}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                        </StackPanel>

                        <!-- Emotion -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Emotion" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Emotion, Mode=OneWay, FallbackValue='neutral'}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                        </StackPanel>

                        <!-- Quality Score -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Quality Score" FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                            <ProgressBar Value="{x:Bind ViewModel.SelectedProfile.QualityScore, Mode=OneWay}" Maximum="1.0" Height="6" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Spacing="6" Margin="0,8,0,0">
                            <Button Content="Preview Voice" HorizontalAlignment="Stretch" />
                            <Button Content="Edit Profile" HorizontalAlignment="Stretch"
                                    Click="EditProfileButton_Click" />
                            <Button Content="Clone Profile" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Multi-Select Actions -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Small}"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.HasMultipleSelection, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            d:Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Batch Actions"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                            <Button Content="Export Selected"
                                    Click="BatchExport_Click"
                                    AutomationProperties.AutomationId="ProfilesView_BatchExportButton"
                                    HorizontalAlignment="Stretch" />
                            <Button Content="Delete Selected"
                                    Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                                    AutomationProperties.AutomationId="ProfilesView_BatchDeleteButton"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Row -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Small}">
            <TextBlock Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                       VerticalAlignment="Center">
                <Run Text="{x:Bind ViewModel.FilteredCount, Mode=OneWay}" />
                <Run Text=" of " />
                <Run Text="{x:Bind ViewModel.TotalProfiles, Mode=OneWay}" />
                <Run Text=" profiles" />
            </TextBlock>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="{StaticResource VSQ.Loading.BackgroundBrush}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
              d:Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"
                              Width="40" Height="40" />
                <TextBlock Text="Loading profiles..."
                           Foreground="{StaticResource VSQ.Loading.TextBrush}"
                           FontSize="{StaticResource VSQ.FontSize.Body}" />
            </StackPanel>
        </Grid>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="0"
                 IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBooleanConverter}}"
                 Severity="Error"
                 Title="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
                 IsClosable="True"
                 Margin="8"
                 VerticalAlignment="Top"
                 d:Visibility="Collapsed" />

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="3"
                              IsVisible="False" 
                              Visibility="Collapsed"
                              d:Visibility="Collapsed" />
    </Grid>
</UserControl>
