<!--
  ProfilesView.xaml - Voice profile management panel
  
  AI GUIDELINES:
  - ViewModel is in VoiceStudio.App.Views.Panels namespace (not ViewModels)
  - Profile items use models:VoiceProfile from VoiceStudio.Core.Models
  - SelectedProfile binding drives the detail editor on the right
  - Use FallbackValue for Name/Language bindings (user may have empty profiles)
  - DO NOT change the master-detail layout structure
  - CreateProfileCommand and DeleteProfileCommand are async
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:models="using:VoiceStudio.Core.Models"
    xmlns:converters="using:VoiceStudio.App.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:ProfilesViewModel, IsDesignTimeCreatable=False}"
    x:DataType="local:ProfilesViewModel">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullToBooleanConverter x:Key="NullToBooleanConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="ProfilesView_Root" 
          AutomationProperties.AutomationId="ProfilesView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                CornerRadius="{StaticResource VSQ.CornerRadius.PanelHeader}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Voice Profiles" 
                               FontSize="{StaticResource VSQ.FontSize.Title}" 
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.TotalProfiles, Mode=OneWay}"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               FontSize="{StaticResource VSQ.FontSize.Caption}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button AutomationProperties.AutomationId="ProfilesView_RefreshButton"
                            Command="{x:Bind ViewModel.LoadProfilesCommand}"
                            ToolTipService.ToolTip="Refresh Profiles"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="ProfilesView_HelpButton"
                            Click="HelpButton_Click"
                            ToolTipService.ToolTip="Help"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE897;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Profile Grid -->
            <ScrollViewer Grid.Column="0" 
                          Padding="{StaticResource VSQ.Spacing.Medium}"
                          RightTapped="ProfilesEmptyArea_RightTapped">
                <GridView x:Name="ProfilesGrid"
                          AutomationProperties.AutomationId="ProfilesView_ProfilesGrid"
                          ItemsSource="{x:Bind ViewModel.FilteredProfiles, Mode=OneWay}"
                          SelectionMode="Single">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:VoiceProfile">
                            <Border Tag="{x:Bind Id, Mode=OneWay}"
                                    Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                                    Width="172"
                                    Height="112"
                                    Padding="8"
                                    PointerPressed="ProfileCard_PointerPressed"
                                    RightTapped="ProfileCard_RightTapped">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind Name, Mode=OneWay, FallbackValue='Unnamed Profile', TargetNullValue='Unnamed Profile'}"
                                               FontSize="{StaticResource VSQ.FontSize.Body}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />

                                    <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,0,0">
                                        <TextBlock Text="{x:Bind Language, Mode=OneWay, FallbackValue='—', TargetNullValue='—'}"
                                                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                    </StackPanel>

                                    <Border x:Name="SelectionIndicator"
                                            Grid.RowSpan="2"
                                            BorderBrush="{StaticResource VSQ.Accent.CyanBrush}"
                                            BorderThickness="2"
                                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                                            Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </ScrollViewer>

            <!-- Splitter -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource VSQ.Panel.BorderBrush}" Margin="4,8" />

            <!-- Detail Inspector Panel -->
            <ScrollViewer Grid.Column="2" Padding="{StaticResource VSQ.Spacing.Medium}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Profile Details"
                               FontSize="{StaticResource VSQ.FontSize.Body}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                    <TextBlock Text="Select a profile to view details"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                               FontStyle="Italic" />

                    <!-- Multi-Select Actions -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Small}"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.HasMultipleSelection, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Batch Actions"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                            <Button Content="Export Selected"
                                    Click="BatchExport_Click"
                                    AutomationProperties.AutomationId="ProfilesView_BatchExportButton" />
                            <Button Content="Delete Selected"
                                    Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                                    AutomationProperties.AutomationId="ProfilesView_BatchDeleteButton" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Row -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Small}">
            <TextBlock Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                       FontSize="{StaticResource VSQ.FontSize.Caption}"
                       VerticalAlignment="Center">
                <Run Text="{x:Bind ViewModel.FilteredCount, Mode=OneWay}" />
                <Run Text=" of " />
                <Run Text="{x:Bind ViewModel.TotalProfiles, Mode=OneWay}" />
                <Run Text=" profiles" />
            </TextBlock>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="{StaticResource VSQ.Loading.BackgroundBrush}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"
                              Width="40" Height="40" />
                <TextBlock Text="Loading profiles..."
                           Foreground="{StaticResource VSQ.Loading.TextBrush}"
                           FontSize="{StaticResource VSQ.FontSize.Body}" />
            </StackPanel>
        </Grid>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="0"
                 IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBooleanConverter}}"
                 Severity="Error"
                 Title="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="True"
                 Margin="8"
                 VerticalAlignment="Top" />

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="3"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
