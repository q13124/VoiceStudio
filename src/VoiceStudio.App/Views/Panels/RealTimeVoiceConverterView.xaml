<!--
  RealTimeVoiceConverterView.xaml - Real-time voice conversion streaming panel
  
  AI GUIDELINES:
  - This panel handles LIVE audio input/output - latency-critical bindings
  - IsStreaming state toggles between idle and active conversion mode
  - Audio device selection (Input/Output) requires IAudioDeviceService
  - DO NOT add async delays or heavy computations to binding updates
  - Level meters update rapidly - use OneWay mode and avoid complex converters
  - StartCommand/StopCommand manage audio stream lifecycle - must be matched
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.RealTimeVoiceConverterView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  xmlns:converters="using:VoiceStudio.App.Converters"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=vm:RealTimeVoiceConverterViewModel, IsDesignTimeCreatable=False}"
  x:DataType="vm:RealTimeVoiceConverterViewModel">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
  </UserControl.Resources>
  <Grid AutomationProperties.AutomationId="RealTimeVoiceConverterView_Root">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <!-- Header -->
    <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.HeaderBackground}" Padding="12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Real-Time Voice Converter" Style="{StaticResource VSQ.Text.Subtitle}" FontWeight="SemiBold" AutomationProperties.Name="Real-Time Voice Converter panel" AutomationProperties.HelpText="Convert voice in real-time from source to target profile"/>
        <Button Grid.Column="1" Content="?" Width="{StaticResource VSQ.Icon.Size.Medium}" Height="{StaticResource VSQ.Icon.Size.Medium}" FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="0" Click="HelpButton_Click" ToolTipService.ToolTip="Show help for Real-Time Voice Converter" AutomationProperties.Name="Help" AutomationProperties.HelpText="Show contextual help for the Real-Time Voice Converter panel" AutomationProperties.AutomationId="RealTimeVoiceConverter_HelpButton"/>
      </Grid>
    </Border>
    <!-- Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="{StaticResource VSQ.Panel.Sidebar.Width.Narrow}"/>
      </Grid.ColumnDefinitions>
      <!-- Converter Configuration -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Configuration -->
        <Border Grid.Row="0" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1" Padding="{StaticResource VSQ.Spacing.Large}" Background="{StaticResource VSQ.Panel.Background.DarkBrush}">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Large}">
            <TextBlock Text="Voice Conversion Setup" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Spacing="{StaticResource VSQ.Spacing.Value.Medium}" Margin="0">
                <TextBlock x:Name="SourceProfileLabel" Text="Source Profile" Style="{StaticResource VSQ.Text.Caption}" AutomationProperties.Name="Source profile label"/>
                <ComboBox x:Name="SourceProfileComboBox" ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SourceProfileId, Mode=TwoWay}" PlaceholderText="Select Source Profile" ToolTipService.ToolTip="Select source voice profile" AutomationProperties.Name="Source profile" AutomationProperties.HelpText="Select source voice profile" AutomationProperties.LabeledBy="{x:Bind SourceProfileLabel}" AutomationProperties.AutomationId="RealTimeVoiceConverter_SourceProfileComboBox" TabIndex="1"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="{StaticResource VSQ.Spacing.Value.Medium}" Margin="0">
                <TextBlock x:Name="TargetProfileLabel" Text="Target Profile" Style="{StaticResource VSQ.Text.Caption}" AutomationProperties.Name="Target profile label"/>
                <ComboBox x:Name="TargetProfileComboBox" ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.TargetProfileId, Mode=TwoWay}" PlaceholderText="Select Target Profile" ToolTipService.ToolTip="Select target voice profile" AutomationProperties.Name="Target profile" AutomationProperties.HelpText="Select target voice profile" AutomationProperties.LabeledBy="{x:Bind TargetProfileLabel}" AutomationProperties.AutomationId="RealTimeVoiceConverter_TargetProfileComboBox" TabIndex="2"/>
              </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
              <Button Content="Start Conversion" Command="{x:Bind ViewModel.StartSessionCommand, Mode=OneWay}" Style="{StaticResource VSQ.Button.Primary}" ToolTipService.ToolTip="Start real-time voice conversion" AutomationProperties.Name="Start conversion" AutomationProperties.HelpText="Start real-time voice conversion" AutomationProperties.AutomationId="RealTimeVoiceConverter_StartButton" TabIndex="3"/>
              <Button Content="Stop" Command="{x:Bind ViewModel.StopSessionCommand, Mode=OneWay}" Style="{StaticResource VSQ.Button.Secondary}" IsEnabled="{x:Bind ViewModel.IsStreaming, Mode=OneWay}" ToolTipService.ToolTip="Stop voice conversion" AutomationProperties.Name="Stop conversion" AutomationProperties.HelpText="Stop voice conversion" AutomationProperties.AutomationId="RealTimeVoiceConverter_StopButton" TabIndex="4"/>
              <Button Content="Pause" Command="{x:Bind ViewModel.PauseSessionCommand, Mode=OneWay}" Style="{StaticResource VSQ.Button.Secondary}" IsEnabled="{x:Bind ViewModel.IsStreaming, Mode=OneWay}" ToolTipService.ToolTip="Pause voice conversion" AutomationProperties.Name="Pause conversion" AutomationProperties.HelpText="Pause voice conversion" AutomationProperties.AutomationId="RealTimeVoiceConverter_PauseButton" TabIndex="5"/>
              <Button Content="Resume" Command="{x:Bind ViewModel.ResumeSessionCommand, Mode=OneWay}" Style="{StaticResource VSQ.Button.Secondary}" IsEnabled="{x:Bind ViewModel.IsPaused, Mode=OneWay}" ToolTipService.ToolTip="Resume voice conversion" AutomationProperties.Name="Resume conversion" AutomationProperties.HelpText="Resume voice conversion" AutomationProperties.AutomationId="RealTimeVoiceConverter_ResumeButton" TabIndex="6"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <!-- Status Display -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Large}" Padding="{StaticResource VSQ.Spacing.Large}">
            <TextBlock Text="Real-Time Conversion Status" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold"/>
            <Border BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource VSQ.CornerRadius.Button}" Padding="12" Background="{StaticResource VSQ.Panel.Background.DarkBrush}">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
                <TextBlock Text="Status: Streaming" Style="{StaticResource VSQ.Text.Body}" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}" AutomationProperties.Name="Conversion status" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="Status: Paused" Style="{StaticResource VSQ.Text.Body}" Visibility="{x:Bind ViewModel.IsPaused, Mode=OneWay}" AutomationProperties.Name="Conversion status" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="Status: Stopped" Style="{StaticResource VSQ.Text.Body}" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" AutomationProperties.Name="Conversion status" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="Real-time voice conversion is active. Audio input will be converted in real-time." Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <!-- Latency Monitoring -->
            <TextBlock Text="Latency Monitoring" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"/>
            <Border BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource VSQ.CornerRadius.Button}" Padding="12" Background="{StaticResource VSQ.Panel.Background.DarkBrush}" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Current:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CurrentLatencyMs, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Average:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.AverageLatencyMs, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Min:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.MinLatencyMs, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Max:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.MaxLatencyMs, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}" Foreground="{StaticResource VSQ.Accent.OrangeBrush}"/>
              </Grid>
            </Border>
            <!-- Quality Metrics -->
            <TextBlock Text="Quality Metrics" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"/>
            <Border BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource VSQ.CornerRadius.Button}" Padding="12" Background="{StaticResource VSQ.Panel.Background.DarkBrush}" Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
                <TextBlock Text="{x:Bind ViewModel.QualityMetricsDisplay, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}" AutomationProperties.Name="Quality metrics" AutomationProperties.LiveSetting="Polite"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Quality Score:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.QualityScore, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="MOS Score:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.MosScore, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}"/>
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Similarity:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SimilarityScore, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}"/>
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Naturalness:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.NaturalnessScore, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}"/>
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="SNR:" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.SnrDb, Mode=OneWay}" Style="{StaticResource VSQ.Text.Body}"/>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
      <!-- Sessions List -->
      <Border Grid.Column="1" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1,0,0,0" Background="{StaticResource VSQ.Panel.Background.DarkBrush}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <!-- Sessions Header -->
          <Border Grid.Row="0" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1" Padding="12" Background="{StaticResource VSQ.Panel.HeaderBackground}">
            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Active Sessions" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold"/>
              <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}" Style="{StaticResource VSQ.Button.Secondary}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Refresh sessions list (F5)" AutomationProperties.Name="Refresh sessions" AutomationProperties.HelpText="Refresh sessions list" TabIndex="1"/>
            </StackPanel>
          </Border>
          <!-- Sessions ListView -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListView ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}" SelectionMode="Single" RightTapped="Session_RightTapped">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ConverterSessionItem">
                  <Border BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1" Padding="12">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                      <TextBlock Text="{x:Bind SessionId, Mode=OneWay}" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                      <TextBlock Text="{x:Bind Status, Mode=OneWay}" Style="{StaticResource VSQ.Text.BodyStrong}" FontWeight="SemiBold"/>
                      <TextBlock Text="{x:Bind SourceProfileId, Mode=OneWay}" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                      <TextBlock Text="{x:Bind TargetProfileId, Mode=OneWay}" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.Row="1" IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}" LoadingMessage="Processing..."/>
    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Title="Real-Time Voice Converter Help" Visibility="Collapsed"/>
  </Grid>
</UserControl>
