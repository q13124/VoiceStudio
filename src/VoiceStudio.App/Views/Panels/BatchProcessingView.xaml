    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:BatchProcessingView">
    <Grid AutomationProperties.AutomationId="BatchProcessingView_Root">
        <controls:BatchQueueTimelineControl x:Name="BatchQueueTimeline" />
        <controls:HelpOverlay x:Name="HelpOverlay" Visibility="Collapsed" />
    </Grid>
</UserControl>
