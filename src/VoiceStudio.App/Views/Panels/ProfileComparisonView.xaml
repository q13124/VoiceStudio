<UserControl x:Class="VoiceStudio.App.Views.Panels.ProfileComparisonView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:ProfileComparisonView">

  <Grid AutomationProperties.AutomationId="ProfileComparisonView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8F1;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Profile Comparison" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.LoadProfilesCommand}"
                AutomationProperties.AutomationId="ProfileComparisonView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="ProfileComparisonView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Profile Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Profile A -->
        <StackPanel Grid.Column="0" Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="12" Height="12" CornerRadius="6" Background="{StaticResource VSQ.Accent.CyanBrush}"/>
            <TextBlock Text="Profile A" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
          <ComboBox PlaceholderText="Select profile A" HorizontalAlignment="Stretch"
                    ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedProfileA, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    AutomationProperties.AutomationId="ProfileComparisonView_ProfileASelect"/>
          <Button Command="{x:Bind ViewModel.PlayProfileACommand}"
                  AutomationProperties.AutomationId="ProfileComparisonView_PlayAButton" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE768;" FontSize="14"/>
              <TextBlock Text="Play A"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Profile B -->
        <StackPanel Grid.Column="1" Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="12" Height="12" CornerRadius="6" Background="{StaticResource VSQ.Accent.GreenBrush}"/>
            <TextBlock Text="Profile B" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
          <ComboBox PlaceholderText="Select profile B" HorizontalAlignment="Stretch"
                    ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedProfileB, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    AutomationProperties.AutomationId="ProfileComparisonView_ProfileBSelect"/>
          <Button Command="{x:Bind ViewModel.PlayProfileBCommand}"
                  AutomationProperties.AutomationId="ProfileComparisonView_PlayBButton" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE768;" FontSize="14"/>
              <TextBlock Text="Play B"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Preview Text & Compare -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <TextBox Header="Preview Text"
                 Text="{x:Bind ViewModel.PreviewText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                 AutomationProperties.AutomationId="ProfileComparisonView_PreviewText"/>
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.CompareProfilesCommand}"
                  AutomationProperties.AutomationId="ProfileComparisonView_CompareButton">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE8F1;" FontSize="14"/>
              <TextBlock Text="Compare"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Command="{x:Bind ViewModel.StopPlaybackCommand}"
                  AutomationProperties.AutomationId="ProfileComparisonView_StopButton"
                  ToolTipService.ToolTip="Stop playback">
            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
          </Button>
        </Grid>
        <ProgressRing IsActive="{x:Bind ViewModel.IsComparing, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsComparing, Mode=OneWay}"
                      Width="24" Height="24" HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Comparison Results -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <ScrollViewer>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE8D6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
            <TextBlock Text="Comparison Results" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnSpacing="12" RowSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Headers -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Metric" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Profile A" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Accent.CyanBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Profile B" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Accent.GreenBrush}" HorizontalAlignment="Center"/>

            <!-- Quality Score -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Quality" FontSize="12"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.ComparisonData.QualityScoreADisplay, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Bind ViewModel.ComparisonData.QualityScoreBDisplay, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <!-- MOS Score -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="MOS Score" FontSize="12"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.ComparisonData.MosScoreA, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Bind ViewModel.ComparisonData.MosScoreB, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <!-- Naturalness -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Naturalness" FontSize="12"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.ComparisonData.NaturalnessA, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="{x:Bind ViewModel.ComparisonData.NaturalnessB, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <!-- SNR -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="SNR (dB)" FontSize="12"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.ComparisonData.SnrDbA, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Grid.Row="4" Grid.Column="2" Text="{x:Bind ViewModel.ComparisonData.SnrDbB, Mode=OneWay, FallbackValue='--'}"
                       FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="ProfileComparisonView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Profile Comparison Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="ProfileComparisonView_LoadingOverlay"/>
  </Grid>
</UserControl>
