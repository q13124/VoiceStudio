<!--
  VoiceCloningWizardView.xaml - Multi-step voice cloning wizard
  
  AI GUIDELINES:
  - This is a wizard with multiple steps controlled by CurrentStep property
  - Use {x:Bind ViewModel.Property, Mode=OneWay/TwoWay} for all bindings
  - DataTemplates for file/audio items must specify x:DataType
  - Visibility bindings should use converters (BooleanToVisibility, etc.)
  - DO NOT modify step transitions without updating CurrentStep validation
  - All async operations use CancellableCommand pattern
-->
<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceCloningWizardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  xmlns:storage="using:Windows.Storage"
  xmlns:converters="using:VoiceStudio.App.Converters"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=vm:VoiceCloningWizardViewModel, IsDesignTimeCreatable=False}"
  x:DataType="vm:VoiceCloningWizardViewModel">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:StringFormatConverter x:Key="StringFormatConverter" />
  </UserControl.Resources>
  <Grid AutomationProperties.AutomationId="VoiceCloningWizardView_Root">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="Voice Cloning Wizard"
          Style="{StaticResource VSQ.Text.Title}"
          VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Cancel"
            Command="{x:Bind ViewModel.CancelWizardCommand, Mode=OneWay}" />
          <Button Content="?"
            Click="HelpButton_Click"
            Style="{StaticResource VSQ.Button.Icon}" />
        </StackPanel>
      </Grid>
    </Border>


    <Border Grid.Row="1"
      Background="{StaticResource VSQ.Background.Darker}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
        Spacing="{StaticResource VSQ.Spacing.Value.Large}">
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Accent.CyanBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="1. Upload"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="2. Configure"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="3. Process"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="4. Review"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>


    <ScrollViewer Grid.Row="2" Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
        <!-- Step 1: Upload Audio -->
        <Border x:Name="Step1Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Visible">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 1: Upload Reference Audio"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />
            <TextBlock
              Text="Upload a clear audio file containing the voice you want to clone. Recommended: 10+ seconds, mono, 16kHz+ sample rate."
              Style="{StaticResource VSQ.Text.Body}"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
              TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <Button Content="Browse Audio File"
                Command="{x:Bind ViewModel.BrowseAudioCommand, Mode=OneWay}" />
              <Button Content="Validate Audio"
                Command="{x:Bind ViewModel.ValidateAudioCommand, Mode=OneWay}" />
            </StackPanel>

            <TextBlock
              Text="{x:Bind ViewModel.AudioFileName, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{x:Bind ViewModel.AudioFileName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedAudioFiles, Mode=OneWay}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="storage:StorageFile">
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="•" Style="{StaticResource VSQ.Text.Body}" />
                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Validation Results -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.AudioValidations, Mode=OneWay}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AudioValidationItem">
                  <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}"
                    Margin="0,0,0,8">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Clip:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind SourceAudioId}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Valid:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind IsValid}" Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Duration:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind DurationDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Sample Rate:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind SampleRateDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Channels:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind ChannelsDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{x:Bind Issues}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}"
                              Style="{StaticResource VSQ.Text.Caption}"
                              Foreground="Orange"
                              Margin="20,0,0,0" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Step 2: Configure -->
        <Border x:Name="Step2Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 2: Configure Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Profile Name:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{x:Bind ViewModel.ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Width="300"
                PlaceholderText="Enter profile name" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Description:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{x:Bind ViewModel.ProfileDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Width="300"
                PlaceholderText="Optional description"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="80" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Engine:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Quality Mode:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{x:Bind ViewModel.QualityModes, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedQualityMode, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <Button Content="Start Processing"
              Command="{x:Bind ViewModel.StartProcessingCommand, Mode=OneWay}"
              HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <!-- Step 3: Process -->
        <Border x:Name="Step3Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 3: Processing Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <ProgressBar Value="{x:Bind ViewModel.ProcessingProgress, Mode=OneWay}"
              Maximum="100"
              Height="20" />
            <TextBlock Text="{x:Bind ViewModel.ProcessingStatus, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}" />
          </StackPanel>
        </Border>

        <!-- Step 4: Review -->
        <Border x:Name="Step4Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 4: Review Results" Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <TextBlock
              Text="{x:Bind ViewModel.CreatedProfileId, Mode=OneWay}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{x:Bind ViewModel.CreatedProfileId, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Quality Metrics -->
            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
              Padding="{StaticResource VSQ.Spacing.Medium}"
              Visibility="{x:Bind ViewModel.QualityMetrics, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
              RightTapped="QualityMetrics_RightTapped">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                  <TextBlock Text="Quality Metrics" Style="{StaticResource VSQ.Text.Body}"
                    FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="MOS:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.MosScoreDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Similarity:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.SimilarityDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Naturalness:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.NaturalnessDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="SNR:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.SnrDbDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Silence ratio:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.SilenceRatioDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Speaking rate:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.SpeakingRateDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Artifacts:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.ArtifactScoreDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Clicks:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.HasClicksDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Distortion:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.HasDistortionDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Device:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{x:Bind ViewModel.QualityMetrics.DeviceDisplay, Mode=OneWay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                </StackPanel>
                <TextBlock Text="Candidate Metrics"
                  Style="{StaticResource VSQ.Text.Body}"
                  FontWeight="SemiBold"
                  Margin="0,8,0,4" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.CandidateMetrics, Mode=OneWay}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:QualityCandidateItem">
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="{x:Bind LabelDisplay}"
                          Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{x:Bind ScoreDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="(" Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="{x:Bind DeviceDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text=")" Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="{x:Bind SelectedDisplay}"
                          Style="{StaticResource VSQ.Text.Caption}" Margin="8,0,0,0" />
                        <TextBlock Text="{x:Bind ReferenceAudio}"
                          Style="{StaticResource VSQ.Text.Caption}" Margin="8,0,0,0" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>


    <Border Grid.Row="3"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,1,0,0"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
          Style="{StaticResource VSQ.Text.Caption}"
          Foreground="Red"
          Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Previous"
            Command="{x:Bind ViewModel.PreviousStepCommand, Mode=OneWay}" />
          <Button Content="Next"
            Command="{x:Bind ViewModel.NextStepCommand, Mode=OneWay}" />
          <Button Content="Finalize"
            Command="{x:Bind ViewModel.FinalizeWizardCommand, Mode=OneWay}"
            Visibility="Collapsed" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay"
      IsVisible="False"
      Visibility="Collapsed" />

  </Grid>
</UserControl>