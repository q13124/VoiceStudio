<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceCloningWizardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  xmlns:converters="using:VoiceStudio.App.Converters">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:StringFormatConverter x:Key="StringFormatConverter" />
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="Voice Cloning Wizard"
          Style="{StaticResource VSQ.Text.Title}"
          VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Cancel"
            Command="{Binding CancelWizardCommand}" />
          <Button Content="?"
            Click="HelpButton_Click"
            Style="{StaticResource VSQ.Button.Icon}" />
        </StackPanel>
      </Grid>
    </Border>


    <Border Grid.Row="1"
      Background="{StaticResource VSQ.Background.Darker}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,0,0,1"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
        Spacing="{StaticResource VSQ.Spacing.Value.Large}">
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Accent.CyanBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="1. Upload"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="2. Configure"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="3. Process"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
        <Rectangle Width="60" Height="2"
          Fill="{StaticResource VSQ.Panel.BorderBrush}"
          VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Ellipse Width="32" Height="32"
            Fill="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Stroke="{StaticResource VSQ.Panel.BorderBrush}"
            StrokeThickness="2" />
          <TextBlock Text="4. Review"
            Style="{StaticResource VSQ.Text.Body}"
            VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>


    <ScrollViewer Grid.Row="2" Padding="{StaticResource VSQ.Spacing.Medium}">
      <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
        <!-- Step 1: Upload Audio -->
        <Border x:Name="Step1Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Visible">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 1: Upload Reference Audio"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />
            <TextBlock
              Text="Upload a clear audio file containing the voice you want to clone. Recommended: 10+ seconds, mono, 16kHz+ sample rate."
              Style="{StaticResource VSQ.Text.Body}"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
              TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <Button Content="Browse Audio File"
                Command="{Binding BrowseAudioCommand}" />
              <Button Content="Validate Audio"
                Command="{Binding ValidateAudioCommand}" />
            </StackPanel>

            <TextBlock
              Text="{Binding AudioFileName}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{Binding AudioFileName, Converter={StaticResource NullToVisibilityConverter}}" />

            <ItemsControl ItemsSource="{Binding SelectedAudioFiles}"
              Visibility="{Binding SelectedAudioFiles.Count, Converter={StaticResource NullToVisibilityConverter}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="•" Style="{StaticResource VSQ.Text.Body}" />
                    <TextBlock Text="{Binding Name}" Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Validation Results -->
            <ItemsControl ItemsSource="{Binding AudioValidations}"
              Visibility="{Binding AudioValidations.Count, Converter={StaticResource NullToVisibilityConverter}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}"
                    Margin="0,0,0,8">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Clip:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding SourceAudioId}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Valid:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding IsValid}" Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Duration:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding DurationDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Sample Rate:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding SampleRateDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Channels:" Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding ChannelsDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Issues}"
                        Visibility="{Binding Issues, Converter={StaticResource NullToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding}"
                              Style="{StaticResource VSQ.Text.Caption}"
                              Foreground="Orange"
                              Margin="20,0,0,0" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Step 2: Configure -->
        <Border x:Name="Step2Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 2: Configure Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Profile Name:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{Binding ProfileName, Mode=TwoWay}"
                Width="300"
                PlaceholderText="Enter profile name" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Description:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <TextBox Text="{Binding ProfileDescription, Mode=TwoWay}"
                Width="300"
                PlaceholderText="Optional description"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="80" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Engine:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding AvailableEngines}"
                SelectedItem="{Binding SelectedEngine, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
              <TextBlock Text="Quality Mode:" Width="150" Style="{StaticResource VSQ.Text.Body}"
                VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding QualityModes}"
                SelectedItem="{Binding SelectedQualityMode, Mode=TwoWay}"
                Width="300" />
            </StackPanel>

            <Button Content="Start Processing"
              Command="{Binding StartProcessingCommand}"
              HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <!-- Step 3: Process -->
        <Border x:Name="Step3Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 3: Processing Voice Cloning"
              Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <ProgressBar Value="{Binding ProcessingProgress}"
              Maximum="100"
              Height="20" />
            <TextBlock Text="{Binding ProcessingStatus}"
              Style="{StaticResource VSQ.Text.Body}" />
          </StackPanel>
        </Border>

        <!-- Step 4: Review -->
        <Border x:Name="Step4Panel"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
          Padding="{StaticResource VSQ.Spacing.Medium}"
          Visibility="Collapsed">
          <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
            <TextBlock Text="Step 4: Review Results" Style="{StaticResource VSQ.Text.Heading}"
              Margin="0,0,0,4" />

            <TextBlock
              Text="{Binding CreatedProfileId}"
              Style="{StaticResource VSQ.Text.Body}"
              Visibility="{Binding CreatedProfileId, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Quality Metrics -->
            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
              Padding="{StaticResource VSQ.Spacing.Medium}"
              Visibility="{Binding QualityMetrics, Converter={StaticResource NullToVisibilityConverter}}"
              RightTapped="QualityMetrics_RightTapped">
              <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}"
                  DataContext="{Binding QualityMetrics}">
                  <TextBlock Text="Quality Metrics" Style="{StaticResource VSQ.Text.Body}"
                    FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="MOS:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding MosScoreDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Similarity:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding SimilarityDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Naturalness:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding NaturalnessDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="SNR:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding SnrDbDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Silence ratio:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding SilenceRatioDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Speaking rate:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding SpeakingRateDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Artifacts:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding ArtifactScoreDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Clicks:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding HasClicksDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Distortion:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding HasDistortionDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <TextBlock Text="Device:" Style="{StaticResource VSQ.Text.Caption}" />
                    <TextBlock
                      Text="{Binding DeviceDisplay}"
                      Style="{StaticResource VSQ.Text.Body}" />
                  </StackPanel>
                </StackPanel>
                <TextBlock Text="Candidate Metrics"
                  Style="{StaticResource VSQ.Text.Body}"
                  FontWeight="SemiBold"
                  Margin="0,8,0,4"
                  Visibility="{Binding CandidateMetrics.Count, Converter={StaticResource NullToVisibilityConverter}}" />
                <ItemsControl ItemsSource="{Binding CandidateMetrics}"
                  Visibility="{Binding CandidateMetrics.Count, Converter={StaticResource NullToVisibilityConverter}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="{Binding LabelDisplay}"
                          Style="{StaticResource VSQ.Text.Caption}" />
                        <TextBlock Text="{Binding ScoreDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="(" Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="{Binding DeviceDisplay}"
                          Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text=")" Style="{StaticResource VSQ.Text.Body}" />
                        <TextBlock Text="{Binding SelectedDisplay}"
                          Style="{StaticResource VSQ.Text.Caption}" Margin="8,0,0,0" />
                        <TextBlock Text="{Binding ReferenceAudio}"
                          Style="{StaticResource VSQ.Text.Caption}" Margin="8,0,0,0" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>


    <Border Grid.Row="3"
      Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
      BorderThickness="0,1,0,0"
      Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="{Binding ErrorMessage}"
          Style="{StaticResource VSQ.Text.Caption}"
          Foreground="Red"
          Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
          Spacing="{StaticResource VSQ.Spacing.Value.Small}">
          <Button Content="Previous"
            Command="{Binding PreviousStepCommand}" />
          <Button Content="Next"
            Command="{Binding NextStepCommand}" />
          <Button Content="Finalize"
            Command="{Binding FinalizeWizardCommand}"
            Visibility="Collapsed" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay"
      IsVisible="False"
      Visibility="Collapsed" />

  </Grid>
</UserControl>