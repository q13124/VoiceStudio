<UserControl x:Class="VoiceStudio.App.Views.Panels.AIMixingMasteringView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:AIMixingMasteringView">
  <Grid AutomationProperties.AutomationId="AIMixingMasteringView_Root">
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed" />
    <StackPanel Spacing="12" Padding="12">
      <TextBlock Text="AI Mixing &amp; Mastering" Style="{StaticResource VSQ.Text.Subtitle}"
        FontWeight="SemiBold" />
      <TextBlock Text="Mix analysis and mastering tools." Style="{StaticResource VSQ.Text.Body}"
        TextWrapping="Wrap" />
      <Button Content="Help" Click="HelpButton_Click" Style="{StaticResource VSQ.Button.Secondary}"
        HorizontalAlignment="Left" />
    </StackPanel>
  </Grid>
</UserControl>