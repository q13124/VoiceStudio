<UserControl x:Class="VoiceStudio.App.Views.Panels.AIMixingMasteringView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:AIMixingMasteringView">
    <Grid AutomationProperties.AutomationId="AIMixingMasteringView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8D6;" FontSize="20"/>
                    <TextBlock Text="AI Mixing &amp; Mastering"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Refresh"
                            AutomationProperties.AutomationId="AIMixingMasteringView_RefreshButton">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Click="HelpButton_Click" ToolTipService.ToolTip="Help"
                            AutomationProperties.AutomationId="AIMixingMasteringView_HelpButton">
                        <FontIcon Glyph="&#xE897;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Mode & Project -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBox Header="Project ID" Text="{x:Bind ViewModel.ProjectId, Mode=TwoWay}"
                                 PlaceholderText="Enter project ID..."
                                 AutomationProperties.AutomationId="AIMixingMasteringView_ProjectId"/>
                        <ComboBox Header="Mode" ItemsSource="{x:Bind ViewModel.AvailableModes, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="AIMixingMasteringView_ModeComboBox"/>
                    </StackPanel>
                </Border>

                <!-- Analyze Button -->
                <Button Command="{x:Bind ViewModel.AnalyzeCommand}"
                        Content="Analyze Mix"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="AIMixingMasteringView_AnalyzeButton"/>

                <!-- Analysis Progress -->
                <ProgressBar Value="{x:Bind ViewModel.AnalysisProgress, Mode=OneWay}"
                             Maximum="100" Minimum="0"
                             Visibility="{x:Bind ViewModel.AnalyzingVisibility, Mode=OneWay}"
                             AutomationProperties.AutomationId="AIMixingMasteringView_AnalysisProgress"/>

                <!-- Suggestions List -->
                <ListView ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSuggestion, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.SuggestionsVisibility, Mode=OneWay}"
                          RightTapped="Suggestion_RightTapped"
                          AutomationProperties.AutomationId="AIMixingMasteringView_SuggestionList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Category}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PriorityDisplay}" FontWeight="SemiBold"
                                                   Visibility="{Binding HighPriorityVisibility}" Foreground="Orange"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ValueChangeDisplay}" FontSize="11"
                                               Visibility="{Binding ValueChangeVisibility}"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock FontSize="10" Opacity="0.5">
                                        <Run Text="Confidence: "/>
                                        <Run Text="{Binding ConfidenceDisplay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Apply Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            Visibility="{x:Bind ViewModel.SuggestionsVisibility, Mode=OneWay}">
                    <Button Command="{x:Bind ViewModel.PreviewSuggestionCommand}" Content="Preview"
                            AutomationProperties.AutomationId="AIMixingMasteringView_PreviewButton"/>
                    <Button Command="{x:Bind ViewModel.ApplySuggestionCommand}" Content="Apply Selected"
                            AutomationProperties.AutomationId="AIMixingMasteringView_ApplySelectedButton"/>
                    <Button Command="{x:Bind ViewModel.ApplyAllCommand}" Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            AutomationProperties.AutomationId="AIMixingMasteringView_ApplyAllButton"/>
                </StackPanel>

                <!-- Before/After Toggle -->
                <ToggleSwitch IsOn="{x:Bind ViewModel.ShowBeforeAfter, Mode=TwoWay}"
                              Header="Before / After Comparison"
                              AutomationProperties.AutomationId="AIMixingMasteringView_BeforeAfterToggle"/>

                <!-- Mastering Section -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mastering" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBox Header="Target Loudness (LUFS)" Text="{x:Bind ViewModel.TargetLoudness, Mode=TwoWay}"
                                 PlaceholderText="-16"
                                 AutomationProperties.AutomationId="AIMixingMasteringView_TargetLoudness"/>
                        <ComboBox Header="Target Format" ItemsSource="{x:Bind ViewModel.AvailableFormats, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedTargetFormat, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="AIMixingMasteringView_FormatComboBox"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{x:Bind ViewModel.AnalyzeMasteringCommand}" Content="Analyze Mastering"
                                    AutomationProperties.AutomationId="AIMixingMasteringView_AnalyzeMasteringButton"/>
                            <Button Command="{x:Bind ViewModel.ApplyMasteringCommand}" Content="Apply Mastering"
                                    Style="{StaticResource AccentButtonStyle}"
                                    AutomationProperties.AutomationId="AIMixingMasteringView_ApplyMasteringButton"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Report Card -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12"
                        Visibility="{x:Bind ViewModel.ReportCardVisibility, Mode=OneWay}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Report Card" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Loudness" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{x:Bind ViewModel.ReportCard.LoudnessDisplay, Mode=OneWay}" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Peak" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{x:Bind ViewModel.ReportCard.PeakDisplay, Mode=OneWay}" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Dynamic Range" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{x:Bind ViewModel.ReportCard.DynamicRangeDisplay, Mode=OneWay}" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="AIMixingMasteringView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
