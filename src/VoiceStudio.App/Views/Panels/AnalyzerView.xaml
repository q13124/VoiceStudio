<UserControl x:Class="VoiceStudio.App.Views.Panels.AnalyzerView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:converters="using:VoiceStudio.App.Converters"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=local:AnalyzerViewModel, IsDesignTimeCreatable=False}"
  x:DataType="local:AnalyzerViewModel">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
  </UserControl.Resources>
  <Grid AutomationProperties.AutomationId="AnalyzerView_Root">
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <!-- Tab View and Audio Selection -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <!-- Note: TabControl is WPF; for WinUI 3, use TabView -->
      <TabView Grid.Column="0" SelectedIndex="0" x:Name="TabView"
        AutomationProperties.Name="Analysis tabs"
        AutomationProperties.HelpText="Select visualization type: Waveform, Spectral, Radar, Loudness, Phase, or AudioOrbs"
        AutomationProperties.AutomationId="Analyzer_TabView">
        <TabViewItem x:Uid="AnalyzerView_WaveformTab" x:Name="WaveformTab" Header="Waveform"
          AutomationProperties.Name="Waveform tab"
          AutomationProperties.HelpText="View waveform visualization" />
        <TabViewItem x:Uid="AnalyzerView_SpectralTab" x:Name="SpectralTab" Header="Spectral"
          AutomationProperties.Name="Spectral tab"
          AutomationProperties.HelpText="View spectrogram visualization" />
        <TabViewItem x:Uid="AnalyzerView_RadarTab" x:Name="RadarTab" Header="Radar"
          AutomationProperties.Name="Radar tab"
          AutomationProperties.HelpText="View radar chart visualization" />
        <TabViewItem x:Uid="AnalyzerView_LoudnessTab" x:Name="LoudnessTab" Header="Loudness"
          AutomationProperties.Name="Loudness tab"
          AutomationProperties.HelpText="View loudness analysis" />
        <TabViewItem x:Uid="AnalyzerView_PhaseTab" x:Name="PhaseTab" Header="Phase"
          AutomationProperties.Name="Phase tab"
          AutomationProperties.HelpText="View phase analysis" />
        <TabViewItem x:Uid="AnalyzerView_AudioOrbsTab" x:Name="AudioOrbsTab" Header="AudioOrbs"
          AutomationProperties.Name="AudioOrbs tab"
          AutomationProperties.HelpText="View circular/orbital frequency visualization" />
      </TabView>
      <!-- Audio Selection -->
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
        Margin="0">
        <Button Content="?" Width="{StaticResource VSQ.Control.Width.Small}"
          Height="{StaticResource VSQ.Control.Height.Small}"
          FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="0"
          Margin="0"
          Click="HelpButton_Click" TabIndex="1"
          ToolTipService.ToolTip="Show help for Audio Analyzer (F1)"
          AutomationProperties.Name="Help"
          AutomationProperties.HelpText="Show contextual help for the Audio Analyzer panel. Press F1 for help."
          AutomationProperties.AutomationId="Analyzer_HelpButton">
        </Button>
        <TextBlock x:Name="AudioIdLabel" x:Uid="AnalyzerView_AudioIdLabel"
          Margin="0"
          VerticalAlignment="Center" AutomationProperties.Name="Audio ID label" />
        <Button x:Uid="AnalyzerView_BrowseButton"
          Command="{x:Bind ViewModel.BrowseAndUploadCommand}"
          TabIndex="2" ToolTipService.ToolTip="Browse and upload an audio file"
          AutomationProperties.Name="Browse audio file"
          AutomationProperties.HelpText="Browse for an audio file to upload and analyze."
          AutomationProperties.AutomationId="Analyzer_BrowseButton"
          Style="{StaticResource AccentButtonStyle}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE8E5;" FontSize="12" />
            <TextBlock Text="Browse" FontSize="12" />
          </StackPanel>
        </Button>
        <TextBox x:Name="AudioIdTextBox"
          Text="{x:Bind ViewModel.SelectedAudioId, Mode=TwoWay}"
          x:Uid="AnalyzerView_AudioIdTextBox"
          Width="{StaticResource VSQ.Input.Width.Wide}"
          Margin="0" TabIndex="3"
          PlaceholderText="or enter audio ID..."
          ToolTipService.ToolTip="Enter audio ID if already uploaded"
          AutomationProperties.Name="Audio ID input"
          AutomationProperties.HelpText="Enter the ID of an already-uploaded audio file to analyze"
          AutomationProperties.LabeledBy="{x:Bind AudioIdLabel}"
          AutomationProperties.AutomationId="Analyzer_AudioIdTextBox"
          RightTapped="AudioIdTextBox_RightTapped" />
        <Button x:Uid="AnalyzerView_LoadButton"
          Command="{x:Bind ViewModel.LoadVisualizationCommand}"
          TabIndex="4" ToolTipService.ToolTip="Load audio for analysis (Enter)"
          AutomationProperties.Name="Load audio"
          AutomationProperties.HelpText="Load the specified audio file for visualization and analysis. Press Enter to load."
          AutomationProperties.AutomationId="Analyzer_LoadButton">
        </Button>
      </StackPanel>
    </Grid>
    <Border Grid.Row="1" Margin="0"
      CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
      BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1"
      Background="{StaticResource VSQ.Panel.Background.DarkBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Zoom/Pan Toolbar (visible for Waveform and Spectral tabs) -->
        <Border Grid.Row="0" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
          BorderThickness="0,0,0,1" Padding="{StaticResource VSQ.Spacing.Medium}"
          Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
          Visibility="{x:Bind ViewModel.IsWaveformOrSpectralTab, Mode=OneWay}">
          <StackPanel Orientation="Horizontal"
            Spacing="{StaticResource VSQ.Spacing.Value.Medium}" HorizontalAlignment="Right">
            <TextBlock x:Uid="AnalyzerView_ZoomLabel" VerticalAlignment="Center"
              Style="{StaticResource VSQ.Text.Caption}"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
            <Button x:Name="ZoomOutButton" Content="−"
              Width="{StaticResource VSQ.Control.Width.Medium}"
              Height="{StaticResource VSQ.Control.Height.Medium}"
              Click="ZoomOutButton_Click" ToolTipService.ToolTip="Zoom out (Ctrl+-)"
              AutomationProperties.Name="Zoom out"
              AutomationProperties.HelpText="Zoom out the visualization" />
            <Button x:Name="ZoomInButton" Content="+"
              Width="{StaticResource VSQ.Control.Width.Medium}"
              Height="{StaticResource VSQ.Control.Height.Medium}"
              Click="ZoomInButton_Click" ToolTipService.ToolTip="Zoom in (Ctrl+=)"
              AutomationProperties.Name="Zoom in"
              AutomationProperties.HelpText="Zoom in the visualization" />
            <Button x:Name="ResetZoomButton" x:Uid="AnalyzerView_ResetZoomButton"
              Padding="12"
              Click="ResetZoomButton_Click"
              ToolTipService.ToolTip="Reset zoom and pan (Ctrl+0)"
              AutomationProperties.Name="Reset zoom"
              AutomationProperties.HelpText="Reset zoom and pan to default" />
            <TextBlock Text="|" VerticalAlignment="Center"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
              Margin="0" />
            <TextBlock x:Uid="AnalyzerView_MouseControls"
              Style="{StaticResource VSQ.Text.Caption}"
              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
              VerticalAlignment="Center" />
          </StackPanel>
        </Border>
        <Grid Grid.Row="1">
          <!-- Error Message -->
          <controls:ErrorMessage x:Uid="AnalyzerView_ErrorMessage"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
            d:Visibility="Collapsed"
            ActionCommand="{x:Bind ViewModel.LoadVisualizationCommand, Mode=OneWay}"
            AutomationProperties.Name="Error message"
            AutomationProperties.LiveSetting="Assertive" />
          <!-- Loading Overlay -->
          <controls:LoadingOverlay IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            x:Uid="AnalyzerView_LoadingOverlay"
            d:Visibility="Collapsed" />
          <!-- Empty State -->
          <controls:EmptyState Icon="📊" Title="No Audio Loaded"
            Message="Enter an audio ID or filename above and click 'Load' to analyze audio. You can view waveforms, spectrograms, loudness analysis, and more."
            Visibility="{x:Bind ViewModel.HasAudioData, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
          <!-- Waveform Tab Content -->
          <controls:WaveformControl x:Name="WaveformControl"
            Visibility="{x:Bind ViewModel.IsWaveformTab, Mode=OneWay}"
            Samples="{x:Bind ViewModel.WaveformSamples, Mode=OneWay}"
            PlaybackPosition="{x:Bind ViewModel.PlaybackPosition, Mode=OneWay}" />
          <!-- Spectral Tab Content -->
          <controls:SpectrogramControl x:Name="SpectrogramControl"
            Visibility="{x:Bind ViewModel.IsSpectralTab, Mode=OneWay}"
            Frames="{x:Bind ViewModel.SpectrogramFrames, Mode=OneWay}"
            PlaybackPosition="{x:Bind ViewModel.PlaybackPosition, Mode=OneWay}" />
          <!-- Radar Tab Content -->
          <controls:RadarChartControl x:Name="RadarChartControl"
            Visibility="{x:Bind ViewModel.IsRadarTab, Mode=OneWay}"
            Data="{x:Bind ViewModel.RadarData, Mode=OneWay}" />
          <!-- Loudness Tab Content -->
          <controls:LoudnessChartControl x:Name="LoudnessChartControl"
            Visibility="{x:Bind ViewModel.IsLoudnessTab, Mode=OneWay}"
            Times="{x:Bind ViewModel.LoudnessTimes, Mode=OneWay}"
            LufsValues="{x:Bind ViewModel.LoudnessLufsValues, Mode=OneWay}"
            IntegratedLufs="{x:Bind ViewModel.LoudnessIntegratedLufs, Mode=OneWay}"
            PeakLufs="{x:Bind ViewModel.LoudnessPeakLufs, Mode=OneWay}"
            Duration="{x:Bind ViewModel.LoudnessDuration, Mode=OneWay}"
            PlaybackPosition="{x:Bind ViewModel.PlaybackPosition, Mode=OneWay}" />
          <!-- Phase Tab Content -->
          <controls:PhaseAnalysisControl x:Name="PhaseAnalysisControl"
            Visibility="{x:Bind ViewModel.IsPhaseTab, Mode=OneWay}"
            PlaybackPosition="{x:Bind ViewModel.PlaybackPosition, Mode=OneWay}" />
          <!-- AudioOrbs Tab Content -->
          <controls:AudioOrbsControl x:Name="AudioOrbsControl"
            Visibility="{x:Bind ViewModel.IsAudioOrbsTab, Mode=OneWay}" />
          <!-- Empty state for unknown tabs -->
          <TextBlock x:Uid="AnalyzerView_NoVisualization" HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
            Visibility="{x:Bind ViewModel.IsOtherTab, Mode=OneWay}" />
        </Grid>
      </Grid>
    </Border>
    <!-- Help Overlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed" d:Visibility="Collapsed" />
  </Grid>
</UserControl>