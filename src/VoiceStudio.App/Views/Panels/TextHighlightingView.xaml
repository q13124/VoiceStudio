<UserControl x:Class="VoiceStudio.App.Views.Panels.TextHighlightingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  xmlns:vm="using:VoiceStudio.App.ViewModels"
  x:DataType="local:TextHighlightingView">
  <Grid AutomationProperties.AutomationId="TextHighlightingView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Text Highlighting"
                     FontSize="{StaticResource VSQ.FontSize.Title}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                     VerticalAlignment="Center" />
          <ComboBox AutomationProperties.AutomationId="TextHighlighting_AudioSelector"
                    ItemsSource="{x:Bind ViewModel.AvailableAudioIds, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedAudioId, Mode=TwoWay}"
                    PlaceholderText="Select audio..."
                    MinWidth="200"
                    VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
          <Button AutomationProperties.AutomationId="TextHighlighting_LoadAudioBtn"
                  Command="{x:Bind ViewModel.LoadAudioFilesCommand}"
                  ToolTipService.ToolTip="Load audio files">
            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
          </Button>
          <Button AutomationProperties.AutomationId="TextHighlighting_RefreshBtn"
                  Command="{x:Bind ViewModel.RefreshCommand}"
                  ToolTipService.ToolTip="Refresh">
            <FontIcon Glyph="&#xE72C;" FontSize="14" />
          </Button>
          <Button AutomationProperties.AutomationId="TextHighlighting_HelpBtn"
                  Click="HelpButton_Click"
                  ToolTipService.ToolTip="Help">
            <FontIcon Glyph="&#xE897;" FontSize="14" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left: Text + Segments -->
      <Grid Grid.Column="0" Margin="0,0,8,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox AutomationProperties.AutomationId="TextHighlighting_TextInput"
                 Grid.Row="0"
                 Header="Text Content"
                 Text="{x:Bind ViewModel.Text, Mode=TwoWay}"
                 PlaceholderText="Enter or paste text for highlighting..."
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="80"
                 MaxHeight="160"
                 Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <TextBlock Text="Playback Position:" VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
          <Slider AutomationProperties.AutomationId="TextHighlighting_TimeSlider"
                  Value="{x:Bind ViewModel.CurrentTime, Mode=TwoWay}"
                  Minimum="0" Maximum="300" StepFrequency="0.1"
                  Width="200" VerticalAlignment="Center" />
          <TextBlock VerticalAlignment="Center"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
            <Run Text="{x:Bind ViewModel.CurrentTime, Mode=OneWay}" />
            <Run Text="s" />
          </TextBlock>
        </StackPanel>

        <Grid Grid.Row="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Text Segments" Margin="0,0,0,4"
                     FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

          <ListView Grid.Row="1"
                    AutomationProperties.AutomationId="TextHighlighting_SegmentsList"
                    ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="vm:HighlightTextSegmentItem">
                <Grid Padding="8,6" ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="{x:Bind Text, Mode=OneWay}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1"
                             Text="{x:Bind TimeRangeDisplay, Mode=OneWay}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                             FontSize="12" />
                  <TextBlock Grid.Column="2"
                             Text="{x:Bind HighlightType, Mode=OneWay}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                             FontSize="12"
                             FontStyle="Italic" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Grid>

      <!-- Right: Actions -->
      <StackPanel Grid.Column="1" Spacing="12" Margin="8,0,0,0">
        <TextBlock Text="Session" FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
        <Button AutomationProperties.AutomationId="TextHighlighting_CreateSessionBtn"
                Content="Create Session"
                Command="{x:Bind ViewModel.CreateSessionCommand}"
                HorizontalAlignment="Stretch" />
        <Button AutomationProperties.AutomationId="TextHighlighting_UpdateSessionBtn"
                Content="Update Session"
                Command="{x:Bind ViewModel.UpdateSessionCommand}"
                HorizontalAlignment="Stretch" />
        <Button AutomationProperties.AutomationId="TextHighlighting_DeleteSessionBtn"
                Content="Delete Session"
                Command="{x:Bind ViewModel.DeleteSessionCommand}"
                HorizontalAlignment="Stretch" />

        <TextBlock Text="Sync" FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   Margin="0,8,0,0" />
        <Button AutomationProperties.AutomationId="TextHighlighting_SyncBtn"
                Content="Sync Highlighting"
                Command="{x:Bind ViewModel.SyncCommand}"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}" />

        <TextBlock Text="File Operations" FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   Margin="0,8,0,0" />
        <Button AutomationProperties.AutomationId="TextHighlighting_SaveBtn"
                Content="Save Session"
                Command="{x:Bind ViewModel.SaveSessionCommand}"
                HorizontalAlignment="Stretch" />
        <Button AutomationProperties.AutomationId="TextHighlighting_LoadBtn"
                Content="Load Session"
                Command="{x:Bind ViewModel.LoadSessionCommand}"
                HorizontalAlignment="Stretch" />
        <Button AutomationProperties.AutomationId="TextHighlighting_ExportBtn"
                Content="Export"
                Command="{x:Bind ViewModel.ExportSessionCommand}"
                HorizontalAlignment="Stretch" />

        <TextBlock Text="{x:Bind ViewModel.SessionId, Mode=OneWay}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   FontSize="11"
                   Margin="0,8,0,0"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            Padding="12,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressRing Grid.Column="0"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="16" Height="16"
                      Margin="0,0,8,0" />
        <TextBlock Grid.Column="1"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="2"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="3"
          Background="#80000000"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <ProgressRing IsActive="True" Width="32" Height="32" />
        <TextBlock Text="Processing..." Foreground="White" />
      </StackPanel>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay"
                          Grid.RowSpan="3"
                          IsVisible="False"
                          Visibility="Collapsed" />
  </Grid>
</UserControl>
