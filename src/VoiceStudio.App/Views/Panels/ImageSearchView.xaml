<UserControl x:Class="VoiceStudio.App.Views.Panels.ImageSearchView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:ImageSearchView">

  <Grid AutomationProperties.AutomationId="ImageSearchView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE721;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Image Search" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="ImageSearchView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Command="{x:Bind ViewModel.ClearHistoryCommand}"
                AutomationProperties.AutomationId="ImageSearchView_ClearHistoryButton"
                ToolTipService.ToolTip="Clear search history">
          <FontIcon Glyph="&#xE74D;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="ImageSearchView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Search Bar -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0"
                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search for images..."
                 KeyDown="SearchBox_KeyDown"
                 AutomationProperties.AutomationId="ImageSearchView_SearchBox"/>
        <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                Command="{x:Bind ViewModel.SearchCommand}"
                AutomationProperties.AutomationId="ImageSearchView_SearchButton"
                ToolTipService.ToolTip="Search (Enter)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE721;" FontSize="14"/>
            <TextBlock Text="Search"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Filters -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE71C;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Filters" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12" RowSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Source" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableSources, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      PlaceholderText="All sources"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="ImageSearchView_SourceFilter"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Category" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      PlaceholderText="All categories"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="ImageSearchView_CategoryFilter"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="Orientation" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableOrientations, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedOrientation, Mode=TwoWay}"
                      PlaceholderText="Any"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="ImageSearchView_OrientationFilter"/>
          </StackPanel>

          <StackPanel Grid.Column="3" Spacing="4">
            <TextBlock Text="Color" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableColors, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedColor, Mode=TwoWay}"
                      PlaceholderText="Any color"
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="ImageSearchView_ColorFilter"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Results Grid -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8B9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Results" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
          <TextBlock FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                     VerticalAlignment="Center">
            <Run Text="("/>
            <Run Text="{x:Bind ViewModel.TotalResults, Mode=OneWay}"/>
            <Run Text=" found)"/>
          </TextBlock>
        </StackPanel>

        <GridView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedResult, Mode=TwoWay}"
                  AutomationProperties.AutomationId="ImageSearchView_ResultsGrid"
                  IsItemClickEnabled="True"
                  SelectionMode="Single">
          <GridView.ItemTemplate>
            <DataTemplate>
              <Border Width="180" Height="200" CornerRadius="6" Margin="4">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" CornerRadius="6,6,0,0" Background="{StaticResource VSQ.Panel.Background}">
                    <FontIcon Glyph="&#xEB9F;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                  </Border>
                  <StackPanel Grid.Row="1" Padding="8,4" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" MaxLines="1"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                      <Run Text="{Binding DimensionsDisplay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding Source}"/>
                    </TextBlock>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </GridView.ItemTemplate>
        </GridView>

        <TextBlock Grid.Row="1"
                   Text="No results. Enter a query and click Search."
                   FontSize="13" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{x:Bind ViewModel.IsSearching, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverseConverter}, FallbackValue=Collapsed}"/>
      </Grid>
    </Border>

    <!-- Pagination -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Command="{x:Bind ViewModel.PreviousPageCommand}"
                AutomationProperties.AutomationId="ImageSearchView_PreviousPageButton"
                ToolTipService.ToolTip="Previous page">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE76B;" FontSize="12"/>
            <TextBlock Text="Previous"/>
          </StackPanel>
        </Button>

        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="13" Foreground="{StaticResource VSQ.Text.PrimaryBrush}">
          <Run Text="Page "/>
          <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}"/>
          <Run Text=" of "/>
          <Run Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}"/>
        </TextBlock>

        <Button Grid.Column="2" Command="{x:Bind ViewModel.NextPageCommand}"
                AutomationProperties.AutomationId="ImageSearchView_NextPageButton"
                ToolTipService.ToolTip="Next page">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Next"/>
            <FontIcon Glyph="&#xE76C;" FontSize="12"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="5"
             AutomationProperties.AutomationId="ImageSearchView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Image Search Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                             AutomationProperties.AutomationId="ImageSearchView_LoadingOverlay"/>
  </Grid>
</UserControl>
