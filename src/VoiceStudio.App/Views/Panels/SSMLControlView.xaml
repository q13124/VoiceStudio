<UserControl x:Class="VoiceStudio.App.Views.Panels.SSMLControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:converters="using:VoiceStudio.App.Converters"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:SSMLControlView">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
    <converters:NullToVisibilityConverter x:Key="NullToVis"/>
  </UserControl.Resources>

  <Grid x:Name="SSMLControlView_Root"
        AutomationProperties.AutomationId="SSMLControlView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="SSML Editor"
                 FontSize="{StaticResource VSQ.FontSize.Title}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.CreateDocumentCommand}"
                AutomationProperties.AutomationId="SSMLControlView_NewButton"
                ToolTipService.ToolTip="New Document (Ctrl+N)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="New"/>
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.ValidateCommand}"
                AutomationProperties.AutomationId="SSMLControlView_ValidateButton"
                ToolTipService.ToolTip="Validate SSML (F5)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE73E;" FontSize="14"/>
            <TextBlock Text="Validate"/>
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.PreviewCommand}"
                Style="{StaticResource AccentButtonStyle}"
                AutomationProperties.AutomationId="SSMLControlView_PreviewButton"
                ToolTipService.ToolTip="Preview SSML (Ctrl+P)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE768;" FontSize="14"/>
            <TextBlock Text="Preview"/>
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="SSMLControlView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="SSMLControlView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Document List -->
      <Border Grid.Column="0"
              BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
              BorderThickness="0,0,1,0" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Documents"
                     FontSize="{StaticResource VSQ.FontSize.Body}" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,8"/>

          <ListView Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Documents, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedDocument, Mode=TwoWay}"
                    SelectionMode="Single"
                    RightTapped="Document_RightTapped"
                    AutomationProperties.AutomationId="SSMLControlView_DocumentsList">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="vm:SSMLDocumentItem">
                <StackPanel Padding="8,6" Spacing="2">
                  <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Body}"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <TextBlock Text="{x:Bind Modified, Mode=OneWay}"
                             FontSize="{StaticResource VSQ.FontSize.Caption}"
                             Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Right: SSML Editor -->
      <Grid Grid.Column="1" Padding="16,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Editor Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <StackPanel Spacing="2" MinWidth="160">
            <TextBlock Text="Profile" FontSize="{StaticResource VSQ.FontSize.Caption}"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedProfileId, Mode=TwoWay}"
                      PlaceholderText="Profile..."
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="SSMLControlView_ProfileComboBox"/>
          </StackPanel>
          <StackPanel Spacing="2" MinWidth="160">
            <TextBlock Text="Project" FontSize="{StaticResource VSQ.FontSize.Caption}"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableProjects, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}"
                      PlaceholderText="Project..."
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="SSMLControlView_ProjectComboBox"/>
          </StackPanel>

          <StackPanel Spacing="2" VerticalAlignment="Bottom">
            <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                       Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                       Visibility="{x:Bind ViewModel.IsValid, Mode=OneWay, Converter={StaticResource BoolToVis}}">
              <Run Text="&#xE73E;" FontFamily="Segoe Fluent Icons"/><Run Text=" Valid"/>
            </TextBlock>
            <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                       Foreground="{StaticResource VSQ.Error.Brush}"
                       Visibility="{x:Bind ViewModel.IsValid, Mode=OneWay, Converter={StaticResource InvBoolToVis}}">
              <Run Text="&#xE711;" FontFamily="Segoe Fluent Icons"/><Run Text=" Invalid"/>
            </TextBlock>
          </StackPanel>
        </StackPanel>

        <!-- SSML Content Editor -->
        <TextBox Grid.Row="1"
                 Text="{x:Bind ViewModel.SsmlContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="&lt;speak&gt;&#10;  &lt;p&gt;Enter SSML here...&lt;/p&gt;&#10;&lt;/speak&gt;"
                 FontFamily="Consolas"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsSpellCheckEnabled="False"
                 AutomationProperties.AutomationId="SSMLControlView_SSMLEditor"/>

        <!-- Validation Results -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="8" Margin="0,8,0,0"
                MaxHeight="120">
          <ScrollViewer>
            <StackPanel Spacing="4">
              <ItemsControl ItemsSource="{x:Bind ViewModel.ValidationErrors, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="{StaticResource VSQ.Error.Brush}">
                      <Run Text="&#xE711;" FontFamily="Segoe Fluent Icons"/>
                      <Run Text="{Binding}"/>
                    </TextBlock>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <ItemsControl ItemsSource="{x:Bind ViewModel.ValidationWarnings, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                               Foreground="Orange">
                      <Run Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"/>
                      <Run Text="{Binding}"/>
                    </TextBlock>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Error.Brush}"
                   Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"/>
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="4" Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="Processing..." Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="4"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="SSMLControlView_HelpOverlay"/>
  </Grid>
</UserControl>
