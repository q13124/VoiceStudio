<UserControl x:Class="VoiceStudio.App.Views.Panels.ImageVideoEnhancementPipelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:ImageVideoEnhancementPipelineView">

  <Grid AutomationProperties.AutomationId="ImageVideoEnhancementPipelineView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE771;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Enhancement Pipeline" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
    </Grid>

    <!-- Content Type & Preset -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Configuration" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <ComboBox Grid.Column="0" Header="Content Type"
                    SelectedItem="{x:Bind ViewModel.ContentType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="EnhancementPipelineView_ContentTypeSelector">
            <x:String>Image</x:String>
            <x:String>Video</x:String>
          </ComboBox>
          <ComboBox Grid.Column="1" Header="Preset"
                    ItemsSource="{x:Bind ViewModel.EnhancementPresets, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="EnhancementPipelineView_PresetSelector"/>
          <CheckBox Grid.Column="2" VerticalAlignment="Bottom"
                    Content="Batch Mode"
                    IsChecked="{x:Bind ViewModel.BatchMode, Mode=TwoWay}"
                    AutomationProperties.AutomationId="EnhancementPipelineView_BatchModeCheckBox"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Available Enhancements -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Available Enhancements (click to add)" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableEnhancements, Mode=OneWay}"
                       AutomationProperties.AutomationId="EnhancementPipelineView_AvailableList">
          <ItemsRepeater.Layout>
            <StackLayout Orientation="Horizontal" Spacing="8"/>
          </ItemsRepeater.Layout>
          <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="local:EnhancementItem">
              <Button Tag="{x:Bind}"
                      PointerPressed="EnhancementItem_PointerPressed"
                      ToolTipService.ToolTip="{x:Bind Description}"
                      AutomationProperties.AutomationId="EnhancementPipelineView_EnhancementButton">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE710;" FontSize="12"/>
                  <TextBlock Text="{x:Bind Name}" FontSize="12"/>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
      </StackPanel>
    </Border>

    <!-- Pipeline Steps -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <FontIcon Glyph="&#xE8A1;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Pipeline Steps" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.PipelineSteps, Mode=OneWay}"
                  AutomationProperties.AutomationId="EnhancementPipelineView_PipelineStepsList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="local:PipelineStep">
              <Grid Padding="8" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource VSQ.Accent.CyanBrush}">
                  <Run Text="#"/>
                  <Run Text="{x:Bind StepNumber}"/>
                </TextBlock>
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                  <TextBlock Text="{x:Bind Description}" FontSize="11" Opacity="0.7"
                             TextTrimming="CharacterEllipsis" MaxLines="1"/>
                </StackPanel>
                <Button Grid.Column="2" CommandParameter="{x:Bind}"
                        Click="MoveStepUp_Click" ToolTipService.ToolTip="Move up"
                        AutomationProperties.AutomationId="EnhancementPipelineView_MoveUpButton">
                  <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                </Button>
                <Button Grid.Column="3" CommandParameter="{x:Bind}"
                        Click="MoveStepDown_Click" ToolTipService.ToolTip="Move down"
                        AutomationProperties.AutomationId="EnhancementPipelineView_MoveDownButton">
                  <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                </Button>
                <Button Grid.Column="4" CommandParameter="{x:Bind}"
                        Click="ConfigureStep_Click" ToolTipService.ToolTip="Configure"
                        AutomationProperties.AutomationId="EnhancementPipelineView_ConfigureButton">
                  <FontIcon Glyph="&#xE9D9;" FontSize="12"/>
                </Button>
                <Button Grid.Column="5" CommandParameter="{x:Bind}"
                        Click="RemoveStep_Click" ToolTipService.ToolTip="Remove"
                        AutomationProperties.AutomationId="EnhancementPipelineView_RemoveButton">
                  <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                </Button>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Quality Display & Actions -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <Grid ColumnSpacing="24">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Original Quality" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                       AutomationProperties.AutomationId="EnhancementPipelineView_OriginalQuality">
              <Run Text="{x:Bind ViewModel.OriginalQuality, Mode=OneWay}"/>
              <Run Text="%"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Enhanced Quality" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.GreenBrush}"
                       AutomationProperties.AutomationId="EnhancementPipelineView_EnhancedQuality">
              <Run Text="{x:Bind ViewModel.EnhancedQuality, Mode=OneWay}"/>
              <Run Text="%"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="Improvement" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                       AutomationProperties.AutomationId="EnhancementPipelineView_QualityImprovement">
              <Run Text="+"/>
              <Run Text="{x:Bind ViewModel.QualityImprovement, Mode=OneWay}"/>
              <Run Text="%"/>
            </TextBlock>
          </StackPanel>
        </Grid>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Command="{x:Bind ViewModel.SelectFilesCommand}"
                  AutomationProperties.AutomationId="EnhancementPipelineView_SelectFilesButton"
                  ToolTipService.ToolTip="Select files to process">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Select Files"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                  Command="{x:Bind ViewModel.ApplyPipelineCommand}"
                  AutomationProperties.AutomationId="EnhancementPipelineView_ApplyButton"
                  ToolTipService.ToolTip="Apply enhancement pipeline">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <FontIcon Glyph="&#xE771;" FontSize="16"/>
              <TextBlock Text="Apply Pipeline" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="2" Command="{x:Bind ViewModel.PreviewPipelineCommand}"
                  AutomationProperties.AutomationId="EnhancementPipelineView_PreviewButton"
                  ToolTipService.ToolTip="Preview pipeline on a single file">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE8FF;" FontSize="14"/>
              <TextBlock Text="Preview"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="3" Command="{x:Bind ViewModel.SavePresetCommand}"
                  AutomationProperties.AutomationId="EnhancementPipelineView_SavePresetButton"
                  ToolTipService.ToolTip="Save current pipeline as preset">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE74E;" FontSize="14"/>
              <TextBlock Text="Save Preset"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Status -->
    <StackPanel Grid.Row="5" Spacing="4">
      <ProgressBar IsIndeterminate="True"
                   Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                   AutomationProperties.AutomationId="EnhancementPipelineView_ProgressBar"/>
      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                 HorizontalAlignment="Center"
                 AutomationProperties.AutomationId="EnhancementPipelineView_StatusText"/>
    </StackPanel>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
