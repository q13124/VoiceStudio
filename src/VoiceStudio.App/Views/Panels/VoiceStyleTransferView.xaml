<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceStyleTransferView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    x:DataType="local:VoiceStyleTransferView">
    <Grid AutomationProperties.AutomationId="VoiceStyleTransferView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Voice Style Transfer"
                           FontSize="{StaticResource VSQ.FontSize.Title}"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button AutomationProperties.AutomationId="StyleTransfer_LoadProfilesBtn"
                            Command="{x:Bind ViewModel.LoadVoiceProfilesCommand}"
                            ToolTipService.ToolTip="Load voice profiles">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button AutomationProperties.AutomationId="StyleTransfer_HelpBtn"
                            Click="HelpButton_Click"
                            ToolTipService.ToolTip="Help">
                        <FontIcon Glyph="&#xE897;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Reference Audio + Style Profile -->
            <ScrollViewer Grid.Column="0" Margin="0,0,8,0">
                <StackPanel Spacing="12">

                    <!-- Reference Audio -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Reference Audio"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <TextBox AutomationProperties.AutomationId="StyleTransfer_ReferenceAudioInput"
                                     Header="Reference Audio ID"
                                     Text="{x:Bind ViewModel.ReferenceAudioId, Mode=TwoWay}"
                                     PlaceholderText="Enter reference audio ID..." />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button AutomationProperties.AutomationId="StyleTransfer_ExtractStyleBtn"
                                        Content="Extract Style"
                                        Command="{x:Bind ViewModel.ExtractStyleCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <Button AutomationProperties.AutomationId="StyleTransfer_AnalyzeStyleBtn"
                                        Content="Analyze Style"
                                        Command="{x:Bind ViewModel.AnalyzeStyleCommand}" />
                                <ProgressRing IsActive="{x:Bind ViewModel.IsExtractingStyle, Mode=OneWay}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Style Profile -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Style Profile"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <Grid RowSpacing="6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Pitch:"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StyleProfile.PitchDisplay, Mode=OneWay}"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Energy:"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StyleProfile.EnergyDisplay, Mode=OneWay}"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Speaking Rate:"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StyleProfile.SpeakingRateDisplay, Mode=OneWay}"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Emotion:"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StyleProfile.EmotionDisplay, Mode=OneWay}"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Style Analysis -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Style Analysis"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <TextBlock Foreground="{StaticResource VSQ.Text.SecondaryBrush}" FontSize="12">
                                <Run Text="Style Markers: " />
                                <Run Text="{x:Bind ViewModel.StyleAnalysis.MarkerCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Generation Controls -->
            <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                <StackPanel Spacing="12">

                    <!-- Target Voice -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Generation Settings"
                                       FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />

                            <ComboBox AutomationProperties.AutomationId="StyleTransfer_TargetVoiceCombo"
                                      Header="Target Voice Profile"
                                      ItemsSource="{x:Bind ViewModel.AvailableVoiceProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.TargetVoiceProfileId, Mode=TwoWay}"
                                      PlaceholderText="Select target voice..."
                                      HorizontalAlignment="Stretch" />

                            <TextBox AutomationProperties.AutomationId="StyleTransfer_TargetTextInput"
                                     Header="Text to Synthesize"
                                     Text="{x:Bind ViewModel.TargetText, Mode=TwoWay}"
                                     PlaceholderText="Enter text to synthesize with style..."
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="80" />

                            <StackPanel>
                                <TextBlock Text="Style Intensity"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Subtle" VerticalAlignment="Center"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                               FontSize="11" Margin="0,0,8,0" />
                                    <Slider AutomationProperties.AutomationId="StyleTransfer_IntensitySlider"
                                            Grid.Column="1"
                                            Value="{x:Bind ViewModel.StyleIntensity, Mode=TwoWay}"
                                            Minimum="0" Maximum="1" StepFrequency="0.05"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="Strong" VerticalAlignment="Center"
                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                               FontSize="11" Margin="8,0,0,0" />
                                </Grid>
                            </StackPanel>

                            <ToggleSwitch AutomationProperties.AutomationId="StyleTransfer_ComparisonToggle"
                                          Header="Show Comparison"
                                          IsOn="{x:Bind ViewModel.ShowComparison, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!-- Generate -->
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button AutomationProperties.AutomationId="StyleTransfer_GenerateBtn"
                                        Content="Generate with Style"
                                        Command="{x:Bind ViewModel.GenerateCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <ProgressRing IsActive="{x:Bind ViewModel.IsGenerating, Mode=OneWay}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.GeneratedAudioId, Mode=OneWay}"
                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing Grid.Column="0"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="16" Height="16"
                              Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="#80000000"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <ProgressRing IsActive="True" Width="32" Height="32" />
                <TextBlock Text="Processing..." Foreground="White" />
            </StackPanel>
        </Grid>

        <controls:HelpOverlay x:Name="HelpOverlay"
                              Grid.RowSpan="3"
                              IsVisible="False"
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
