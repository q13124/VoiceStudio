<UserControl
    x:Class="VoiceStudio.App.Views.Panels.TextBasedSpeechEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters"
    x:Name="Root">
    <UserControl.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:NumberFormatConverter x:Key="F2FormatConverter" Format="F2" />
        <converters:StringFormatConverter x:Key="StringFormatConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
                    <TextBlock Text="Text-Based Speech Editor"
                        Style="{StaticResource VSQ.Text.Title}"
                        VerticalAlignment="Center" />
                    <TextBox Text="{x:Bind ViewModel.AudioId, Mode=TwoWay}"
                        Width="200"
                        PlaceholderText="Audio ID"
                        Margin="4,0,0,0" />
                    <Button Content="Load"
                        Command="{x:Bind ViewModel.LoadAudioCommand, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <Button Content="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}" />
                    <Button Content="?"
                        Click="HelpButton_Click"
                        Style="{StaticResource VSQ.Button.Icon}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Left: Transcript and waveform -->
            <Grid Grid.Column="0" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Transcript editor -->
                <Border Grid.Row="0"
                    Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}"
                    Margin="0,0,0,4">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                Text="Transcript"
                                Style="{StaticResource VSQ.Text.Heading}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <Button Content="Transcribe"
                                    Command="{x:Bind ViewModel.TranscribeCommand, Mode=OneWay}" />
                                <Button Content="Align"
                                    Command="{x:Bind ViewModel.AlignTranscriptCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                        <TextBox Text="{x:Bind ViewModel.EditedTranscript, Mode=TwoWay}"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            Height="100"
                            PlaceholderText="Transcript will appear here after transcribing..." />
                        <TextBlock
                            Text="{x:Bind ViewModel.OriginalTranscript, Mode=OneWay}"
                            Style="{StaticResource VSQ.Text.Caption}"
                            Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                            Visibility="{x:Bind ViewModel.OriginalTranscript, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Waveform -->
                <Border Grid.Row="1"
                    Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}"
                    Margin="0,0,0,4"
                    Visibility="{x:Bind ViewModel.ShowWaveform, Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Text="Waveform"
                            Style="{StaticResource VSQ.Text.Body}"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <controls:WaveformControl x:Name="WaveformControl"
                            Height="150" />
                    </StackPanel>
                </Border>

                <!-- Segments list -->
                <Border Grid.Row="2"
                    Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel>
                        <TextBlock Text="Transcript Segments"
                            Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />
                        <ListView ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedSegment, Mode=TwoWay}"
                            RightTapped="Segment_RightTapped">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="{StaticResource VSQ.Spacing.Value.Small}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Text}"
                                                Style="{StaticResource VSQ.Text.Body}" />
                                            <TextBlock Style="{StaticResource VSQ.Text.Caption}"
                                                Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                                <Run
                                                    Text="{Binding StartTime, Converter={StaticResource F2FormatConverter}}" />s
                                                - <Run
                                                    Text="{Binding EndTime, Converter={StaticResource F2FormatConverter}}" />
                                                s </TextBlock>
                                        </StackPanel>
                                        <ItemsControl Grid.Column="1"
                                            ItemsSource="{Binding Words}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                                                        BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="4,2">
                                                        <TextBlock Text="{Binding Word}"
                                                            Style="{StaticResource VSQ.Text.Caption}"
                                                            FontSize="10" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: Edit controls -->
            <Border Grid.Column="1"
                Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1,0,0,0"
                Padding="{StaticResource VSQ.Spacing.Medium}">
                <ScrollViewer>
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
                        <!-- Word editing -->
                        <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Word Editing"
                                    Style="{StaticResource VSQ.Text.Body}" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedWord.Word, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Caption}"
                                    Visibility="{x:Bind ViewModel.SelectedWord, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

                                <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                    <TextBox Text="{x:Bind ViewModel.ReplacementText, Mode=TwoWay}"
                                        Width="150"
                                        PlaceholderText="Replacement text" />
                                    <Button Content="Replace"
                                        Command="{x:Bind ViewModel.ReplaceWordCommand, Mode=OneWay}" />
                                </StackPanel>

                                <Button Content="Delete Word"
                                    Command="{x:Bind ViewModel.DeleteWordCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Insert text -->
                        <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Insert Text" Style="{StaticResource VSQ.Text.Body}"
                                    FontWeight="SemiBold" />

                                <TextBlock Text="Profile:" Style="{StaticResource VSQ.Text.Caption}" />
                                <ComboBox
                                    ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedProfileId, Mode=TwoWay}"
                                    PlaceholderText="Select profile" />
                                <Button Content="Load Profiles"
                                    Command="{x:Bind ViewModel.LoadProfilesCommand, Mode=OneWay}" />

                                <TextBlock Text="Text:" Style="{StaticResource VSQ.Text.Caption}" />
                                <TextBox Text="{x:Bind ViewModel.InsertText, Mode=TwoWay}"
                                    PlaceholderText="Text to insert" />

                                <TextBlock Text="Position (seconds):"
                                    Style="{StaticResource VSQ.Text.Caption}" />
                                <NumberBox Value="{x:Bind ViewModel.InsertPosition, Mode=TwoWay}"
                                    Minimum="0"
                                    SmallChange="0.1" />

                                <Button Content="Insert"
                                    Command="{x:Bind ViewModel.InsertTextCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Filler words -->
                        <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Filler Words"
                                    Style="{StaticResource VSQ.Text.Body}" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RemovedFillerWordCount, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Caption}" />
                                <Button Content="Remove Filler Words"
                                    Command="{x:Bind ViewModel.RemoveFillerWordsCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Settings -->
                        <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Settings" Style="{StaticResource VSQ.Text.Body}"
                                    FontWeight="SemiBold" />

                                <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                    <TextBlock Text="Engine:" Width="80"
                                        Style="{StaticResource VSQ.Text.Caption}"
                                        VerticalAlignment="Center" />
                                    <ComboBox
                                        ItemsSource="{x:Bind ViewModel.AvailableEngines, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedEngine, Mode=TwoWay}"
                                        Width="150" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                    <TextBlock Text="Quality:" Width="80"
                                        Style="{StaticResource VSQ.Text.Caption}"
                                        VerticalAlignment="Center" />
                                    <ComboBox
                                        ItemsSource="{x:Bind ViewModel.QualityModes, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedQualityMode, Mode=TwoWay}"
                                        Width="150" />
                                </StackPanel>

                                <ToggleSwitch IsOn="{x:Bind ViewModel.ShowWaveform, Mode=TwoWay}"
                                    OffContent="Hide Waveform"
                                    OnContent="Show Waveform" />
                                <ToggleSwitch
                                    IsOn="{x:Bind ViewModel.ShowABComparison, Mode=TwoWay}"
                                    OffContent="Hide A/B"
                                    OnContent="Show A/B Comparison" />
                            </StackPanel>
                        </Border>

                        <!-- Apply edits -->
                        <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                            Padding="{StaticResource VSQ.Spacing.Medium}">
                            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Final Audio" Style="{StaticResource VSQ.Text.Body}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.FinalAudioId, Mode=OneWay}"
                                    Style="{StaticResource VSQ.Text.Caption}"
                                    Visibility="{x:Bind ViewModel.FinalAudioId, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                                <Button Content="Apply All Edits"
                                    Command="{x:Bind ViewModel.ApplyEditsCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                <TextBlock Grid.Column="1"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="Red"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay"
            IsVisible="False"
            Visibility="Collapsed" />
    </Grid>
</UserControl>