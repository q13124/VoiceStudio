<UserControl x:Class="VoiceStudio.App.Views.Panels.DiagnosticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:DiagnosticsView">
    <Grid Background="{StaticResource VSQ.Window.Background}" AutomationProperties.AutomationId="DiagnosticsView_Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background}" 
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE9D9;" FontSize="20"/>
                    <TextBlock Text="Diagnostics" 
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="?" Click="HelpButton_Click" ToolTipService.ToolTip="Help"/>
            </Grid>
        </Border>

        <!-- Tab Navigation -->
        <Grid Grid.Row="1">
            <TabView x:Name="DiagnosticsTabView" 
                     TabWidthMode="Equal"
                     IsAddTabButtonVisible="False">
                <TabViewItem Header="System Info"/>
                <TabViewItem Header="Logs"/>
                <TabViewItem Header="Traces"/>
                <TabViewItem Header="Network"/>
                <TabViewItem Header="Engines"/>
                <TabViewItem Header="Commands"/>
                <TabViewItem Header="Environment"/>
            </TabView>

            <!-- System Info Content -->
            <Grid x:Name="SystemInfoGrid" Visibility="Visible" Margin="0,48,0,0">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">
                        <!-- Resource Gauges Section -->
                        <Border Background="{StaticResource VSQ.Panel.Background}" 
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Resource Monitor" 
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- CPU Gauge -->
                                    <Border Grid.Column="0" 
                                            Background="{StaticResource VSQ.Window.Background}"
                                            CornerRadius="8" 
                                            Padding="16">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE950;" FontSize="24" 
                                                      Foreground="{StaticResource VSQ.Accent.Brush}"/>
                                            <TextBlock Text="CPU" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            <TextBlock x:Name="CpuUsageText" 
                                                       Text="--%" 
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                            <ProgressBar x:Name="CpuProgressBar"
                                                         Minimum="0" 
                                                         Maximum="100" 
                                                         Value="0"
                                                         Height="8"
                                                         CornerRadius="4"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Memory Gauge -->
                                    <Border Grid.Column="1" 
                                            Background="{StaticResource VSQ.Window.Background}"
                                            CornerRadius="8" 
                                            Padding="16">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE964;" FontSize="24" 
                                                      Foreground="{StaticResource VSQ.Accent.Brush}"/>
                                            <TextBlock Text="Memory" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            <TextBlock x:Name="MemoryUsageText" 
                                                       Text="-- GB" 
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                            <ProgressBar x:Name="MemoryProgressBar"
                                                         Minimum="0" 
                                                         Maximum="100" 
                                                         Value="0"
                                                         Height="8"
                                                         CornerRadius="4"/>
                                            <TextBlock x:Name="MemoryDetailsText" 
                                                       Text="-- / -- GB"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- GPU Memory Gauge -->
                                    <Border Grid.Column="2" 
                                            Background="{StaticResource VSQ.Window.Background}"
                                            CornerRadius="8" 
                                            Padding="16">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE7F4;" FontSize="24" 
                                                      Foreground="{StaticResource VSQ.Accent.Brush}"/>
                                            <TextBlock Text="GPU Memory" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            <TextBlock x:Name="GpuMemoryUsageText" 
                                                       Text="-- GB" 
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                            <ProgressBar x:Name="GpuMemoryProgressBar"
                                                         Minimum="0" 
                                                         Maximum="100" 
                                                         Value="0"
                                                         Height="8"
                                                         CornerRadius="4"/>
                                            <TextBlock x:Name="GpuMemoryDetailsText" 
                                                       Text="-- / -- GB"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- GPU Utilization Gauge -->
                                    <Border Grid.Column="3" 
                                            Background="{StaticResource VSQ.Window.Background}"
                                            CornerRadius="8" 
                                            Padding="16">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE9F5;" FontSize="24" 
                                                      Foreground="{StaticResource VSQ.Accent.Brush}"/>
                                            <TextBlock Text="GPU Load" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            <TextBlock x:Name="GpuLoadText" 
                                                       Text="--%" 
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                            <ProgressBar x:Name="GpuLoadProgressBar"
                                                         Minimum="0" 
                                                         Maximum="100" 
                                                         Value="0"
                                                         Height="8"
                                                         CornerRadius="4"/>
                                            <TextBlock x:Name="GpuNameText" 
                                                       Text="--"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- System Overview Section -->
                        <Border Background="{StaticResource VSQ.Panel.Background}" 
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="System Overview" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                <Grid RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="OS Version:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OsVersionText" Text="{x:Bind ViewModel.OsVersion, Mode=OneWay, FallbackValue='Detecting...'}" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <TextBlock Grid.Row="1" Text=".NET Version:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DotNetVersionText" Text="{x:Bind ViewModel.DotNetVersion, Mode=OneWay, FallbackValue='Detecting...'}" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <TextBlock Grid.Row="2" Text="App Version:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AppVersionText" Text="{x:Bind ViewModel.AppVersion, Mode=OneWay, FallbackValue='1.0.0'}" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <TextBlock Grid.Row="3" Text="RAM:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RamText" Text="Loading..." Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <TextBlock Grid.Row="4" Text="GPU:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GpuText" Text="Checking..." Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Active Jobs Section (Job Queue Visualization) -->
                        <Border Background="{StaticResource VSQ.Panel.Background}" 
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Active Jobs" 
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <Button Grid.Column="1" 
                                            x:Name="RefreshJobsButton"
                                            Content="Refresh"
                                            Click="RefreshJobs_Click"
                                            Padding="8,4"/>
                                </Grid>
                                
                                <!-- Job Queue Summary -->
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Queued" 
                                                   FontSize="12"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock x:Name="QueuedJobsCount" 
                                                   Text="0" 
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Running" 
                                                   FontSize="12"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock x:Name="RunningJobsCount" 
                                                   Text="0" 
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="Orange"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="Completed" 
                                                   FontSize="12"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock x:Name="CompletedJobsCount" 
                                                   Text="0" 
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="Green"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="3" Spacing="4">
                                        <TextBlock Text="Failed" 
                                                   FontSize="12"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock x:Name="FailedJobsCount" 
                                                   Text="0" 
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="Red"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Active Jobs List -->
                                <ListView x:Name="ActiveJobsListView" 
                                          MaxHeight="200"
                                          SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="8,4" MinHeight="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Status Icon -->
                                                <FontIcon Grid.Column="0" 
                                                          Glyph="{Binding StatusIcon}"
                                                          Foreground="{Binding StatusColor}"
                                                          FontSize="16"
                                                          Margin="0,0,12,0"/>
                                                
                                                <!-- Job Name -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding JobType}" 
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding JobId}" 
                                                               FontSize="11"
                                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- Progress Bar -->
                                                <StackPanel Grid.Column="2" 
                                                            VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding Progress}"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Height="6"/>
                                                    <TextBlock Text="{Binding ProgressText}"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- Duration -->
                                                <TextBlock Grid.Column="3" 
                                                           Text="{Binding Duration}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                
                                <!-- Empty State -->
                                <TextBlock x:Name="NoActiveJobsText"
                                           Text="No active jobs"
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Logs Content -->
            <Grid x:Name="LogsGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <Grid Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <ComboBox x:Name="LogLevelFilter" PlaceholderText="Log Level" Width="120"/>
                        <TextBox x:Name="LogSearchBox" PlaceholderText="Search logs..." Width="200"/>
                        <Button Content="Export"/>
                    </StackPanel>
                    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background}" CornerRadius="8">
                        <ListView x:Name="LogsListView" Padding="8"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- Traces Content (Phase 5.1.3: Distributed Tracing Visualization) -->
            <Grid x:Name="TracesGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <Grid Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Trace Filters -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <TextBox x:Name="TraceIdSearchBox" 
                                 PlaceholderText="Search by Trace ID or Correlation ID..." 
                                 Width="300"/>
                        <ComboBox x:Name="TraceStatusFilter" PlaceholderText="Status" Width="120">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Success"/>
                            <ComboBoxItem Content="Error"/>
                            <ComboBoxItem Content="Pending"/>
                        </ComboBox>
                        <ComboBox x:Name="TraceTimeRangeFilter" PlaceholderText="Time Range" Width="140">
                            <ComboBoxItem Content="Last 5 min"/>
                            <ComboBoxItem Content="Last 15 min"/>
                            <ComboBoxItem Content="Last 1 hour"/>
                            <ComboBoxItem Content="Last 24 hours"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>
                        <Button x:Name="RefreshTracesButton" Content="Refresh"/>
                        <Button x:Name="ExportTracesButton" Content="Export"/>
                    </StackPanel>
                    
                    <!-- Trace Summary -->
                    <Border Grid.Row="1" 
                            Background="{StaticResource VSQ.Panel.Background}" 
                            CornerRadius="8" 
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Total Traces -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Total Traces" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TotalTracesCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Success Rate -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Success Rate" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TraceSuccessRate" 
                                           Text="100%" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="Green"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Avg Duration -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Avg Duration" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TraceAvgDuration" 
                                           Text="--" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Error Count -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Errors" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TraceErrorCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="Red"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Timeline View -->
                    <Border Grid.Row="2" 
                            Background="{StaticResource VSQ.Panel.Background}" 
                            CornerRadius="8">
                        <Grid Padding="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Timeline Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Trace ID" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="Start Time" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Grid.Column="2" 
                                           Text="Timeline / Spans" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                <TextBlock Grid.Column="3" 
                                           Text="Duration" 
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            </Grid>
                            
                            <!-- Trace List with Timeline Bars -->
                            <ListView x:Name="TracesListView" 
                                      Grid.Row="1"
                                      SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,8" MinHeight="40">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Trace ID -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE9D9;" FontSize="12"/>
                                                <TextBlock Text="{Binding ShortTraceId}" 
                                                           FontFamily="Consolas"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Start Time -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding StartTimeFormatted}" 
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                            
                                            <!-- Timeline Bar (Span Visualization) -->
                                            <Grid Grid.Column="2" 
                                                  Margin="8,0" 
                                                  VerticalAlignment="Center">
                                                <ProgressBar Minimum="0" 
                                                             Maximum="100" 
                                                             Value="{Binding DurationPercent}"
                                                             Height="16"
                                                             CornerRadius="3"/>
                                                <ItemsControl ItemsSource="{Binding Spans}" 
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="{Binding WidthPercent}" 
                                                                    Height="12"
                                                                    Background="{Binding StatusColor}"
                                                                    CornerRadius="2"
                                                                    Margin="1,0"
                                                                    ToolTipService.ToolTip="{Binding TooltipText}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                            
                                            <!-- Duration -->
                                            <TextBlock Grid.Column="3" 
                                                       Text="{Binding DurationFormatted}" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <!-- Empty State -->
                            <StackPanel x:Name="TracesEmptyState" 
                                        Grid.Row="1"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <FontIcon Glyph="&#xE9D9;" FontSize="48" Opacity="0.3"/>
                                <TextBlock Text="No traces available" 
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Traces will appear here when distributed tracing is active" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Network Content -->
            <Grid x:Name="NetworkGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">
                        <Border Background="{StaticResource VSQ.Panel.Background}" 
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Connection Status" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                <Grid RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Backend API:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BackendStatusText" Text="Connected" Foreground="Green"/>
                                    <TextBlock Grid.Row="1" Text="Base URL:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BaseUrlText" Text="http://localhost:8000" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <TextBlock Grid.Row="2" Text="Last Ping:" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LastPingText" Text="--" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="Test Connection" x:Name="TestConnectionButton"/>
                            <Button Content="Reconnect" x:Name="ReconnectButton"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Engines Content -->
            <Grid x:Name="EnginesGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <Grid Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <Button Content="Refresh Engines" x:Name="RefreshEnginesButton"/>
                        <Button Content="Stop All" x:Name="StopAllEnginesButton"/>
                    </StackPanel>
                    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background}" CornerRadius="8">
                        <ListView x:Name="EnginesListView" Padding="8"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- Commands Content -->
            <Grid x:Name="CommandsGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <Grid Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Commands Summary -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource VSQ.Panel.Background}" 
                            CornerRadius="8" 
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Total Commands -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Total Commands" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TotalCommandsCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Working -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Working" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WorkingCommandsCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="Green"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Broken -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Broken" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="BrokenCommandsCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="Red"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Total Executions -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Total Executions" 
                                           FontSize="12"
                                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TotalExecutionsCount" 
                                           Text="0" 
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <Button x:Name="RefreshCommandsButton" Content="Refresh" Click="RefreshCommands_Click"/>
                        <ComboBox x:Name="CommandStatusFilter" PlaceholderText="Filter by Status" Width="150">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Working"/>
                            <ComboBoxItem Content="Broken"/>
                            <ComboBoxItem Content="Unknown"/>
                            <ComboBoxItem Content="Disabled"/>
                        </ComboBox>
                        <TextBox x:Name="CommandSearchBox" PlaceholderText="Search commands..." Width="200"/>
                    </StackPanel>
                    
                    <!-- Commands List -->
                    <Border Grid.Row="2" 
                            Background="{StaticResource VSQ.Panel.Background}" 
                            CornerRadius="8">
                        <ListView x:Name="CommandsListView" Padding="8">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,4" Background="{StaticResource VSQ.Panel.Background}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Status" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Exec" FontWeight="SemiBold" ToolTipService.ToolTip="Can Execute" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="Command ID" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="3" Text="Title" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="4" Text="Shortcut" FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="5" Text="Success" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="6" Text="Fails" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="7" Text="Avg (ms)" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="8" Text="Last Run" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,4" MinHeight="36">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Status Icon -->
                                        <FontIcon Grid.Column="0" 
                                                  Glyph="{Binding StatusGlyph}" 
                                                  Foreground="{Binding StatusColor}"
                                                  FontSize="16"
                                                  VerticalAlignment="Center"
                                                  ToolTipService.ToolTip="{Binding StatusText}"/>
                                        
                                        <!-- CanExecute Icon -->
                                        <FontIcon Grid.Column="1" 
                                                  Glyph="{Binding CanExecuteGlyph}" 
                                                  Foreground="{Binding CanExecuteColor}"
                                                  FontSize="14"
                                                  VerticalAlignment="Center"
                                                  ToolTipService.ToolTip="{Binding CanExecuteText}"/>
                                        
                                        <!-- Command ID -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding CommandId}" 
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- Title -->
                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding Title}" 
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- Shortcut -->
                                        <TextBlock Grid.Column="4" 
                                                   Text="{Binding Shortcut}" 
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        
                                        <!-- Success Count -->
                                        <TextBlock Grid.Column="5" 
                                                   Text="{Binding SuccessCount}" 
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="Green"/>
                                        
                                        <!-- Failure Count -->
                                        <TextBlock Grid.Column="6" 
                                                   Text="{Binding FailureCount}" 
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding FailureColor}"/>
                                        
                                        <!-- Avg Execution Time -->
                                        <TextBlock Grid.Column="7" 
                                                   Text="{Binding AvgExecutionMs}" 
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Last Executed -->
                                        <TextBlock Grid.Column="8" 
                                                   Text="{Binding LastExecutedText}" 
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                   ToolTipService.ToolTip="{Binding LastExecuted}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>

            <!-- Environment Content -->
            <Grid x:Name="EnvironmentGrid" Visibility="Collapsed" Margin="0,48,0,0">
                <ScrollViewer Padding="16">
                    <Border Background="{StaticResource VSQ.Panel.Background}" 
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Environment Variables" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <ListView x:Name="EnvVarsListView" MaxHeight="400"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Legacy grids for backwards compatibility -->
        <Grid x:Name="ErrorsTabGrid" Visibility="Collapsed"/>
        <Grid x:Name="AuditLogTabGrid" Visibility="Collapsed"/>
        <Grid x:Name="AnalyticsTabGrid" Visibility="Collapsed"/>
        <Grid x:Name="PerformanceTabGrid" Visibility="Collapsed"/>
        <Grid x:Name="FeatureFlagsTabGrid" Visibility="Collapsed"/>
        <Grid x:Name="EnvironmentTabGrid" Visibility="Collapsed"/>

        <controls:HelpOverlay x:Name="HelpOverlay" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
