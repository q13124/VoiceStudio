<UserControl x:Class="VoiceStudio.App.Views.Panels.PresetLibraryView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:PresetLibraryView">

  <Grid AutomationProperties.AutomationId="PresetLibraryView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE71B;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Preset Library" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        <TextBlock Text="{x:Bind ViewModel.TotalPresets, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Margin="4,0,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="PresetLibraryView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="PresetLibraryView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Search & Filters -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search presets..."
                 AutomationProperties.AutomationId="PresetLibraryView_SearchBox"/>
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" Header="Type" PlaceholderText="All types"
                    ItemsSource="{x:Bind ViewModel.AvailablePresetTypes, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedPresetType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="PresetLibraryView_TypeFilter"/>
          <ComboBox Grid.Column="1" Header="Category" PlaceholderText="All categories"
                    ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="PresetLibraryView_CategoryFilter"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Preset List -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <Grid>
        <ListView ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                  RightTapped="Preset_RightTapped"
                  AutomationProperties.AutomationId="PresetLibraryView_PresetList">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="8,6" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Category}" FontSize="11"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{Binding PresetType}" FontSize="11"
                               Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Button Command="{Binding DataContext.ApplyPresetCommand, ElementName=PresetLibraryView_PresetList}"
                          CommandParameter="{Binding}" ToolTipService.ToolTip="Apply" Padding="6">
                    <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                  </Button>
                  <Button Command="{Binding DataContext.DeletePresetCommand, ElementName=PresetLibraryView_PresetList}"
                          CommandParameter="{Binding}" ToolTipService.ToolTip="Delete" Padding="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                  </Button>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <TextBlock Text="No presets found" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
      </Grid>
    </Border>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Style="{StaticResource VSQ.Button.Primary}" Command="{x:Bind ViewModel.CreatePresetCommand}"
              AutomationProperties.AutomationId="PresetLibraryView_CreateButton"
              ToolTipService.ToolTip="Create new preset (Ctrl+N)">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE710;" FontSize="14"/>
          <TextBlock Text="New Preset"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="PresetLibraryView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Preset Library Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="PresetLibraryView_LoadingOverlay"/>
  </Grid>
</UserControl>
