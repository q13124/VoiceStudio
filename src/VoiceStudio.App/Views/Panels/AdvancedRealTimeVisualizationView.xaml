<UserControl x:Class="VoiceStudio.App.Views.Panels.AdvancedRealTimeVisualizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls"
             xmlns:local="using:VoiceStudio.App.Views.Panels"
             x:DataType="local:AdvancedRealTimeVisualizationView">
  <Grid AutomationProperties.AutomationId="AdvancedRealTimeVisualizationView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
            Padding="16,12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon Glyph="&#xE9D9;" FontSize="20"/>
        <TextBlock Text="Advanced Visualization"
                   FontWeight="SemiBold"
                   FontSize="{StaticResource VSQ.FontSize.Title}"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
    </Border>
    
    <!-- Content: Under Development -->
    <Grid Grid.Row="1" Padding="32">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MaxWidth="400">
        <FontIcon Glyph="&#xE9D9;" FontSize="64" Opacity="0.4" HorizontalAlignment="Center"/>
        <TextBlock Text="Advanced Real-Time Visualization"
                   FontSize="{StaticResource VSQ.FontSize.Subtitle}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Real-time audio visualization with advanced spectral analysis, 3D visualizations, and GPU-accelerated rendering."
                   FontSize="{StaticResource VSQ.FontSize.Body}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Planned Features:"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBlock Text="- Real-time spectrogram with customizable color maps"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- 3D frequency visualization"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- Formant tracking display"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="- GPU-accelerated rendering"
                       Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
    
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="2" IsVisible="False" Visibility="Collapsed"/>
  </Grid>
</UserControl>
