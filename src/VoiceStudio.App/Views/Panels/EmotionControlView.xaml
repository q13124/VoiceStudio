<UserControl x:Class="VoiceStudio.App.Views.Panels.EmotionControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:converters="using:VoiceStudio.App.Converters"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:EmotionControlView">

  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
    <converters:NullToVisibilityConverter x:Key="NullToVis"/>
  </UserControl.Resources>

  <Grid x:Name="EmotionControlView_Root"
        AutomationProperties.AutomationId="EmotionControlView_Root"
        Background="{StaticResource VSQ.Panel.Background}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Padding="16,12"
          Background="{StaticResource VSQ.Panel.Background.HeaderBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Emotion Control"
                 FontSize="{StaticResource VSQ.FontSize.Title}"
                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                 VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="EmotionControlView_RefreshButton"
                ToolTipService.ToolTip="Refresh (F5)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="EmotionControlView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <ScrollViewer Grid.Row="1" Padding="16,8">
      <StackPanel Spacing="12">

        <!-- Target Audio -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Target Audio" FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <TextBox Text="{x:Bind ViewModel.TargetAudioId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Enter audio ID..."
                     AutomationProperties.AutomationId="EmotionControlView_TargetAudioIdTextBox"/>
          </StackPanel>
        </Border>

        <!-- Primary Emotion -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Primary Emotion" FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEmotions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedPrimaryEmotion, Mode=TwoWay}"
                      PlaceholderText="Select emotion..."
                      HorizontalAlignment="Stretch"
                      AutomationProperties.AutomationId="EmotionControlView_PrimaryEmotionComboBox"/>
            <StackPanel Spacing="2">
              <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                         Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                <Run Text="Intensity:"/>
                <Run Text="{x:Bind ViewModel.PrimaryIntensity, Mode=OneWay}"/>
                <Run Text="%"/>
              </TextBlock>
              <Slider Value="{x:Bind ViewModel.PrimaryIntensity, Mode=TwoWay}"
                      Minimum="0" Maximum="100" StepFrequency="1"
                      AutomationProperties.AutomationId="EmotionControlView_PrimaryIntensitySlider"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Emotion Blending -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <ToggleSwitch IsOn="{x:Bind ViewModel.EnableBlending, Mode=TwoWay}"
                          OnContent="Emotion Blending" OffContent="Emotion Blending"
                          AutomationProperties.AutomationId="EmotionControlView_BlendingToggle"/>

            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.EnableBlending, Mode=OneWay, Converter={StaticResource BoolToVis}}">
              <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEmotions, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSecondaryEmotion, Mode=TwoWay}"
                        PlaceholderText="Secondary emotion..."
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="EmotionControlView_SecondaryEmotionComboBox"/>
              <StackPanel Spacing="2">
                <TextBlock FontSize="{StaticResource VSQ.FontSize.Caption}"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                  <Run Text="Secondary Intensity:"/>
                  <Run Text="{x:Bind ViewModel.SecondaryIntensity, Mode=OneWay}"/>
                  <Run Text="%"/>
                </TextBlock>
                <Slider Value="{x:Bind ViewModel.SecondaryIntensity, Mode=TwoWay}"
                        Minimum="0" Maximum="100" StepFrequency="1"
                        AutomationProperties.AutomationId="EmotionControlView_SecondaryIntensitySlider"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Command="{x:Bind ViewModel.PreviewEmotionCommand}"
                  AutomationProperties.AutomationId="EmotionControlView_PreviewButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE768;" FontSize="14"/>
              <TextBlock Text="Preview"/>
            </StackPanel>
          </Button>
          <Button Command="{x:Bind ViewModel.ApplyEmotionCommand}"
                  Style="{StaticResource AccentButtonStyle}"
                  AutomationProperties.AutomationId="EmotionControlView_ApplyButton">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE73E;" FontSize="14"/>
              <TextBlock Text="Apply Emotion"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Presets -->
        <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Presets" FontSize="{StaticResource VSQ.FontSize.Body}"
                       FontWeight="SemiBold" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>

            <ListView ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                      SelectionMode="Single"
                      RightTapped="Preset_RightTapped"
                      MaxHeight="200"
                      AutomationProperties.AutomationId="EmotionControlView_PresetsList">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:EmotionControlPresetItem">
                  <Grid Padding="8,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Body}"
                                 Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                      <TextBlock Text="{x:Bind BlendingDisplay, Mode=OneWay}"
                                 FontSize="{StaticResource VSQ.FontSize.Caption}"
                                 Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Click="PresetLoadButton_Click"
                            Background="Transparent" Padding="6,4"
                            ToolTipService.ToolTip="Load Preset">
                      <FontIcon Glyph="&#xE896;" FontSize="12"/>
                    </Button>
                    <Button Grid.Column="2" Click="PresetDeleteButton_Click"
                            Background="Transparent" Padding="6,4"
                            ToolTipService.ToolTip="Delete Preset">
                      <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource VSQ.Error.Brush}"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>

            <!-- Save Preset -->
            <StackPanel Spacing="4" Margin="0,4,0,0">
              <TextBox Text="{x:Bind ViewModel.NewPresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Preset name..."
                       AutomationProperties.AutomationId="EmotionControlView_NewPresetNameTextBox"/>
              <TextBox Text="{x:Bind ViewModel.NewPresetDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Description (optional)..."
                       AutomationProperties.AutomationId="EmotionControlView_NewPresetDescTextBox"/>
              <Button Command="{x:Bind ViewModel.SavePresetCommand}"
                      HorizontalAlignment="Right"
                      AutomationProperties.AutomationId="EmotionControlView_SavePresetButton">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                  <TextBlock Text="Save Preset"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}"
                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.Error.Brush}"
                   Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"/>
      </Grid>
    </Border>

    <!-- Loading Overlay -->
    <Grid Grid.RowSpan="3" Background="{StaticResource VSQ.Loading.BackgroundBrush}"
          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48"
                      Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"/>
        <TextBlock Text="Processing..." Foreground="{StaticResource VSQ.Loading.TextBrush}"
                   FontSize="{StaticResource VSQ.FontSize.Body}"/>
      </StackPanel>
    </Grid>

    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3"
                          IsVisible="False" Visibility="Collapsed"
                          AutomationProperties.AutomationId="EmotionControlView_HelpOverlay"/>
  </Grid>
</UserControl>
