<UserControl x:Class="VoiceStudio.App.Views.Panels.EmotionControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:StringFormatConverter x:Key="StringFormatConverter" />
        <converters:NumberFormatConverter x:Key="PercentFormatConverter" Format="F0" Suffix="%" />
        <converters:NumberFormatConverter x:Key="NumberFormatConverter" Format="F0" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    Text="Emotion Control"
                    Style="{StaticResource VSQ.Text.Title}"
                    VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                    Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                    <Button Content="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}" />
                    <Button Content="?"
                        Click="HelpButton_Click"
                        Style="{StaticResource VSQ.Button.Icon}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" Padding="{StaticResource VSQ.Spacing.Medium}">
            <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Medium}">
                <!-- Target Audio -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Target Audio" Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <TextBlock Text="Audio ID:" Width="100"
                                Style="{StaticResource VSQ.Text.Body}" VerticalAlignment="Center" />
                            <TextBox Text="{x:Bind ViewModel.TargetAudioId, Mode=TwoWay}"
                                Width="200"
                                PlaceholderText="Enter audio ID" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Primary Emotion -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Primary Emotion" Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />

                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <TextBlock Text="Emotion:" Width="100"
                                Style="{StaticResource VSQ.Text.Body}" VerticalAlignment="Center" />
                            <ComboBox
                                ItemsSource="{x:Bind ViewModel.AvailableEmotions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedPrimaryEmotion, Mode=TwoWay}"
                                Width="200"
                                PlaceholderText="Select emotion" />
                            <Button Content="Load Emotions"
                                Command="{x:Bind ViewModel.LoadEmotionsCommand, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <TextBlock Text="Intensity:" Width="100"
                                Style="{StaticResource VSQ.Text.Body}" VerticalAlignment="Center" />
                            <Slider Value="{x:Bind ViewModel.PrimaryIntensity, Mode=TwoWay}"
                                Minimum="0" Maximum="100"
                                TickFrequency="10"
                                Width="200" />
                            <TextBlock
                                Text="{x:Bind ViewModel.PrimaryIntensity, Mode=OneWay, Converter={StaticResource PercentFormatConverter}}"
                                Style="{StaticResource VSQ.Text.Caption}"
                                VerticalAlignment="Center"
                                Width="50" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Secondary Emotion (Blending) -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Emotion Blending" Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />

                        <ToggleSwitch IsOn="{x:Bind ViewModel.EnableBlending, Mode=TwoWay}"
                            OffContent="Blending Disabled"
                            OnContent="Blending Enabled" />

                        <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}"
                            Visibility="{x:Bind ViewModel.EnableBlending, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Secondary:" Width="100"
                                    Style="{StaticResource VSQ.Text.Body}"
                                    VerticalAlignment="Center" />
                                <ComboBox
                                    ItemsSource="{x:Bind ViewModel.AvailableEmotions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedSecondaryEmotion, Mode=TwoWay}"
                                    Width="200"
                                    PlaceholderText="Select secondary emotion" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="Intensity:" Width="100"
                                    Style="{StaticResource VSQ.Text.Body}"
                                    VerticalAlignment="Center" />
                                <Slider Value="{x:Bind ViewModel.SecondaryIntensity, Mode=TwoWay}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="10"
                                    Width="200" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SecondaryIntensity, Mode=OneWay, Converter={StaticResource PercentFormatConverter}}"
                                    Style="{StaticResource VSQ.Text.Caption}"
                                    VerticalAlignment="Center"
                                    Width="50" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Actions" Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <Button Content="Preview Emotion"
                                Command="{x:Bind ViewModel.PreviewEmotionCommand, Mode=OneWay}" />
                            <Button Content="Apply Emotion"
                                Command="{x:Bind ViewModel.ApplyEmotionCommand, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock
                            Text="{x:Bind ViewModel.PreviewAudioId, Mode=OneWay}"
                            Style="{StaticResource VSQ.Text.Caption}"
                            Visibility="{x:Bind ViewModel.PreviewAudioId, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Presets -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                Text="Emotion Presets"
                                Style="{StaticResource VSQ.Text.Heading}"
                                Margin="0,0,0,4" />
                            <Button Grid.Column="1"
                                Content="Load Presets"
                                Command="{x:Bind ViewModel.LoadPresetsCommand, Mode=OneWay}" />
                        </Grid>

                        <ListView ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                            RightTapped="Preset_RightTapped"
                            Height="200">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="{StaticResource VSQ.Spacing.Value.Small}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}"
                                                Style="{StaticResource VSQ.Text.Body}"
                                                FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}"
                                                Style="{StaticResource VSQ.Text.Caption}"
                                                Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                TextTrimming="CharacterEllipsis"
                                                MaxLines="1" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource VSQ.Text.Caption}"
                                                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                                                    <Run Text="{Binding PrimaryEmotion}" /> (<Run
                                                        Text="{Binding PrimaryIntensity, Converter={StaticResource NumberFormatConverter}}" />
                                                    %) </TextBlock>
                                                <TextBlock Text=" + "
                                                    Style="{StaticResource VSQ.Text.Caption}"
                                                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                    Visibility="{Binding SecondaryEmotion, Converter={StaticResource NullToVisibilityConverter}}" />
                                                <TextBlock Style="{StaticResource VSQ.Text.Caption}"
                                                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                    Visibility="{Binding SecondaryEmotion, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Run Text="{Binding SecondaryEmotion}" /> (<Run
                                                        Text="{Binding SecondaryIntensity, Converter={StaticResource NumberFormatConverter}}" />
                                                    %) </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                            <Button Content="Load"
                                                Click="PresetLoadButton_Click" />
                                            <Button Content="Delete"
                                                Click="PresetDeleteButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Save Preset -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="{StaticResource VSQ.Spacing.Medium}">
                    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                        <TextBlock Text="Save Preset" Style="{StaticResource VSQ.Text.Heading}"
                            Margin="0,0,0,4" />

                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <TextBlock Text="Name:" Width="100"
                                Style="{StaticResource VSQ.Text.Body}" VerticalAlignment="Center" />
                            <TextBox Text="{x:Bind ViewModel.NewPresetName, Mode=TwoWay}"
                                Width="200"
                                PlaceholderText="Preset name" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                            <TextBlock Text="Description:" Width="100"
                                Style="{StaticResource VSQ.Text.Body}" VerticalAlignment="Center" />
                            <TextBox Text="{x:Bind ViewModel.NewPresetDescription, Mode=TwoWay}"
                                Width="200"
                                PlaceholderText="Optional description"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="60" />
                        </StackPanel>

                        <Button Content="Save Preset"
                            Command="{x:Bind ViewModel.SavePresetCommand, Mode=OneWay}"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2"
            Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
                <TextBlock Grid.Column="1"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Style="{StaticResource VSQ.Text.Caption}"
                    Foreground="Red"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay"
            IsVisible="False"
            Visibility="Collapsed" />
    </Grid>
</UserControl>