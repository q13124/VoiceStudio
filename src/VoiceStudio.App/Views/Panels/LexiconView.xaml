<UserControl x:Class="VoiceStudio.App.Views.Panels.LexiconView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:LexiconView">
    <Grid x:Name="LexiconView_Root" 
          AutomationProperties.AutomationId="LexiconView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Lexicon" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{x:Bind ViewModel.RefreshCommand}"
                            AutomationProperties.AutomationId="LexiconView_RefreshButton"
                            ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="12">
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Create Lexicon" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.NewLexiconName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Lexicon name"
                                 AutomationProperties.AutomationId="LexiconView_NewLexiconName"/>
                        <TextBox Text="{x:Bind ViewModel.NewLexiconLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Language (e.g. en)"
                                 AutomationProperties.AutomationId="LexiconView_NewLexiconLanguage"/>
                        <TextBox Text="{x:Bind ViewModel.NewLexiconDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Description (optional)"
                                 AutomationProperties.AutomationId="LexiconView_NewLexiconDescription"/>
                        <Button Command="{x:Bind ViewModel.CreateLexiconCommand}"
                                Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="LexiconView_CreateButton">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                <TextBlock Text="Create"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Lexicons" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.Lexicons, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLexicon, Mode=TwoWay}"
                                  MaxHeight="300"
                                  AutomationProperties.AutomationId="LexiconView_LexiconList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Language}" FontSize="11" Opacity="0.6"/>
                                            <TextBlock Text="{Binding EntryCountDisplay}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Command="{x:Bind ViewModel.UpdateLexiconCommand}"
                                    AutomationProperties.AutomationId="LexiconView_UpdateLexiconButton"
                                    ToolTipService.ToolTip="Update selected lexicon">
                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                            </Button>
                            <Button Command="{x:Bind ViewModel.DeleteLexiconCommand}"
                                    AutomationProperties.AutomationId="LexiconView_DeleteLexiconButton"
                                    ToolTipService.ToolTip="Delete selected lexicon">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="12">
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Add Entry" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{x:Bind ViewModel.NewEntryWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Word"
                                         AutomationProperties.AutomationId="LexiconView_NewEntryWord"/>
                                <TextBox Grid.Column="1"
                                         Text="{x:Bind ViewModel.NewEntryPronunciation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Pronunciation (IPA)"
                                         AutomationProperties.AutomationId="LexiconView_NewEntryPronunciation"/>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{x:Bind ViewModel.NewEntryPartOfSpeech, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Part of speech"
                                         AutomationProperties.AutomationId="LexiconView_NewEntryPOS"/>
                                <TextBox Grid.Column="1"
                                         Text="{x:Bind ViewModel.NewEntryNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Notes"
                                         AutomationProperties.AutomationId="LexiconView_NewEntryNotes"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Command="{x:Bind ViewModel.CreateEntryCommand}"
                                        Style="{StaticResource VSQ.Button.Primary}"
                                        AutomationProperties.AutomationId="LexiconView_AddEntryButton">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        <TextBlock Text="Add Entry"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.UpdateEntryCommand}"
                                        AutomationProperties.AutomationId="LexiconView_UpdateEntryButton"
                                        ToolTipService.ToolTip="Update selected entry">
                                    <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                                </Button>
                                <Button Command="{x:Bind ViewModel.DeleteEntryCommand}"
                                        AutomationProperties.AutomationId="LexiconView_DeleteEntryButton"
                                        ToolTipService.ToolTip="Delete selected entry">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Entries" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <ListView ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
                                      MaxHeight="300"
                                      AutomationProperties.AutomationId="LexiconView_EntryList">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Word}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Pronunciation}" FontStyle="Italic"/>
                                            <TextBlock Grid.Column="2" Text="{Binding PartOfSpeechDisplay}" FontSize="11" Opacity="0.6"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search Entries" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Search entries..."
                                         AutomationProperties.AutomationId="LexiconView_SearchBox"/>
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.SearchEntriesCommand}"
                                        AutomationProperties.AutomationId="LexiconView_SearchButton">
                                    <FontIcon Glyph="&#xE721;" FontSize="14"/>
                                </Button>
                            </Grid>
                            <ListView ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                                      MaxHeight="200"
                                      AutomationProperties.AutomationId="LexiconView_SearchResults">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="4">
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="{Binding Entry.Word}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding Entry.Pronunciation}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LexiconName}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <InfoBar IsOpen="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Severity="Informational"
                             Title="Loading..." IsClosable="False"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
