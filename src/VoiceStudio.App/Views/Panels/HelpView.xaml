<UserControl x:Class="VoiceStudio.App.Views.Panels.HelpView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:HelpView">
    <Grid x:Name="HelpView_Root" 
          AutomationProperties.AutomationId="HelpView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Help" 
                           FontSize="{StaticResource VSQ.FontSize.Title}" 
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.AutomationId="HelpView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="12">
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search help topics..."
                                 AutomationProperties.AutomationId="HelpView_SearchBox"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                  PlaceholderText="All Categories" HorizontalAlignment="Stretch"
                                  AutomationProperties.AutomationId="HelpView_CategoryFilter"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Topics" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.Topics, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedTopic, Mode=TwoWay}"
                                  MaxHeight="400"
                                  AutomationProperties.AutomationId="HelpView_TopicList">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="4">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.6"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="12">
                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.SelectedTopic.Title, Mode=OneWay, FallbackValue='Select a topic'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                       AutomationProperties.AutomationId="HelpView_TopicTitle"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedTopic.Category, Mode=OneWay, FallbackValue=''}"
                                       FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedTopic.Content, Mode=OneWay, FallbackValue='Select a help topic from the list to view its content.'}"
                                       TextWrapping="Wrap" FontSize="13"
                                       AutomationProperties.AutomationId="HelpView_TopicContent"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Keyboard Shortcuts" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                            <ListView ItemsSource="{x:Bind ViewModel.Shortcuts, Mode=OneWay}"
                                      MaxHeight="250"
                                      AutomationProperties.AutomationId="HelpView_ShortcutsList">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4" ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource VSQ.Panel.Background}"
                                                    CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="12"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="2"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
