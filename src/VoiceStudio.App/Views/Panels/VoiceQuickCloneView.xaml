<UserControl x:Class="VoiceStudio.App.Views.Panels.VoiceQuickCloneView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:VoiceQuickCloneView">

  <Grid AutomationProperties.AutomationId="VoiceQuickCloneView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8D7;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Quick Clone" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.ResetCommand}"
                AutomationProperties.AutomationId="VoiceQuickCloneView_ResetButton"
                ToolTipService.ToolTip="Reset (Ctrl+R)">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="VoiceQuickCloneView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Audio File Selection -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Audio Source" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" IsReadOnly="True"
                   Text="{x:Bind ViewModel.AudioFileName, Mode=OneWay, FallbackValue='No file selected', TargetNullValue='No file selected'}"
                   PlaceholderText="Select an audio file..."
                   AutomationProperties.AutomationId="VoiceQuickCloneView_AudioFileDisplay"/>
          <Button Grid.Column="1" Style="{StaticResource VSQ.Button.Primary}"
                  Command="{x:Bind ViewModel.BrowseAudioCommand}"
                  AutomationProperties.AutomationId="VoiceQuickCloneView_BrowseButton"
                  ToolTipService.ToolTip="Browse audio file (Ctrl+O)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xED25;" FontSize="14"/>
              <TextBlock Text="Browse"/>
            </StackPanel>
          </Button>
        </Grid>

        <StackPanel Spacing="4">
          <TextBlock Text="Profile Name (optional)" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBox Text="{x:Bind ViewModel.ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Auto-generated from filename"
                   AutomationProperties.AutomationId="VoiceQuickCloneView_ProfileNameTextBox"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Auto-Detected Settings -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Auto-Detected Settings" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="24">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Engine" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.DetectedEngine, Mode=OneWay, FallbackValue='Pending...', TargetNullValue='Pending...'}"
                       FontSize="14" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                       AutomationProperties.AutomationId="VoiceQuickCloneView_DetectedEngine"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Quality Mode" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.DetectedQualityMode, Mode=OneWay, FallbackValue='Pending...', TargetNullValue='Pending...'}"
                       FontSize="14" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                       AutomationProperties.AutomationId="VoiceQuickCloneView_DetectedQualityMode"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Clone Action -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="12">
        <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.QuickCloneCommand}"
                AutomationProperties.AutomationId="VoiceQuickCloneView_CloneButton"
                ToolTipService.ToolTip="Start quick clone (Ctrl+Q)">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE8D7;" FontSize="16"/>
            <TextBlock Text="Quick Clone" FontSize="14" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>

        <ProgressBar Value="{x:Bind ViewModel.ProcessingProgress, Mode=OneWay}"
                     Maximum="1.0" Minimum="0.0"
                     Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                     AutomationProperties.AutomationId="VoiceQuickCloneView_ProgressBar"/>

        <TextBlock Text="{x:Bind ViewModel.ProcessingStatus, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                   FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                   HorizontalAlignment="Center"
                   Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"/>
      </StackPanel>
    </Border>

    <!-- Results -->
    <Border Grid.Row="4" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="16" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8D6;" FontSize="12" Foreground="{StaticResource VSQ.Accent.GreenBrush}"/>
          <TextBlock Text="Results" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>

        <Grid ColumnSpacing="12" RowSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile ID:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="0" Grid.Column="1"
                     Text="{x:Bind ViewModel.CreatedProfileId, Mode=OneWay, FallbackValue='--', TargetNullValue='--'}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}" IsTextSelectionEnabled="True"
                     AutomationProperties.AutomationId="VoiceQuickCloneView_ProfileIdResult"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Audio URL:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="1" Grid.Column="1"
                     Text="{x:Bind ViewModel.CreatedProfileUrl, Mode=OneWay, FallbackValue='--', TargetNullValue='--'}"
                     FontSize="12" Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                     IsTextSelectionEnabled="True" TextWrapping="Wrap"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Quality:" FontSize="12"
                     Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
          <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12"
                     Foreground="{StaticResource VSQ.Accent.GreenBrush}"
                     AutomationProperties.AutomationId="VoiceQuickCloneView_QualityResult">
            <Run Text="{x:Bind ViewModel.QualityScore, Mode=OneWay}"/>
          </TextBlock>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="5"
             AutomationProperties.AutomationId="VoiceQuickCloneView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Quick Clone Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred', TargetNullValue='An error occurred'}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="6" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="6"
                             IsLoading="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                             AutomationProperties.AutomationId="VoiceQuickCloneView_LoadingOverlay"/>
  </Grid>
</UserControl>
