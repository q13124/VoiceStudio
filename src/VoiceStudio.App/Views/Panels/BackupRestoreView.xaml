<UserControl x:Class="VoiceStudio.App.Views.Panels.BackupRestoreView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:BackupRestoreView">

    <Grid AutomationProperties.AutomationId="BackupRestoreView_Root" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE895;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                <TextBlock Text="Backup &amp; Restore" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.LoadBackupsCommand}"
                        AutomationProperties.AutomationId="BackupRestoreView_RefreshButton"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button Click="HelpButton_Click"
                        AutomationProperties.AutomationId="BackupRestoreView_HelpButton"
                        ToolTipService.ToolTip="Help">
                    <FontIcon Glyph="&#xE897;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Create Backup -->
        <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                    <TextBlock Text="Create Backup" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <TextBox Text="{x:Bind ViewModel.BackupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Backup name"
                         AutomationProperties.AutomationId="BackupRestoreView_BackupNameInput"/>
                <TextBox Text="{x:Bind ViewModel.BackupDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Description (optional)" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="48"
                         AutomationProperties.AutomationId="BackupRestoreView_DescriptionInput"/>

                <!-- Include Options -->
                <TextBlock Text="Include:" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Content="Profiles" IsChecked="{x:Bind ViewModel.IncludeProfiles, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_IncludeProfiles"/>
                    <CheckBox Content="Projects" IsChecked="{x:Bind ViewModel.IncludeProjects, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_IncludeProjects"/>
                    <CheckBox Content="Settings" IsChecked="{x:Bind ViewModel.IncludeSettings, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_IncludeSettings"/>
                    <CheckBox Content="Models" IsChecked="{x:Bind ViewModel.IncludeModels, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_IncludeModels"/>
                </StackPanel>

                <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CreateBackupCommand}"
                        AutomationProperties.AutomationId="BackupRestoreView_CreateButton">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE895;" FontSize="14"/>
                        <TextBlock Text="Create Backup"/>
                    </StackPanel>
                </Button>

                <ProgressRing IsActive="{x:Bind ViewModel.IsCreatingBackup, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsCreatingBackup, Mode=OneWay}"
                              Width="24" Height="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Backup List -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Available Backups" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}" Margin="0,0,0,8"/>
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Backups, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedBackup, Mode=TwoWay}"
                          RightTapped="Backup_RightTapped"
                          AutomationProperties.AutomationId="BackupRestoreView_BackupList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Created}" FontSize="10"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                                   Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="P" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                   Visibility="{Binding IncludesProfiles}"/>
                                        <TextBlock Text="J" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                   Visibility="{Binding IncludesProjects}"/>
                                        <TextBlock Text="S" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                   Visibility="{Binding IncludesSettings}"/>
                                        <TextBlock Text="M" FontSize="9" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                                   Visibility="{Binding IncludesModels}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding DataContext.RestoreBackupCommand, ElementName=BackupRestoreView_BackupList}"
                                        CommandParameter="{Binding}" ToolTipService.ToolTip="Restore" Padding="6">
                                    <FontIcon Glyph="&#xE777;" FontSize="14"/>
                                </Button>
                                <Button Grid.Column="2"
                                        Command="{Binding DataContext.DeleteBackupCommand, ElementName=BackupRestoreView_BackupList}"
                                        CommandParameter="{Binding}" ToolTipService.ToolTip="Delete" Padding="6">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Restore Options & Upload -->
        <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <TextBlock Text="Restore Options:" FontSize="12" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Content="Profiles" IsChecked="{x:Bind ViewModel.RestoreProfiles, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_RestoreProfiles"/>
                    <CheckBox Content="Projects" IsChecked="{x:Bind ViewModel.RestoreProjects, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_RestoreProjects"/>
                    <CheckBox Content="Settings" IsChecked="{x:Bind ViewModel.RestoreSettings, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_RestoreSettings"/>
                    <CheckBox Content="Models" IsChecked="{x:Bind ViewModel.RestoreModels, Mode=TwoWay}"
                              AutomationProperties.AutomationId="BackupRestoreView_RestoreModels"/>
                </StackPanel>
                <Button Command="{x:Bind ViewModel.UploadBackupCommand}" HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="BackupRestoreView_UploadButton">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE898;" FontSize="14"/>
                        <TextBlock Text="Upload Backup File"/>
                    </StackPanel>
                </Button>
                <ProgressRing IsActive="{x:Bind ViewModel.IsRestoring, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsRestoring, Mode=OneWay}"
                              Width="24" Height="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="4"
                 AutomationProperties.AutomationId="BackupRestoreView_ErrorInfoBar"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error" Title="Backup &amp; Restore Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
                 IsClosable="True"/>

        <!-- HelpOverlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

        <!-- Loading Overlay -->
        <controls:LoadingOverlay Grid.RowSpan="5"
                                 IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                 AutomationProperties.AutomationId="BackupRestoreView_LoadingOverlay"/>
    </Grid>
</UserControl>
