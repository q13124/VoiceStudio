<UserControl x:Class="VoiceStudio.App.Views.Panels.EngineRecommendationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels"
    x:DataType="local:EngineRecommendationView">
    <Grid AutomationProperties.AutomationId="EngineRecommendationView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE735;" FontSize="20"/>
                    <TextBlock Text="Engine Recommendation"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VSQ.FontSize.Title}"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{x:Bind ViewModel.GetRecommendationsCommand}"
                        ToolTipService.ToolTip="Get recommendations"
                        AutomationProperties.AutomationId="EngineRecommendationView_GetButton">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="12">

                <!-- Quality Criteria -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quality Requirements" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <NumberBox Header="Min MOS Score" Value="{x:Bind ViewModel.MinMosScore, Mode=TwoWay}"
                                   Minimum="0" Maximum="5" SpinButtonPlacementMode="Compact"
                                   PlaceholderText="e.g. 3.5"
                                   AutomationProperties.AutomationId="EngineRecommendationView_MinMos"/>
                        <NumberBox Header="Min Similarity" Value="{x:Bind ViewModel.MinSimilarity, Mode=TwoWay}"
                                   Minimum="0" Maximum="1" SpinButtonPlacementMode="Compact"
                                   PlaceholderText="e.g. 0.85"
                                   AutomationProperties.AutomationId="EngineRecommendationView_MinSimilarity"/>
                        <NumberBox Header="Min Naturalness" Value="{x:Bind ViewModel.MinNaturalness, Mode=TwoWay}"
                                   Minimum="0" Maximum="1" SpinButtonPlacementMode="Compact"
                                   PlaceholderText="e.g. 0.8"
                                   AutomationProperties.AutomationId="EngineRecommendationView_MinNaturalness"/>
                    </StackPanel>
                </Border>

                <!-- Preferences -->
                <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                        CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Preferences" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.PreferSpeed, Mode=TwoWay}"
                                      Header="Prefer Speed Over Quality"
                                      AutomationProperties.AutomationId="EngineRecommendationView_PreferSpeedToggle"/>
                        <TextBox Header="Quality Tier" Text="{x:Bind ViewModel.QualityTier, Mode=TwoWay}"
                                 PlaceholderText="e.g. high, medium, low"
                                 AutomationProperties.AutomationId="EngineRecommendationView_QualityTier"/>
                    </StackPanel>
                </Border>

                <!-- Get Recommendations Button -->
                <Button Command="{x:Bind ViewModel.GetRecommendationsCommand}"
                        Content="Get Recommendations"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="EngineRecommendationView_RunButton"/>

                <!-- Recommendations List -->
                <ListView ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}"
                          RightTapped="Recommendation_RightTapped"
                          AutomationProperties.AutomationId="EngineRecommendationView_RecommendationList">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,4">
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EngineName}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ScoreDisplay}" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Reason}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="MOS" FontSize="10" Opacity="0.5"/>
                                            <TextBlock Text="{Binding MosScore}" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Similarity" FontSize="10" Opacity="0.5"/>
                                            <TextBlock Text="{Binding Similarity}" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Speed" FontSize="10" Opacity="0.5"/>
                                            <TextBlock Text="{Binding SpeedFactor}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="16" Height="16"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           AutomationProperties.AutomationId="EngineRecommendationView_StatusText"/>
            </Grid>
        </Border>

        <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="3" IsVisible="False" Visibility="Collapsed"/>
    </Grid>
</UserControl>
