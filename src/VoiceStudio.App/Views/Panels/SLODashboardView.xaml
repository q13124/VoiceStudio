<UserControl x:Class="VoiceStudio.App.Views.Panels.SLODashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:local="using:VoiceStudio.App.Views.Panels">
    <Grid x:Name="SLODashboardView_Root" 
          AutomationProperties.AutomationId="SLODashboardView_Root"
          Background="{StaticResource VSQ.Panel.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                Padding="{StaticResource VSQ.Spacing.Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="SLO Dashboard" 
                               FontSize="{StaticResource VSQ.FontSize.Title}" 
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}" />
                    <Border Background="{StaticResource VSQ.Status.HealthyBrush}" 
                            CornerRadius="4" 
                            Padding="8,4" 
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.AllSlosHealthy, Mode=OneWay}">
                        <TextBlock Text="All SLOs Healthy" 
                                   FontSize="12" 
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="8">
                    <Button Content="Refresh" 
                            Command="{x:Bind ViewModel.RefreshCommand}"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button x:Name="HelpButton" 
                            Content="?" 
                            Click="HelpButton_Click"
                            Width="32"
                            Style="{StaticResource DefaultButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary Bar -->
        <Border Grid.Row="1" 
                Background="{StaticResource VSQ.Panel.Background.SecondaryBrush}" 
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Total SLOs -->
                <StackPanel Grid.Column="0" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="Total SLOs" 
                               FontSize="12" 
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalSloCount, Mode=OneWay}" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                </StackPanel>

                <!-- Healthy -->
                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="Healthy" 
                               FontSize="12" 
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.HealthySloCount, Mode=OneWay}" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Status.HealthyBrush}"/>
                </StackPanel>

                <!-- Warning -->
                <StackPanel Grid.Column="2" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="Warning" 
                               FontSize="12" 
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.WarningSloCount, Mode=OneWay}" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Status.DegradedBrush}"/>
                </StackPanel>

                <!-- Critical -->
                <StackPanel Grid.Column="3" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="Critical" 
                               FontSize="12" 
                               Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.CriticalSloCount, Mode=OneWay}" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VSQ.Status.UnhealthyBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: SLO Gauges Grid -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="16">
            <ItemsControl ItemsSource="{x:Bind ViewModel.SloMetrics, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <toolkit:UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:SloMetric">
                        <Border Background="{StaticResource VSQ.Panel.Background.CardBrush}" 
                                CornerRadius="8" 
                                Padding="16"
                                BorderBrush="{x:Bind StatusBorderBrush, Mode=OneWay}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- SLO Name -->
                                <TextBlock Grid.Row="0" 
                                           Text="{x:Bind Name}" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Gauge Visualization -->
                                <Grid Grid.Row="1" 
                                      Height="100" 
                                      Margin="0,12,0,0">
                                    <!-- Background Arc -->
                                    <ProgressRing Width="80" 
                                                  Height="80" 
                                                  IsIndeterminate="False"
                                                  Value="{x:Bind CurrentValuePercent, Mode=OneWay}"
                                                  Maximum="100"
                                                  Foreground="{x:Bind StatusColor, Mode=OneWay}"/>
                                    <!-- Center Value -->
                                    <StackPanel VerticalAlignment="Center" 
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind CurrentValueFormatted, Mode=OneWay}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind Unit}" 
                                                   FontSize="10" 
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Target and Thresholds -->
                                <StackPanel Grid.Row="2" 
                                            Margin="0,12,0,0" 
                                            Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Target:" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{x:Bind TargetFormatted}" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Warning:" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{x:Bind WarningThresholdFormatted}" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource VSQ.Status.DegradedBrush}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Status Badge -->
                                <Border Grid.Row="3" 
                                        Background="{x:Bind StatusBadgeBackground, Mode=OneWay}" 
                                        CornerRadius="4" 
                                        Padding="8,4" 
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{x:Bind Status, Mode=OneWay}" 
                                               FontSize="11" 
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" 
              Background="#80000000" 
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center">
                <ProgressRing IsActive="True" 
                              Width="48" 
                              Height="48"/>
                <TextBlock Text="Loading SLO data..." 
                           Margin="0,16,0,0" 
                           Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Help Overlay -->
        <controls:HelpOverlay x:Name="HelpOverlay" 
                              Grid.RowSpan="3"
                              IsVisible="False" 
                              Visibility="Collapsed" />
    </Grid>
</UserControl>
