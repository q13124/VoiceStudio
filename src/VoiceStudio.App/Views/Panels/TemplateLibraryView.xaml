<UserControl x:Class="VoiceStudio.App.Views.Panels.TemplateLibraryView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:VoiceStudio.App.Controls"
  xmlns:local="using:VoiceStudio.App.Views.Panels"
  x:DataType="local:TemplateLibraryView">

  <Grid AutomationProperties.AutomationId="TemplateLibraryView_Root" Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8A5;" FontSize="24" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
        <TextBlock Text="Template Library" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Command="{x:Bind ViewModel.RefreshCommand}"
                AutomationProperties.AutomationId="TemplateLibraryView_RefreshButton"
                ToolTipService.ToolTip="Refresh">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <Button Click="HelpButton_Click"
                AutomationProperties.AutomationId="TemplateLibraryView_HelpButton"
                ToolTipService.ToolTip="Help">
          <FontIcon Glyph="&#xE897;" FontSize="14"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Search & Category Filter -->
    <Border Grid.Row="1" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search templates..."
                 AutomationProperties.AutomationId="TemplateLibraryView_SearchBox"/>
        <ComboBox Header="Category" PlaceholderText="All categories" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                  AutomationProperties.AutomationId="TemplateLibraryView_CategoryFilter"/>
      </StackPanel>
    </Border>

    <!-- Template List -->
    <Border Grid.Row="2" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <ListView ItemsSource="{x:Bind ViewModel.Templates, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedTemplate, Mode=TwoWay}"
                AutomationProperties.AutomationId="TemplateLibraryView_TemplateList">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8,6" ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Category}" FontSize="11"
                             Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
                  <TextBlock FontSize="11" Foreground="{StaticResource VSQ.Text.SecondaryBrush}">
                    <Run Text="Used:"/>
                    <Run Text="{Binding UsageCount}"/>
                  </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="11" TextTrimming="CharacterEllipsis" MaxLines="1"
                           Foreground="{StaticResource VSQ.Text.SecondaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Command="{Binding DataContext.ApplyTemplateCommand, ElementName=TemplateLibraryView_TemplateList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Apply" Padding="6">
                  <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                </Button>
                <Button Command="{Binding DataContext.DeleteTemplateCommand, ElementName=TemplateLibraryView_TemplateList}"
                        CommandParameter="{Binding}" ToolTipService.ToolTip="Delete" Padding="6">
                  <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                </Button>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Border>

    <!-- Create Template Section -->
    <Border Grid.Row="3" Background="{StaticResource VSQ.Panel.Background.DarkBrush}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource VSQ.Accent.CyanBrush}"/>
          <TextBlock Text="Create Template" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource VSQ.Text.PrimaryBrush}"/>
        </StackPanel>
        <TextBox Text="{x:Bind ViewModel.CreatingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Template name"
                 AutomationProperties.AutomationId="TemplateLibraryView_NameInput"/>
        <TextBox Text="{x:Bind ViewModel.CreatingCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Category (optional)"
                 AutomationProperties.AutomationId="TemplateLibraryView_CategoryInput"/>
        <TextBox Text="{x:Bind ViewModel.CreatingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Description (optional)" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                 AutomationProperties.AutomationId="TemplateLibraryView_DescriptionInput"/>
        <Button Style="{StaticResource VSQ.Button.Primary}" HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CreateTemplateCommand}"
                AutomationProperties.AutomationId="TemplateLibraryView_CreateButton">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE710;" FontSize="14"/>
            <TextBlock Text="Create Template"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Error InfoBar -->
    <InfoBar Grid.Row="4"
             AutomationProperties.AutomationId="TemplateLibraryView_ErrorInfoBar"
             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
             Severity="Error" Title="Template Library Error"
             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='', TargetNullValue=''}"
             IsClosable="True"/>

    <!-- HelpOverlay -->
    <controls:HelpOverlay x:Name="HelpOverlay" Grid.RowSpan="5" IsVisible="False" Visibility="Collapsed"/>

    <!-- Loading Overlay -->
    <controls:LoadingOverlay Grid.RowSpan="5"
                             IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             AutomationProperties.AutomationId="TemplateLibraryView_LoadingOverlay"/>
  </Grid>
</UserControl>
