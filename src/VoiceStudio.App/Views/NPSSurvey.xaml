<!--
  NPSSurvey.xaml - Net Promoter Score survey dialog
  
  AI GUIDELINES:
  - Follows Phase 1 XAML Reliability patterns (x:DataType, d:DataContext, FallbackValue)
  - Uses VSQ design tokens for consistent styling
  - NPS scale: 0-10 with category labels (Detractor, Passive, Promoter)
  - Bindings use {x:Bind} with Mode and FallbackValue where appropriate
-->
<ContentDialog
    x:Class="VoiceStudio.App.Views.NPSSurvey"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VoiceStudio.App.ViewModels"
    xmlns:converters="using:VoiceStudio.App.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:NPSSurveyViewModel, IsDesignTimeCreatable=False}"
    x:DataType="vm:NPSSurveyViewModel"
    Title="Quick Feedback"
    PrimaryButtonText="Submit"
    PrimaryButtonCommand="{x:Bind ViewModel.SubmitSurveyCommand, Mode=OneWay}"
    SecondaryButtonText="Maybe Later"
    SecondaryButtonCommand="{x:Bind ViewModel.SetRemindLaterCommand, Mode=OneWay}"
    CloseButtonText="Dismiss"
    CloseButtonCommand="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
    DefaultButton="Primary"
    x:Name="NPSSurveyDialog">

    <ContentDialog.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        
        <!-- Score button style -->
        <Style x:Key="NPSScoreButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.Resources>

    <Grid MinWidth="500" MinHeight="320" Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock 
                Text="How likely are you to recommend VoiceStudio?" 
                Style="{StaticResource SubtitleTextBlockStyle}"
                TextWrapping="Wrap"
                Margin="0,0,0,4" />
            <TextBlock 
                Text="Your feedback helps us improve the experience for everyone."
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- NPS Score Selection (0-10) -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Score buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <Button Content="0" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="0"
                        ToolTipService.ToolTip="Not at all likely"
                        AutomationProperties.Name="Score 0 - Not at all likely" />
                <Button Content="1" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="1"
                        AutomationProperties.Name="Score 1" />
                <Button Content="2" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="2"
                        AutomationProperties.Name="Score 2" />
                <Button Content="3" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="3"
                        AutomationProperties.Name="Score 3" />
                <Button Content="4" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="4"
                        AutomationProperties.Name="Score 4" />
                <Button Content="5" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="5"
                        ToolTipService.ToolTip="Neutral"
                        AutomationProperties.Name="Score 5 - Neutral" />
                <Button Content="6" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="6"
                        AutomationProperties.Name="Score 6" />
                <Button Content="7" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="7"
                        AutomationProperties.Name="Score 7" />
                <Button Content="8" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="8"
                        AutomationProperties.Name="Score 8" />
                <Button Content="9" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="9"
                        AutomationProperties.Name="Score 9" />
                <Button Content="10" Style="{StaticResource NPSScoreButtonStyle}"
                        Command="{x:Bind ViewModel.SetScoreCommand, Mode=OneWay}"
                        CommandParameter="10"
                        ToolTipService.ToolTip="Extremely likely"
                        AutomationProperties.Name="Score 10 - Extremely likely" />
            </StackPanel>
            
            <!-- Scale labels -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <TextBlock 
                    Text="Not at all likely" 
                    HorizontalAlignment="Left"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="11" />
                <TextBlock 
                    Text="Extremely likely" 
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="11" />
            </Grid>
        </Grid>

        <!-- Selected Score Display -->
        <Border 
            Grid.Row="2" 
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="4"
            Padding="12,8"
            Margin="0,0,0,16"
            Visibility="{x:Bind ViewModel.HasScore, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            d:Visibility="Visible">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Your score:" />
                    <Run Text="{x:Bind ViewModel.Score, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text=" / 10" />
                </TextBlock>
                <Border 
                    Padding="8,4"
                    CornerRadius="4"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <TextBlock 
                        Text="{x:Bind ViewModel.CategoryLabel, Mode=OneWay, FallbackValue='Category'}"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        FontSize="12" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Additional Feedback (Optional) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Tell us more (optional)" Margin="0,0,0,8" />
            <TextBox 
                Text="{x:Bind ViewModel.AdditionalFeedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="What's the main reason for your score?"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                MinHeight="80"
                MaxHeight="120"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                AutomationProperties.Name="Additional feedback input" />
        </StackPanel>

        <!-- Status Messages -->
        <StackPanel Grid.Row="4">
            <!-- Submitting indicator -->
            <StackPanel 
                Orientation="Horizontal" 
                Spacing="8"
                Visibility="{x:Bind ViewModel.IsSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock 
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Submitting...'}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Success message -->
            <Border
                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                CornerRadius="4"
                Padding="12,8"
                Visibility="{x:Bind ViewModel.IsSubmitted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock 
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay, FallbackValue='Thank you!'}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Error message -->
            <Border
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                CornerRadius="4"
                Padding="12,8"
                Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                d:Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE783;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    <TextBlock 
                        Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, FallbackValue='An error occurred'}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>
