<UserControl x:Class="VoiceStudio.App.Views.GlobalSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls">
    <Border Background="{StaticResource VSQ.Panel.Background}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
            Padding="0"
            MinWidth="{StaticResource VSQ.Text.MaxWidth.Wide}"
            MaxWidth="{StaticResource VSQ.Text.MaxWidth.Wide}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Search Box -->
                <RowDefinition Height="Auto"/>   <!-- Results Summary -->
                <RowDefinition Height="*"/>      <!-- Results List -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>
            <!-- Search Box -->
            <Grid Grid.Row="0" Margin="16,16,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                        PlaceholderText="Search across profiles, projects, audio, markers, scripts..."
                        Margin="0,0,12,0"
                        KeyDown="SearchBox_KeyDown"
                        TabIndex="1"
                        AutomationProperties.Name="Search query"
                        AutomationProperties.HelpText="Enter search terms to find profiles, projects, audio files, markers, and scripts across the application"
                        ToolTipService.ToolTip="Search across all content types. Press Enter to navigate to selected result, Esc to close, Arrow keys to navigate results"/>
                <Button Grid.Column="1"
                        Content="Search"
                        Command="{x:Bind ViewModel.SearchCommand, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.CanSearch, Mode=OneWay}"
                        TabIndex="2"
                        AutomationProperties.Name="Search button"
                        AutomationProperties.HelpText="Execute search query"
                        ToolTipService.ToolTip="Execute search (or press Enter)"/>
            </Grid>
            <!-- Results Summary -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,0,16,12" Visibility="{x:Bind ViewModel.ResultsSummaryVisibility, Mode=OneWay}">
                <TextBlock Text="{x:Bind ViewModel.TotalResults, Mode=OneWay}" 
                          Style="{StaticResource VSQ.Text.Body}" 
                          FontWeight="SemiBold"
                          Margin="0,0,16,0"
                          AutomationProperties.Name="Search results count"/>
            </StackPanel>
            <!-- Loading Overlay -->
            <controls:LoadingOverlay Grid.Row="2"
                                    IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                    LoadingMessage="Searching..."/>
            <!-- Error Message -->
            <controls:ErrorMessage Grid.Row="2"
                                 Title="Search Error"
                                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                 Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"/>
            <!-- Results List -->
            <ListView x:Name="ResultsList"
                     Grid.Row="2"
                     ItemsSource="{x:Bind ViewModel.FilteredResults, Mode=OneWay}"
                     SelectedItem="{x:Bind ViewModel.SelectedResult, Mode=TwoWay}"
                     SelectionMode="Single"
                     Margin="12,0,12,12"
                     ItemClick="ResultsList_ItemClick"
                     Visibility="{x:Bind ViewModel.ResultsListVisibility, Mode=OneWay}"
                     TabIndex="3"
                     AutomationProperties.Name="Search results"
                     AutomationProperties.HelpText="List of search results. Use arrow keys to navigate, Enter to select, or click to navigate"
                     ToolTipService.ToolTip="Search results. Use arrow keys to navigate, Enter or click to navigate to result">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Type Icon -->
                            <TextBlock Grid.Column="0" 
                                      FontSize="{StaticResource VSQ.FontSize.Title}" 
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      AutomationProperties.Name="Result type icon">
                                <Run Text="•"/>
                            </TextBlock>
                            <!-- Result Content -->
                            <StackPanel Grid.Column="1" Spacing="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="{Binding Title}" 
                                          Style="{StaticResource VSQ.Text.Body}" 
                                          FontWeight="SemiBold"
                                          AutomationProperties.Name="Result title"/>
                                <TextBlock Text="{Binding Preview}" 
                                          Style="{StaticResource VSQ.Text.Caption}" 
                                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                          TextWrapping="Wrap"
                                          MaxLines="2"
                                          TextTrimming="CharacterEllipsis"
                                          AutomationProperties.Name="Result preview"/>
                                <TextBlock Text="{Binding Description}" 
                                          Style="{StaticResource VSQ.Text.Caption}" 
                                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                                          TextWrapping="Wrap"
                                          MaxLines="1"
                                          TextTrimming="CharacterEllipsis"
                                          AutomationProperties.Name="Result description"/>
                            </StackPanel>
                            <!-- Panel Indicator -->
                            <TextBlock Grid.Column="2" 
                                      Text="{Binding PanelId}" 
                                      Style="{StaticResource VSQ.Text.Caption}" 
                                      Foreground="{StaticResource VSQ.Accent.CyanBrush}"
                                      Margin="12,0,0,0"
                                      VerticalAlignment="Center"
                                      AutomationProperties.Name="Panel identifier"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!-- Empty State -->
            <StackPanel x:Name="EmptyStatePanel"
                       Grid.Row="2" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Spacing="{StaticResource VSQ.Spacing.Value.Medium}"
                       Visibility="Collapsed">
                <TextBlock Text="🔍" 
                          FontSize="48" 
                          HorizontalAlignment="Center" 
                          Opacity="0.5"
                          AutomationProperties.Name="Empty state icon"/>
                <TextBlock Text="No results found" 
                          Style="{StaticResource VSQ.Text.Body}" 
                          Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Empty state message"/>
                <TextBlock Text="Try a different search query" 
                          Style="{StaticResource VSQ.Text.Caption}" 
                          Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Empty state hint"/>
            </StackPanel>
            <!-- Footer -->
            <StackPanel Grid.Row="3" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Spacing="{StaticResource VSQ.Spacing.Value.Medium}"
                       Margin="16,12,16,16">
                <TextBlock Text="Enter: Navigate   Esc: Close   Ctrl+K: Open Search" 
                          Style="{StaticResource VSQ.Text.Caption}" 
                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                          AutomationProperties.Name="Keyboard shortcuts hint"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
