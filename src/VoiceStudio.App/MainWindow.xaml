<Window x:Class="VoiceStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:views="using:VoiceStudio.App.Views">
    <Grid Background="{StaticResource VSQ.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Workspace -->
            <RowDefinition Height="26"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>
        <!-- Top command toolbar -->
        <controls:CustomizableToolbar Grid.Row="0" Margin="8,0,8,4" x:Name="CommandToolbar"/>
        <!-- Main workspace -->
        <Grid Grid.Row="1" Margin="8,0,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="55*"/>
                <ColumnDefinition Width="25*"/>
            </Grid.ColumnDefinitions>
            <!-- Nav rail -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#141820" CornerRadius="8" Padding="4">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,8" Spacing="8">
                    <ToggleButton x:Name="NavStudio" Content="S" ToolTipService.ToolTip="Studio" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavProfiles" Content="P" ToolTipService.ToolTip="Profiles" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavLibrary" Content="L" ToolTipService.ToolTip="Library" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavEffects" Content="E" ToolTipService.ToolTip="Effects" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavTrain" Content="T" ToolTipService.ToolTip="Train" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavAnalyze" Content="A" ToolTipService.ToolTip="Analyze" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavSettings" Content="⚙" ToolTipService.ToolTip="Settings" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                    <ToggleButton x:Name="NavLogs" Content="D" ToolTipService.ToolTip="Logs" Width="40" Height="40" Margin="0,0,0,4" PointerEntered="NavButton_PointerEntered" PointerExited="NavButton_PointerExited"/>
                </StackPanel>
            </Border>
            <!-- Left / Center / Right PanelHosts -->
            <controls:PanelHost Grid.Row="0" Grid.Column="1" Margin="4,0,4,4" x:Name="LeftPanelHost"/>
            <controls:PanelHost Grid.Row="0" Grid.Column="2" Margin="0,0,4,4" x:Name="CenterPanelHost"/>
            <controls:PanelHost Grid.Row="0" Grid.Column="3" Margin="0,0,0,4" x:Name="RightPanelHost"/>
            <!-- Bottom PanelHost -->
            <controls:PanelHost Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" x:Name="BottomPanelHost"/>
        </Grid>
        <!-- Status bar -->
        <Border Grid.Row="2" Height="26" Background="#141820" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1,1,1,0">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="0,0,12,0">
                    <Border x:Name="ProcessingIndicator" Width="8" Height="8" CornerRadius="4" Background="#FF00FF00" ToolTipService.ToolTip="Processing: Idle" Opacity="0.3" />
                    <Border x:Name="NetworkIndicator" Width="8" Height="8" CornerRadius="4" Background="#FF00FF00" ToolTipService.ToolTip="Network: Connected" Opacity="1" />
                    <Border x:Name="EngineIndicator" Width="8" Height="8" CornerRadius="4" Background="#FF00FF00" ToolTipService.ToolTip="Engine: Ready" Opacity="1" />
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="StatusText" Text="Ready" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Job:" Margin="0,0,4,0"/>
                    <TextBlock x:Name="JobStatusText" Text="Idle"/>
                    <ProgressBar x:Name="JobProgressBar" Width="200" Height="6" Margin="12,0,0,0" Value="0"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="CPU 12%" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock Text="GPU 4%" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock Text="RAM 26%" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock x:Name="ClockText" Text="21:34" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Toast Notification Container (IDEA 11) -->
        <StackPanel x:Name="ToastContainer" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,80" Spacing="0" MaxWidth="400"/>
        <!-- Global Search Overlay (IDEA 5) -->
        <Grid x:Name="GlobalSearchOverlay" Grid.Row="1" Background="#80000000" Visibility="Collapsed" Tapped="GlobalSearchOverlay_Tapped">
            <views:GlobalSearchView x:Name="GlobalSearchView" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100,0,0"/>
        </Grid>
        <!-- Collaboration Indicators (IDEA 25) -->
        <Border Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Background="{StaticResource VSQ.Panel.BackgroundBrush}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Width="280" MaxHeight="400">
            <controls:CollaborationIndicator x:Name="CollaborationIndicator"/>
        </Border>
    </Grid>
</Window>
