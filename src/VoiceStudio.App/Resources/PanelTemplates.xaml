<!--
  ============================================================================
  PanelTemplates.xaml - Panel DataTemplates for VoiceStudio
  
  AI GUIDELINES:
  - DO NOT DELETE existing templates - PanelRegistry maps IDs to types here
  - DO NOT RENAME template keys - will break panel loading
  - Panel types must match actual ViewType classes in Views.Panels namespace
  - Adding new panel templates is allowed following existing pattern
  ============================================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="using:VoiceStudio.App.Views.Panels"
                    xmlns:controls="using:VoiceStudio.App.Controls">
  <!-- 9 advanced panels already scaffolded -->
  <DataTemplate x:Key="Tpl.TextSpeechEditor">
    <views:TextSpeechEditorView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.Prosody">
    <views:ProsodyView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.SpatialStage">
    <views:SpatialStageView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.MixAssistant">
    <views:MixAssistantView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.StyleTransfer">
    <views:StyleTransferView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.EmbeddingExplorer">
    <views:EmbeddingExplorerView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.Assistant">
    <views:AssistantView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.Lexicon">
    <views:LexiconView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.VoiceMorph">
    <views:VoiceMorphView/>
  </DataTemplate>
  <!-- Phase 7 Video Panels -->
  <DataTemplate x:Key="Tpl.VideoGen">
    <views:VideoGenView/>
  </DataTemplate>
  <DataTemplate x:Key="Tpl.VideoEdit">
    <views:VideoEditView/>
  </DataTemplate>
  <!-- Selector instance used by MainWindow TabViews -->
  <controls:PanelTemplateSelector x:Key="PanelTemplateSelector"
    TextSpeechEditorTemplate="{StaticResource Tpl.TextSpeechEditor}"
    ProsodyTemplate="{StaticResource Tpl.Prosody}"
    SpatialTemplate="{StaticResource Tpl.SpatialStage}"
    MixAssistantTemplate="{StaticResource Tpl.MixAssistant}"
    StyleTransferTemplate="{StaticResource Tpl.StyleTransfer}"
    EmbeddingExplorerTemplate="{StaticResource Tpl.EmbeddingExplorer}"
    AssistantTemplate="{StaticResource Tpl.Assistant}"
    LexiconTemplate="{StaticResource Tpl.Lexicon}"
    VoiceMorphTemplate="{StaticResource Tpl.VoiceMorph}"
    VideoGenTemplate="{StaticResource Tpl.VideoGen}"
    VideoEditTemplate="{StaticResource Tpl.VideoEdit}"/>
</ResourceDictionary>
