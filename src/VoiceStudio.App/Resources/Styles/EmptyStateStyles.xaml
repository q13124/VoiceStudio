<!--
  ============================================================================
  EmptyStateStyles.xaml - Empty state visual styles
  
  AI GUIDELINES:
  - DO NOT DELETE empty state styles - used across panels for no-data views
  - References DesignTokens.xaml colors and Text.xaml typography
  ============================================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Empty State Container Style -->
  <Style x:Key="VSQ.EmptyState.Container" TargetType="StackPanel">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Spacing" Value="{StaticResource VSQ.Spacing.Value.Large}" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Spacing.XLarge}" />
  </Style>
  <!-- Empty State Icon Style -->
  <Style x:Key="VSQ.EmptyState.Icon" TargetType="TextBlock">
    <Setter Property="FontSize" Value="48" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <!-- Empty State Title Style -->
  <Style x:Key="VSQ.EmptyState.Title" TargetType="TextBlock">
    <Setter Property="Style" Value="{StaticResource VSQ.Text.Body}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.EmptyState.TextBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MaxWidth" Value="{StaticResource VSQ.Text.MaxWidth.Standard}" />
  </Style>
  <!-- Empty State Message Style -->
  <Style x:Key="VSQ.EmptyState.Message" TargetType="TextBlock">
    <Setter Property="Style" Value="{StaticResource VSQ.Text.Caption}" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.EmptyState.TextBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MaxWidth" Value="{StaticResource VSQ.Text.MaxWidth.Standard}" />
  </Style>
  <!-- Empty State Action Button Style -->
  <Style x:Key="VSQ.EmptyState.ActionButton" TargetType="Button"
    BasedOn="{StaticResource VSQ.Button.Primary}">
    <Setter Property="Margin" Value="{StaticResource VSQ.Toast.ActionButton.Margin}" />
  </Style>
</ResourceDictionary>