<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Toast Container Style -->
  <Style x:Key="VSQ.Toast.Container" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource VSQ.CornerRadius.Panel}" />
    <Setter Property="Padding" Value="{StaticResource VSQ.Toast.Padding}" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Toast.Margin}" />
    <Setter Property="MinWidth" Value="{StaticResource VSQ.Text.MaxWidth.Standard}" />
    <Setter Property="MaxWidth" Value="{StaticResource VSQ.Text.MaxWidth.Wide}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <!-- Toast Success Style -->
  <Style x:Key="VSQ.Toast.Success" TargetType="Border"
    BasedOn="{StaticResource VSQ.Toast.Container}">
    <Setter Property="Background" Value="{StaticResource VSQ.Success.Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Success.Brush}" />
  </Style>
  <!-- Toast Error Style -->
  <Style x:Key="VSQ.Toast.Error" TargetType="Border" BasedOn="{StaticResource VSQ.Toast.Container}">
    <Setter Property="Background" Value="{StaticResource VSQ.Error.Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Error.Brush}" />
  </Style>
  <!-- Toast Warning Style -->
  <Style x:Key="VSQ.Toast.Warning" TargetType="Border"
    BasedOn="{StaticResource VSQ.Toast.Container}">
    <Setter Property="Background" Value="{StaticResource VSQ.Warn.Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Warn.Brush}" />
  </Style>
  <!-- Toast Info Style -->
  <Style x:Key="VSQ.Toast.Info" TargetType="Border" BasedOn="{StaticResource VSQ.Toast.Container}">
    <Setter Property="Background" Value="{StaticResource VSQ.Accent.CyanBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Accent.CyanBrush}" />
  </Style>
  <!-- Toast Progress Style -->
  <Style x:Key="VSQ.Toast.Progress" TargetType="Border"
    BasedOn="{StaticResource VSQ.Toast.Container}">
    <Setter Property="Background" Value="{StaticResource VSQ.Panel.Background.DarkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Accent.CyanBrush}" />
  </Style>
  <!-- Toast Title Text Style -->
  <Style x:Key="VSQ.Toast.Title" TargetType="TextBlock">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="{StaticResource VSQ.FontSize.Body}" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.Text.PrimaryBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <!-- Toast Message Text Style -->
  <Style x:Key="VSQ.Toast.Message" TargetType="TextBlock">
    <Setter Property="FontSize" Value="{StaticResource VSQ.FontSize.Body}" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.Text.PrimaryBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Opacity" Value="0.9" />
  </Style>
  <!-- Toast Dismiss Button Style -->
  <Style x:Key="VSQ.Toast.DismissButton" TargetType="Button">
    <Setter Property="Content" Value="✕" />
    <Setter Property="FontSize" Value="{StaticResource VSQ.FontSize.Caption}" />
    <Setter Property="Padding" Value="{StaticResource VSQ.Button.Padding.Small}" />
    <Setter Property="MinWidth" Value="{StaticResource VSQ.Control.Height.Small}" />
    <Setter Property="MinHeight" Value="{StaticResource VSQ.Control.Height.Small}" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.Text.SecondaryBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource VSQ.CornerRadius.Small}" />
  </Style>
  <!-- Toast Action Button Style -->
  <Style x:Key="VSQ.Toast.ActionButton" TargetType="Button">
    <Setter Property="Margin" Value="{StaticResource VSQ.Toast.ActionButton.Margin}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Style" Value="{StaticResource VSQ.Button.Secondary}" />
    <Setter Property="FontSize" Value="{StaticResource VSQ.FontSize.Caption}" />
    <Setter Property="Padding" Value="{StaticResource VSQ.Toast.ActionButton.Padding}" />
  </Style>
  <!-- Toast Progress Bar Style -->
  <Style x:Key="VSQ.Toast.ProgressBar" TargetType="ProgressBar">
    <Setter Property="IsIndeterminate" Value="True" />
    <Setter Property="Height" Value="4" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Toast.Progress.Margin}" />
    <Setter Property="Foreground" Value="{StaticResource VSQ.Accent.CyanBrush}" />
    <Setter Property="Background" Value="{StaticResource VSQ.Panel.Background.DarkerBrush}" />
  </Style>
  <!-- Toast Stack Panel Style -->
  <Style x:Key="VSQ.Toast.ContentPanel" TargetType="StackPanel">
    <Setter Property="Spacing" Value="{StaticResource VSQ.Spacing.Value.Small}" />
  </Style>
</ResourceDictionary>