<!--
  ============================================================================
  LoadingSkeletonStyles.xaml - Loading skeleton animation styles
  
  AI GUIDELINES:
  - DO NOT DELETE skeleton styles - used by loading states across panels
  - Animation storyboards are performance-sensitive; test changes
  - References DesignTokens.xaml colors
  ============================================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Skeleton Shimmer Animation -->
  <Storyboard x:Key="VSQ.Skeleton.Shimmer" RepeatBehavior="Forever">
    <DoubleAnimation Storyboard.TargetName="SkeletonGradientTransform"
      Storyboard.TargetProperty="X"
      From="-200"
      To="200"
      Duration="0:0:1.5"
      EnableDependentAnimation="False">
      <DoubleAnimation.EasingFunction>
        <CubicEase EasingMode="EaseInOut" />
      </DoubleAnimation.EasingFunction>
    </DoubleAnimation>
  </Storyboard>
  <!-- Skeleton Rectangle Style -->
  <Style x:Key="VSQ.Skeleton.Rectangle" TargetType="Rectangle">
    <Setter Property="Fill" Value="{StaticResource VSQ.Panel.Background.DarkerBrush}" />
    <Setter Property="Opacity" Value="0.5" />
    <Setter Property="RadiusX" Value="{StaticResource VSQ.CornerRadius.Value.Small}" />
    <Setter Property="RadiusY" Value="{StaticResource VSQ.CornerRadius.Value.Small}" />
  </Style>
  <!-- Skeleton Card Style -->
  <Style x:Key="VSQ.Skeleton.Card" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource VSQ.CornerRadius.Panel}" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Spacing.Medium}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Panel.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource VSQ.Panel.Background.DarkBrush}" />
    <Setter Property="Padding" Value="{StaticResource VSQ.Spacing.Medium}" />
  </Style>
  <!-- Skeleton List Item Style -->
  <Style x:Key="VSQ.Skeleton.ListItem" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource VSQ.CornerRadius.Button}" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Spacing.Margin.BottomSmall}" />
    <Setter Property="BorderBrush" Value="{StaticResource VSQ.Panel.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource VSQ.Panel.Background.DarkBrush}" />
    <Setter Property="Padding" Value="{StaticResource VSQ.Spacing.Medium}" />
    <Setter Property="Height" Value="{StaticResource VSQ.Control.Height.Large}" />
  </Style>
  <!-- Skeleton Text Line Style -->
  <Style x:Key="VSQ.Skeleton.TextLine" TargetType="Rectangle">
    <Setter Property="Style" Value="{StaticResource VSQ.Skeleton.Rectangle}" />
    <Setter Property="Height" Value="{StaticResource VSQ.FontSize.Body}" />
    <Setter Property="Margin" Value="{StaticResource VSQ.Spacing.Margin.BottomSmall}" />
  </Style>
  <!-- Skeleton Avatar Style -->
  <Style x:Key="VSQ.Skeleton.Avatar" TargetType="Ellipse">
    <Setter Property="Fill" Value="{StaticResource VSQ.Panel.Background.DarkerBrush}" />
    <Setter Property="Opacity" Value="0.5" />
    <Setter Property="Width" Value="{StaticResource VSQ.Icon.Size.Large}" />
    <Setter Property="Height" Value="{StaticResource VSQ.Icon.Size.Large}" />
  </Style>
</ResourceDictionary>