<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="VSQ.Background" Color="#101319"/>
  <SolidColorBrush x:Key="VSQ.Panel"      Color="#141922"/>
  <SolidColorBrush x:Key="VSQ.Surface"    Color="#1A2030"/>
  <SolidColorBrush x:Key="VSQ.Border"     Color="#233246"/>
  <SolidColorBrush x:Key="VSQ.Text"       Color="#E8F0FA"/>
  <SolidColorBrush x:Key="VSQ.SubtleText" Color="#9EB3C8"/>
  <SolidColorBrush x:Key="VSQ.Accent"     Color="#2EC4E6"/>
  <SolidColorBrush x:Key="VSQ.AccentAlt"  Color="#7C4DFF"/>
  <SolidColorBrush x:Key="VSQ.Warn"       Color="#FFC857"/>
  <SolidColorBrush x:Key="VSQ.Danger"     Color="#FF5A5F"/>
  <x:Double x:Key="VSQ.CornerRadius">12</x:Double>
</ResourceDictionary>
