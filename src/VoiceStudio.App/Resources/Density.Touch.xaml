  <x:Double x:Key="VSQ.Gap">12</x:Double>
  <x:Double x:Key="VSQ.ControlHeight">44</x:Double>
  <x:Double x:Key="VSQ.TabStripHeight">48</x:Double>
</ResourceDictionary>
