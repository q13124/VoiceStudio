<!--
  ============================================================================
  Theme.HighContrast.xaml - High Contrast theme for VoiceStudio
  
  WCAG AAA Compliant:
  - Minimum contrast ratio 7:1 for normal text
  - Minimum contrast ratio 4.5:1 for large text
  - Pure black background with pure white text for maximum contrast
  
  AI GUIDELINES:
  - DO NOT DELETE theme color keys - used by theme system
  - DO NOT RENAME keys - must match base theme structure
  - These colors are specifically chosen for accessibility compliance
  ============================================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Pure black background for maximum contrast -->
  <SolidColorBrush x:Key="VSQ.Background" Color="#000000"/>
  
  <!-- Slightly lighter panels for visual separation -->
  <SolidColorBrush x:Key="VSQ.Panel"      Color="#1A1A1A"/>
  
  <!-- Surface color for cards and elevated elements -->
  <SolidColorBrush x:Key="VSQ.Surface"    Color="#262626"/>
  
  <!-- High visibility border -->
  <SolidColorBrush x:Key="VSQ.Border"     Color="#FFFFFF"/>
  
  <!-- Pure white text for maximum contrast (21:1 ratio with black) -->
  <SolidColorBrush x:Key="VSQ.Text"       Color="#FFFFFF"/>
  
  <!-- Secondary text - still high contrast -->
  <SolidColorBrush x:Key="VSQ.SubtleText" Color="#CCCCCC"/>
  
  <!-- Bright cyan accent for visibility -->
  <SolidColorBrush x:Key="VSQ.Accent"     Color="#00FFFF"/>
  
  <!-- Bright yellow alternate accent -->
  <SolidColorBrush x:Key="VSQ.AccentAlt"  Color="#FFFF00"/>
  
  <!-- Bright green for success/info states -->
  <SolidColorBrush x:Key="VSQ.Warn"       Color="#00FF00"/>
  
  <!-- Bright red for errors/danger states -->
  <SolidColorBrush x:Key="VSQ.Danger"     Color="#FF0000"/>
  
  <!-- Sharp corners for high contrast mode -->
  <x:Double x:Key="VSQ.CornerRadius">0</x:Double>
</ResourceDictionary>
