<!--
  ============================================================================
  ErrorMessages.xaml - User-friendly error messages for VoiceStudio
  Phase 5.4.4 - Centralized error message resource dictionary
  
  AI GUIDELINES:
  - DO NOT DELETE existing messages - they are used across the application
  - DO NOT RENAME message keys - ViewModels depend on exact key names
  - Messages should be user-friendly and actionable
  - Include {0}, {1}, etc. for dynamic placeholders
  ============================================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:system="using:System">

  <!-- ========================================================================
       General Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.General.Unknown">
    An unexpected error occurred. Please try again or restart the application.
  </system:String>
  
  <system:String x:Key="Error.General.Timeout">
    The operation took too long and timed out. Please try again.
  </system:String>
  
  <system:String x:Key="Error.General.Cancelled">
    The operation was cancelled.
  </system:String>
  
  <system:String x:Key="Error.General.InvalidOperation">
    This operation cannot be performed at this time.
  </system:String>

  <!-- ========================================================================
       Backend/Network Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Backend.Unavailable">
    Cannot connect to the VoiceStudio backend. Please ensure it is running.
  </system:String>
  
  <system:String x:Key="Error.Backend.Timeout">
    The backend did not respond in time. Please check the connection.
  </system:String>
  
  <system:String x:Key="Error.Backend.ServerError">
    The backend encountered an error. Error code: {0}
  </system:String>
  
  <system:String x:Key="Error.Backend.NotFound">
    The requested resource was not found.
  </system:String>
  
  <system:String x:Key="Error.Backend.Unauthorized">
    Access denied. Please check your credentials.
  </system:String>

  <!-- ========================================================================
       Engine Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Engine.NotAvailable">
    The voice engine "{0}" is not available. Please check installation.
  </system:String>
  
  <system:String x:Key="Error.Engine.NotInitialized">
    The voice engine has not been initialized. Please wait or restart.
  </system:String>
  
  <system:String x:Key="Error.Engine.SynthesisFailed">
    Voice synthesis failed. Please try again with different settings.
  </system:String>
  
  <system:String x:Key="Error.Engine.TranscriptionFailed">
    Transcription failed. Please check the audio file format.
  </system:String>
  
  <system:String x:Key="Error.Engine.ModelNotFound">
    The voice model "{0}" could not be found. Please download it first.
  </system:String>
  
  <system:String x:Key="Error.Engine.InsufficientMemory">
    Not enough memory to run the voice engine. Try closing other applications.
  </system:String>
  
  <system:String x:Key="Error.Engine.GPUNotAvailable">
    GPU acceleration is not available. Falling back to CPU processing.
  </system:String>
  
  <system:String x:Key="Error.Engine.CUDAError">
    CUDA error occurred. Please update your GPU drivers.
  </system:String>

  <!-- ========================================================================
       File Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.File.NotFound">
    The file "{0}" could not be found.
  </system:String>
  
  <system:String x:Key="Error.File.AccessDenied">
    Access to the file "{0}" was denied. Check file permissions.
  </system:String>
  
  <system:String x:Key="Error.File.InvalidFormat">
    The file format is not supported. Supported formats: {0}
  </system:String>
  
  <system:String x:Key="Error.File.Corrupted">
    The file appears to be corrupted and cannot be opened.
  </system:String>
  
  <system:String x:Key="Error.File.TooLarge">
    The file is too large. Maximum size: {0}
  </system:String>
  
  <system:String x:Key="Error.File.SaveFailed">
    Failed to save the file. Please check available disk space.
  </system:String>
  
  <system:String x:Key="Error.File.InUse">
    The file is being used by another application.
  </system:String>

  <!-- ========================================================================
       Audio Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Audio.InvalidFormat">
    The audio format is not supported. Please use WAV, MP3, or FLAC.
  </system:String>
  
  <system:String x:Key="Error.Audio.TooShort">
    The audio is too short. Minimum duration: {0} seconds.
  </system:String>
  
  <system:String x:Key="Error.Audio.TooLong">
    The audio is too long. Maximum duration: {0} minutes.
  </system:String>
  
  <system:String x:Key="Error.Audio.NoAudioDevice">
    No audio playback device found. Please connect headphones or speakers.
  </system:String>
  
  <system:String x:Key="Error.Audio.PlaybackFailed">
    Failed to play audio. Please check your audio device.
  </system:String>
  
  <system:String x:Key="Error.Audio.RecordingFailed">
    Failed to start recording. Please check microphone permissions.
  </system:String>
  
  <system:String x:Key="Error.Audio.NoMicrophone">
    No microphone detected. Please connect a microphone.
  </system:String>

  <!-- ========================================================================
       Project Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Project.LoadFailed">
    Failed to load the project. The file may be corrupted.
  </system:String>
  
  <system:String x:Key="Error.Project.SaveFailed">
    Failed to save the project. Please try saving to a different location.
  </system:String>
  
  <system:String x:Key="Error.Project.VersionMismatch">
    This project was created with a newer version of VoiceStudio.
  </system:String>
  
  <system:String x:Key="Error.Project.MissingAssets">
    Some project assets are missing: {0}
  </system:String>

  <!-- ========================================================================
       Voice Profile Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Profile.NotFound">
    The voice profile "{0}" could not be found.
  </system:String>
  
  <system:String x:Key="Error.Profile.CreateFailed">
    Failed to create voice profile. Please try again.
  </system:String>
  
  <system:String x:Key="Error.Profile.InsufficientSamples">
    Not enough audio samples. Please provide at least {0} seconds of audio.
  </system:String>
  
  <system:String x:Key="Error.Profile.PoorQuality">
    Audio quality is too low for voice cloning. Please use higher quality audio.
  </system:String>
  
  <system:String x:Key="Error.Profile.TrainingFailed">
    Voice profile training failed. Please check the training data.
  </system:String>

  <!-- ========================================================================
       Validation Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Validation.Required">
    This field is required.
  </system:String>
  
  <system:String x:Key="Error.Validation.TooShort">
    Must be at least {0} characters.
  </system:String>
  
  <system:String x:Key="Error.Validation.TooLong">
    Cannot exceed {0} characters.
  </system:String>
  
  <system:String x:Key="Error.Validation.InvalidFormat">
    Invalid format. Expected: {0}
  </system:String>
  
  <system:String x:Key="Error.Validation.OutOfRange">
    Value must be between {0} and {1}.
  </system:String>

  <!-- ========================================================================
       System Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.System.DiskFull">
    Not enough disk space. Please free up some space and try again.
  </system:String>
  
  <system:String x:Key="Error.System.MemoryLow">
    System memory is running low. Close some applications and try again.
  </system:String>
  
  <system:String x:Key="Error.System.PermissionDenied">
    Permission denied. Try running VoiceStudio as administrator.
  </system:String>
  
  <system:String x:Key="Error.System.DependencyMissing">
    Required component "{0}" is missing. Please reinstall VoiceStudio.
  </system:String>
  
  <system:String x:Key="Error.System.ConfigurationError">
    Configuration error. Please reset settings to defaults.
  </system:String>

  <!-- ========================================================================
       User Action Error Messages
       ======================================================================== -->
  
  <system:String x:Key="Error.Action.InProgress">
    Another operation is in progress. Please wait for it to complete.
  </system:String>
  
  <system:String x:Key="Error.Action.RateLimited">
    Too many requests. Please wait a moment before trying again.
  </system:String>
  
  <system:String x:Key="Error.Action.Unsupported">
    This action is not supported in the current context.
  </system:String>

  <!-- ========================================================================
       Success Messages
       ======================================================================== -->
  
  <system:String x:Key="Success.General">
    Operation completed successfully.
  </system:String>
  
  <system:String x:Key="Success.FileSaved">
    File saved successfully.
  </system:String>
  
  <system:String x:Key="Success.ProjectSaved">
    Project saved successfully.
  </system:String>
  
  <system:String x:Key="Success.SynthesisComplete">
    Voice synthesis completed.
  </system:String>
  
  <system:String x:Key="Success.ProfileCreated">
    Voice profile created successfully.
  </system:String>
  
  <system:String x:Key="Success.ExportComplete">
    Export completed successfully. File saved to: {0}
  </system:String>

  <!-- ========================================================================
       Warning Messages
       ======================================================================== -->
  
  <system:String x:Key="Warning.UnsavedChanges">
    You have unsaved changes. Save before continuing?
  </system:String>
  
  <system:String x:Key="Warning.LargeFile">
    This file is large and may take a while to process.
  </system:String>
  
  <system:String x:Key="Warning.LowQuality">
    Audio quality is below recommended levels. Results may vary.
  </system:String>
  
  <system:String x:Key="Warning.ExperimentalFeature">
    This feature is experimental and may not work as expected.
  </system:String>
  
  <system:String x:Key="Warning.DeprecatedFormat">
    This file format is deprecated. Consider converting to a newer format.
  </system:String>

  <!-- ========================================================================
       Info Messages
       ======================================================================== -->
  
  <system:String x:Key="Info.Processing">
    Processing... This may take a few moments.
  </system:String>
  
  <system:String x:Key="Info.Downloading">
    Downloading required files...
  </system:String>
  
  <system:String x:Key="Info.Loading">
    Loading...
  </system:String>
  
  <system:String x:Key="Info.Initializing">
    Initializing voice engine...
  </system:String>
  
  <system:String x:Key="Info.Ready">
    Ready.
  </system:String>

</ResourceDictionary>
