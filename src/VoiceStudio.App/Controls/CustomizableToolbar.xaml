<UserControl x:Class="VoiceStudio.App.Controls.CustomizableToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:VoiceStudio.App.Services"
    xmlns:local="using:VoiceStudio.App.Controls"
    x:DataType="local:CustomizableToolbar">
    <Grid x:Name="ToolbarGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!-- Transport Section -->
        <StackPanel x:Name="TransportSection" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Items will be added dynamically -->
        </StackPanel>
        <!-- Project Section -->
        <StackPanel x:Name="ProjectSection" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
            <!-- Items will be added dynamically -->
        </StackPanel>
        <!-- History/Workspace Section -->
        <StackPanel x:Name="HistorySection" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,0,0,0">
            <!-- Items will be added dynamically -->
        </StackPanel>
        <!-- Performance Section -->
        <StackPanel x:Name="PerformanceSection" Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <!-- Items will be added dynamically -->
        </StackPanel>
    </Grid>
</UserControl>
