<UserControl
  x:Class="VoiceStudio.App.Controls.TrainingProgressChart"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:VoiceStudio.App.Controls"
  x:DataType="local:TrainingProgressChart">
  <Grid x:Name="ChartContainer" Background="Transparent">
    <Path x:Name="LossPath" Stroke="Cyan" StrokeThickness="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    <Path x:Name="QualityPath" Stroke="Lime" StrokeThickness="1.5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.9" />
    <TextBlock x:Name="EmptyStateText" Text="No training data yet" HorizontalAlignment="Center" VerticalAlignment="Center"
      Foreground="{StaticResource VSQ.Text.SecondaryBrush}" Opacity="0.6" Visibility="Collapsed" />
  </Grid>
</UserControl>
