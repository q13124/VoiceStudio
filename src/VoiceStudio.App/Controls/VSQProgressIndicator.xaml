<UserControl
    x:Class="VoiceStudio.App.Controls.VSQProgressIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:VoiceStudio.App.Controls"
    mc:Ignorable="d"
    x:DataType="local:VSQProgressIndicator">
    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
        <ProgressBar
            x:Name="ProgressBarControl"
            Foreground="{StaticResource VSQ.Progress.ForegroundBrush}"
            Value="{x:Bind Progress, Mode=OneWay}"
            Minimum="0"
            Maximum="100"
            Visibility="{x:Bind ProgressBarVisibility, Mode=OneWay}" />
        <ProgressRing
            x:Name="ProgressRingControl"
            Width="{StaticResource VSQ.Icon.Size.Medium}"
            Height="{StaticResource VSQ.Icon.Size.Medium}"
            Foreground="{StaticResource VSQ.Loading.ForegroundBrush}"
            IsActive="{x:Bind IsIndeterminate, Mode=OneWay}"
            Visibility="{x:Bind ProgressRingVisibility, Mode=OneWay}" />
        <TextBlock
            x:Name="ProgressTextBlock"
            Text="{x:Bind ProgressText, Mode=OneWay}"
            Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
            FontSize="{StaticResource VSQ.FontSize.Caption}"
            HorizontalAlignment="Center"
            Visibility="{x:Bind ProgressTextVisibility, Mode=OneWay}" />
    </StackPanel>
</UserControl>