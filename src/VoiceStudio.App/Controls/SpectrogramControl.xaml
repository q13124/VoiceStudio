<UserControl x:Class="VoiceStudio.App.Controls.SpectrogramControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid x:Name="SpectrogramContainer" Background="Black">
    <Image x:Name="SpectrogramImage"
      Stretch="Fill"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch" />
    <Line x:Name="PlaybackLine"
      Stroke="Yellow"
      StrokeThickness="2"
      Visibility="Collapsed"
      StrokeDashArray="5,5" />
    <TextBlock Text="No spectrogram data available"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
      Opacity="0.5"
      Visibility="Collapsed"
      x:Name="EmptyStateText" />
  </Grid>
</UserControl>