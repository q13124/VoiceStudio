<UserControl
    x:Class="VoiceStudio.App.Controls.PlotlyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Image display for static plotly charts -->
        <Image x:Name="ChartImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               AutomationProperties.Name="Plotly Chart"
               AutomationProperties.HelpText="Displays a plotly-generated static chart image visualization"/>
        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingIndicator"
                      IsActive="False"
                      Width="40"
                      Height="40"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed"/>
        <!-- Empty state -->
        <TextBlock x:Name="EmptyStateText"
                   Text="No chart data available"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
                   Visibility="Collapsed"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="{StaticResource VSQ.Spacing.Medium}"/>
    </Grid>
</UserControl>
