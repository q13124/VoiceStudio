<UserControl
    x:Class="VoiceStudio.App.Controls.VSQBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        x:Name="BadgeBorder"
        Background="{x:Bind BadgeBackground, Mode=OneWay}"
        CornerRadius="{StaticResource VSQ.CornerRadius.Medium}"
        Padding="{StaticResource VSQ.Spacing.Small}">
        <TextBlock
            x:Name="BadgeText"
            Text="{x:Bind Text, Mode=OneWay}"
            Foreground="{x:Bind BadgeForeground, Mode=OneWay}"
            FontSize="{StaticResource VSQ.FontSize.Caption}"
            FontWeight="SemiBold" />
    </Border>
</UserControl>