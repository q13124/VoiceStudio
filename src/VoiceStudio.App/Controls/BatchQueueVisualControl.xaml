<UserControl x:Class="VoiceStudio.App.Controls.BatchQueueVisualControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <x:Double x:Key="QueueItemHeight">60</x:Double>
  </UserControl.Resources>
  <Border Background="{StaticResource VSQ.Panel.Background}"
    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1" CornerRadius="4">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <!-- Queue Header -->
      <Border Grid.Row="0" Background="{StaticResource VSQ.Panel.HeaderBackground}"
        BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Visual Queue" FontWeight="SemiBold"
            FontSize="{StaticResource VSQ.FontSize.Caption}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Position:" FontSize="{StaticResource VSQ.FontSize.Caption}"
              VerticalAlignment="Center" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
            <TextBlock Text="{x:Bind QueuePosition, Mode=OneWay}"
              FontSize="{StaticResource VSQ.FontSize.Caption}" VerticalAlignment="Center"
              Margin="0,0,8,0" Foreground="{StaticResource VSQ.Text.SecondaryBrush}" />
            <Button Content="Clear Queue" Click="ClearQueue_Click"
              Style="{StaticResource VSQ.Button.Secondary}"
              FontSize="{StaticResource VSQ.FontSize.Caption}" Padding="8,4"
              AutomationProperties.Name="Clear queue" />
          </StackPanel>
        </Grid>
      </Border>
      <!-- Queue Items -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="QueueItemsPanel" Spacing="4" Padding="8">
          <!-- Queue items will be added here programmatically -->
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>