<ContentDialog x:Class="VoiceStudio.App.Controls.ErrorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Controls"
    x:DataType="local:ErrorDialog"
    Title="Error"
    PrimaryButtonText="OK"
    CloseButtonText="Report Error"
    DefaultButton="Primary"
    AutomationProperties.AutomationId="ErrorDialog_Root">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <StackPanel Spacing="12" AutomationProperties.AutomationId="ErrorDialog_Content">
        <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}"
            TextWrapping="Wrap"
            AutomationProperties.AutomationId="ErrorDialog_MessageText" />
        <TextBlock Text="{x:Bind ErrorDetails, Mode=OneWay}"
            TextWrapping="Wrap"
            AutomationProperties.AutomationId="ErrorDialog_DetailsText" />
        <TextBlock Text="{x:Bind TechnicalDetails, Mode=OneWay}"
            TextWrapping="Wrap"
            AutomationProperties.AutomationId="ErrorDialog_TechnicalDetailsText" />
    </StackPanel>
</ContentDialog>