<ContentDialog x:Class="VoiceStudio.App.Controls.ErrorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Error"
    PrimaryButtonText="OK"
    CloseButtonText="Report Error"
    DefaultButton="Primary">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <StackPanel Spacing="12">
        <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}"
            TextWrapping="Wrap" />
        <TextBlock Text="{x:Bind ErrorDetails, Mode=OneWay}"
            TextWrapping="Wrap" />
        <TextBlock Text="{x:Bind TechnicalDetails, Mode=OneWay}"
            TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>