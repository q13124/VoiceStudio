<UserControl x:Class="VoiceStudio.App.Controls.LoadingButton"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:VoiceStudio.App.Controls"
  x:DataType="local:LoadingButton">
  <Grid>
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <Button x:Name="ButtonControl"
      Content="{x:Bind ButtonContent, Mode=OneWay}"
      Command="{x:Bind Command, Mode=OneWay}"
      CommandParameter="{x:Bind CommandParameter, Mode=OneWay}"
      IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
      AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}"
      AutomationProperties.HelpText="{x:Bind AutomationHelpText, Mode=OneWay}" />
  </Grid>
</UserControl>