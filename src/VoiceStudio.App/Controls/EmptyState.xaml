<UserControl x:Class="VoiceStudio.App.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:VoiceStudio.App.Controls"
             x:DataType="local:EmptyState">
    <StackPanel HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Spacing="{StaticResource VSQ.Spacing.Value.Large}"
                Margin="0">
        <!-- Icon -->
        <TextBlock x:Name="IconText"
                  Text="{x:Bind Icon, Mode=OneWay}"
                  FontSize="48"
                  HorizontalAlignment="Center"
                  Opacity="0.5"
                  Visibility="{x:Bind HasIcon, Mode=OneWay}"
                  AutomationProperties.Name="Empty state icon"/>
        <!-- Title -->
        <TextBlock x:Name="TitleText"
                  Text="{x:Bind Title, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Body}"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
                  HorizontalAlignment="Center"
                  TextAlignment="Center"
                  TextWrapping="Wrap"
                  MaxWidth="{StaticResource VSQ.Text.MaxWidth.Standard}"
                  AutomationProperties.Name="Empty state title"/>
        <!-- Message -->
        <TextBlock x:Name="MessageText"
                  Text="{x:Bind Message, Mode=OneWay}"
                  Style="{StaticResource VSQ.Text.Caption}"
                  Foreground="{StaticResource VSQ.EmptyState.TextBrush}"
                  HorizontalAlignment="Center"
                  TextAlignment="Center"
                  TextWrapping="Wrap"
                  MaxWidth="{StaticResource VSQ.Text.MaxWidth.Standard}"
                  Visibility="{x:Bind HasMessage, Mode=OneWay}"
                  AutomationProperties.Name="Empty state message"/>
        <!-- Action Button -->
        <Button x:Name="ActionButton"
               Content="{x:Bind ActionText, Mode=OneWay}"
               Command="{x:Bind ActionCommand, Mode=OneWay}"
               Visibility="{x:Bind HasAction, Mode=OneWay}"
               Style="{StaticResource VSQ.Button.Primary}"
               Margin="0"
               AutomationProperties.Name="Empty state action button"/>
    </StackPanel>
</UserControl>
