<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VoiceStudio.App.Controls.DynamicParameterPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Loading State -->
        <StackPanel x:Name="LoadingPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <ProgressRing IsActive="True" Width="32" Height="32" />
            <TextBlock Text="Loading parameters..."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Error State -->
        <StackPanel x:Name="ErrorPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <FontIcon Glyph="&#xE783;" FontSize="32"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            <TextBlock x:Name="ErrorText"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            <Button x:Name="RetryButton"
                    Content="Retry"
                    HorizontalAlignment="Center"
                    Click="RetryButton_Click" />
        </StackPanel>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE946;" FontSize="32"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="No parameters available"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Parameters Content -->
        <ScrollViewer x:Name="ContentScrollViewer"
                      Visibility="Collapsed"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollMode="Auto"
                      Padding="0,0,12,0">
            <StackPanel x:Name="ParametersContainer" Spacing="4" />
        </ScrollViewer>
    </Grid>
</UserControl>
