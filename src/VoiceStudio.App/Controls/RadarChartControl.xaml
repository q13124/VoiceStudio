<UserControl x:Class="VoiceStudio.App.Controls.RadarChartControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Controls"
    x:DataType="local:RadarChartControl">
    <Grid x:Name="RadarContainer" Background="Transparent">
        <Canvas x:Name="RadarCanvas" />
        <Path x:Name="RadarPath"
            Stroke="Cyan"
            StrokeThickness="2"
            Fill="#4C00FFFF"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />
        <TextBlock Text="No radar data available"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
            Opacity="0.5"
            Visibility="Collapsed"
            x:Name="EmptyStateText" />
    </Grid>
</UserControl>