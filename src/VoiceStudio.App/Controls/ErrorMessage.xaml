<UserControl x:Class="VoiceStudio.App.Controls.ErrorMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <Border BorderThickness="1" Padding="12">
        <StackPanel Spacing="6">
            <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" />
            <TextBlock Text="{x:Bind Message, Mode=OneWay}" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>