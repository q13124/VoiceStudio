<UserControl
    x:Class="VoiceStudio.App.Controls.VSQFormField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:VoiceStudio.App.Controls"
    mc:Ignorable="d"
    x:DataType="local:VSQFormField">
    <StackPanel Spacing="{StaticResource VSQ.Spacing.Value.Small}">
        <TextBlock
            x:Name="LabelText"
            Text="{x:Bind Label, Mode=OneWay}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Foreground="{StaticResource VSQ.Text.PrimaryBrush}"
            FontSize="{StaticResource VSQ.FontSize.Body}" />
        <TextBox
            x:Name="InputTextBox"
            Text="{x:Bind Text, Mode=TwoWay}"
            PlaceholderText="{x:Bind Placeholder, Mode=OneWay}"
            MinHeight="{StaticResource VSQ.Input.Height.Standard}"
            Padding="{StaticResource VSQ.Spacing.Medium}"
            CornerRadius="{StaticResource VSQ.CornerRadius.Small}"
            Background="{StaticResource VSQ.Panel.Background.DarkerBrush}"
            BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
            BorderThickness="1"
            FocusVisualPrimaryBrush="{StaticResource VSQ.Focus.BorderBrush}"
            FocusVisualPrimaryThickness="{StaticResource VSQ.Focus.BorderThickness}"
            TextChanged="InputTextBox_TextChanged" />
        <TextBlock
            x:Name="ErrorText"
            Text="{x:Bind ErrorMessage, Mode=OneWay}"
            Foreground="{StaticResource VSQ.Error.Brush}"
            FontSize="{StaticResource VSQ.FontSize.Caption}"
            Visibility="{x:Bind ErrorVisibility, Mode=OneWay}" />
        <TextBlock
            x:Name="HelpTextBlock"
            Text="{x:Bind HelpText, Mode=OneWay}"
            Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
            FontSize="{StaticResource VSQ.FontSize.Caption}"
            Visibility="{x:Bind HelpVisibility, Mode=OneWay}" />
    </StackPanel>
</UserControl>