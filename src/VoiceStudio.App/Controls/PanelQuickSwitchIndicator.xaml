<UserControl x:Class="VoiceStudio.App.Controls.PanelQuickSwitchIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceStudio.App.Controls"
    x:DataType="local:PanelQuickSwitchIndicator">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <Border Background="{StaticResource VSQ.PanelHost.HeaderBackgroundBrush}"
        CornerRadius="8"
        Padding="12"
        BorderBrush="{StaticResource VSQ.Border.DefaultBrush}"
        BorderThickness="1"
        MinWidth="200">
        <StackPanel Spacing="6">
            <TextBlock x:Name="PanelNameText"
                Text="Panel Name"
                FontWeight="SemiBold"
                HorizontalAlignment="Center" />
            <TextBlock x:Name="PanelRegionText"
                Text="Region"
                FontSize="12"
                Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>