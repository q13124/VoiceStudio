<UserControl x:Class="VoiceStudio.App.Controls.PanelQuickSwitchIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Phase 0: keep XAML minimal to avoid XamlCompiler.exe crashes. -->
    <Border Background="#181D26"
        CornerRadius="8"
        Padding="12"
        BorderBrush="#333333"
        BorderThickness="1"
        MinWidth="200">
        <StackPanel Spacing="6">
            <TextBlock x:Name="PanelNameText"
                Text="Panel Name"
                FontWeight="SemiBold"
                HorizontalAlignment="Center" />
            <TextBlock x:Name="PanelRegionText"
                Text="Region"
                FontSize="12"
                Foreground="#BBBBBB"
                HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>