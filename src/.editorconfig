# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = false
insert_final_newline = false

# Roslynator Analyzers - Configured as suggestions for style rules, warnings for code quality
# Helps catch bugs and code quality issues without blocking builds
dotnet_analyzer_diagnostic.category-roslynator.severity = warning

# Roslynator Style Rules - Downgrade to suggestion (still visible, not counted in budget)
# RCS1037: Remove trailing white-space (1848 occurrences - pure style)
dotnet_diagnostic.RCS1037.severity = suggestion
# RCS1181: Convert comment to documentation comment (1286 occurrences - doc style)
dotnet_diagnostic.RCS1181.severity = suggestion
# RCS1123: Add parentheses when necessary (146 occurrences - style preference)
dotnet_diagnostic.RCS1123.severity = suggestion
# RCS1189: Add or remove region name (192 occurrences - style preference)
dotnet_diagnostic.RCS1189.severity = suggestion

# Error handling rules
# CA1031: Do not catch general exception types - downgrade to suggestion in test code
# Production code should still catch specific exceptions
dotnet_diagnostic.CA1031.severity = suggestion

# RCS1163: Unused parameter (from Debugrolereport.md)
dotnet_code_quality_unused_parameters = all:suggestion
dotnet_diagnostic.RCS1163.severity = suggestion

# ===== C# Specific Settings =====
[*.cs]
indent_size = 4
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_sort_system_directives_first = true

# MVVM Source Generator compatibility
# Ensure partial classes work correctly with source generators
csharp_style_prefer_readonly_struct = true:suggestion

# ===== XAML Settings =====
[*.xaml]
indent_size = 2
max_line_length = 200

# Rapid XAML Toolkit Configuration
# Note: Install 'Rapid XAML Toolkit' VS extension for full functionality
# https://marketplace.visualstudio.com/items?itemName=MattLaceyLtd.RapidXamlToolkit

# RXT150: Use Name not x:Name (prefer x:Name for WinUI 3)
dotnet_diagnostic.RXT150.severity = none

# RXT160: Accessibility - Button should have AutomationProperties.Name
dotnet_diagnostic.RXT160.severity = warning

# RXT170: Accessibility - Image should have AutomationProperties.Name
dotnet_diagnostic.RXT170.severity = warning

# RXT200: Attribute formatting (multi-line vs single-line)
dotnet_diagnostic.RXT200.severity = suggestion

# XAML Binding Analyzer Rules (custom)
# These work with scripts/lint_xaml.py and build validation

# Require x:DataType on UserControl root
# Enforced via CI (see .github/workflows/build.yml)

# Prefer x:Bind over Binding
# Enforced via lint_xaml.py and pre-commit hooks

# ===== VoiceStudio XAML Conventions =====
# - All UserControls must have x:DataType
# - All panels must have d:DataContext for designer support
# - Loading overlays must have d:Visibility="Collapsed"
# - StaticResource references must use VSQ.* tokens
# - See: docs/developer/XAML_AI_CHECKLIST.md