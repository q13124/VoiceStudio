# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = false
insert_final_newline = false

# Roslynator Analyzers - Configured as warnings (non-blocking)
# Helps catch bugs and code quality issues without blocking builds
dotnet_analyzer_diagnostic.category-roslynator.severity = warning

# Error handling rules
# CA1031: Do not catch general exception types (catches empty/overly broad catches)
dotnet_diagnostic.CA1031.severity = warning

# RCS1163: Unused parameter (from Debugrolereport.md)
dotnet_code_quality_unused_parameters = all:suggestion
dotnet_diagnostic.RCS1163.severity = warning