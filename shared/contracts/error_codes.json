{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "error_codes.json",
  "title": "VoiceStudio Error Codes",
  "description": "Error codes used across VoiceStudio components",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "codes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] }
        }
      }
    }
  }
}
