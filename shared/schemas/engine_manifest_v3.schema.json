{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://voicestudio.app/schemas/engine_manifest_v3.schema.json",
  "title": "VoiceStudio Engine Manifest v3",
  "description": "Engine metadata schema for VoiceStudio engine manifests. Updated 2026-02 to match actual usage.",
  "type": "object",
  "required": ["engine_id", "name", "type", "version"],
  "properties": {
    "engine_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$",
      "description": "Unique engine identifier (lowercase, alphanumeric with hyphens/underscores)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable engine name"
    },
    "type": {
      "type": "string",
      "enum": ["audio", "video", "image", "llm"],
      "description": "Primary engine category"
    },
    "subtype": {
      "type": "string",
      "description": "Engine subtype (e.g., tts, stt, avatar, upscaler, chat)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?(\\.\\d+)?(-[a-zA-Z0-9.]+)?$",
      "description": "Engine version (e.g., 1.0, 2.0.1, 1.0.0-beta)"
    },
    "implementation_status": {
      "type": "string",
      "enum": ["full", "basic", "placeholder", "external"],
      "description": "Implementation status: full (complete), basic (partial), placeholder (stub), external (external tool)"
    },
    "implementation_notes": {
      "type": "string",
      "description": "Notes about implementation status or requirements"
    },
    "venv_family": {
      "type": "string",
      "description": "Virtual environment family for dependency isolation (e.g., venv_core_tts, venv_video)"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Detailed engine description"
    },
    "author": {
      "type": "string",
      "description": "Engine author or team name"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0, MPL-2.0)"
    },
    "python_version": {
      "type": "string",
      "pattern": "^>=?\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Required Python version (e.g., >=3.8, >=3.10)"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Python package dependencies as name:version pairs"
    },
    "model_paths": {
      "type": "object",
      "properties": {
        "base": {
          "type": "string",
          "description": "Base path for model storage"
        }
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Paths for model storage (supports environment variables like %PROGRAMDATA%)"
    },
    "supported_formats": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Supported file formats for output"
    },
    "supported_languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Supported language codes (ISO 639-1, optionally with region like zh-cn)"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Engine capabilities as string identifiers (e.g., voice_cloning, text_to_speech, lip_sync)"
    },
    "device_requirements": {
      "type": "object",
      "properties": {
        "gpu": {
          "type": "string",
          "enum": ["required", "recommended", "optional"],
          "description": "GPU requirement level"
        },
        "vram_min_gb": {
          "type": "number",
          "minimum": 0,
          "description": "Minimum GPU VRAM in GB"
        },
        "ram_min_gb": {
          "type": "number",
          "minimum": 0,
          "description": "Minimum system RAM in GB"
        }
      },
      "description": "Hardware requirements for the engine"
    },
    "entry_point": {
      "type": "string",
      "description": "Python module path to engine class (e.g., app.core.engines.xtts_engine.XTTSEngine)"
    },
    "config_schema": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "default": {},
          "enum": {"type": "array"},
          "minimum": {"type": "number"},
          "maximum": {"type": "number"},
          "description": {"type": "string"}
        }
      },
      "description": "Engine-specific configuration options schema"
    },
    "contract": {
      "type": "object",
      "properties": {
        "input": {
          "type": "object",
          "properties": {
            "audio_formats": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Supported input audio formats"
            },
            "video_formats": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Supported input video formats"
            },
            "sample_rates": {
              "type": "array",
              "items": {"type": "integer"},
              "description": "Supported sample rates in Hz"
            },
            "max_duration_seconds": {
              "type": "number",
              "description": "Maximum input duration in seconds"
            },
            "min_duration_seconds": {
              "type": "number",
              "description": "Minimum input duration in seconds"
            },
            "text_max_chars": {
              "type": "integer",
              "description": "Maximum text input length"
            }
          },
          "additionalProperties": true,
          "description": "Input specifications"
        },
        "output": {
          "type": "object",
          "properties": {
            "audio_format": {"type": "string"},
            "video_format": {"type": "string"},
            "sample_rate": {"type": "integer"},
            "bit_depth": {"type": "integer"},
            "channels": {"type": "integer"},
            "codec": {"type": "string"},
            "default_fps": {"type": "integer"}
          },
          "additionalProperties": true,
          "description": "Output specifications"
        },
        "resources": {
          "type": "object",
          "properties": {
            "vram_mb": {
              "type": "integer",
              "description": "VRAM usage in MB"
            },
            "ram_mb": {
              "type": "integer",
              "description": "RAM usage in MB"
            },
            "cpu_threads": {
              "type": "integer",
              "description": "CPU threads used"
            },
            "timeout_seconds": {
              "type": "integer",
              "description": "Operation timeout in seconds"
            }
          },
          "description": "Resource requirements"
        }
      },
      "description": "Engine input/output contract specifications"
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "size_bytes": {"type": "integer"},
          "download_url": {"type": "string", "format": "uri"},
          "checksum": {
            "type": "object",
            "properties": {
              "algorithm": {"type": "string", "enum": ["sha256", "md5"]},
              "value": {"type": "string"}
            }
          },
          "default": {"type": "boolean", "default": false}
        }
      },
      "description": "Available model variants"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "quality_benchmarks": {
          "type": "object",
          "properties": {
            "mos_score": {"type": "number", "minimum": 1, "maximum": 5},
            "wer": {"type": "number", "minimum": 0, "maximum": 1},
            "rtf": {"type": "number", "minimum": 0, "description": "Real-time factor"}
          }
        },
        "performance": {
          "type": "object",
          "properties": {
            "avg_latency_ms": {"type": "number"},
            "throughput_samples_per_sec": {"type": "number"}
          }
        }
      },
      "description": "Engine quality and performance metrics"
    },
    "ui": {
      "type": "object",
      "properties": {
        "icon": {"type": "string", "description": "Icon path or data URI"},
        "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "category": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      },
      "description": "UI display configuration"
    },
    "deprecated": {
      "type": "object",
      "properties": {
        "is_deprecated": {"type": "boolean", "default": false},
        "message": {"type": "string"},
        "replacement": {"type": "string"},
        "sunset_date": {"type": "string", "format": "date"}
      }
    }
  },
  "additionalProperties": true
}
