{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://voicestudio.app/schemas/plugin-manifest.schema.json",
  "title": "VoiceStudio Plugin Manifest v4",
  "description": "Unified plugin manifest schema for VoiceStudio backend (Python) and frontend (C#) plugins. Implements architectural principles: modularity, security isolation, resource management, version control, and marketplace distribution (Phase 4).",
  "type": "object",
  "required": ["name", "version", "author", "plugin_type", "category"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Manifest schema version (v4 adds distribution, catalog, trust fields)",
      "enum": ["3.0.0", "4.0.0"],
      "default": "4.0.0"
    },
    "id": {
      "type": "string",
      "description": "Globally unique plugin identifier (recommended: reverse-domain format)",
      "pattern": "^[a-z][a-z0-9._-]{0,127}$",
      "minLength": 1,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "description": "Unique plugin identifier (lowercase alphanumeric + underscores)",
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "minLength": 1,
      "maxLength": 64
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable plugin name for UI display",
      "maxLength": 100
    },
    "version": {
      "type": "string",
      "description": "Plugin version in semantic versioning format (major.minor.patch)",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "author": {
      "type": "string",
      "description": "Plugin author or organization name",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Short plugin description (1-2 sentences)",
      "maxLength": 500
    },
    "long_description": {
      "type": "string",
      "description": "Detailed plugin description with features and usage",
      "maxLength": 5000
    },
    "plugin_type": {
      "type": "string",
      "description": "Plugin architecture type",
      "enum": ["backend_only", "frontend_only", "full_stack"]
    },
    "category": {
      "type": "string",
      "description": "Functional category for plugin classification",
      "enum": [
        "voice_synthesis",
        "speech_recognition",
        "audio_effects",
        "audio_analysis",
        "voice_conversion",
        "video_processing",
        "integrations",
        "utilities",
        "developer_tools",
        "themes_ui",
        "other"
      ]
    },
    "min_app_version": {
      "type": "string",
      "description": "Minimum required VoiceStudio application version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "min_api_version": {
      "type": "string",
      "description": "Minimum required plugin API version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "capabilities": {
      "type": "object",
      "description": "Plugin capabilities and features",
      "properties": {
        "backend_routes": {
          "type": "boolean",
          "description": "Whether plugin provides backend API routes",
          "default": false
        },
        "ui_panels": {
          "type": "array",
          "description": "List of UI panel identifiers provided by plugin",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          },
          "uniqueItems": true
        },
        "engines": {
          "type": "array",
          "description": "Audio/video engines provided by plugin",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "effects": {
          "type": "array",
          "description": "Audio effects provided by plugin",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "export_formats": {
          "type": "array",
          "description": "Export formats supported by plugin",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "import_formats": {
          "type": "array",
          "description": "Import formats supported by plugin",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "integrations": {
          "type": "array",
          "description": "External service integrations",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "mcp_integration": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "MCP server name if plugin provides MCP integration, false/omit otherwise"
        }
      },
      "additionalProperties": false
    },
    "entry_points": {
      "type": "object",
      "description": "Plugin entry points for backend and frontend",
      "properties": {
        "backend": {
          "type": "string",
          "description": "Backend entry point (module.function format, e.g., 'plugin.register')",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)+$"
        },
        "frontend": {
          "type": "string",
          "description": "Frontend entry point (DLL filename, e.g., 'MyPlugin.dll')",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*\\.dll$"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "description": "Plugin dependencies",
      "properties": {
        "python": {
          "type": "array",
          "description": "Python package dependencies (pip specifier format)",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+(\\[.+\\])?(>=|<=|==|!=|~=|>|<)?[a-zA-Z0-9._-]*$"
          }
        },
        "plugins": {
          "type": "array",
          "description": "Other VoiceStudio plugins this plugin depends on",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}(>=|<=|==)?\\d+\\.\\d+\\.\\d+$"
          }
        },
        "system": {
          "type": "array",
          "description": "System-level dependencies (informational)",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "array",
      "description": "Permissions required by plugin (capability-based security)",
      "items": {
        "type": "string",
        "enum": [
          "filesystem.read",
          "filesystem.write",
          "filesystem.execute",
          "filesystem.read.self",
          "filesystem.write.self",
          "filesystem.read.workspace",
          "filesystem.write.workspace",
          "filesystem.read.user_selected",
          "filesystem.write.user_selected",
          "network.http",
          "network.websocket",
          "network.listen",
          "network.localhost",
          "network.allowed_domains",
          "network.any",
          "audio.input",
          "audio.output",
          "audio.process",
          "system.process",
          "system.info",
          "system.clipboard.read",
          "system.clipboard.write",
          "engine.tts",
          "engine.stt",
          "engine.vc",
          "engine.config",
          "engine.register",
          "ui.notify",
          "ui.dialog",
          "ui.panel",
          "ui.toolbar",
          "ui.theme",
          "ui.context_menu",
          "data.project.read",
          "data.project.write",
          "data.settings.read",
          "data.settings.write",
          "data.storage",
          "integration.plugin_events",
          "integration.plugin_call",
          "integration.external_api",
          "user.credentials",
          "notifications"
        ]
      },
      "uniqueItems": true
    },
    "settings_schema": {
      "type": "object",
      "description": "JSON Schema for plugin-specific settings (inline)",
      "properties": {
        "type": { "type": "string" },
        "properties": { "type": "object" },
        "required": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional plugin metadata",
      "properties": {
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Plugin homepage URL"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Source code repository URL"
        },
        "documentation": {
          "type": "string",
          "format": "uri",
          "description": "Documentation URL"
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier (e.g., MIT, Apache-2.0)",
          "maxLength": 50
        },
        "tags": {
          "type": "array",
          "description": "Searchable tags for plugin discovery",
          "items": { "type": "string", "maxLength": 30 },
          "maxItems": 10
        },
        "icon": {
          "type": "string",
          "description": "Path to plugin icon (relative to plugin directory)"
        }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "description": "Security configuration following defence-in-depth principles (v4 enhanced)",
      "properties": {
        "isolation_mode": {
          "type": "string",
          "description": "Execution isolation level for plugin code",
          "enum": ["in_process", "sandboxed", "out_of_process", "subprocess", "wasm"],
          "default": "in_process"
        },
        "permissions": {
          "type": "object",
          "description": "Phase 4: Granular permission declarations for policy enforcement",
          "properties": {
            "filesystem": {
              "type": "object",
              "description": "Filesystem access permissions",
              "properties": {
                "read": {
                  "type": "array",
                  "description": "Paths the plugin can read (supports patterns)",
                  "items": { "type": "string" }
                },
                "write": {
                  "type": "array",
                  "description": "Paths the plugin can write (supports patterns)",
                  "items": { "type": "string" }
                },
                "scope": {
                  "type": "string",
                  "description": "Filesystem scope restriction",
                  "enum": ["none", "plugin_data", "user_data", "project", "system"],
                  "default": "none"
                }
              },
              "additionalProperties": false
            },
            "network": {
              "type": "object",
              "description": "Network access permissions",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Whether network access is allowed",
                  "default": false
                },
                "allowed_hosts": {
                  "type": "array",
                  "description": "Allowed network hosts (supports wildcards)",
                  "items": { "type": "string" }
                },
                "allowed_ports": {
                  "type": "array",
                  "description": "Allowed port numbers or ranges",
                  "items": {
                    "oneOf": [
                      { "type": "integer", "minimum": 1, "maximum": 65535 },
                      { "type": "string", "pattern": "^\\d+-\\d+$" }
                    ]
                  }
                },
                "protocols": {
                  "type": "array",
                  "description": "Allowed network protocols",
                  "items": {
                    "type": "string",
                    "enum": ["http", "https", "websocket", "tcp", "udp"]
                  },
                  "default": ["https"]
                }
              },
              "additionalProperties": false
            },
            "audio": {
              "type": "object",
              "description": "Audio device access permissions",
              "properties": {
                "capture": {
                  "type": "boolean",
                  "description": "Allow audio capture (microphone)",
                  "default": false
                },
                "playback": {
                  "type": "boolean",
                  "description": "Allow audio playback",
                  "default": true
                },
                "process": {
                  "type": "boolean",
                  "description": "Allow audio stream processing",
                  "default": true
                }
              },
              "additionalProperties": false
            },
            "gpu": {
              "type": "object",
              "description": "GPU access permissions",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Allow GPU compute access",
                  "default": false
                },
                "vram_limit_mb": {
                  "type": "integer",
                  "description": "Maximum VRAM allocation in MB",
                  "minimum": 0
                },
                "device_selection": {
                  "type": "string",
                  "description": "GPU device selection strategy",
                  "enum": ["any", "primary", "secondary", "specific"],
                  "default": "any"
                }
              },
              "additionalProperties": false
            },
            "host_api": {
              "type": "object",
              "description": "VoiceStudio host API access permissions",
              "properties": {
                "allowed_apis": {
                  "type": "array",
                  "description": "List of allowed host API namespaces",
                  "items": {
                    "type": "string",
                    "enum": [
                      "audio.playback",
                      "audio.capture",
                      "audio.process",
                      "project.read",
                      "project.write",
                      "settings.read",
                      "settings.write",
                      "ui.notifications",
                      "ui.dialogs",
                      "ui.panels",
                      "engine.invoke",
                      "plugin.communicate"
                    ]
                  }
                },
                "denied_apis": {
                  "type": "array",
                  "description": "Explicitly denied APIs (overrides allowed)",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "subprocess": {
              "type": "object",
              "description": "Subprocess spawning permissions (Phase 4 sandbox model)",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Allow plugin to run in subprocess",
                  "default": false
                },
                "spawn_children": {
                  "type": "boolean",
                  "description": "Allow plugin subprocess to spawn child processes",
                  "default": false
                },
                "allowed_executables": {
                  "type": "array",
                  "description": "List of allowed executables the subprocess can invoke",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "signature": {
          "type": "object",
          "description": "Digital signature for authenticity verification",
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["RSA-SHA256", "ECDSA-P256", "Ed25519"],
              "description": "Signature algorithm used"
            },
            "public_key_id": {
              "type": "string",
              "description": "Key ID for signature verification"
            },
            "signature": {
              "type": "string",
              "description": "Base64-encoded digital signature"
            },
            "certificate_chain": {
              "type": "array",
              "description": "PEM certificate chain for verification",
              "items": { "type": "string" }
            }
          },
          "required": ["algorithm", "signature"]
        },
        "trusted_publisher": {
          "type": "boolean",
          "description": "Whether plugin is from a verified/trusted publisher",
          "default": false
        },
        "sandbox_config": {
          "type": "object",
          "description": "Sandboxing configuration when isolation_mode is sandboxed",
          "properties": {
            "allow_network": {
              "type": "boolean",
              "default": false
            },
            "allow_filesystem": {
              "type": "boolean",
              "default": false
            },
            "allowed_paths": {
              "type": "array",
              "description": "Specific filesystem paths plugin can access",
              "items": { "type": "string" }
            },
            "allowed_hosts": {
              "type": "array",
              "description": "Specific network hosts plugin can contact",
              "items": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "resource_limits": {
      "type": "object",
      "description": "Per-plugin resource budgets to prevent denial-of-service",
      "properties": {
        "max_memory_mb": {
          "type": "integer",
          "description": "Maximum memory usage in megabytes",
          "minimum": 0,
          "maximum": 8192,
          "default": 512
        },
        "max_cpu_percent": {
          "type": "number",
          "description": "Maximum CPU usage percentage (0-100)",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        },
        "max_io_mbps": {
          "type": "number",
          "description": "Maximum I/O throughput in MB/s",
          "minimum": 0,
          "default": 100
        },
        "max_execution_time_ms": {
          "type": "integer",
          "description": "Maximum execution time per operation in milliseconds",
          "minimum": 0,
          "default": 30000
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "description": "Maximum number of concurrent tasks",
          "minimum": 1,
          "maximum": 100,
          "default": 4
        },
        "requires_gpu": {
          "type": "boolean",
          "description": "Whether plugin requires GPU access",
          "default": false
        },
        "gpu_memory_mb": {
          "type": "integer",
          "description": "Estimated GPU memory requirement in MB",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "description": "Plugin lifecycle configuration",
      "properties": {
        "auto_start": {
          "type": "boolean",
          "description": "Whether plugin starts automatically on app launch",
          "default": true
        },
        "lazy_load": {
          "type": "boolean",
          "description": "Whether to defer loading until first use",
          "default": false
        },
        "restart_on_failure": {
          "type": "boolean",
          "description": "Whether to automatically restart on crash",
          "default": true
        },
        "max_restart_attempts": {
          "type": "integer",
          "description": "Maximum restart attempts before disabling",
          "minimum": 0,
          "default": 3
        },
        "health_check_interval_ms": {
          "type": "integer",
          "description": "Interval for health checks in milliseconds",
          "minimum": 1000,
          "default": 30000
        }
      },
      "additionalProperties": false
    },
    "deprecation": {
      "type": "object",
      "description": "Deprecation information for version evolution",
      "properties": {
        "deprecated": {
          "type": "boolean",
          "description": "Whether this version is deprecated",
          "default": false
        },
        "deprecation_date": {
          "type": "string",
          "format": "date",
          "description": "Date when deprecation was announced"
        },
        "sunset_date": {
          "type": "string",
          "format": "date",
          "description": "Date when plugin will stop working"
        },
        "migration_guide": {
          "type": "string",
          "format": "uri",
          "description": "URL to migration documentation"
        },
        "replacement_plugin": {
          "type": "string",
          "description": "Plugin ID of recommended replacement"
        }
      }
    },
    "distribution": {
      "type": "object",
      "description": "Phase 4: Distribution and packaging information for marketplace",
      "properties": {
        "package_format": {
          "type": "string",
          "description": "Distribution package format",
          "enum": ["vspkg", "directory", "zip"],
          "default": "vspkg"
        },
        "download_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to download the plugin package"
        },
        "checksum": {
          "type": "object",
          "description": "Package integrity verification",
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["sha256", "sha384", "sha512"],
              "default": "sha256"
            },
            "value": {
              "type": "string",
              "description": "Hash value in hex format"
            }
          }
        },
        "size_bytes": {
          "type": "integer",
          "description": "Package size in bytes",
          "minimum": 0
        },
        "release_date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of release"
        },
        "release_channel": {
          "type": "string",
          "description": "Release channel for staged rollouts",
          "enum": ["stable", "beta", "alpha", "nightly"],
          "default": "stable"
        },
        "changelog_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to changelog or release notes"
        },
        "min_installer_version": {
          "type": "string",
          "description": "Minimum plugin installer version required",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    },
    "catalog": {
      "type": "object",
      "description": "Phase 4: Catalog listing metadata for plugin discovery",
      "properties": {
        "category": {
          "type": "string",
          "description": "Primary category for marketplace browsing",
          "enum": [
            "audio_effects",
            "voice_synthesis",
            "speech_recognition",
            "voice_conversion",
            "audio_analysis",
            "video_processing",
            "integrations",
            "utilities",
            "developer_tools",
            "themes_ui",
            "other"
          ]
        },
        "subcategory": {
          "type": "string",
          "description": "Secondary category for finer filtering",
          "maxLength": 50
        },
        "featured": {
          "type": "boolean",
          "description": "Whether plugin is featured in marketplace",
          "default": false
        },
        "popularity_score": {
          "type": "number",
          "description": "Computed popularity score (0-100)",
          "minimum": 0,
          "maximum": 100
        },
        "download_count": {
          "type": "integer",
          "description": "Total download count",
          "minimum": 0
        },
        "rating": {
          "type": "object",
          "description": "User rating statistics",
          "properties": {
            "average": {
              "type": "number",
              "minimum": 0,
              "maximum": 5
            },
            "count": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "screenshots": {
          "type": "array",
          "description": "URLs to plugin screenshots for catalog display",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "caption": { "type": "string", "maxLength": 200 },
              "type": { "type": "string", "enum": ["screenshot", "banner", "icon"] }
            },
            "required": ["url"]
          },
          "maxItems": 10
        },
        "demo_video_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to demonstration video"
        },
        "pricing": {
          "type": "object",
          "description": "Pricing information (for future marketplace)",
          "properties": {
            "model": {
              "type": "string",
              "enum": ["free", "freemium", "paid", "subscription", "donation"],
              "default": "free"
            },
            "price_usd": {
              "type": "number",
              "description": "Price in USD (if paid)",
              "minimum": 0
            },
            "trial_days": {
              "type": "integer",
              "description": "Trial period in days",
              "minimum": 0
            }
          }
        },
        "supported_languages": {
          "type": "array",
          "description": "Languages supported by the plugin UI",
          "items": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
          }
        },
        "keywords": {
          "type": "array",
          "description": "Additional search keywords",
          "items": { "type": "string", "maxLength": 30 },
          "maxItems": 20
        }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "description": "Phase 4: Trust and verification information for security",
      "properties": {
        "publisher_id": {
          "type": "string",
          "description": "Verified publisher identifier",
          "maxLength": 128
        },
        "publisher_name": {
          "type": "string",
          "description": "Human-readable publisher name",
          "maxLength": 100
        },
        "publisher_verified": {
          "type": "boolean",
          "description": "Whether publisher identity is verified",
          "default": false
        },
        "code_signed": {
          "type": "boolean",
          "description": "Whether package is cryptographically signed",
          "default": false
        },
        "signature_info": {
          "type": "object",
          "description": "Details about the code signature",
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["ed25519", "rsa-sha256", "ecdsa-p256"]
            },
            "signer_id": {
              "type": "string",
              "description": "Identifier of the signing key"
            },
            "signed_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the package was signed"
            },
            "expires_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the signature expires (optional)"
            }
          }
        },
        "security_audit": {
          "type": "object",
          "description": "Security audit information",
          "properties": {
            "audited": {
              "type": "boolean",
              "description": "Whether plugin has been security audited",
              "default": false
            },
            "auditor": {
              "type": "string",
              "description": "Name of the auditing entity"
            },
            "audit_date": {
              "type": "string",
              "format": "date",
              "description": "Date of last audit"
            },
            "audit_version": {
              "type": "string",
              "description": "Version that was audited"
            },
            "report_url": {
              "type": "string",
              "format": "uri",
              "description": "URL to audit report"
            }
          }
        },
        "trust_level": {
          "type": "string",
          "description": "Computed trust level based on verification status",
          "enum": ["unknown", "community", "verified", "official", "certified"]
        },
        "policy_compliance": {
          "type": "array",
          "description": "Policy requirements the plugin complies with",
          "items": {
            "type": "string",
            "enum": [
              "no_telemetry",
              "offline_capable",
              "open_source",
              "privacy_preserving",
              "gdpr_compliant",
              "accessibility_compliant"
            ]
          },
          "uniqueItems": true
        },
        "content_rating": {
          "type": "string",
          "description": "Content rating for age-appropriate filtering",
          "enum": ["everyone", "teen", "mature"],
          "default": "everyone"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "plugin_type": { "const": "full_stack" } }
      },
      "then": {
        "properties": {
          "entry_points": {
            "required": ["backend", "frontend"]
          }
        },
        "required": ["entry_points"]
      }
    },
    {
      "if": {
        "properties": { "plugin_type": { "const": "backend_only" } }
      },
      "then": {
        "properties": {
          "entry_points": {
            "required": ["backend"]
          }
        },
        "required": ["entry_points"]
      }
    },
    {
      "if": {
        "properties": { "plugin_type": { "const": "frontend_only" } }
      },
      "then": {
        "properties": {
          "entry_points": {
            "required": ["frontend"]
          }
        },
        "required": ["entry_points"]
      }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "properties": { "backend_routes": { "const": true } },
            "required": ["backend_routes"]
          }
        },
        "required": ["capabilities"]
      },
      "then": {
        "properties": {
          "plugin_type": { "enum": ["backend_only", "full_stack"] }
        }
      }
    }
  ]
}
