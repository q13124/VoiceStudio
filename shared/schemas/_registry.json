{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "_registry.json",
  "title": "VoiceStudio Schema Registry",
  "description": "Registry of all shared schemas for VoiceStudio",
  "version": "1.1.0",
  "schemas": [
    {
      "id": "voice_profile.schema.json",
      "path": "schemas/voice_profile.schema.json",
      "description": "Voice profile schema with avatar support"
    },
    {
      "id": "issue.schema.json",
      "path": "schemas/issue.schema.json",
      "description": "Issue tracking schema"
    },
    {
      "id": "analyze_voice_request.schema.json",
      "path": "contracts/analyze_voice_request.schema.json",
      "description": "Voice analysis request contract"
    },
    {
      "id": "layout_state.schema.json",
      "path": "contracts/layout_state.schema.json",
      "description": "UI layout state contract"
    },
    {
      "id": "mcp_operation.schema.json",
      "path": "contracts/mcp_operation.schema.json",
      "description": "MCP operation contract"
    },
    {
      "id": "mcp_operation_response.schema.json",
      "path": "contracts/mcp_operation_response.schema.json",
      "description": "MCP operation response contract"
    },
    {
      "id": "error_codes.json",
      "path": "contracts/error_codes.json",
      "description": "Error code definitions"
    }
  ]
}
