{
  "$schema": "../../shared/schemas/plugin-manifest.schema.json",
  "name": "{{PLUGIN_NAME}}",
  "display_name": "{{DISPLAY_NAME}}",
  "version": "{{VERSION}}",
  "author": "{{AUTHOR}}",
  "description": "{{DESCRIPTION}}",
  "plugin_type": "backend_only",
  "category": "voice_synthesis",
  "min_app_version": "1.0.0",
  "capabilities": {
    "backend_routes": true,
    "engines": ["tts"]
  },
  "entry_points": {
    "backend": "register"
  },
  "dependencies": {
    "python": ["numpy>=1.20.0"],
    "plugins": [],
    "system": []
  },
  "permissions": ["audio.process"],
  "metadata": {
    "license": "MIT",
    "tags": ["engine", "adapter", "tts"]
  },
  "security": {
    "isolation_mode": "in_process"
  }
}
