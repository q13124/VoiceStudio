{
  "engine_id": "rvc_v2",
  "name": "RVC v2 (Enhanced Voice Conversion)",
  "type": "audio",
  "subtype": "voice_conversion",
  "version": "2.0.0",
  "venv_family": "venv_voice_conversion",
  "description": "RVC v2 - Enhanced retrieval-based voice conversion with RMVPE pitch extraction and improved quality",
  "author": "RVC Project",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "rvc-python": ">=1.0.0",
    "fairseq": ">=0.12.0",
    "librosa": ">=0.10.0",
    "torch": ">=2.0.0",
    "soundfile": ">=0.12.0",
    "numpy": ">=1.21.0",
    "praat-parselmouth": ">=0.4.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\rvc_v2",
    "hubert": "%PROGRAMDATA%\\VoiceStudio\\models\\rvc_v2\\hubert",
    "rmvpe": "%PROGRAMDATA%\\VoiceStudio\\models\\rvc_v2\\rmvpe"
  },
  "capabilities": [
    "voice_conversion",
    "real_time_conversion",
    "pitch_shifting",
    "low_latency",
    "high_quality",
    "rmvpe_pitch_extraction",
    "v2_architecture",
    "improved_quality"
  ],
  "quality_features": {
    "mos_estimate": "4.2-4.7",
    "similarity_score": "very_high",
    "naturalness": "very_high",
    "speed": "very_fast",
    "latency": "very_low",
    "quality_tier": "high"
  },
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 6
  },
  "entry_point": "app.core.engines.rvc_engine:RVCEngine",
  "config_schema": {
    "model_path": {
      "type": "string",
      "default": null,
      "description": "Path to RVC v2 model directory"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": ["cuda", "cpu"],
      "description": "Device to use for inference"
    },
    "gpu": {
      "type": "boolean",
      "default": true,
      "description": "Whether to use GPU if available"
    },
    "sample_rate": {
      "type": "integer",
      "default": 40000,
      "description": "Sample rate for processing"
    },
    "hop_length": {
      "type": "integer",
      "default": 128,
      "description": "Hop length for processing"
    },
    "pitch_extraction_method": {
      "type": "string",
      "default": "rmvpe",
      "enum": ["rmvpe", "pm", "harvest", "dio", "crepe"],
      "description": "Pitch extraction method (rmvpe recommended for v2)"
    },
    "model_version": {
      "type": "string",
      "default": "v2",
      "enum": ["v1", "v2"],
      "description": "RVC model architecture version"
    },
    "protect": {
      "type": "number",
      "default": 0.33,
      "minimum": 0,
      "maximum": 0.5,
      "description": "Voice protection ratio (0.33 default, lower = more conversion)"
    },
    "filter_radius": {
      "type": "integer",
      "default": 3,
      "minimum": 0,
      "maximum": 7,
      "description": "Median filter radius for pitch smoothing"
    }
  },
  "defaults": {
    "pitch_extraction_method": "rmvpe",
    "model_version": "v2",
    "protect": 0.33
  },
  "contract": {
    "input": {
      "audio_formats": ["wav", "mp3", "flac", "ogg"],
      "sample_rates": [16000, 22050, 44100, 48000],
      "max_duration_seconds": 120
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 44100,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 6144,
      "timeout_seconds": 240
    }
  }
}
