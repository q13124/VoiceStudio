{
  "engine_id": "aeneas",
  "name": "Aeneas",
  "type": "audio",
  "subtype": "alignment",
  "version": "1.0",
  "venv_family": "venv_stt",
  "description": "Audio-text alignment and subtitle generation - synchronizes audio with text",
  "author": "ReadBeyond",
  "license": "AGPL-3.0",
  "python_version": ">=3.8",
  "dependencies": {
    "aeneas": ">=1.7.3",
    "numpy": ">=1.21.0"
  },
  "model_paths": {},
  "supported_formats": [
    "wav",
    "mp3",
    "m4a",
    "flac"
  ],
  "capabilities": [
    "audio_text_alignment",
    "subtitle_generation",
    "srt_export",
    "vtt_export",
    "word_level_alignment",
    "phrase_level_alignment"
  ],
  "device_requirements": {
    "gpu": "optional",
    "vram_min_gb": 0,
    "ram_min_gb": 2
  },
  "entry_point": "app.core.engines.aeneas_engine.AeneasEngine",
  "config_schema": {
    "alignment_type": {
      "type": "string",
      "default": "auto",
      "enum": [
        "auto",
        "forced",
        "sentence"
      ],
      "description": "Alignment type"
    },
    "output_format": {
      "type": "string",
      "default": "srt",
      "enum": [
        "srt",
        "vtt",
        "json",
        "smil"
      ],
      "description": "Output subtitle format"
    },
    "language": {
      "type": "string",
      "default": "en",
      "description": "Language code for alignment"
    }
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        24000,
        44100
      ],
      "max_duration_seconds": 30,
      "text_max_chars": 5000
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 22050,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 0,
      "ram_mb": 2048,
      "timeout_seconds": 120
    }
  }
}
