{
  "engine_id": "whisper_ui",
  "name": "Whisper UI",
  "type": "audio",
  "subtype": "stt",
  "version": "1.0",
  "description": "Whisper UI - User interface wrapper for Whisper STT with enhanced features",
  "author": "Whisper UI Community",
  "license": "MIT",
  "python_version": ">=3.8",
  "dependencies": {
    "openai-whisper": ">=20230314",
    "faster-whisper": ">=1.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\whisper_ui",
    "models": "%PROGRAMDATA%\\VoiceStudio\\models\\whisper_ui\\models"
  },
  "supported_formats": ["wav", "mp3", "m4a", "flac", "ogg"],
  "capabilities": [
    "speech_to_text",
    "transcription",
    "translation",
    "word_timestamps",
    "language_detection",
    "gui_interface"
  ],
  "device_requirements": {
    "gpu": "optional",
    "vram_min_gb": 0,
    "ram_min_gb": 2
  },
  "entry_point": "app.core.engines.whisper_ui_engine.WhisperUIEngine",
  "config_schema": {
    "model": {
      "type": "string",
      "default": "base",
      "enum": ["tiny", "base", "small", "medium", "large", "large-v2", "large-v3"],
      "description": "Whisper model size"
    },
    "language": {
      "type": "string",
      "default": "auto",
      "description": "Language code (auto for auto-detect)"
    },
    "device": {
      "type": "string",
      "default": "cpu",
      "enum": ["cuda", "cpu"],
      "description": "Device to use for inference"
    },
    "use_faster_whisper": {
      "type": "boolean",
      "default": true,
      "description": "Use faster-whisper for faster inference"
    }
  }
}

