{
  "engine_id": "festival",
  "name": "Festival / Flite",
  "type": "audio",
  "subtype": "tts",
  "version": "1.0",
  "venv_family": "venv_fast_tts",
  "description": "Festival/Flite - Legacy open-source TTS system (Festival framework with Flite runtime)",
  "author": "Festival/Flite Team",
  "license": "BSD",
  "python_version": ">=3.8",
  "dependencies": {},
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\festival",
    "voices": "%PROGRAMDATA%\\VoiceStudio\\models\\festival\\voices"
  },
  "supported_formats": [
    "wav"
  ],
  "capabilities": [
    "text_to_speech",
    "legacy_tts",
    "accessibility",
    "lightweight"
  ],
  "device_requirements": {
    "gpu": "not_required",
    "vram_min_gb": 0,
    "ram_min_gb": 1
  },
  "entry_point": "app.core.engines.festival_flite_engine.FestivalFliteEngine",
  "config_schema": {
    "executable_path": {
      "type": "string",
      "default": "festival",
      "description": "Path to Festival/Flite executable"
    },
    "voice": {
      "type": "string",
      "default": "kal_diphone",
      "description": "Voice name"
    },
    "use_flite": {
      "type": "boolean",
      "default": true,
      "description": "Use Flite (lightweight) instead of full Festival"
    }
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        24000,
        44100
      ],
      "max_duration_seconds": 30,
      "text_max_chars": 5000
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 22050,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 0,
      "ram_mb": 1024,
      "timeout_seconds": 120
    }
  }
}
