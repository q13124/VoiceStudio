{
  "engine_id": "gpt_sovits",
  "name": "GPT-SoVITS",
  "type": "audio",
  "subtype": "vc",
  "version": "1.0",
  "description": "GPT-SoVITS - Voice conversion and fine-tuning with GPT and SoVITS",
  "author": "GPT-SoVITS Team",
  "license": "MIT",
  "python_version": ">=3.8",
  "dependencies": {
    "torch": ">=1.9.0",
    "transformers": ">=4.20.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\gpt_sovits",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\gpt_sovits\\checkpoints",
    "gpt_models": "%PROGRAMDATA%\\VoiceStudio\\models\\gpt_sovits\\gpt",
    "sovits_models": "%PROGRAMDATA%\\VoiceStudio\\models\\gpt_sovits\\sovits"
  },
  "supported_formats": [
    "wav",
    "mp3"
  ],
  "capabilities": [
    "voice_conversion",
    "voice_cloning",
    "fine_tuning",
    "real_time_conversion"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.gpt_sovits_engine.GPTSovitsEngine",
  "config_schema": {
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "gpt_model_path": {
      "type": "string",
      "default": "",
      "description": "Path to GPT model checkpoint"
    },
    "sovits_model_path": {
      "type": "string",
      "default": "",
      "description": "Path to SoVITS model checkpoint"
    }
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        24000,
        44100
      ],
      "max_duration_seconds": 30,
      "text_max_chars": 5000
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 22050,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 120
    }
  }
}
