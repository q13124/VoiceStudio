{
  "engine_id": "mockingbird",
  "name": "MockingBird Clone",
  "type": "audio",
  "subtype": "vc",
  "version": "1.0",
  "venv_family": "venv_voice_conversion",
  "description": "MockingBird - Real-time voice cloning and conversion",
  "author": "MockingBird Team",
  "license": "MIT",
  "python_version": ">=3.8",
  "dependencies": {
    "torch": ">=1.9.0",
    "librosa": ">=0.9.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\mockingbird",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\mockingbird\\checkpoints"
  },
  "supported_formats": [
    "wav",
    "mp3"
  ],
  "capabilities": [
    "voice_cloning",
    "voice_conversion",
    "real_time_cloning",
    "high_quality"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.mockingbird_engine.MockingBirdEngine",
  "config_schema": {
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "model_id": {
      "type": "string",
      "default": "mockingbird",
      "description": "MockingBird model identifier"
    }
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        24000,
        44100
      ],
      "max_duration_seconds": 30,
      "text_max_chars": 5000
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 22050,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 120
    }
  },
  "implementation_status": "basic",
  "implementation_notes": "Basic implementation. Some advanced features may be missing."
}