{
  "engine_id": "whisperx",
  "name": "WhisperX STT",
  "type": "audio",
  "subtype": "stt",
  "version": "1.0",
  "venv_family": "venv_stt",
  "description": "Speech-to-text with word-level timestamps and speaker diarization (WhisperX)",
  "author": "m-bain",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "whisperx": ">=3.1.0",
    "torch": ">=2.0.0",
    "numpy": ">=1.24.0"
  },
  "model_paths": {},
  "supported_languages": ["auto", "en", "es", "fr", "de", "it", "pt", "ru", "ja", "ko", "zh", "ar", "hi", "nl", "pl", "tr", "sv", "no", "fi", "da", "cs", "hu", "ro", "vi", "id", "th", "uk", "he", "fa", "ta", "ur", "bn", "te", "kn", "ml", "si", "my", "km", "lo", "ka", "am", "sw", "af", "az", "mk", "be", "eu", "gl", "ha", "jv", "kk", "ky", "lb", "mg", "ms", "ne", "ny", "ps", "so", "su", "tg", "uz", "yi", "yo", "zu"],
  "capabilities": ["speech_to_text", "transcription", "language_detection", "word_timestamps", "speaker_diarization", "multi_language_stt"],
  "device_requirements": {"gpu": "optional", "vram_min_gb": 2, "ram_min_gb": 4},
  "entry_point": "app.core.engines.whisperx_engine.WhisperXEngine",
  "config_schema": {
    "model_name": {"type": "string", "default": "base", "enum": ["tiny", "base", "small", "medium", "large-v2", "large-v3"], "description": "Whisper model size"},
    "device": {"type": "string", "default": "cuda", "enum": ["cuda", "cpu"]},
    "gpu": {"type": "boolean", "default": true},
    "compute_type": {"type": "string", "default": "float16", "enum": ["float16", "int8", "float32"]}
  },
  "tasks": ["transcribe", "stt", "speech_to_text", "language_detection", "diarization"],
  "resources": {"needs": ["cuda_optional"], "vram_gb": 2, "ram_gb": 4},
  "lifecycle": {"pool_size": 1, "idle_timeout_seconds": 300, "startup_timeout_seconds": 60},
  "implementation_status": "full",
  "implementation_notes": "WhisperX adapter with optional speaker diarization (TD-037)."
}
