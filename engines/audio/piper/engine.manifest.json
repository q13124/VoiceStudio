{
  "engine_id": "piper",
  "name": "Piper TTS",
  "type": "audio",
  "subtype": "tts",
  "version": "1.0",
  "venv_family": "venv_fast_tts",
  "description": "Fast, local neural text-to-speech engine",
  "author": "rhasspy",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "piper-tts": ">=1.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\piper",
    "voices": "%PROGRAMDATA%\\VoiceStudio\\models\\piper\\voices"
  },
  "supported_languages": [
    "en",
    "es",
    "fr",
    "de",
    "it",
    "pt",
    "pl",
    "ru",
    "zh",
    "ja"
  ],
  "capabilities": [
    "fast_tts",
    "low_latency",
    "offline",
    "multi_voice"
  ],
  "device_requirements": {
    "gpu": "optional",
    "vram_min_gb": 0,
    "ram_min_gb": 2
  },
  "entry_point": "app.core.engines.piper_engine.PiperEngine",
  "config_schema": {
    "voice": {
      "type": "string",
      "default": "en_US-lessac-medium",
      "description": "Voice model identifier"
    },
    "device": {
      "type": "string",
      "default": "cpu",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    }
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        24000,
        44100
      ],
      "max_duration_seconds": 30,
      "text_max_chars": 5000
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 22050,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 0,
      "ram_mb": 2048,
      "timeout_seconds": 120
    }
  },
  "implementation_status": "full",
  "implementation_notes": "Fully implemented audio engine."
}