{
  "engine_id": "sovits_svc",
  "name": "So-VITS-SVC 4.0",
  "type": "audio",
  "subtype": "voice_conversion",
  "version": "4.0",
  "venv_family": "venv_voice_conversion",
  "description": "So-VITS-SVC 4.0 - High-quality voice conversion using checkpoint-based models",
  "author": "So-VITS-SVC Team",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "torch": ">=2.0.0",
    "librosa": ">=0.10.0",
    "soundfile": ">=0.12.0",
    "numpy": ">=1.21.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\checkpoints"
  },
  "supported_formats": [
    "wav",
    "mp3"
  ],
  "capabilities": [
    "voice_conversion",
    "real_time_conversion",
    "pitch_shifting",
    "high_quality"
  ],
  "quality_features": {
    "mos_estimate": "4.0-4.5",
    "similarity_score": "very_high",
    "naturalness": "high",
    "speed": "fast",
    "latency": "low"
  },
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 2,
    "ram_min_gb": 4
  },
  "entry_point": "app.core.engines.sovits_svc_engine.SoVITSSVCEngine",
  "config_schema": {
    "checkpoint_path": {
      "type": "string",
      "default": null,
      "description": "Path to model.pth checkpoint file (default: models/checkpoints/<project>/model.pth)"
    },
    "config_path": {
      "type": "string",
      "default": null,
      "description": "Path to config.json file (default: models/checkpoints/<project>/config.json)"
    },
    "project_name": {
      "type": "string",
      "default": "MyVoiceProj",
      "description": "Project name for default checkpoint/config paths"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "gpu": {
      "type": "boolean",
      "default": true,
      "description": "Whether to use GPU if available"
    },
    "sample_rate": {
      "type": "integer",
      "default": 22050,
      "description": "Sample rate for processing"
    },
    "infer_command": {
      "type": "string",
      "default": null,
      "description": "Command template for So-VITS-SVC inference. Supports {input}, {output}, {checkpoint}, {config}, {pitch_shift}, {device}, {sample_rate}."
    },
    "infer_workdir": {
      "type": "string",
      "default": null,
      "description": "Working directory for the inference command (optional)."
    },
    "allow_passthrough": {
      "type": "boolean",
      "default": false,
      "description": "If true, returns input audio when inference is not configured."
    }
  },
  "checkpoint_layout": {
    "model_file": "model.pth",
    "config_file": "config.json",
    "base_path": "models/checkpoints/<project>/",
    "description": "Checkpoint layout: models/checkpoints/<project>/model.pth + config.json"
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac"
      ],
      "sample_rates": [
        16000,
        22050,
        44100,
        48000
      ],
      "max_duration_seconds": 60
    },
    "output": {
      "audio_format": "wav",
      "sample_rate": 44100,
      "bit_depth": 16,
      "channels": 1
    },
    "resources": {
      "vram_mb": 2048,
      "ram_mb": 4096,
      "timeout_seconds": 180
    }
  },
  "implementation_status": "basic",
  "implementation_notes": "Basic implementation. Some advanced features may be missing."
}