{
  "engine_id": "speaker_encoder",
  "name": "Speaker Encoder",
  "type": "audio",
  "subtype": "embedding",
  "version": "1.0",
  "venv_family": "venv_voice_conversion",
  "description": "Extract speaker embeddings for voice cloning, similarity comparison, and speaker verification",
  "author": "VoiceStudio",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "resemblyzer": ">=0.1.4",
    "speechbrain": ">=0.5.0",
    "torch": ">=2.0.0",
    "numpy": ">=1.24.0",
    "librosa": ">=0.10.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\speaker_encoder",
    "cache": "%PROGRAMDATA%\\VoiceStudio\\models\\speaker_encoder\\cache"
  },
  "supported_languages": [
    "universal"
  ],
  "capabilities": [
    "speaker_embedding",
    "speaker_verification",
    "speaker_similarity",
    "voice_fingerprint"
  ],
  "device_requirements": {
    "gpu": "optional",
    "vram_min_gb": 1,
    "ram_min_gb": 4
  },
  "contract": {
    "input": {
      "audio_formats": [
        "wav",
        "mp3",
        "flac",
        "ogg"
      ],
      "sample_rates": [
        8000,
        16000,
        22050,
        44100,
        48000
      ],
      "max_duration_seconds": 60,
      "min_duration_seconds": 1
    },
    "output": {
      "format": "json",
      "includes": [
        "embedding_vector",
        "similarity_score",
        "speaker_id"
      ]
    },
    "resources": {
      "vram_mb": 1024,
      "ram_mb": 4096,
      "timeout_seconds": 30
    }
  },
  "entry_point": "app.core.engines.speaker_encoder_engine.SpeakerEncoderEngine",
  "config_schema": {
    "backend": {
      "type": "string",
      "default": "resemblyzer",
      "enum": [
        "resemblyzer",
        "speechbrain"
      ],
      "description": "Speaker encoder backend to use"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "gpu": {
      "type": "boolean",
      "default": true,
      "description": "Whether to use GPU if available"
    },
    "embedding_dim": {
      "type": "integer",
      "default": 256,
      "description": "Dimension of output embedding vector"
    }
  },
  "tasks": [
    "encode_speaker",
    "embedding",
    "speaker_verification",
    "speaker_similarity"
  ],
  "resources": {
    "needs": [
      "cuda_optional"
    ],
    "vram_gb": 1,
    "ram_gb": 4
  },
  "lifecycle": {
    "pool_size": 2,
    "idle_timeout_seconds": 300,
    "startup_timeout_seconds": 30
  },
  "preHooks": [
    "ensure_models"
  ],
  "postHooks": [],
  "log": {
    "stderr_to_file": true,
    "stdout_to_file": false,
    "rotate_mb": 32,
    "log_dir": "runtime/logs"
  },
  "security": {
    "allow_net": false,
    "allow_fs_roots": [
      "%PROGRAMDATA%/VoiceStudio/models",
      "%APPDATA%/VoiceStudio"
    ],
    "allowed_hosts": [],
    "allowed_ports": []
  },
  "implementation_status": "basic",
  "implementation_notes": "Basic implementation. Some advanced features may be missing."
}