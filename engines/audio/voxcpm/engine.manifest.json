{
  "engine_id": "voxcpm",
  "name": "VoxCPM",
  "type": "audio",
  "subtype": "tts",
  "version": "1.0",
  "description": "VoxCPM - Chinese and multilingual TTS with high quality",
  "author": "VoxCPM Team",
  "license": "Apache-2.0",
  "python_version": ">=3.8",
  "dependencies": {
    "torch": ">=1.9.0",
    "transformers": ">=4.20.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\voxcpm",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\voxcpm\\checkpoints"
  },
  "supported_formats": ["wav", "mp3"],
  "capabilities": [
    "text_to_speech",
    "multilingual",
    "chinese_tts",
    "voice_cloning"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.voxcpm_engine.VoxCPMEngine",
  "config_schema": {
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": ["cuda", "cpu"],
      "description": "Device to use for inference"
    },
    "language": {
      "type": "string",
      "default": "zh",
      "description": "Language code (zh for Chinese, en for English, etc.)"
    }
  }
}

