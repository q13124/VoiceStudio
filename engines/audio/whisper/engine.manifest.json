{
  "engine_id": "whisper",
  "name": "Whisper STT",
  "type": "audio",
  "subtype": "stt",
  "version": "1.0",
  "description": "OpenAI Whisper speech-to-text transcription using faster-whisper for fast inference",
  "author": "OpenAI / Hugging Face",
  "license": "MIT",
  "python_version": ">=3.10",
  "dependencies": {
    "faster-whisper": "==1.0.3",
    "torch": ">=2.2.2"
  },
  "model_paths": {
    "cache": "%PROGRAMDATA%\\VoiceStudio\\models\\whisper",
    "download": "%PROGRAMDATA%\\VoiceStudio\\models\\whisper\\downloads"
  },
  "supported_languages": [
    "auto", "en", "es", "fr", "de", "it", "pt", "ru", "ja", "ko", "zh", "ar", "hi",
    "nl", "pl", "tr", "sv", "no", "fi", "da", "cs", "hu", "ro", "vi", "id", "th",
    "uk", "he", "fa", "ta", "ur", "bn", "te", "kn", "ml", "si", "my", "km", "lo",
    "ka", "am", "sw", "af", "az", "mk", "be", "bs", "eu", "gl", "ha", "jv", "kk",
    "ky", "lb", "mg", "ms", "ne", "ny", "ps", "so", "su", "tg", "uz", "yi", "yo", "zu"
  ],
  "capabilities": [
    "speech_to_text",
    "transcription",
    "language_detection",
    "word_timestamps",
    "multi_language_stt"
  ],
  "device_requirements": {
    "gpu": "optional",
    "vram_min_gb": 2,
    "ram_min_gb": 4
  },
  "entry_point": "app.core.engines.whisper_engine.WhisperEngine",
  "config_schema": {
    "model_name": {
      "type": "string",
      "default": "base",
      "enum": ["tiny", "base", "small", "medium", "large-v2", "large-v3", "large-v3-turbo"],
      "description": "Whisper model size (tiny=fastest, large-v3-turbo=best quality)"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": ["cuda", "cpu"],
      "description": "Device to use for inference"
    },
    "gpu": {
      "type": "boolean",
      "default": true,
      "description": "Whether to use GPU if available"
    },
    "compute_type": {
      "type": "string",
      "default": "float16",
      "enum": ["float16", "int8", "int8_float16", "int8_bfloat16", "float32"],
      "description": "Compute type for faster-whisper (float16 for GPU, int8 for CPU)"
    }
  },
  "tasks": [
    "transcribe",
    "stt",
    "speech_to_text",
    "language_detection"
  ],
  "resources": {
    "needs": ["cuda_optional"],
    "vram_gb": 2,
    "ram_gb": 4
  },
  "lifecycle": {
    "pool_size": 2,
    "idle_timeout_seconds": 300,
    "startup_timeout_seconds": 30
  },
  "preHooks": ["ensure_models"],
  "postHooks": [],
  "log": {
    "stderr_to_file": true,
    "stdout_to_file": false,
    "rotate_mb": 64,
    "log_dir": "runtime/logs"
  },
  "security": {
    "allow_net": false,
    "allow_fs_roots": [
      "%PROGRAMDATA%/VoiceStudio/models",
      "%APPDATA%/VoiceStudio"
    ],
    "allowed_hosts": [],
    "allowed_ports": []
  }
}

