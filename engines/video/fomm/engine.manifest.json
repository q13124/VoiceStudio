{
  "engine_id": "fomm",
  "name": "First Order Motion Model",
  "type": "video",
  "subtype": "avatar",
  "version": "1.0",
  "venv_family": "venv_video",
  "description": "Motion transfer for avatars - animates static images based on driving video",
  "author": "Aliaksandr Siarohin",
  "license": "MIT",
  "python_version": ">=3.8",
  "dependencies": {
    "torch": ">=1.9.0",
    "torchvision": ">=0.10.0",
    "opencv-python": ">=4.5.0",
    "face-alignment": ">=1.3.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\fomm",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\fomm\\checkpoints"
  },
  "supported_formats": [
    "mp4",
    "avi",
    "mov"
  ],
  "capabilities": [
    "motion_transfer",
    "avatar_animation",
    "face_animation",
    "video_generation"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.fomm_engine.FOMMEngine",
  "config_schema": {
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "relative": {
      "type": "boolean",
      "default": true,
      "description": "Use relative motion representation"
    },
    "adapt_movement_scale": {
      "type": "boolean",
      "default": true,
      "description": "Adapt movement scale to source image"
    }
  },
  "contract": {
    "input": {
      "video_formats": [
        "mp4",
        "webm",
        "avi"
      ],
      "audio_formats": [
        "wav",
        "mp3"
      ],
      "max_duration_seconds": 300
    },
    "output": {
      "video_format": "mp4",
      "codec": "h264",
      "default_fps": 24
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 600
    }
  },
  "implementation_status": "external",
  "implementation_notes": "Delegates to external tool. Requires fomm to be installed and running."
}