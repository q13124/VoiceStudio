{
  "engine_id": "sadtalker",
  "name": "SadTalker",
  "type": "video",
  "subtype": "avatar",
  "version": "1.0",
  "venv_family": "venv_video",
  "description": "Talking head generation with realistic lip-sync from single image and audio",
  "author": "SadTalker Team",
  "license": "Apache-2.0",
  "python_version": ">=3.8",
  "dependencies": {
    "torch": ">=1.9.0",
    "torchvision": ">=0.10.0",
    "opencv-python": ">=4.5.0",
    "face-alignment": ">=1.3.0",
    "gfpgan": ">=1.3.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\sadtalker",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\sadtalker\\checkpoints"
  },
  "supported_formats": [
    "mp4",
    "avi",
    "mov"
  ],
  "capabilities": [
    "talking_head",
    "lip_sync",
    "avatar_generation",
    "audio_driven_animation"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.sadtalker_engine.SadTalkerEngine",
  "config_schema": {
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "face_enhance": {
      "type": "boolean",
      "default": true,
      "description": "Enable face enhancement using GFPGAN"
    },
    "batch_size": {
      "type": "integer",
      "default": 2,
      "minimum": 1,
      "maximum": 8,
      "description": "Batch size for processing"
    },
    "size": {
      "type": "integer",
      "default": 512,
      "enum": [
        256,
        512
      ],
      "description": "Output video resolution"
    }
  },
  "contract": {
    "input": {
      "video_formats": [
        "mp4",
        "webm",
        "avi"
      ],
      "audio_formats": [
        "wav",
        "mp3"
      ],
      "max_duration_seconds": 300
    },
    "output": {
      "video_format": "mp4",
      "codec": "h264",
      "default_fps": 24
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 600
    }
  },
  "implementation_status": "external",
  "implementation_notes": "Delegates to external tool. Requires sadtalker to be installed and running."
}