{
  "engine_id": "openjourney",
  "name": "OpenJourney",
  "type": "image",
  "subtype": "generation",
  "version": "1.0",
  "venv_family": "venv_image",
  "description": "OpenJourney - Midjourney-style image generation using Stable Diffusion",
  "author": "PromptHero",
  "license": "CreativeML Open RAIL-M",
  "python_version": ">=3.10",
  "dependencies": {
    "diffusers": ">=0.21.0",
    "torch": ">=2.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\openjourney",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\openjourney\\checkpoints"
  },
  "supported_formats": [
    "png",
    "jpg",
    "webp"
  ],
  "capabilities": [
    "text_to_image",
    "image_to_image",
    "inpainting",
    "midjourney_style",
    "artistic"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.openjourney_engine.OpenJourneyEngine",
  "config_schema": {
    "model_id": {
      "type": "string",
      "default": "prompthero/openjourney-v4",
      "description": "OpenJourney model identifier"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "version": {
      "type": "string",
      "default": "v4",
      "enum": [
        "v1",
        "v2",
        "v3",
        "v4"
      ],
      "description": "OpenJourney model version"
    }
  },
  "contract": {
    "input": {
      "image_formats": [
        "png",
        "jpg",
        "webp"
      ],
      "max_resolution": "2048x2048",
      "prompt_max_chars": 2000
    },
    "output": {
      "image_format": "png",
      "default_resolution": "512x512"
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 300
    }
  }
}
