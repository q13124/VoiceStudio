{
  "engine_id": "automatic1111",
  "name": "AUTOMATIC1111 WebUI",
  "type": "image",
  "subtype": "generation",
  "version": "1.0",
  "description": "Stable Diffusion WebUI - Popular web interface for Stable Diffusion with extensive features",
  "author": "AUTOMATIC1111",
  "license": "AGPL-3.0",
  "python_version": ">=3.10",
  "dependencies": {
    "xformers": ">=0.0.20"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\automatic1111",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\automatic1111\\models\\Stable-diffusion",
    "loras": "%PROGRAMDATA%\\VoiceStudio\\models\\automatic1111\\models\\Lora",
    "embeddings": "%PROGRAMDATA%\\VoiceStudio\\models\\automatic1111\\embeddings"
  },
  "supported_formats": [
    "png",
    "jpg",
    "webp"
  ],
  "capabilities": [
    "text_to_image",
    "image_to_image",
    "inpainting",
    "outpainting",
    "img2img",
    "controlnet",
    "lora_loading",
    "embedding_loading",
    "upscaling",
    "face_restoration"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.automatic1111_engine.Automatic1111Engine",
  "config_schema": {
    "webui_url": {
      "type": "string",
      "default": "http://127.0.0.1:7860",
      "description": "AUTOMATIC1111 WebUI server URL"
    },
    "api_endpoint": {
      "type": "string",
      "default": "/sdapi/v1",
      "description": "API endpoint path"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "sampler": {
      "type": "string",
      "default": "Euler a",
      "description": "Sampling method"
    },
    "steps": {
      "type": "integer",
      "default": 20,
      "minimum": 1,
      "maximum": 150,
      "description": "Number of sampling steps"
    },
    "cfg_scale": {
      "type": "number",
      "default": 7.0,
      "minimum": 1.0,
      "maximum": 30.0,
      "description": "Classifier-free guidance scale"
    }
  },
  "contract": {
    "input": {
      "image_formats": [
        "png",
        "jpg",
        "webp"
      ],
      "max_resolution": "2048x2048",
      "prompt_max_chars": 2000
    },
    "output": {
      "image_format": "png",
      "default_resolution": "512x512"
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 300
    }
  }
}
