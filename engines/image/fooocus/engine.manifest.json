{
  "engine_id": "fooocus",
  "name": "Fooocus",
  "type": "image",
  "subtype": "generation",
  "version": "1.0",
  "venv_family": "venv_image",
  "description": "Fooocus - Simplified Stable Diffusion interface focused on quality and ease of use",
  "author": "lllyasviel",
  "license": "Apache-2.0",
  "python_version": ">=3.10",
  "dependencies": {
    "torch": ">=2.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\fooocus",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\fooocus\\models\\checkpoints",
    "loras": "%PROGRAMDATA%\\VoiceStudio\\models\\fooocus\\models\\loras"
  },
  "supported_formats": [
    "png",
    "jpg",
    "webp"
  ],
  "capabilities": [
    "text_to_image",
    "image_to_image",
    "inpainting",
    "lora_loading",
    "quality_optimization",
    "simplified_interface"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.fooocus_engine.FooocusEngine",
  "config_schema": {
    "server_url": {
      "type": "string",
      "default": "http://127.0.0.1:7865",
      "description": "Fooocus server URL"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "performance": {
      "type": "string",
      "default": "quality",
      "enum": [
        "speed",
        "quality",
        "extreme_speed",
        "extreme_quality"
      ],
      "description": "Performance preset"
    }
  },
  "contract": {
    "input": {
      "image_formats": [
        "png",
        "jpg",
        "webp"
      ],
      "max_resolution": "2048x2048",
      "prompt_max_chars": 2000
    },
    "output": {
      "image_format": "png",
      "default_resolution": "512x512"
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 300
    }
  }
}
