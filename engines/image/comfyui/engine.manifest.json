{
  "engine_id": "comfyui",
  "name": "ComfyUI",
  "type": "image",
  "subtype": "generation",
  "version": "1.0",
  "venv_family": "venv_comfy",
  "description": "ComfyUI - Powerful node-based Stable Diffusion workflow engine",
  "author": "ComfyUI Community",
  "license": "Apache-2.0",
  "python_version": ">=3.10",
  "dependencies": {
    "torch": ">=2.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\comfyui",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\comfyui\\models\\checkpoints",
    "loras": "%PROGRAMDATA%\\VoiceStudio\\models\\comfyui\\models\\loras",
    "controlnet": "%PROGRAMDATA%\\VoiceStudio\\models\\comfyui\\models\\controlnet",
    "vae": "%PROGRAMDATA%\\VoiceStudio\\models\\comfyui\\models\\vae"
  },
  "supported_formats": [
    "png",
    "jpg",
    "webp"
  ],
  "capabilities": [
    "text_to_image",
    "image_to_image",
    "inpainting",
    "controlnet",
    "lora_loading",
    "workflow_execution",
    "node_based_workflows",
    "batch_processing",
    "video_generation"
  ],
  "device_requirements": {
    "gpu": "recommended",
    "vram_min_gb": 4,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.comfyui_engine.ComfyUIEngine",
  "config_schema": {
    "server_url": {
      "type": "string",
      "default": "http://127.0.0.1:8188",
      "description": "ComfyUI server URL"
    },
    "device": {
      "type": "string",
      "default": "cuda",
      "enum": [
        "cuda",
        "cpu"
      ],
      "description": "Device to use for inference"
    },
    "workflow_path": {
      "type": "string",
      "default": "",
      "description": "Path to workflow JSON file (optional)"
    }
  },
  "contract": {
    "input": {
      "image_formats": [
        "png",
        "jpg",
        "webp"
      ],
      "max_resolution": "2048x2048",
      "prompt_max_chars": 2000
    },
    "output": {
      "image_format": "png",
      "default_resolution": "512x512"
    },
    "resources": {
      "vram_mb": 4096,
      "ram_mb": 8192,
      "timeout_seconds": 300
    }
  },
  "implementation_status": "external",
  "implementation_notes": "Delegates to external tool. Requires comfyui to be installed and running."
}