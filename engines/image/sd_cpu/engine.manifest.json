{
  "engine_id": "sd_cpu",
  "name": "Stable Diffusion CPU-only",
  "type": "image",
  "subtype": "generation",
  "version": "1.0",
  "description": "Stable Diffusion CPU-only forks - Runs on CPU without GPU requirements",
  "author": "Various",
  "license": "Apache-2.0",
  "python_version": ">=3.10",
  "dependencies": {
    "diffusers": ">=0.21.0",
    "torch": ">=2.0.0"
  },
  "model_paths": {
    "base": "%PROGRAMDATA%\\VoiceStudio\\models\\sd_cpu",
    "checkpoints": "%PROGRAMDATA%\\VoiceStudio\\models\\sd_cpu\\checkpoints"
  },
  "supported_formats": ["png", "jpg", "webp"],
  "capabilities": [
    "text_to_image",
    "image_to_image",
    "inpainting",
    "cpu_only",
    "low_resource"
  ],
  "device_requirements": {
    "gpu": "not_required",
    "vram_min_gb": 0,
    "ram_min_gb": 8
  },
  "entry_point": "app.core.engines.sd_cpu_engine.SDCPUEngine",
  "config_schema": {
    "model_id": {
      "type": "string",
      "default": "runwayml/stable-diffusion-v1-5",
      "description": "Stable Diffusion model identifier"
    },
    "device": {
      "type": "string",
      "default": "cpu",
      "enum": ["cpu"],
      "description": "Device (CPU only)"
    },
    "low_mem": {
      "type": "boolean",
      "default": true,
      "description": "Enable low memory mode"
    }
  }
}

