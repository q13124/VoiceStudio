<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:bal="http://schemas.microsoft.com/wix/BalExtension">
  <Bundle Name="VoiceStudio"
          Version="1.0.0.0"
          Manufacturer="UltraClone"
          UpgradeCode="B6C8CDA7-2B4D-4B6A-893C-9E8D3B9E22B9"
          IconSourceFile="bundle.ico">
    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.RtfLicense"
                                SuppressOptionsUI="no" 
                                ShowVersion="yes" />
    <Chain>
      <!-- Optional: VC++ 2015-2022 x64 if present -->
      <ExePackage Id="VCppRedist" DisplayName="Microsoft Visual C++ Redistributable (x64)"
                  SourceFile="..\3rdparty\VC_redist.x64.exe"
                  InstallCommand="/quiet /norestart"
                  RepairCommand="/repair /quiet /norestart"
                  DetectCondition="VCREDISTX64_EXISTS"
                  Compressed="yes" Vital="no" PerMachine="yes" />
      <!-- Optional: ffmpeg static if present (your silent switch may vary) -->
      <ExePackage Id="FFmpeg" DisplayName="FFmpeg"
                  SourceFile="..\3rdparty\ffmpeg-setup.exe"
                  InstallCommand="/S"
                  DetectCondition="FFMPEG_EXISTS"
                  Compressed="yes" Vital="no" PerMachine="yes" />

      <!-- Required: App/Service MSI -->
      <MsiPackage Id="VoiceStudioAppMsi"
                  SourceFile="..\..\out\msi\VoiceStudioSetup.msi"
                  DisplayInternalUI="no" Compressed="yes" Vital="yes" />

      <!-- Required: Content MSI (models + pyenv) -->
      <MsiPackage Id="VoiceStudioContentMsi"
                  SourceFile="..\..\out\msi\VoiceStudioContent.msi"
                  DisplayInternalUI="no" Compressed="yes" Vital="yes" />
    </Chain>

    <!-- Simple detection variables -->
    <Variable Name="VCREDISTX64_EXISTS" Type="string" Value="false" bal:Overridable="yes" />
    <Variable Name="FFMPEG_EXISTS" Type="string" Value="false" bal:Overridable="yes" />

    <bal:Condition Message="This installer must be run as Administrator.">
      Privileged
    </bal:Condition>
  </Bundle>
</Wix>
