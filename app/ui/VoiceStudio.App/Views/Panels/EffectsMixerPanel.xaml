<UserControl x:Class="VoiceStudio.App.Views.Panels.EffectsMixerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls"
             xmlns:vm="using:VoiceStudio.App.Views.Panels"
             xmlns:converters="using:VoiceStudio.App.Converters">
    <UserControl.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:EffectsMixerViewModel x:Name="ViewModel"/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource VSQ.Spacing.Medium},{StaticResource VSQ.Spacing.Value.Small}">
            <TextBlock Text="Project ID:" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0" VerticalAlignment="Center"/>
            <TextBox Text="{x:Bind ViewModel.SelectedProjectId, Mode=TwoWay}" PlaceholderText="Enter project ID" Width="200" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="Load Mixer" Command="{x:Bind ViewModel.LoadMixerStateCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="Save Mixer" Command="{x:Bind ViewModel.SaveMixerStateCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="Reset" Command="{x:Bind ViewModel.ResetMixerStateCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Medium},0"/>
        </StackPanel>

        <!-- Upper half: Mixer (vertical faders) -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" 
                                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="{StaticResource VSQ.CornerRadius.Button}" 
                                    Padding="{StaticResource VSQ.Spacing.Value.Small}" 
                                    Margin="{StaticResource VSQ.Spacing.Value.Small}" 
                                    Width="80">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,{StaticResource VSQ.Spacing.Value.Small}"/>
                                    <controls:FaderControl Height="200" Margin="0,0,0,{StaticResource VSQ.Spacing.Value.Small}" Volume="{Binding Volume, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Lower half: Node view or FX chain list -->
        <Border Grid.Row="3"
                Background="{StaticResource VSQ.Background.Darker}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,8,0,0"
                Padding="8">
            <TextBlock Text="FX Chain / Node View" 
                      Style="{StaticResource VSQ.Text.Body}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

