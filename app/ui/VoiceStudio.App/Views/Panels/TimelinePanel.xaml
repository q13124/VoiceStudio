<UserControl x:Class="VoiceStudio.App.Views.Panels.TimelinePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceStudio.App.Controls"
    xmlns:vm="using:VoiceStudio.App.Views.Panels"
    xmlns:converters="using:VoiceStudio.App.Converters">
    <UserControl.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:TimelineViewModel x:Name="ViewModel"/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Timeline Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="{StaticResource VSQ.Spacing.Medium},0">
            <Button Content="Add Track" Command="{x:Bind ViewModel.AddTrackCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="▶ Play" Command="{x:Bind ViewModel.PlayAudioCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="⏸ Pause" Command="{x:Bind ViewModel.PauseAudioCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="⏹ Stop" Command="{x:Bind ViewModel.StopAudioCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Medium},0"/>
            <Button Content="Zoom In" Command="{x:Bind ViewModel.ZoomInCommand}" Margin="0,0,{StaticResource VSQ.Spacing.Value.Small},0"/>
            <Button Content="Zoom Out" Command="{x:Bind ViewModel.ZoomOutCommand}"/>
            <TextBlock Text="{x:Bind ViewModel.ZoomLevelDisplay, Mode=OneWay}" Margin="{StaticResource VSQ.Spacing.Value.Large},0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tracks Area -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <controls:EmptyState Icon="🎵" Title="No Tracks" Message="Get started by adding your first track. Click 'Add Track' to create a new audio track." ActionText="Add Track" Command="{x:Bind ViewModel.AddTrackCommand, Mode=OneWay}" Visibility="{x:Bind ViewModel.HasTracks, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
            <ListView ItemsSource="{x:Bind ViewModel.Tracks, Mode=OneWay}" SelectionMode="None" ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" Visibility="{x:Bind ViewModel.HasTracks, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="{StaticResource VSQ.Spacing.Value.Small}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="{StaticResource VSQ.Spacing.Value.Small}" Background="{StaticResource VSQ.Panel.Background.HeaderBrush}" Padding="{StaticResource VSQ.Spacing.Value.Small}">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="{Binding Engine, StringFormat='Engine: {0}'}" FontSize="{StaticResource VSQ.FontSize.Caption}" Foreground="{StaticResource VSQ.EmptyState.TextBrush}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Height="60" CornerRadius="{StaticResource VSQ.CornerRadius.Button}" Background="{StaticResource VSQ.Panel.Background.DarkBrush}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="1">
                                <controls:WaveformControl Samples="{Binding WaveformSamples, Mode=OneWay}" Mode="peak" ZoomLevel="{Binding DataContext.TimelineZoom, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" WaveformColor="Cyan"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Visualizer Area -->
        <Border Grid.Row="2" Background="{StaticResource VSQ.Background.Darker}" BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" BorderThickness="0,1,0,0" Margin="0,8,0,0">
            <controls:SpectrogramControl Height="120"/>
        </Border>
    </Grid>
</UserControl>

