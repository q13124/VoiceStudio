<UserControl x:Class="VoiceStudio.App.Views.Panels.DiagnosticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ListView for log entries -->
        <ListView Grid.Column="0" Margin="0,0,8,0">
            <ListViewItem>
                <TextBlock Text="[INFO] System initialized" Style="{StaticResource VSQ.Text.Caption}"/>
            </ListViewItem>
            <ListViewItem>
                <TextBlock Text="[INFO] Backend connected" Style="{StaticResource VSQ.Text.Caption}"/>
            </ListViewItem>
            <ListViewItem>
                <TextBlock Text="[WARN] High latency detected" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.WarnBrush}"/>
            </ListViewItem>
            <ListViewItem>
                <TextBlock Text="[ERROR] Connection lost" Style="{StaticResource VSQ.Text.Caption}" Foreground="{StaticResource VSQ.ErrorBrush}"/>
            </ListViewItem>
        </ListView>

        <!-- Small charts for performance metrics -->
        <StackPanel Grid.Column="1">
            <Border Background="{StaticResource VSQ.Background.Darker}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="CPU Usage" Style="{StaticResource VSQ.Text.Caption}" Margin="0,0,0,4"/>
                    <ProgressBar Value="45" Height="20"/>
                    <TextBlock Text="45%" Style="{StaticResource VSQ.Text.Caption}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource VSQ.Background.Darker}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Memory Usage" Style="{StaticResource VSQ.Text.Caption}" Margin="0,0,0,4"/>
                    <ProgressBar Value="60" Height="20"/>
                    <TextBlock Text="60%" Style="{StaticResource VSQ.Text.Caption}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource VSQ.Background.Darker}"
                    BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="GPU Usage" Style="{StaticResource VSQ.Text.Caption}" Margin="0,0,0,4"/>
                    <ProgressBar Value="30" Height="20"/>
                    <TextBlock Text="30%" Style="{StaticResource VSQ.Text.Caption}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

