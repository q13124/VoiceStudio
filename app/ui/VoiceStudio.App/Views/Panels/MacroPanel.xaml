<UserControl x:Class="VoiceStudio.App.Views.Panels.MacroPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:VoiceStudio.App.Controls"
             xmlns:vm="using:VoiceStudio.App.Views.Panels"
             xmlns:converters="using:VoiceStudio.App.Converters">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:MacroViewModel x:Name="ViewModel"/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <ToggleButton Content="Macros" IsChecked="{x:Bind ViewModel.ShowMacrosView, Mode=TwoWay}" Margin="0,0,8,0"/>
            <ToggleButton Content="Automation" IsChecked="{x:Bind ViewModel.ShowAutomationView, Mode=TwoWay}"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource VSQ.Background.Darker}" 
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}">
            <Grid>
                <controls:MacroNodeEditorControl x:Name="NodeEditor" 
                                               Macro="{x:Bind ViewModel.SelectedMacro, Mode=OneWay}" 
                                               Visibility="{x:Bind ViewModel.ShowMacrosView, Mode=OneWay}"/>
                <TextBlock Text="Select a macro to edit, or create a new one." 
                          Style="{StaticResource VSQ.Text.Body}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource VSQ.Text.SecondaryBrush}"
                          Visibility="{x:Bind ViewModel.SelectedMacro, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

