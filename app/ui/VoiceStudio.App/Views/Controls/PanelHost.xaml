<UserControl x:Class="VoiceStudio.App.Views.Controls.PanelHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource VSQ.Background.Darker}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                <FontIcon x:Name="PanelIcon" FontSize="14" Foreground="{StaticResource VSQ.Accent.CyanBrush}" Margin="0,0,6,0"/>
                <TextBlock x:Name="PanelTitle" 
                          Text="Panel"
                          Style="{StaticResource VSQ.Text.Body}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Header Buttons: pop-out, collapse, options -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0">
                <Button x:Name="PopOutButton" 
                       Style="{StaticResource VSQ.Button.Icon}"
                       ToolTipService.ToolTip="Pop out">
                    <FontIcon FontSize="12" Glyph="&#xE71A;"/>
                </Button>
                <Button x:Name="CollapseButton"
                       Style="{StaticResource VSQ.Button.Icon}"
                       ToolTipService.ToolTip="Collapse">
                    <FontIcon FontSize="12" Glyph="&#xE70D;"/>
                </Button>
                <Button x:Name="OptionsButton"
                       Style="{StaticResource VSQ.Button.Icon}"
                       ToolTipService.ToolTip="Options">
                    <FontIcon FontSize="12" Glyph="&#xE712;"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Border x:Name="ContentBorder"
                Grid.Row="1"
                CornerRadius="{StaticResource VSQ.CornerRadius.Panel}"
                Background="{StaticResource VSQ.Background.Dark}"
                BorderBrush="{StaticResource VSQ.Panel.BorderBrush}"
                BorderThickness="1"
                Padding="8">
            <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"/>
        </Border>
    </Grid>
</UserControl>

