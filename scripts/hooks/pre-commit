#!/bin/bash
# VoiceStudio Pre-Commit Hook
# Checks:
# 1. XAML safety (nested Views, compile-time validation)
# 2. Audit log entries for changed files

set -e

# Configuration
AUDIT_ENABLED="${VOICESTUDIO_AUDIT_ENABLED:-1}"
AUDIT_STRICT="${VOICESTUDIO_AUDIT_STRICT:-0}"
XAML_CHECK_ENABLED="${VOICESTUDIO_XAML_CHECK:-1}"

# Get repo root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# =============================================================================
# XAML Safety Check (GitHub #10947)
# =============================================================================

if [ "$XAML_CHECK_ENABLED" = "1" ]; then
    STAGED_XAML=$(echo "$STAGED_FILES" | grep '\.xaml$' || true)
    
    if [ -n "$STAGED_XAML" ]; then
        echo "Running XAML pre-commit checks..."
        
        # Check for deeply nested Views (causes silent XamlCompiler failures)
        for file in $STAGED_XAML; do
            if echo "$file" | grep -qE 'Views/[^/]+/[^/]+/[^/]+\.xaml$'; then
                echo ""
                echo "ERROR: XAML file in deeply nested Views subfolder detected!"
                echo "  File: $file"
                echo "  This can cause silent XamlCompiler.exe failures (GitHub #10947)"
                echo "  Move to Views/ root or Views/{Category}/ (max 1 level deep)"
                echo ""
                echo "Bypass with: git commit --no-verify"
                exit 1
            fi
        done
        
        echo "XAML pre-commit checks passed."
    fi
fi

# =============================================================================
# Audit Log Check
# =============================================================================

# Skip if audit is disabled
if [ "$AUDIT_ENABLED" != "1" ]; then
    exit 0
fi

# Get repo root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Check if verify_audit_entries.py exists
VERIFY_SCRIPT="$REPO_ROOT/scripts/verify_audit_entries.py"

if [ ! -f "$VERIFY_SCRIPT" ]; then
    echo "Warning: verify_audit_entries.py not found, skipping audit check"
    exit 0
fi

# Run verification
echo "Checking audit log entries for staged files..."
if python "$VERIFY_SCRIPT" $STAGED_FILES; then
    echo "Audit log entries verified."
    exit 0
else
    if [ "$AUDIT_STRICT" = "1" ]; then
        echo ""
        echo "ERROR: Some staged files are missing audit log entries."
        echo "Run: python scripts/patch_wrapper.py --files <files> --summary \"<description>\""
        echo "Or bypass with: git commit --no-verify"
        exit 1
    else
        echo "Warning: Some files may be missing audit entries (non-strict mode)"
        exit 0
    fi
fi
