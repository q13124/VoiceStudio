# Auto-detect text files and normalize to LF on commit, CRLF on checkout (Windows)
* text=auto

# Force LF for cross-platform compatibility
*.py text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.xaml text eol=lf
*.cs text eol=lf

# Force CRLF for Windows-specific files
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.whl binary
*.onnx binary
*.gguf binary
