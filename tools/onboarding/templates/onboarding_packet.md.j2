{#
    VoiceStudio Onboarding Packet Template (Jinja2)
    
    This template generates a markdown onboarding packet for role-based agents.
    
    Variables:
    - role: RoleConfig (id, name, short_name, prompt_path, guide_path, primary_gates)
    - prompt: PromptContent (identity_section, next_actions, full_text)
    - guide: GuideContent (summary, full_text)
    - project_state: ProjectState (phase, active_gate, active_task_id, active_task_title)
    - role_context: RoleContext (blockers)
    - context_bundle: Optional context allocation data
    - issues: List of issues assigned to this role
    - generated_at: ISO timestamp
    - include_full_guide: Boolean flag
#}
