{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tts_response.schema.json",
  "title": "VoiceSynthesizeResponse",
  "description": "Response schema for /api/voice/synthesize endpoint",
  "type": "object",
  "required": ["audio_id", "audio_url", "duration", "quality_score"],
  "properties": {
    "audio_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the synthesized audio"
    },
    "audio_url": {
      "type": "string",
      "minLength": 1,
      "description": "URL to download the synthesized audio"
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "Audio duration in seconds"
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall quality score (0.0-1.0)"
    },
    "quality_metrics": {
      "type": ["object", "null"],
      "description": "Detailed quality metrics",
      "properties": {
        "mos_score": {
          "type": ["number", "null"],
          "minimum": 1,
          "maximum": 5,
          "description": "Mean Opinion Score (1.0-5.0)"
        },
        "similarity": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Voice similarity (0.0-1.0)"
        },
        "naturalness": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Naturalness score (0.0-1.0)"
        },
        "snr_db": {
          "type": ["number", "null"],
          "description": "Signal-to-noise ratio (dB)"
        },
        "artifact_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Artifact score (lower is better)"
        },
        "has_clicks": {
          "type": ["boolean", "null"],
          "description": "Whether clicks were detected"
        },
        "has_distortion": {
          "type": ["boolean", "null"],
          "description": "Whether distortion was detected"
        },
        "voice_profile_match": {
          "type": ["object", "null"],
          "description": "Voice profile matching results",
          "additionalProperties": true
        }
      }
    }
  }
}
