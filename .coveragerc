[run]
# Coverage configuration for VoiceStudio Quantum+
source = app,backend
omit = 
    */tests/*
    */test_*
    */__pycache__/*
    */venv/*
    */.venv/*
    */site-packages/*
    */migrations/*
    */manage.py
    */conftest.py
    */setup.py

[report]
# Coverage report settings
precision = 2
show_missing = True
skip_covered = False

# Minimum coverage threshold - fails if below this
# Phase 4 target: 95% coverage
fail_under = 95

# Partial branch coverage
partial_branches =
    pragma: no branch
    if __name__ == .__main__.:

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @property
    @staticmethod
    @classmethod
    # Defensive assertions and type guards
    assert False
    raise RuntimeError

[html]
# HTML report settings
directory = htmlcov
title = VoiceStudio Quantum+ Coverage Report

[xml]
# XML report settings (for CI/CD)
output = coverage.xml

