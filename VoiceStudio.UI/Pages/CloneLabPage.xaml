<Page
  x:Class="VoiceStudio.UI.Pages.CloneLabPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Padding="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Step 1: metadata + consent -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Profile Name"/>
      <TextBox x:Name="ProfileName" Width="220"/>
      <TextBlock Text="Owner"/>
      <TextBox x:Name="OwnerName" Width="180"/>
      <TextBlock Text="Source"/>
      <ComboBox x:Name="SourceKind" Width="150">
        <x:String>Self</x:String><x:String>Licensed</x:String><x:String>PublicDomain</x:String>
      </ComboBox>
      <CheckBox x:Name="ConsentCheck" Content="I certify rights/consent to clone this voice" />
    </StackPanel>

    <!-- Step 2: reference audio -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
      <TextBlock Text="Reference Audio"/>
      <TextBox x:Name="RefAudio" Width="420" IsReadOnly="True"/>
      <Button Content="Browse…" Click="OnPickRef"/>
      <Button Content="Create Profile" Click="OnCreateProfile" Margin="12,0,0,0"/>
    </StackPanel>

    <!-- Provenance preview -->
    <Grid Grid.Row="2">
      <TextBox x:Name="ProvPreview" AcceptsReturn="True" TextWrapping="Wrap" />
    </Grid>

    <TextBlock Grid.Row="3" x:Name="CloneStatus" Text="Ready" Opacity="0.8"/>
  </Grid>
</Page>
