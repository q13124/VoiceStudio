@page "/ABCompare"
@model VoiceStudio.UI.Pages.ABComparePage
@{
    Response.Headers["Cache-Control"] = "no-store";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>A/B Compare</title>
    <style>
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 2rem; }
        .row { display: flex; gap: 2rem; }
        .card { border: 1px solid #ddd; border-radius: 8px; padding: 1rem; width: 360px; }
        h1 { margin-top: 0; }
        audio { width: 100%; margin-top: .5rem; }
        .actions { margin-top: 1rem; display: flex; gap: .5rem; }
        button { padding: .5rem 1rem; }
    </style>
</head>
<body>
    <h1>A/B Compare</h1>
    <div class="row">
        <div class="card">
            <h3>Sample A</h3>
            <audio controls src="/ABCompare?handler=Audio&id=A"></audio>
        </div>
        <div class="card">
            <h3>Sample B</h3>
            <audio controls src="/ABCompare?handler=Audio&id=B"></audio>
        </div>
        <div class="card">
            <h3>Null Test</h3>
            <div>
                <a href="/ABCompare?handler=NullDiff" download>Download null-diff.wav</a>
            </div>
        </div>
    </div>
</body>
</html>
