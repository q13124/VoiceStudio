<UserControl x:Class="VoiceStudio.UI.Controls.PhonemeGridControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="8">
        <StackPanel>
            <TextBlock Text="Phoneme Overrides" FontSize="18"/>
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" Height="260" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Grapheme" Binding="{Binding Grapheme}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="IPA" Binding="{Binding IPA}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Override (IPA)" Binding="{Binding Override}"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Copy to Mastering Rack" Click="OnCopy"/>
                <TextBlock x:Name="Status" Opacity="0.8"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
