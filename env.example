# VoiceStudio Environment Configuration
# Copy this file to .env and customize for your environment

# Database Configuration
DB_URL=postgresql+psycopg://voicestudio:secret@localhost:5432/voicestudio
# For SQLite (development): DB_URL=sqlite:///./app.db

# A/B Testing Persistence
AB_PERSIST_ENABLED=true

# Evaluation Ingest
EVALS_INGEST_ENABLED=true
EVALS_INGEST_TOKEN=supersecrettoken

# Prometheus Metrics
PROM_ENABLED=true
PROM_ENDPOINT=/metrics
PROM_INSTRUMENT_APP=true
PROM_GROUP_PATHS=true
PROM_LATENCY_BUCKETS_MS=5,10,25,50,100,250,500,1000,2500,5000,10000

# Audio Metrics
METRICS_ENABLED=true
METRICS_TIMEOUT_SEC=20
METRICS_FFMPEG_PATH=
METRICS_FFPROBE_PATH=

# FFmpeg Paths (optional)
FFMPEG_PATH=
FFPROBE_PATH=

# DCGM Exporter (documentation only)
DCGM_EXPORTER_ENABLED=false

# Production Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
